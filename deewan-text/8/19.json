{
    "id": 19,
    "title": "حرف الضاد",
    "huruf": [
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَقِرُّ لَهُ الْأَبْصَارُ عَيْنِي قَدْ عَفَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَرَى الْهُودَ قَدْ وَلَّوْا بِذُلٍّ إِلَى اخْتِفَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمِنْ وَالِدِي شَيْخًا وَأَصْلًا وَمُقْتَفَى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ وَكُلِّ الَّذِي قَفَا"],
      ["بِهَذَا الْقَدْرِ وَالْمِقْدَارِ مَا قَالَ قَائِلٌ", "ضِيَاءٌ مِنَ الْهَادِي الْبَرِيَّةِ مُصْطَفَى"]
    ]
  }