{
    "id": 11,
    "title": "حرف الكاف",
    "huruf": [
      ["كَئِيبٌ سَلَمَّى سَلِّمِينِي لِمَالِكِي", "سَأَمْشِي لِطَهَ خَيْرِ فِهْرٍ وَمَالِكِ"],
      ["إِلَى خَيْرِ نَاسٍ خَيْرِ مَنْ وَطِئَ الثَّرَى", "وَخَيْرِ نِزَارٍ خَيْرِ حَيٍّ وَهَالِكِ"],
      ["مُحَمَّدُ مَأْمُونُ السَّمَاءِ رَسُولُنَا", "وَهَبْتُ لَهُ نَفْسِي وَكُلَّ مَمَالِكِي"],
      ["يُؤَرِّقُنِي ذِكْرَى سُرَاهُ بِمَكَّةٍ", "وَقَدْ كِدْتُ أَسْرِي أَوْ سَرَيْتُ كَذَاكَ"],
      ["سَرَيْتُ بِرُوحِي أَقْتَفِي جِسْمَ أَحْمَدَ", "فَعَمَّ لِقَاءٌ لَيْسَ ذَيْنِ هُنَالِكِ"],
      ["هُنَاكَ تَلَاقَى الرُّوحُ بِالْجِسْمِ فَإِيَّا", "صَفَا لِي وَقْتِي فِيهِ بَعْدَ تَهَالُكِ"],
      ["نَبِيٌّ كَرِيمٌ أَكْرَمَ اللَّهُ خَلْقَهُ", "بِبَعْثَتِهِ رُحْمَى لِنَاسٍ وَنَاسِكِ"],
      ["مِنَ الْكُفْرِ وَالْإِشْرَاكِ حَرَّرَ دَاعِيًا", "إِلَى الْوَاحِدِ الْقَهَّارِ هَادِي الْمَنَاسِكِ"],
      ["وَأَدَّبَهُ إِذْ سَيَّرَ الذِّكْرَ خَلْقَهُ", "وَشَفَّعَهُ فِي الْخَلْقِ رَبُّ الْمَلَائِكِ"],
      ["فَكُنْ لِي شَفِيعًا يَا رَسُولُ فَإِنَّنِي", "خَدِيمُكَ أَدْعُو دَارِكِ الْعَبْدَ دَارِكِ"],
      ["فَإِنِّي لَا أَنْفَكُّ أَخْدُمُ دِينَهُ", "وَلَوْ وَاجَهُونِي بِالْأَذَى وَالْمَعَارِكِ"],
      ["أَرَانِي لَدَى الْبَيْتِ الْحَرَامِ وَإِنَّنِي", "مُنَادٍ لِقَاءَ مَنْ جَاءَنَا بِالْمَنَاسِكِ"],
      ["وَبَنِيَّ وَخَادِمِي أَشْكُوهُ لِخَالِقِي", "بِيُمْنِ الْمُقَفَّى مُقْتَفَى كُلِّ سَالِكِ"],
      ["تَكَاتَلَ أَجْنَادُ الضَّلَالَةِ صَوْبَهَا", "لِدِينِ شَكَوْتُ فَهْوَ خَيْرُ مُدَارِكِ"],
      ["كَدَأْبِكَ دِينًا حَقِّقِ النَّصْرَ عَاجِلًا", "وَقَدْ بَلَغَ السَّيْلُ الزُّبَى فَلْتُدَارِكِ"],
      ["بِهَزْمِكَ أَحْزَابَ الضَّلَالَةِ قَبْلَهَا", "تُبَدِّدُهُمْ بِعَزْمِهِمْ لِلْمَهَالِكِ"],
      ["نَصَرْتَ إِلَهِي يَشْكُرًا وَمَحَبَّتَهُ", "وَبَارَكْتَ فِي زَادِ الْخَلِيلِ الْمُبَارَكِ"],
      ["فَلَقَّتْ لِمُوسَى الْبَحْرَ وَالرُّوحُ بَعْدَهُ", "عَلَوْتَ بِهِ يَحْيَى خَيَادَةَ الْمَلَائِكِ"],
      ["بِحَقِّكَ فَانْصُرْ ضَارِعًا مُتَضَرِّعًا", "بِأَذْيَالِ خَيْرِ الْخَلْقِ نَجْلِ الْعَوَاتِكِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِمَكَّةَ أَدْعُو خَيْرَ رَبٍّ وَمَالِكِ"],
      ["بِحُبِّ قُبَيْسٍ مِنْ حِرَاءٍ وَإِنَّنِي", "أُنَادِي مُجِيبًا بَاسِطًا غَيْرَ مَاسِكِ"],
      ["فَهَبْنِي خَيَادَةً مَا حَيِيتُ كَرِيمَةً", "وَمِنْ بَعْدِ لِلْفِرْدَوْسِ فَوْقَ الْأَرَائِكِ"],
      ["فَتَكْفِينِيَ الْبَلْوَى بِطُولِكَ وَهَذِهِ", "وَتُشْجِينِي فِي الْعِلْمِ كُلَّ الْمَدَارِكِ"],
      ["وَتَكْفِي شُرُورَ الْإِنْسِ وَالْجِنِّ كُلِّهِمْ", "تُضِيءُ فِي الظَّلَامَاتِ مِنْ كُلِّ حَالِكِ"],
      ["حَيَاتِي تَعْلُو بِالْمَحَبَّةِ وَالتُّقَى", "وَمَوْتِي يَتْلُو بِالشُّهُودِ كَذَلِكِ"],
      ["بِتَارِيسَ لَيْتَ أَنَّنِي أَرْجِعُ لِطَيْبَةٍ", "قَدِ ازْدَدْتُ شَوْقًا عِنْدَ قُرْبِ لِقَائِهَا"],
      ["إِلَى الْحَرَمِ الْعَالِي الرَّفِيعِ مَنَارُهُ", "إِلَى مَرْقَدِ الْمَاضِي الصِّلَالِ رِوَايَا"],
      ["إِلَى حُجُرَاتٍ عَظَّمَ اللَّهُ شَأْنَهَا", "بِدَمْعِ مُنَادٍ حَوْلَهَا بِبُكَائِي"],
      ["إِلَى حُجُرَاتٍ طَهَّرَ اللَّهُ أَهْلَهَا", "مِنَ الرِّجْسِ وَالْفَحْشَا وَكُلِّ طَهُاءِ"],
      ["مَصَادِرُ آيَاتٍ مَوَارِدُ رَحْمَةٍ", "بِهَا الْبَيْتُ فِيهَا حَلَّ وَحُيِّيَ بِثَنَاءِ"],
      ["مَحَطُّ أَنْظَارِ السَّمَاءِ وَمُنْتَهَى", "مَسِيرِ الْمَلَإِ الْأَعْلَى شُرُوفَ ضِيَاءِ"],
      ["فَلَا بَأْسَ صَفَا وَقْتِي وَبَاتَ مُؤَمَّلِي", "قَرِيبًا وَحُبُّ الْهَاشِمِيِّ غِذَائِي"],
      ["تَرَى حُجَرَ الْمَاضِي الصِّلَالِ بِهِ اخْتَفَى", "دُجَى الْكُفْرِ وَالْأَهْوَاءِ وَكُلُّ عَنَاءِ"],
      ["أَنَالُ وُقُوفًا خَاضِعًا مُتَأَدِّبًا", "أَمَامَ الْإِمَامِ الْقَرْمِ وَهْوَ شِفَائِي"],
      ["وَقَفْتُ أَمَامَ الْهَاشِمِيِّ مُصَلِّيًا", "لِتُقْضَى فُؤَادِي كَـالُ هَنَاءِ"],
      ["أَمَامِي إِمَامِي الْحَقُّ جَلَّ جَلَالُهُ", "وَخَلْفِي إِمَامِي الْهَاشِمِيُّ بِرَاقِي"],
      ["مُلَازِمُ عَبْدَ اللَّهِ سَيِّدَ خَلْقِهِ", "أَتُوبُ وَتَذْرِي مَا تَرَكْتُ وَرَاقِي"],
      ["فَسَلْ خَالِقِي تَفْرِيجَ كَرْبِي وَكَرْبِ مَنْ", "تَعَلَّقَ بِي إِنِّي أَسِيرٌ لِقَائِهِ"],
      ["رَسُولُ شُعُوبٍ يَنْتَمُونَ لِأَحْمَدَ", "بِحُبٍّ وَإِخْلَاصٍ وَصِدْقٍ وَلَاءِ"],
      ["تُحَادِثُهُمْ أَعْدَاءَ الْحَنِيفَةِ جَهْرَةً", "إِلَى خَالِقِي شَكْوَى صَبَاحَ مَسَاءِ"],
      ["سَأَلْتُ إِلَهِي أَنْ يُذِلَّ بِسُرْعَةٍ", "عِصَابَاتِ إِسْرَائِيلَ أَهْلَ غَبَاءِ"],
      ["وَطَهِّرْ لَنَا الْقُدْسَ الشَّرِيفَ وَأَهْلِكَنْ", "أُبَاةَ النَّدَى وَدَيَّانَهُمْ رِقَابَ إِمَاءِ"],
      ["لَقَدْ حَارَبُوا عِيسَى وَيَحْيَى وَأَحْمَدَا", "فَهَبْ لِيَهُودِ الْقُدْسِ كُلَّ بَلَاءِ"],
      ["وَحَرَّرْ لَنَا سِينَا بِمُوسَى وَأَحْمَدَ", "وَعِيسَى وَإِبْرَاهِيمَ أَهْلِ عَلاَءِ"],
      ["وَتَغْتَصِبَ الْأَقْصَى بِجَاهِ مُحَمَّدٍ", "وَسِرِّ الَّذِي نَاجَى بِغَارِ حِرَاءِ"],
      ["وَبَعْدُ فَنَالٌ فِي سُرُورٍ وَغِبْطَةٍ", "سَأَحْثُو إِلَى الْبَطْحَاءِ بَحْرَ فَضَاءِ"],
      ["فَمَكَّةُ هَذِي ذَا الْمَقَامُ وَهَذِهِ", "جِبَالُ شِيرٍ فِي سَنًا وَسَنَاءِ"],
      ["وَهَذِي عَرَفَاتٌ ذَاكَ جَمْعٌ وَمَشْعَرٌ", "بِهَا وَقَفَ الْمَاضِي لِمَحْوِ الْعَمَاءِ"],
      ["يَوْمَئِذٍ قَدْ طَاوَى الْأَرْضَ طَائِرًا", "إِلَى الْمُصْطَفَى الْمُخْتَارِ بَحْرِ عَطَاءِ"],
      ["مَعِي صَاحِبِي وَصِهْرِي وَخَادِمِي", "أَبُو حَزْمٍ بَلْقِيسُ أَهْلُ وَلَاءِ"],
      ["جَزَاهُمْ إِلَهِي كُلَّ خَيْرٍ وَيَعْلُونَ", "بِنَاءَهُمْ فِي الْمَجْدِ كُلَّ بِنَاءِ"],
      ["فَهَبْ لِي وَهَبْ عَبْدَ الْمَلِيكِ مُرَادَهُ", "بِلَا سَبَبٍ إِلَّا صُدُورُ قَضَاءِ"],
      ["وَتَقْبَلَنَا هَبِ الْمُسِيئِينَ جُمْلَةً", "لِمُحْسِنِنَا هَبْنِي لِعَيْنِ الصَّفَاءِ"],
      ["جَزَى اللَّهُ عَنِّي وَالِدِي وَمُعَلِّمِي", "لَدَى حَضْرَةِ الْمَوْلَى كُلَّ جَزَاءِ"],
      ["بِالْغُوسِ أَحْبَابٌ كِرَامٌ أَجِلَّةٌ", "فَأَذْكُرُهُمْ أُهْدِي لَهُمْ بِدُعَاءِ"],
      ["بِأَزْرِي وَكَانُوا مِنْ أُكَيْنِي لِكَوْلَا", "فَتَذَكُّرُهُمْ عِنْدِي يَوْمَ صَفَاءِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ لَدَى الْمَوْلَى كُلَّ رِضَاءِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَهَذَا سَيْرُ قَلْبِي وَهْوَ مَحْضُ عَطَاءِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَبُلِّغْنِي بِالْآلِ أَهْلِ عَبَاءِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِطَهَ مَسِيرِي وَهْوَ مِنْهُ جَزَائِي"],
      ["أَسِيرُ بِهِ لِلَّهِ جَلَّ جَلَالُهُ", "وَفُزْتُ بِجَمْعِ الْحُسْنِ تَمَّ فَنَائِي"],
      ["فَمَا لِي قَلْبٌ عِنْدَ أَحْدَثَ لَا أَرَى", "أَمِيلُ إِلَى الْأَغْيَارِ بَعْدَ بَقَاءِ"],
      ["أَرَى كُلَّ شَيْءٍ مَا خَلَا اللَّهَ بَاطِلًا", "فَحَقَّ يَقِينِي إِذْ أَمَاطَ غِطَائِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِطَهَ سُرُورِي بِالْأَمِينِ غِنَائِي"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ خِتَامُ ثَنَائِي"]
    ]
  }