{
    "id": 25,
    "title": "إحقا",
    "huruf": [
      ["أَكْسَرَى أَيُّوَانُكَ هَلْ دَهَاكَ وَأَنْذَرَا", "بُرُوزُ نَبِيٍّ إِنَّ كِسْرَى تَقَهْمَرَا"],
      ["أَكْسَرَى أَنُوشِرْوَانُ جَاءَ مُحَمَّدٌ", "بِآيَاتِهِ الْكُبْرَى وَقَصْرُكَ أَبْصَرَا"],
      ["أَكْسَرَى أَنُوشِرْوَانُ جَاءَ مُحَمَّدٌ", "وَهَلْ قَطَعَ الْأَنْهَارَ أَمْ هَلْ تَفَجَّرَا"],
      ["أَكْسَرَى أَنُوشِرْوَانُ جَاءَ مُحَمَّدٌ", "وَهَلْ قَدْ أَتَاكَ الْإِيذِنَانُ مُكَبَّرَا"],
      ["أَكْسَرَى أَنُوشِرْوَانُ جَاءَ مُحَمَّدٌ", "يَتْلُو ذِكْرًا مُنْذِرًا وَمُبَشِّرَا"],
      ["وَقَدْ سَمِعَ الْمَعْبُودُ اللَّهُ نَاطِقًا", "وَقَدْ أَنْبَأَ الْكُهَّانُ مَا كَانَ مُضْمَرَا"],
      ["سَلَامٌ عَلَى نُورِ الْإِلَهِ الَّذِي حَبَا", "بِأَنْوَارِهِ أَنْوَارَ كِسْرَى وَقَيْصَرَا"],
      ["سَلَامٌ عَلَى مَنْ جَاءَ وَهْوَ بِمَكَّةٍ", "يَهُودُ بِهِ إِيوَانُ كِسْرَى تَكَسَّرَا"],
      ["سَلَامٌ عَلَى سِرِّ الْوُجُودِ وَزُمْرَةٍ", "فَلِلَّهِ مَا أَعْلَى وَأَعْلَى وَأَبْهَرَا"],
      ["سَلَامٌ عَلَى مَنْ جَاءَ وَالْكَوْنُ كُلُّهُ", "ظَلَامٌ وَمِنْ أَنْوَارِهِ قَدْ تَنَوَّرَا"],
      ["سَلَامٌ عَلَيْهِ مِنْ خَدِيمٍ مُتَيَّمٍ", "بِبَغْدَادَ وَهْنًا لَا يَنَامُ تَفَكَّرَا"],
      ["فَمَنْ هَدَّ هَذَا الْقَصْرَ وَهْوَ بِمَكَّةٍ", "وَلِيدًا فَلَنْ يُبْقِي لِهَذَا الْكُفْرِ مَطْهَرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأُبْصِرُ حَطَّ الْمُسْلِمِينَ مُوَقَّرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَلْقَى عَدُوُّ الدِّينِ سَوْطًا مُدَمَّرَا"]
    ]
  }