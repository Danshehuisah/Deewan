{
    "id": 12,
    "title": "حرف الميم",
    "huruf": [
      ["مَدِينَةُ مَاحِي الْكُفْرِ وَالْعَارِ وَالرِّجْسِ", "مَدَى الدَّهْرِ فِيهَا قُرَّةُ الْعَيْنِ وَالنَّفْسِ"],
      ["تَذَكَّرْتُهَا وَالْحَالُ أَنِّي مُخَيِّمٌ", "بِبَارِيسَ أَنْحُوهَا لِمَحْبُوبِيَ الرِّجْسِ"],
      ["أَرَانِي إِذَا مَا جِئْتُ طَيْبَةَ زَائِرًا", "يُقَرِّبُنِي قُرْبًا يَتِمُّ بِهِ أُنْسِي"],
      ["أَأَكْرَمُ خَلْقِ اللَّهِ أَحْمَدُ مَا تَرَى", "لِزُوَّارِهِ حَالٌ مِنْ كُلِّ مَعْنًى وَمِنْ حِسِّ"],
      ["وَإِنَّ إِلَهِي وَمَلْجَأِي مُخْتَارُ", "الْعَوَالِمِ مِنْ جِنٍّ خَفِيٍّ وَمِنْ إِنْسِ"],
      ["عَظِيمٌ عَظِيمُ الْخُلْقِ وَالْجُودِ وَالْعَطَا", "بِهِ زَالَ هَمِّي ثُمَّ كَسْرِي كَذَا بُؤْسِي"],
      ["وَإِنْ دُهِشَ الْأَقْطَابُ يَوْمًا بِمَشْهَدٍ", "أَرَاهُ فَيُعْلِينِي إِلَى أَعْظَمِ الْكُرْسِيِّ"],
      ["وَهَبْتُ لِكُلِّ الْمَادِحِينَ شَفَاعَةً", "وَهَلْ يَقْبَلُ الْمَحْمُودُ تَشْفِيعَهُمْ لُبْسِي"],
      ["عَلَى أَنِّي أَرْجُو عُمُومَ شَفَاعَةٍ", "بِنَيْلِ الْأَمِينِ لِمَنْ يَهْوَى الْعَبِيدُ مِنَ الْإِنْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَأَمْرُكَ مَقْبُولٌ عَلَى الْعَيْنِ وَالرَّأْسِ"],
      ["دَعَوْتَ إِلَى التَّوْحِيدِ لِلَّهِ وَحْدَهُ", "فَكُلٌّ سِوَاهُ يَانٍ مَحَاهُ وَطُمْسِ"],
      ["هُوَ الْكُلُّ مِنْهُ الْكُلُّ لَا رَبَّ غَيْرُهُ", "فَمَا ثَمَّ مِنْ كُفْءٍ وَلَا ثَمَّ مِنْ عَكْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَدُرُّ لَنَا مِنْ كُلِّ بَطْشٍ وَمِنْ حَبْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأُصْبِحَ مَيْمُونًا حَيَاتِي كَذَا أُمْسِي"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُكَافِينَا عَنْ أَهْلٍ وَصَحْبٍ وَعَنْ جِنْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَتُوبُ عَلَيَّ الشَّافِعِي مِنْ كُلِّ بَأْسٍ وَمِنْ طَمْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "سَلَامًا وَوَفَّاكَ خَيْرَ بَنِي حُسِّ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَمِنْكَ عِلَاجِي مَرَضُ الْقَلْبِ وَالنَّفْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أُحِبُّكَ حُبًّا لَا يَزَالُ إِلَى الرَّمْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَكُلِّي لِخَيْرِ الْخَلْقِ فِي الْيَوْمِ وَالْأَمْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَبَهْجَةُ حِبِّي فِيكَ أَوْحَى مِنَ الشَّمْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَطْرُدُ إِشْكَالَ اللَّعِينِ مِنَ الْقُدْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَسْتَأْصِلُ الْخُبْثَ الْيَهُودَ مِنَ الْأُسِّ"],
      ["وَتِهْلِكَ دَجَّالَ الْيَهُودِ وَتَهْلِكَ", "إِيوَانًا وَدَيَّانًا فَيَكْمُلُ لِي أُنْسِي"],
      ["لِتَهْلِكَ أُجُوكُوا فَبَلْهُمْ وَتَنْجَلِي", "لَنَا فَيْضُكَ التَّضْرَاءُ شَامِلَ ثَمْرِ الْغَرْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَتَيْنَا لِكَشْفِ الْكَرْبِ وَاللَّهْمِ وَاللَّبْسِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ ذَوِي الْفَضْلِ وَالْبَأْسِ"],
      ["عَلَيْكَ مَدَى الْأَيَّامِ مَا قَالَ خَادِمٌ", "مَدِينَةُ مَاحِي الْكُفْرِ وَالْغَارِ وَالرِّجْسِ"]
    ]
