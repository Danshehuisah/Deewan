{
    "id": 9,
    "title": "حرف الطاء",
    "huruf": [
      ["طَبِيبِي قَرِيبٌ هَلْ سِقَامِي تُسْمَعُ", "يُقَابِلُنِي يَوْمِي الْمُفَقَّى الْمُشَفَّعُ"],
      ["أَرَانِي إِذَا مَا جِئْتُ يَوْمًا مُحَمَّدًا", "تُقْضَى آمَالِي كَمَا أَتَوَقَّعُ"],
      ["مُحَمَّدُ خَيْرُ الْعَالَمِينَ وَسِيلَتِي", "أَتَاكَ خَدِيمٌ ضَارِعٌ يَتَشَفَّعُ"],
      ["أَتَيْتُ بِصِنْوِي ثُمَّ أَهْلِي وَوَالِدِي", "سِرَاعًا وَحَوْلَ الْهَاشِمِيِّ تَجَمَّعُوا"],
      ["وَخَلْفِي جُمُوعٌ يَرْجُونَ لِحِزْبِكُمْ", "يَعُمُّهُمُ الشَّفِيعُ أَجْمَعُ أَكْنَعُ"],
      ["أَيَا نَفْسُ أَدْرَكْتِ الْأَمَانِيَ فَهَذِهِ", "مَرَابِعُ خَيْرِ النَّاسِ وَالنُّورُ يَسْطَعُ"],
      ["فَأَلْقَتْ عَصَاهَا وَاسْتَقَرَّتْ بِهَا النَّوَى", "وَيَلْتَ الْمُنَى مَا بَالُ عَيْنَيْكِ تَدْمَعُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَعَيْشٌ بِدُونِ الْحُبِّ فِيكَ مُضَيَّعُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِقَاءٌ كَحَسْوِ الطَّيْرِ لِلْقَلْبِ مُوجِعُ"],
      ["وَيَوْمٌ كَأَلْفٍ مِنْ سِنِينَ أَعُدُّهُ", "قَصِيرًا فَمَا نَفْسِي بِذَلِكَ تَقْنَعُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَلَى رَغْمِ أَنْفِي بِالسَّلَامِ أُوَدِّعُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَهَلْ بَعْدَ هَذَا كُلِّهِ سَوْفَ أَرْجِعُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَدَى الدَّهْرِ دِينَ الْمُصْطَفَى الْقَرْمِ أَتْبَعُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَقَامُكَ مَحْمُودٌ لَدَى الْحَشْرِ تَشْفَعُ"]
    ]
  }