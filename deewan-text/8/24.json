{
    "id": 24,
    "title": "حرف الميم",
    "huruf": [
      ["تَفَافَةُ إِبْرَاهِيمَ وَالْعِلْمُ كُلُّهُ", "مَدِيحُ الْإِمَامِ الْهَاشِمِيِّ وَفَضْلُهُ"],
      ["وَمَنْ فِعْلُهُ نَهْجُ الْإِلَهِ وَدِينُهُ", "وَلَيْسَ سِوَاهُ إِنَّمَا الْقَوْلُ قَوْلُهُ"],
      ["بَنَى قُبَّةَ الْإِسْلَامِ بِالْوَحْيِ دَاعِيًا", "إِلَيْهِ مَجِيعُ النَّاسِ قَدْ عَمَّ ظِلُّهُ"],
      ["خَدِيمُكَ هَذَا فِي بَرِيسَ مُعَوَّقٌ", "سِوَاهُ لَدَى وَادِي الْعَقِيقِ مَا وَصْلُهُ"],
      ["يُعَلِّلُ نَفْسًا بِالْوِصَالِ لَعَلَّهُ", "بِوَقْتٍ مِنَ الْأَوْقَاتِ تَنْفَكُّ رِجْلُهُ"],
      ["فَهَلْ تَسْمَحُ الْأَيَّامُ بِالسَّيْرِ لِلنَّقَا", "فَيَقْضِي لَنَا كُلَّ الْقُوَاتِ أَهْلُهُ"],
      ["فَقَدْ طَالَ عُزْلِي عَنْ وُفُودِ جَنَابِهِ", "فَارْحَمْ خَيْرَ النَّاسِ مَنْ طَالَ عُزْلُهُ"],
      ["فَأَمْشِي إِلَى ذَاكَ الْجَنَابِ مُعَقِّرًا", "خُدُودِي وَزَالَ السُّقْمُ عَنِّي وَذُلُّهُ"],
      ["فَيَشْفَى سِقَامًا كَلَّ عَنْهُ طَبِيبُهُ", "وَجَرَّاحُهُ وَاشْتَدَّ فِي الْجِسْمِ نَيْلُهُ"],
      ["وَفَرَّ اضْطِرَابِي بَعْدَ طُولٍ تَجَلُّدٍ", "وَقَدْ فَرَّ طَلُّ الدَّمْعِ حَقًّا وَوَبْلُهُ"],
      ["عَلَى أَنَّ لُطْفَ اللَّهِ ثُمَّ جَمَالَهُ", "لَقَدْ غَمَرَانِي لَا يُرَى عَوْضُ شَكْلُهُ"],
      ["جَاءَ الْعَائِدُونَ لَا يَرَوْنَ مُسَوَّسًا", "فَقَدْ عَادَ فَرْعُ السُّقْمِ عَنْهُمْ وَأَصْلُهُ"],
      ["شَرَحْتُ بِهَذَا حَالِي وَلَيْسَ بِحَاجَةٍ", "إِلَى الشَّرْحِ وَالتَّبْيِينِ وَالْحَلُّ حَلُّهُ"],
      ["مَعِي ذِكْرُ مَوْلَانَا الْجَلِيلِ جَلَالُهُ", "مِنَ الصَّادِقِ الْمَصْدُوقِ أَمْسَى نَقْلُهُ"],
      ["يَبْقَى أَتْلُوهُ بِجَهْرٍ وَخُفْيَةٍ", "دَوَامًا وَمِثْلُ الْيَوْمِ فِي ذَاكَ لَيْلُهُ"],
      ["فَهَلْ أَبْصَرَتْ عَيْنَاكَ أَحْلَى مَعِيشَةً", "مِنَ الْعَبْدِ فَهْوَ الْحَمْدُ لِلَّهِ كُلُّهُ"],
      ["رَأَيْتَ رَسُولَ اللَّهِ جَهْرًا وَيَفْعَلُهُ", "بِتَارِيسَ هَلْ ذَاكَ الْمَحَلُّ مَحَلُّهُ"],
      ["فَشَأْنُكَ خَيْرُ النَّاسِ وَالْخَادِمُ الَّذِي", "لَهُ زَمَنٌ مَا جَامَعَ الصَّرْفَ عَذْلُهُ"],
      ["فَشَأْنُكَ خَيْرُ النَّاسِ وَالْخَادِمُ الَّذِي", "لِطُولِ افْتِرَاقٍ خَيْرٌ قَدْ طَارَ عَذْلُهُ"],
      ["فَشَأْنُكَ خَيْرُ النَّاسِ وَالْخَادِمُ الَّذِي", "فَرَضْتُهُ حُبُّ الْأَمِينِ وَنَفْلُهُ"],
      ["تَكَالَبَ أَعْدَاءٌ عَلَيْهِ لِحُبِّكُمْ", "فَشَتَّ لَهُمْ شَذًا لِيَجْمَعَ شَمْلَهُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَقُودُ لَنَا مَا فَاتَ طُرًّا وَمِثْلَهُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "نَبِيٌّ لَدَى هَذَا الْخُوَيْدِمِ سُؤْلُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمِنْ وَالِدِي لَا زَالَ فِي الْخُلْدِ نُزْلُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَعُودُ إِلَى شُغْلِي وَشُغْلِي شُغْلُهُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "أَنَالُ عَطَاءً مِنْهُ قَدْ طَالَ ذَيْلُهُ"]
    ]
