{
    "id": 3,
    "title": "حرف الجيم",
    "huruf": [
      ["جَمَعْتَ وُجُودًا هَيْئَةً وَجَلَالًا", "وَأَبْصَرْتُ مِنْ ذَا بَهْجَةً وَجَمَالًا"],
      ["جَمَالُكَ أَنْسَانِي هَيْئَةً وَمَحَبَّةً", "فَأَنْتَ أَنِيسُ الْمُرْسَلِينَ كَمَالًا"],
      ["وَكُلُّهُمْ حَازَ الْمَكَارِمَ وَالْعُلَا", "وَمَا كَإِمَامِ الْهَاشِمِيِّ خِصَالًا"],
      ["مُحَمَّدُ يَا خَيْرَ الْأَنَامِ وَسِيلَتِي", "حَبَاكَ إِلَهِي مَا يُقَوِّي مَقَالًا"],
      ["وَأَنْتَ وَهَبْتَ الْبِيضَ وَالسُّودَ فَانْتَهَى", "إِلَيْكَ خَدِيدٌ مَرْسُومٌ مِنْكَ مَنَالًا"],
      ["وَأَعْيِيكَ يَا خَيْرَ الْأَنَامِ وَسِيلَتِي", "مُنِيلِي لَدَى الْيَوْمِ الرَّهِيبِ نَوَالًا"],
      ["وَتَبْتِيلِي إِنِّي صِرْتُ مُحَمَّدًا", "عَلَى الْبَرِّ وَالْأَجْوَاءِ أَرْجُو وِصَالًا"],
      ["فَجَاوَزْتُ أَوْطَانِي وَأَهْلِي وَأُسْرَتِي", "أَجُوبُ الْفَلَا لَمْ أَشْكُ قَطُّ كَلَالًا"],
      ["بِكُولَا طَوْرًا أَوْ بِيُوفٍ وَمَرَّةً", "بِتَارِيسَ دَارِ الْفَاسِقِينَ كُسَالَى"],
      ["بِبَلْجِيكَ يَوْمًا ثُمَّ يَوْمًا تَجَوَّلًا", "بِقَاهِرَةٍ أَبْغِي هُنَاكَ جَمَالًا"],
      ["لِعَبْدِ الْمَلِيكِ الْقَرْمِ قَدْ جِئْتُ مُوهِنًا", "وَمَا لِيَ إِلَّا أَبْغِي فَهَبْ لِي خَيَالًا"],
      ["بِبَيْرُوتَ أَحْبُو فِي الشُّرُوقِ خَادِمًا", "رَسُولَ إِلَهِ الْعَرْشِ وَهْوَ تَعَالَى"],
      ["كَرَاشِي بِهَا خَلْقِي وَأَهْلَ مَوَدَّتِي", "هُمْ نَصَرُوا دِينَ النَّبِيِّ فَعَالًا"],
      ["قَدِ اعْتَصَمُوا بِالْحَبْلِ حَبْلِ مُحَمَّدٍ", "كُهُولًا وَأَطْفَالًا نِسَاءً وَرِجَالًا"],
      ["بِدَارِ عُلُومِ الدِّينِ أَدْرَكْتُ نُهْيَهُ", "فَقَدْ شَيَّدُوا مَجْدًا يَفُوقُ مَقَالًا"],
      ["لِمَرْكَزِ إِنْعَامِ الْإِلَهِ تَشَوَّقِي", "فَقَدْ شَادَ مَجْدًا إِذْ أَتَاحَ مَجَالًا"],
      ["بِالنُّورِ بِالْهُدَى الْقَدِيمِ عِصَارَتِي", "مَسِيرِي إِلَى الْمَوْلَى وَجَلَّ جَلَالًا"],
      ["لِهَنْكُوكَ مِنْ بَتَكُوكَ جَاءَ خَدِيمُكُمْ", "يُوَائِلُ لَكَ الْأَشْوَاقَ وَهْوَ أَطَالَا"],
      ["بِفَارِغِ صَبْرٍ قَدْ أَتَى مُتَطَلِّقًا", "فَحَقِّقْ رَجَا عَبْدٍ لَزَالَكَ مَالًا"],
      ["فَفِي كُلِّ حَيٍّ قَدْ خَبَطَتْ بِبِغْضَةٍ", "إِلَى كُلِّ حَيٍّ قَدْ بَذَلْتَ مَثَالًا"],
      ["عَلَوْتُ الْبِحَارَ الزَّاخِرَاتِ وَإِنَّنِي", "عَلَوْتُ الْقُرَى وَالْمُدْنَ بَلْ وَالْجِبَالَا"],
      ["أَرُومُ رِضَى الْبَارِي لِنُصْرَةِ دِينِهِ", "وَأَمْضِي لِلْجِدِّ الْجَدِيدِ مِثَالًا"],
      ["ضَعِيفٌ عَلِيلٌ شَائِبٌ مُتَحَسِّرٌ", "لِيَنْصُرَ دِينًا لَا يُرِيدُ قِتَالًا"],
      ["لِأَنَّ النَّبِيَّ الْهَاشِمِيَّ الدَّهْرَ مَا غَدَا", "بَلَى صَدَّ أَعْدَائِي وَرَدَّ ضَلَالًا"],
      ["تَقَاذَفَهُ الْأَجْوَاءُ شَرْقًا وَمَغْرِبًا", "يُبِينُ الْهُدَى فِعْلًا وَقَوْلًا وَحَالًا"],
      ["بِكُنْتُونَ جَنْبَ الْقَرَمِ سَعْدًا تَوَسُّلِي", "بِقَائِدِهِ رَدَّ الْجُيُوشَ وَصَالَالًا"],
      ["رَمَاهُمْ بِأَمْرِ الْهَاشِمِيِّ وَإِنَّهُ", "أَذَاقَ الْجُمُوعَ الْمُغْتَدِينَ وَبَالًا"],
      ["عَلَيْكَ سَلَامُ اللَّهِ يَا سَعْدُ إِنَّهُ", "أَتَاكَ خِفَافٌ يَرْجِعُونَ ثِقَالًا"],
      ["لِيَبْكِ مَنْ كُنْتُونَ بِالصِّينِ نَائِحًا", "وَكُولَا تَدْعُو قَدْ أَبَتْ لِلرِّحَالِ"],
      ["تَمَسَّكْ بِأَذْيَالِ النَّبِيِّ مُتَابِعًا", "مَذَاهِبَهُ وَالْمُحْدَثَاتُ فَلَا الَ"],
      ["فَتَغْيِبُكَ عَنْ دُسْتُورِ كُرْزٍ وَخَالِدٍ", "وَتَغْيِبُكَ عَنْ جُونٍ يَرُومُ مُحَالًا"],
      ["فَمَا تَابَلُّونَ أَوْ لَيْنٌ وَمَرْكَسٌ", "بِمُوحًى إِلَيْهِمْ خَلَّ عَنْكَ خَبَالًا"],
      ["كِتَابٌ مِنَ اللَّهِ الْجَلِيلِ جَلَالُهُ", "قَدِيمٌ وَنَابِقٌ لَا يَخَافُ زَوَالًا"],
      ["تَلَاهُ الْفَتَى الْمَأْمُونُ جَهْرًا وَيَتْلُو", "فَدَعْ بَعْدَ هَذَا كُلَّ قِيلٍ وَقَالَا"],
      ["فَيَا رَبِّ قَرِّبْ لِي الْعُيُونَ بِأَنْ أَرَى", "سِوَى الْحَقِّ مِنْ ذَا الْقَرْنِ زَالَ وَزَالَا"],
      ["وَيَعْلُو لِوَاءَ الْهَاشِمِيِّ وَقَدْ هَوَى", "لِوَاءُ الْغَيِّ وَالطُّغْيَانِ وَهْوَ تَعَالَى"],
      ["إِلَيْكَ وَلَا أَرْجُو سِوَاكَ وَإِنْ يَكُنْ", "سِوَاكَ مَتَالِيَ مَا قَبُلْتُ نَوَالًا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَجِرْنِي وَأَصْحَابِي أَرَاكَ ثِمَالًا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَشْمَلُ أَصْحَابَ النَّبِيِّ وَآلَا"]
    ]
