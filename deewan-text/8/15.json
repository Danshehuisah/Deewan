{
    "id": 15,
    "title": "حرف العين",
    "huruf": [
      ["عَلَى صَاحِبِ الْمِعْرَاجِ طَهَ تَحِيَّتِي", "فَسِيرِي إِلَيْهِ الدَّهْرَ تُبْلَغُ بُغْيَتِي"],
      ["أَسِيرُ لَهُ وَالشَّوْقُ مِنِّي مُبَرِّحٌ", "إِلَى طَيْبَةٍ أَهْدِي لِطَهَ تَحِيَّتِي"],
      ["تَحَرَّكَ رَحْلِي مِنْ مَدِينَةِ كَوْلَا", "أَرُومُ وِصَالًا مِنْ أَرَاضٍ تَطِيبُ"],
      ["أَطُوفُ فِي الْآفَاقِ وَالْحَالُ إِنَّنِي", "وُقُوفٌ بِبَابِ الْهَاشِمِيِّ الْقَرْمِ أَبْغِي"],
      ["يَئُوبُ لِكُنْفِي مِنْ دُؤُوبٍ وَمَقْصَدِي", "فَدُومِي لِطَهَ الْهَاشِمِيِّ وَهُوَ مُنْبَتِي"],
      ["إِلَى خَاتِمِ الرُّسُلِ الْكِرَامِ مُحَمَّدٍ", "عَلَيْهِ مِنَ الرَّحْمَنِ أَزْكَى تَحِيَّةٍ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "طَوَى السَّبْعَ طَيًّا ثُمَّ نَاجَى بِغَشْيَةِ"],
      ["يُطْبِقُهُ بِالرَّوْضِ الشَّرِيفِ وَمَا حَوَتْ", "مِنَ الشِّعْبِ وَالنِّسْوَانِ طُرًّا وَصِبْيَةِ"],
      ["وَلَيْسَ نَجَاحٌ فِي سُلُوكِ سِوَاهُ", "وَلَوْ زَخْرَفُوا الْآرَاءَ مِنْ كُلِّ فِرْيَةِ"],
      ["رَجَائِي رَفْعُ الدِّينِ وَالسُّنَّةِ الَّتِي", "تَجَاهَلَهَا الْأَقْوَامُ فِي كُلِّ فَرْيَةِ"],
      ["فَهَلْ تَجْمَعُ الْأَيَّامُ شَمْلَ مُحَمَّدٍ", "عَلَى نَهْجِهِ مِنْ دُونِ شَطْطٍ وَمِزْيَةِ"],
      ["تَطَاوَلَ لَيْلِي عِنْدَ كَوْلَا فَلَمْ أَنَمْ", "حَنِينًا إِلَى الْمَأْمُونِ هَادِي الْبَرِيَّةِ"],
      ["رَجَعْتُ وَمَا جِئْتُ الْمَدِينَةَ رَاضِيًا", "وَطَأْطَأْتُ رَأْسِي تَحْتَ أَقْصَى قَضِيَّةِ"],
      ["مَرَرْتُ بِأَحْبَابٍ كِرَامٍ أَمَاجِدٍ", "بِالْغُوسِ قَدْ جَاءُوا بِأَبْهَى عَشِيَّةِ"],
      ["جَزَاهُمْ إِلَهِي كُلَّ خَيْرٍ وَجَاءَهُمْ", "مِنَ اللَّهِ مَوْلَى الْخَلْقِ كُلُّ بَقِيَّةِ"],
      ["وَبَدَّدَ شَمْلَ الْمُرْجِفِينَ وَجَاءَهُمْ", "عَلَى عَكْسِ مَا رَامُوهُ كُلُّ بَلِيَّةِ"],
      ["وَيَكْفِي صِحَابِي شَرَّ قَوْمٍ عَلِمْتُمُ", "يَكِيدُونَ دِينَ الْهَاشِمِيِّ فَيُخْفَى"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَعْلُو عَلَى كُلِّ الْيَتُاتِ بِثَتْيَةِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَقْبَلُ حَجَّاتٍ وَتَقْبَلُ مَشِيَّتِي"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَشْفَعُ لِي عِنْدَ الْكَرِيمِ السَّجِيَّةِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَصَحْبٍ وَأَحْبَابٍ وَأَهْلَ وَصِيَّتِي"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "فَحَقِّقْ رَجَائِي قَبْلَ يَوْمِ مَنِيَّتِي"]
    ]
