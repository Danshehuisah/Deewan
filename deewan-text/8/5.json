{
    "id": 5,
    "title": "حرف الذال",
    "huruf": [
      ["ذَهَبْتُ بِذِكْرِ الْهَاشِمِيِّ أُجَاوِبُ", "مَعِي قَلَمِي وَاللَّوْحُ وَالْخَطُّ يَذْهَبُ"],
      ["ذَكَرْتُ النَّبِيَّ الْهَاشِمِيَّ فَزَادَنِي", "شَرَفًا وَعُلًى حَتَّى سَمَوْتُ وَأَطْيَبُ"],
      ["ذَكَرْتُ جَمَالَ الْهَاشِمِيِّ فَلَمْ يَدَعْ", "لِغَيْرِ جَمَالٍ فِي الْفُؤَادِ مُشَعَّبُ"],
      ["ذَكَرْتُ رَسُولَ اللَّهِ طَهَ مُحَمَّدًا", "فَفَاحَ لَنَا مِنْ نَشْرِهِ مِسْكُ مَشْرَبُ"],
      ["ذَكَرْتُ الَّذِي شَقَّ الْقَمَرْ بِنَظْرَةٍ", "وَكَلَّمَهُ الْأَشْجَارُ وَالْجِذْعُ يَخْطُبُ"],
      ["ذَكَرْتُ الَّذِي نَادَاهُ فِي الْغَارِ جِبْرِئِيلٌ", "فَعَلَّمَهُ الْقُرْآنَ وَالدِّينُ يَقْرُبُ"],
      ["ذَكَرْتُ الَّذِي أَسْرَى بِهِ اللَّهُ لَيْلَةً", "فَعَايَنَ مَا لَمْ يَعْهَدُ الْخَلْقُ يُرْقَبُ"],
      ["ذَكَرْتُ الَّذِي بِالْحَقِّ نَطْقُهُ", "فَبِالْحَقِّ جَاءَ الْحَقُّ وَالْخَلْقُ تَغْلِبُ"],
      ["ذَكَرْتُ الَّذِي أَخْبَارُهُ كُلُّهَا هُدًى", "فَبِالْهُدَى هَدَانَا وَالضَّلَالُ مُذَنْبُ"],
      ["ذَكَرْتُ الَّذِي بِالْوَحْيِ جِبْرِيلُ جَاءَهُ", "فَحَيَّا بِهِ الْمَوْتَى وَأَحْيَا وَيُعْجِبُ"],
      ["ذَكَرْتُ الَّذِي بِالنُّورِ نُورُهُ", "فَنُورُهُ أَضَاءَ الْكَوْنُ وَالْكَوْنُ يُخْضِبُ"],
      ["ذَكَرْتُ الَّذِي بِالْحَقِّ يُحْيِي الْبِلَادَ", "فَقَدْ أَحْيَا الْبِلَادَ وَأَهْلُهَا تُرْحَبُ"],
      ["ذَكَرْتُ الَّذِي بِالْعَدْلِ يَحْكُمُ بَيْنَنَا", "فَحُكْمُهُ عَدْلٌ وَالْجَوْرُ يُذْهَبُ"],
      ["ذَكَرْتُ الَّذِي فِي الذِّكْرِ ذِكْرُهُ", "فَذِكْرُهُ عَلَى الْأَيَّامِ يَبْقَى وَيُكْتَبُ"],
      ["ذَكَرْتُ الَّذِي بِالْخُلْقِ أَعْظَمُ خُلْقِهِ", "فَخُلْقُهُ قُرْآنٌ وَفِيهِ نُحِبُّ"],
      ["ذَكَرْتُ الَّذِي بِالْحَمْدِ حَمْدُهُ", "فَحَمْدُهُ عَلَى الْأَشْيَاءِ يَبْقَى وَيُطْلَبُ"],
      ["ذَكَرْتُ الَّذِي بِالْحَقِّ بَعَثَهُ", "فَبِالْحَقِّ بُعِثْ الْهَادِي وَالْحَقُّ يَغْلِبُ"],
      ["ذَكَرْتُ الَّذِي بِالنَّاسِ نَاسُهُ", "فَنَاسُهُ أَعْلَاهُمْ وَأَعْظَمُ وَأَطْيَبُ"],
      ["ذَكَرْتُ رَسُولَ اللَّهِ طَهَ مُحَمَّدًا", "فَذِكْرُهُ لِقَلْبِي رَاحَةٌ وَتَطَيُّبُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَدَى الدَّهْرِ مَا ذَرَّتْ نُجُومٌ وَكَوْكَبُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ فِي الْخَلَائِقِ تُنْخَبُ"]
