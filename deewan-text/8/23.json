{
    "id": 23,
    "title": "حرف التاء",
    "huruf": [
      ["تَرَاءَى هِلَالٌ أَوْ جَمَالٌ فَأَبْتُلِ", "مَتَى لَاحَ وَجْهُ الْهَاشِمِيِّ وَأَصْبُو"],
      ["تَبَدَّى فَأَهْلًا ثُمَّ سَهْلًا وَمَرْحَبًا", "بِوَجْهِكَ عَاشَ الْبَرَايَا وَقَوَّوْا"],
      ["مُحَيَّا كَبَدْرِ التَّمِّ وَالشَّمْسِ فَاصْدَحُوا", "لِخَالِقِهِ مَرَّ الْجَدِيدَيْنِ وَافْتَحُوا"],
      ["فَعُمْرِي مَا شَاهَدْتُ شِبْهَ جَمَالِهِ", "فَلِيَ الْمَدْحُ وَالتَّنْزِيهُ عُمْرِيَ مُوثَقُ"],
      ["لَقَدْ لَاحَ هَذَا الْوَجْهُ وَالْكَوْنُ كُلُّهُ", "ظَلَامٌ وَقَدْ ضَلَّ كُلُّ ذَا الْكَوْنِ مُسْبَكُ"],
      ["فَعَمَّ الْهُدَى وَالْخَيْرُ وَالْفَيْضُ وَالْجَدَا", "وَقَدْ شَاعَ ذِكْرُ اللَّهِ وَالْكُفْرُ مُبْتَكُ"],
      ["هَنِيئًا لَنَا أَتْبَاعَ أَحْمَدَ قَدْ أَتَى", "لَنَا خَيْرُ دَاعٍ لِلْأَسَاطِيرِ مُسْلِكُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَجَيْشُ هُجُومِي بِالْحَبِيبِ مُسَلَّكُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأَدْعُو لِدِينِ الْهَاشِمِيِّ وَأُثْبِتُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَسْتُ أَرَى ضِدًّا مَدَى الدَّهْرِ يُشْبِهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَرَى الدَّهْرَ عَبْدًا خَاشِعًا لَكَ يَغْبِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمِنْ وَالِدِي قَدْ كَانَ لِلْخَيْرِ يَثْبُتُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَعِزٌّ لَهُ فِي صَحْبِهِ الدَّهْرَ يَثْبُتُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ صَيَّرُوا الْكُفْرَ يَثْبُتُ"]
    ]
  }