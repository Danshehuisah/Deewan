{
    "id": 14,
    "title": "حرف الصاد",
    "huruf": [
      ["صَبَا جَبَلَا نُعْمَانَ بِاللَّهِ خَلَّصَ", "نَسِيمًا سَرَى مِنْ ذَا الْعَقِيقِ فَيَخْلُصُ"],
      ["فَإِنَّ نَسِيمًا مِثْلَهُ سَيَتِمُّ لِي", "شِفَاءَ سِقَامِي بَلْ يُتِمُّ تَخْلُصِي"],
      ["إِلَى رَحْمَةِ اللَّهِ السَّرَاجِ مُحَمَّدٍ", "إِلَى خَيْرِ دَاعٍ لِلْبَرَايَا مُخْلِصٍ"],
      ["إِلَى أَحْمَدَ الْمَاضِي إِلَيْهِ تَوَجُّهِي", "وَسِيَّانِ عِنْدِي مَادِحِي وَمُنْقِصِي"],
      ["إِلَيْكَ رَسُولَ الْعَالَمِينَ مُحَمَّدًا", "شَفِيعَ الْوَرَى فِي الْكُلِّ جِدُّ مُخَصَّصِ"],
      ["لِمَنْ جَاءَ بِالْعِزِّ الْعَظِيمِ وَخِزْيِ مَنْ", "تَوَلَّى عَنِ الْمُثْلَى وَلَمْ يَتَخَصَّصِ"],
      ["هَدَى الْخَلْقَ لِلنَّهْجِ الْقَوِيمِ وَقَدْ شَفَى", "سِقَامَهُمْ مِنْ كُلِّ أَعْمَى وَأَبْرَصِ"],
      ["سَرَى بِكَ لَيْلًا ثُمَّ أَدْنَاكَ رَاهِبًا", "إِلَى حَضْرَةٍ لَمْ يُلْفَ مَوْطِنُ أَخْمَصِ"],
      ["تَجَاوَزْتَ أَفْلَاكَ النُّجُومِ وَقَدْ دَنَا", "لَكَ الْعِلْمُ وَالْأَسْرَارُ خَيْرُ مُخَلَّصِ"],
      ["وَنِلْتَ مَقَامًا قَدْ تَقَاصَرَ دُونَهُ", "مَجِيعُ هُدَاةِ الْخَلْقِ مِنْ كُلِّ مُخْلِصِ"],
      ["فَرَحْتُ لَهُ مِنْ مَغْرِبِ الشَّمْسِ أَرْتَجِي", "يُخَلِّصُنِي هَلْ غَيْرُ طَهَ مُخَلِّصِي"],
      ["فَإِنَّكَ بَابُ اللَّهِ لَيْسَ يُلْفَى مُسْلِكٌ", "سِوَاكَ إِلَى رَبِّ الْكَرِيمِ الْمُخَصَّصِ"],
      ["فَأَنْتَ سِرَاجُ الدِّينِ وَالنُّورُ سَاطِعٌ", "وَظِلُّ الْوَرَى وَالظِّلُّ لَمْ يَتَقَلَّصِ"],
      ["أَتَاكَ مُحِبٌّ شَاعِرٌ خَادِمٌ لَكُمْ", "أَرَى مَدْحَ غَيْرِ الْهَاشِمِيِّ مُنَقِّصِي"],
      ["أَتَيْتُكَ يَسْعًا ثُمَّ عَشْرًا وَإِنَّنِي", "أَتَيْتُكَ هَذِي فَاهْدِنِي لَا تَرْبِصِ"],
      ["أَسِيرُ وَفِي الشَّوْقِ الْمُرِيحِ لَمْ أَنَمْ", "فَلَسْتُ إِلَى الْعَيْنِ الرَّقِيدِ بِأَخْرَصِ"],
      ["فَحَيِّ وَجُرِّدْ فِي وِصَالِ مُحَمَّدٍ", "بِحِينٍ وَمَعْنًى بَلْ بِطُولٍ تَشَخُّصِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَخُصَّ خَدِيمًا يَا كَرِيمُ وَخَصِّصِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَا رَبَّ فَاقْبَلْ حَجَّنَا وَلْتُمَحَّصِ"],
      ["وَأَصْلِحْ شُؤُونَ الْمُسْلِمِينَ وَخُصَّصُوا", "لِصَحْبِي وَأَحْبَابِي فَأَصْلِحْ وَخَصِّصِ"],
      ["وَدَمِّرْ عُدَاةَ الْمُسْلِمِينَ جَمِيعَهُمْ", "مَنَارًا وَدَيَّانًا وَرِجْسًا وَنَقْصًا"],
      ["وَأَلْحِقْ بِهِ مَنْ قَدْ عَلِمْتَ وَطَهِّرَنْ", "مَسِيرًا وَدَيَّانًا وَرِجْسًا وَنَقْصًا"],
      ["لَعَلَّ عَرَفَاتٍ وَالْمَقَامَ فَخَاطِرِي", "جَمِيعُ بِلَادِ اللَّهِ لِلدِّينِ تَخْلُصِ"],
      ["أُوحِدُ رَبِّي ثُمَّ أَهْوَى مُحَمَّدًا", "وَأُثْنِي عَلَى الْهَادِي وَفِيهِ أَخَصِّصِ"],
      ["أَرَانِي أَرَى الْهَادِي وَلَيْسَ سِوَاهُ", "وَكَمْ مَنْ سَرَى فِي الْمَعْرُوفِ مُخَصَّصِ"],
      ["جَزَى اللَّهُ عَنِّي وَالِدِي وَأَحِبَّتِي", "جَزَاءَ قَائِدٍ قَدْ عَاشَ أَفْضَلَ مُخْلِصِ"],
      ["عَلَيْهِ مَدَى الْأَيَّامِ مَا قَالَ مُغْرَمٌ", "صَبَا جَبَلَا نُعْمَانَ بِاللَّهِ خَلَّصِ"]
    ]
  }