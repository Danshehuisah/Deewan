    "title": "حرف الياء",
    "huruf": [
      ["يَمَّمْتُ رِكَابِي مَهْبِطَ الْوَحْيِ مُلْتَقَى", "كِتَابَ دِينِ الْهَاشِمِيِّ الَّذِي اتَّقَى"],
      ["أَسِيرُ إِلَى الْبَطْحَا أَطُوفُ بِبَيْتِهِ", "وَأَمْشِي إِلَى نُورِ الْهُدَى مُتَشَوِّفَا"],
      ["أُوَافِي حَبِيبًا رَافِدًا حَوْلَ رَوْضَةٍ", "عَلَى الْخُلْدِ وَالْفِرْدَوْسِ أَبْهَى تَشَوُّفَا"],
      ["فَإِنَّ لَكَ مِنْ مَرْأًى هُنَاكَ وَمَسْمَعٍ", "تَرَى الْعِلْمَ وَالْعِرْفَانَ يَجْرِي تَدَفُّقَا"],
      ["تَرَى كُلَّ أَخْيَارِ الْخَلَائِقِ حَوْلَهُ", "لِإِنْسَانِ عَيْنِ الْخَلْقِ لِلْكُلِّ مُسْتَقَى"],
      ["يُؤَدُّونَ حَقَّ الْحَقِّ فِي وَصْلِ حَبِيبِهِمْ", "مُحَمَّدُ مُخْتَارُ الْإِلَهِ وَمُنْتَقَى"],
      ["فَهَرْوَلْتُ مِنْ أَرْضِي بِكُولَا طَائِرًا", "بِحُبٍّ وَإِيمَانٍ بِهِ مُتَعَلِّقَا"],
      ["بِالْغُوسِ وَالْخَرْطُومِ لَيْلًا وَإِنَّنِي", "كَذِي الشَّوْقِ لَا أُولِي عَلَى الْغَيْرِ مُطْلَقَا"],
