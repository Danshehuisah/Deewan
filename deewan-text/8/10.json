      ["عَلَيْكَ أَيَا بِرْهَامُ بَعْدَ مُحَمَّدٍ", "صَلَاةً وَتَسْلِيمًا يَزِيدَانِ رَوْنَقَا"],
      ["لَدَى قَصْرِ رَأْسِ التِّينِ زُرْتُ تَوَسُّلًا", "لِطَهَ فَتَاهُ جَابِرًا وَتَعَلَّقَا"],
      ["وَأَهْدَيْتُ لِلْمُرْسِي الْكَبِيرِ تَحِيَّةً", "كَذَا لِزُوَيْلٍ فِي الثَّنَاكِينَ أَفْلَقَا"],
      ["فَعَنْهُمْ رِضَى الْبَارِي وَعَنْهُمْ يُشْهَدُ", "وَيُعْطِي لَنَا فَيْضًا بِرًّا مُتَدَفِّقَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "رِضَا اللَّهِ عَنْ شَيْخِي أَبِي كَانَ مُشْفِقَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأُودِعُ أَوْلَادِي لَدَيْكَ تَوَثُّقَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأَهْلِي وَأَحْبَابِي وَمَنْ قَدْ تَعَلَّقَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَا أَمَّ رَحْلِي مَهْبِطَ الْوَحْيِ مُلْتَقَى"]
