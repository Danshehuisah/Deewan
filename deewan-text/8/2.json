{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["بَلَى إِنَّهُ هَذِي أَرَاضِي طَهَ مُحَمَّدٍ", "فَذَاكَ عَقِيقٌ ذَاكَ سَلْعٌ وَعَرْقَدُ"],
      ["وَهَذَا أُحُدٌ هَذَا قُبَاءٌ وَبَيْنَ ذَا", "وَذَاكَ مَرَادُ الْمُنْعِمِ الْمَوْلَى مُحَمَّدُ"],
      ["وَذَاكَ بَطْحَانٌ وَهَذَاكَ خَنْدَقٌ", "بِهِ قَرَّ صَفْرٌ كَانَ قَبْلُ يَهُودُ"],
      ["بِهِ هُرِمَ الْجَيْشُ الْعَرَمْرَمُ بَعْدَمَا", "تَبَيَّنَ أَنَّ الرَّبَّ أَعْلَى وَيَنْفَرِدُ"],
      ["وَقَدْ رَجَعَ الْمَنْصُورُ وَالْجِبْتُ خَاشِعٌ", "بِمَأْتَمِ كُفْرٍ فِي الْجَزِيرَةِ يُعْقَدُ"],
      ["وَقَدْ جَاءَ نَصْرُ اللَّهِ وَالْفَتْحُ وَالْهُدَى", "دُجَى الْكُفْرِ وَالطُّغْيَانِ إِذْ جَاءَ أَحْمَدُ"],
      ["وَأَشْرَقَ نُورُ الْعِلْمِ وَالرُّشْدِ وَالتُّقَى", "أَلَا اتَّبِعُوا دِينَ الرَّسُولِ فَتَسْعَدُوا"],
      ["كَسَعْدِ الْمَاضِينَ مِنْهُمْ إِمَامِهِمْ", "أَبُو بَكْرٍ الْأَنْقَى الْمَعَلَّى الْمُسَدَّدُ"],
      ["وَكَالشَّيْخِ لِلْكُبْرَى الْمُطَهَّرِ مَنْ عَدَا", "سِرَاجًا وَفَارُوقًا وَذَاكَ الْمُؤَيَّدُ"],
      ["وَعُثْمَانُ ذُو النُّورَيْنِ كُلٌّ قَدِ اعْتَلَى", "ذُرَى الْمَجْدِ فِي الدَّارَيْنِ وَالْكُلُّ صِنْدِيدُ"],
      ["وَسَيِّدُهُمْ لَيْثُ الْكِتَابِ وَصِنْدِيدُهُمْ", "عَلِيٌّ أَبُو السِّبْطَيْنِ سَيْفِي الْمُهَنَّدُ"],
      ["وَحَمْزَةُ وَالْعَبَّاسُ وَاذْكُرْ جَعْفَرًا", "وَشَايِبَةَ أَبْهَى النَّاسِ فَخْرًا مُسَدَّدُ"],
      ["إِلَيْكَ رَسُولَ اللَّهِ حِبٌّ وَخَادِمٌ", "يَرُومُ رِضَى الْبَارِي وَفِي الْخُلْقِ يَجْتَهِدُ"],
      ["عَلَيْكَ سَلَامٌ وَهْوَ مِسْكِي وَإِلْيَا", "عَلَى الْجَوِّ فِي تَيْهَاءَ يَامَةَ أَنْجُدُ"],
      ["أُجَمْجِمُ فِي الْأَجْوَاءِ طَوْرًا وَتَارَةً", "أُجَابِي الْمَوَامِي فَأَجْفَدُ ثُمَّ أَجْفَدُ"],
      ["عَلَى هَيْكَلٍ يَفْرِي الْفَلا وَحَنِينُهُ", "حَنِينُ عِشَارٍ أَوْ لَكَ الْبَرْقُ يَرْعُدُ"],
      ["مَرَرْتُ بِبَدْرٍ بِالْقَلِيبِ تَذَكُّرًا", "لِقَائِدِنَا الْأَعْلَى الْمُفَقَّى وَأَمْجَدِ"],
      ["أَيُسْمَحُ سُؤْلِي فَأَدْنُو مُعَانِقًا", "لِأَهْلِ الْقَلِيبِ الْكَافِرِينَ الْأَنْجُدِ"],
      ["وَأَسْأَلُهُمْ مَاذَا لَقُوا حِينَ هَيَّجُوا", "الْمُفَقَّى بِجَيْشٍ رَتَّلُوهُ وَجَنَّدُوا"],
      ["أَبُو جَهْلٍ الْعَاقِي وَوَلِيدٌ وَشَيْبَةٌ", "كَذَا عُتْبَةٌ إِذْ قَلَّدُوهُمْ وَأَوْفَدُوا"],
      ["بِلِقَاءِ بَدْرٍ قَدْ أُسِرُوا بِذِكْرِهِ", "فَكُلٌّ فَتَى أَوْ أَسِيرٌ مُفْرَدُ"],
      ["أُعَقِّرُ نَضْوِي عِنْدَ مَمْشَى مُحَمَّدٍ", "وَبَيْنَ جُلَاتِي هُرْشِدٍ طَرِيقٌ مُهْمَدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مِنَ الْعَبْدِ فِي رَكْبٍ وَرَوْضٍ كَمَا يَقْصِدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَمْ أَكُ فِي دَرْكِ الْمُنَى أَتَرَدَّدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمِنْ وَالِدِي شَيْخِي وَمَا زَالَ يَحْمَدُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "تَطِيبُ حَيَاتِي ثُمَّ فِي الْقَبْرِ أَسْعَدُ"]
    ]
  }