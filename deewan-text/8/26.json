{
    "id": 26,
    "title": "حرف اللام ألف",
    "huruf": [
      ["رَسُولَ إِلَهِ الْعَالَمِينَ تَعَالَى", "خَدِيمُكَ نَادَى يَا رَسُولُ تَعَالَى"],
      ["خَدِيمُكَ نَادَى يَا رَسُولُ فَلَا أَرَى", "فَقِيرًا إِلَى غَيْرِ الْإِلَهِ تَعَالَى"],
      ["خَدِيمٌ بِأَقْصَى الْغَرْبِ يَدْعُو مُحَمَّدًا", "وَلَيْسَ يَرَى غَيْرَ الرَّسُولِ ثِمَالَا"],
      ["خَدِيمٌ ثَوَى بِالْبَابِ وَهْوَ مُؤَمَّلٌ", "إِيَّاكَ كَرِيمًا وَهْوَ جِئْتُ أَطَالَا"],
      ["تَصَاغَرَ عِنْدِي غَيْرُ أَحْمَدَ إِنَّنِي", "أَرْجُو مِنَ الْهَادِي الْعِبَادِ مَنَالَا"],
      ["كَرِيمَ السَّجَايَا وَاسِعَ الْجُودِ مَا تَرَى", "لِضَيْفِ كَرِيمٍ قَدْ أَجَادَ مَقَالَا"],
      ["فَهَبْهُ عَلَى مِقْدَارِ كَيْفَ اصْطَفَى", "الْبَرَايَا عَطَاءً لَا يَخَافُ زَوَالَا"],
      ["فَفِي كُلِّ حَيٍّ قَدْ خَبَطَتْ بِيَمِينِهِ", "وَإِنِّي كَشَاخٍ قَدْ أَرُومُ نَوَالَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَشْمَلُ أَصْحَابَ النَّبِيِّ وَآلَا"]
    ]
  }