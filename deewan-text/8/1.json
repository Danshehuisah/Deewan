{
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["أَطْيَفُ سَرَى أَمْ أَنَّ رَكْبِيَ أَقْمَا", "مَوَاطِنَ خَيْرِ النَّاسِ لِلْمَثْوَى صَمَمَّا"],
      ["وَهَلْ يَا تَرَى إِنِّي أُؤَمِّلُ بَلْدَةً", "وَأَمْشِي بِتَأْدِيبٍ لِطَهَ مُسَلَّمَا"],
      ["أَنَا جِئْتُ أَمِينَ اللَّهِ خَازِنَ سِرِّهِ", "وَمُعْطِي ذَوِي الْفَاقَاتِ كَثْرًا وَمَغْنَمَا"],
      ["أُنَادِيهِ طَهَ الْمُنْعِمَ الْمَوْلَى مُحَمَّدًا", "أَتَاكَ خَدِيمٌ شَائِبُ الْفَوْدِ مُعْدِمَا"],
      ["أَذْكُرُ حَالِي أَمْ كَفَاكَ فَإِنَّمَا", "تَكَرَّمْتَ لِي مِنْ قَبْلُ مَا كُنْتُ مُلْزَمَا"],
      ["مَكَارِمُ أَهْلِ الْجُودِ فِيكَ تَجَمَّعَتْ", "فَقَدْ عِشْتَ أَسْعَى النَّاسِ بَلْ دُمْتَ أَكْرَمَا"],
      ["وَجِئْتُكَ عَبْدًا ضَارِعًا مُنْشِئًا لَهَا", "فَأَوَّلَ الْقَافِيَةِ خَادِمًا جَاءَ مُغْرَمَا"],
      ["مُحِبًّا فَقِيرًا سَائِلًا جَاءَ شَاعِرًا", "يَجُوبُ الْفَيَافِي حَازَ شَيْئًا وَمَهْرَمَا"],
      ["فَإِنَّكَ خَيْرُ النَّاسِ مِنْ خَيْرِ أُمَّةٍ", "إِلَى خَيْرِ مَوْلًى قَدْ دَعَوْتَ مُعَظَّمَا"],
      ["فَسُدْتَ الْوَرَى عَبْدَ الْإِلَهِ شَفِيعَنَا", "لِوَاءُ الْحَمْدِ فِي كَفَّيْكَ أَعْلَى وَأَعْظَمَا"],
      ["لِظِلِّكَ يَأْوِي الْأَنْبِيَاءُ وَكُلُّهُمْ", "يَرَوْنَ أَبًا لِلْكُلِّ أَوْفَى وَأَرْحَمَا"],
      ["فَجَاهُكَ هَذَا لَمْ يَضِقْ عَنْ خَدِيمِهِ", "فَكُنْ لِي شَفِيعًا بَلْ أَجِرْنِي تَكَرُّمَا"],
      ["إِذَا اسْتَوْجَبَ الْخُدَّامُ عِتْقًا مُعَجَّلًا", "لَدَى الشَّيْبِ أَحْبُو أَنَّ عِتْقِيَ حَتْمَا"],
      ["فَكُنْ لِي رَسُولَ الْعَالَمِينَ مُحَمَّدًا", "فَإِنِّي خَدِيمٌ عَاشَ فِيكَ مُهَيَّمَا"],
      ["أَتَيْتُكَ شَرْخًا ثُمَّ كَهْلًا وَإِنَّنِي", "أَتَيْتُكَ شَيْخًا لَا يَزَالُ مُتَيَّمَا"],
      ["غَرَامِي وَتَبْيَاضِي وَوَجْدِيَ رُفْقَتِي", "وَقَدْ بَاتَ شِعْرِي عَنْ سِوَاكَ مُحَرَّمَا"],
      ["إِلَيْكَ وَإِلَّا فَالرَّكَابُ لَمْ تَسِرْ", "لِسَانِي طَلْقٌ فِيكَ وَالْكُلُّ تَوَمًا"],
      ["بِغَانَةَ وَالْأَحْيَا رُقُودٌ وَلَمْ يَزَلْ", "فُؤَادِي بِحُبِّ الْهَاشِمِيِّ مُهَيَّمَا"],
      ["أُخَاطِبُهُ بِالشِّعْرِ وَالْقَلَمِ الَّذِي", "يُقَرِّبُ أَقْصَى مَا أَكِنُّ مُبَرَّجَا"],
      ["بِبِرٍّ وَبَحْرٍ قَدْ بَعَثْتُ مَدَائِحِي", "وَهَذَا الْيَوْمَ أَشْدُو فِي الْهَوَامِ مُتَرَنِّمَا"],
      ["أُخَاطِبُهُ بِالْمَدْحِ وَهْوَ بِطَيْبَةٍ", "وَإِنِّي أَرَى الْبَيْتَ الْعَتِيقَ الْمُحَرَّمَا"],
      ["أُلَاحِظُ رُكْبَانًا أَمْسَى مُقْبِلًا", "أَثَرْتُ مَكَانًا شَاهَهُ الْبَدْرُ مُحْرِمَا"],
      ["بِمَرِّ الصَّفَا فَوْقَ الْبِطَاحِ مِنْ بَطْنِ مَكَّةَ", "أُنَاشِدُ مَدْحَ الْهَاشِمِيِّ مُبَرَّقَا"],
      ["بِجَمْعٍ وَمِنًى وَالْمُسْلِمُونَ حَوْلَهُمْ", "بِذِكْرٍ وَتَكْبِيرٍ تَرَى الْكُلَّ أَحْرَمَا"],
      ["فَمَنْ لِي بِالْإِلْمَامِ بِطَيْبَةٍ وَالْقَنَا", "مَقَرِّ رَسُولٍ جَاءَ أَخِيرًا مُقَدَّمَا"],
      ["مَرَادُ أَمِينِ اللَّهِ مَرْكَزُ أَحْمَدَ", "بِهَا نَصْرُ الْإِسْلَامِ أَعْلَى وَأَفْخَمَا"],
      ["بِهَا ظَلَّ جِبْرِيلُ الْأَمِينُ مُوَاظِبًا", "وَمُسْتَخْدَمًا فِي شَأْنِ مَنْ جَاءَ مُخْتَمَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مِنَ الْعَبْدِ إِبْرَاهِيمَ شَوْقًا وَمَغْرَمَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "قَوِيَّ رَجَاءٍ بَلْ أُرَجِّي مُنَسَّمَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَفَرِّجْ كُرُوبَ الْمُسْلِمِينَ وَعَمِّمَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمِنْكَ إِيَابِي مُصْطَفَى الْكَوْنِ مُكْرَمَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَيُرْزَقُ وَفْدِي مِنْكَ أَوْبًا وَمَغْنَمَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ مَا قَالَ مُغْرَمٌ", "أَطْيَفُ سَرَى أَمْ أَنَّ رَكْبِيَ أَقْمَا"]
    ]
  }