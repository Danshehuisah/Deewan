{
    "id": 4,
    "title": "حرف الدال",
    "huruf": [
      ["دُمُوعٌ كَرَفْرَافِ اللَّجِينِ تُبَرِّحُ", "عَلَى صِدْقِ شَوْقٍ بَيْنَمَا الْوَقْتُ مُوهِنُ"],
      ["عَلَى هَيْكَلٍ فَوْقَ الْغَمَامِ قَاصِدًا", "مَزَارَكَ أَعْلَى النَّاسِ خُلْقًا وَأَحْسَنُ"],
      ["مُحَمَّدُ يَا خَيْرَ الْأَنَامِ فَمَا تَرَى", "لِمُبْتَلًى شَدِيدِ الْحُبِّ وَالْمَدْحَ يُحْسِنُ"],
      ["إِلَى جَمْعِكَ الْمَدَّاحَ بُغْيَتِي وَإِنَّهُ", "أَسِيرُ هَوًى لَمْ يُلْفَ فِي الدَّهْرِ يُحْسِنُ"],
      ["فَكُنْ لِي شَفِيعًا يَا شَفِيعُ فَكُلُّ مَنْ", "سِوَاكَ فَقِيرٌ لِلشَّفَاعَةِ مُعْلِنُ"],
      ["وَلِي أَرْجُوهَا بَشَرًا وَلَمْ أَنَلْ لَهَا", "سَبَبًا غَيْرُ الْكَبَائِرِ تَغْلِبُنِي"],
      ["أَتَيْتُكَ لَا أَرْجُو سِوَاكَ مُحَمَّدًا", "وَأَنْتَ مَزُورِي أَنْتَ لِلْخَيْرِ مَعْدِنُ"],
      ["بِفَارَانَ بِالْبَطْحَاءِ بِالْبَيْتِ تَقْبَلَنِي", "خَدِيمًا رَفِيفًا لِلْجِنَانِ فَيُؤْنَسُ"],
      ["فَصِلْنِي رَسُولَ اللَّهِ طَهَ مُؤَمَّلًا", "فَلَمْ يَأْتِ لِي مِنْ عِنْدِ غَيْرِكَ مَأْمَنُ"],
      ["أَرَانِي كَفَرِي لَاجِئًا عِنْدَ بَابِكُمْ", "وَكُلٌّ عَظِيمُ السُّؤْلِ كُلٌّ يُذَنْدِنُ"],
      ["بِمَوْقِفِ بَدْرٍ لَا يَزَالُ تَذَكُّرِي", "إِلَى مَنْ عَذَا يُحْيِي الذَّمَارَ وَيُومِنُ"],
      ["وَبَدْرٌ حَرَىً فِيهِ الْجُمُوعُ تَفَرَّقَتْ", "بِصَارِمِهِ الصَّمْصَامِ عَنْهُمْ يُبَدِّدُ"],
      ["وَأُحُدٌ بِهِ عَمُّ النَّبِيِّ تَشَظَّى", "حُسَيْنٌ وَحَمْزَاةُ الَّذِي كَانَ أَحْمَدُ"],
      ["وَقَدْ شُدِّدَتْ تِلْكَ الْحُرُوبُ لِنَصْرِهِ", "فَأَعْلَى بِنَا ذِكْرًا وَدِينًا مُشَيَّدُ"],
      ["بِسَيْفِ ابْنِ ذِي الْيَزَنِ الْكَرِيمِ مُحَمَّدٍ", "وَجِبْرِيلُ يَحْمِي الْحَقَّ وَالْحَقُّ يُشْهَدُ"],
      ["يُقَاتِلُ عَنْهُ الصِّدِّيقُ فِي كُلِّ مَوْطِنٍ", "وَفَارُوقُ يَحْمِي الْحَوْزَ وَالْكُلُّ يَحْمَدُ"],
      ["وَعُثْمَانُ وَاللَّيْثُ الْهُمَامُ كِلَاهُمَا", "يُقَاتِلُ عَنْهُ وَهْوَ بِالنَّصْرِ يُؤْيَدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتَرْحَمَ عَبْدًا بِالذُّنُوبِ مُفَنَّدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَلَا تَخْذِلَنِّي فِي الْخُطُوبِ وَأَسْعُدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَقِيَنِي مَقِيلَ السُّوءِ وَالْخَطْبُ يُرْصِدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَنْصُرُنِي فِي كُلِّ يَوْمٍ وَتُسْعِدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمَنْ يَكُ عَوْدًا لِلْأَمِينِ وَيَحْمُدُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ جُدُودٌ وَأَنْجُدُ"]
    ]
