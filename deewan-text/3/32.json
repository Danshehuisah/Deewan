{
    "id": 32,
    "title": "حرف الواو",
    "huruf": [
      ["وَإِنِّي أُسَامَى الدَّهْرَ سُعْدَى كَذَا أَرْوَى", "لِحُبِّ حَبِيبٍ مَا تَذَكَّرْتُهُ أَرْوَى"],
      ["فَإِنْ تَسْأَلُوا عَنْ مَذْهَبِي وَمُعَتَّقِي", "فَحُبُّ النَّبِيِّ الْهَاشِمِيِّ وَهْوَ مَنْ أَهْوَى"],
      ["إِلَيْهِ مَسِيرِي وَهْوَ قَصْدِي وَمَطْلَبِي", "سَبِيلِي اقْتِفَا مَا عَنْ حَالَتَيْهِ يُرْوَى"],
      ["فَإِنْ مَنَّنِي بِالْوَصْلِ يَوْمًا مُحَمَّدٌ", "شَفَيْتُ عَلِيلًا إِذْ مَسَاءَاتُهُ تُطْوَى"],
      ["وَمَنْ صَدَّ عَنِّي وَالْأَمِينُ مُوَاصِلِي", "وَمَنْ مَنَّنِي بِالْوَصْلِ سِيَّانِ فِي الْجُدْوَى"],
      ["هُوَ الْأَمْنُ وَالتَّيْسِيرُ وَالسَّعْدُ وَالْمُنَى", "لَهُ الْعُرْوَةُ الْوُثْقَى وَهْوَ الْمُسْنَدُ الْأَقْوَى"],
      ["أَتَى وَأَبَانَ الرُّشْدَ لِلْخَلْقِ وَالْهُدَى", "وَمَهَّدَ لِلْإِسْلَامِ فَاتَّضَحَتِ الْأَسْمَا"],
      ["عَلَيْهِ صَلَّى اللَّهُ ثُمَّ سَلَّمَهُ", "صَلَاةً وَتَسْلِيمًا عَلَى رَاكِبِ الْقُصْوَى"],
      ["عَلَيْهِ صَلَّى اللَّهُ ثُمَّ سَلَّمَهُ", "صَلَاةً وَتَسْلِيمًا تَدُرُّ بِهَا الْأَنْوَا"]
    ]
  }