{
    "id": 4,
    "title": "حرف الثاء",
    "huruf": [
      ["فَحُبِّي لِخَيْرِ الْخَلْقِ أَمْسَى ثَابِتَا", "عَلَى أَنَّنِي فِيهِ أَزِيدُ وَثَابِتُ"],
      ["فَمَا الْحُسْنُ إِلَّا حُسْنُ وَجْهِ مُحَمَّدٍ", "يَبِيتُ لِنَاجِيهِ رَبَّهُ وَهْوَ قَانِتُ"],
      ["وَإِلَى مَدَى الْأَيَّامِ شِعْرِي مَدِيحُهُ", "وَفِكْرِي فِيهِ الدَّهْرَ وَوَقْتِي صَامِتُ"],
      ["فَمَا طَابَ عَيْشٌ دُونَ نَيْلِ وَصَالِهِ", "فَغَرْسُ هَوَى الْمَاضِي بِقَلْبِي نَابِتُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتُقْضَى لَنَا بِالْحُبِّ تِلْكَ الْقَوَابِتُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ حُبُّهُمْ لِي نَابِتُ"]
    ]
  }