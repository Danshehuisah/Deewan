{
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["فِرَارِيَ لَدَى الْمَاجِي قَبْلَ جِنَائِي", "قُبُولِي وَتَطْهِيرِي وَرَفْعُ غَطَائِي"],
      ["وَيُثْبِتُنِي فِي الْخَادِمِينَ خَطِيرًا", "وَيُقْبَلُ أَمْدَاحِي لِيَوْمِ لِقَائِي"],
      ["وَيَقْطَعُ غَيَّ الْبَيْنِ بِالْوَصْلِ دَائِمًا", "قَدِ اشْتَغَلَتْ بِالشَّوْقِ كُلُّ حَشَائِي"],
      ["أَلَا يَا خَيْرَ الْأَنَامِ نَبِيَّنَا", "فَمِنْكَ أَتَى الْأَرْسَالَ كُلُّ جِبَاءِ"],
      ["وَفِي كُلِّ حَيٍّ مِنْ جَنَابِكَ بَعْفَةٌ", "فَأَسْدِلْ لِإِبْرَاهِيمَ سَيْبَ عَطَاءِ"],
      ["فَقِيرٌ غَرِيبٌ شَاعِرٌ خَادِمٌ لَكُمْ", "مُحِبٌّ لَقِي لِلْحَبِّ كُلَّ جَفَاءِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ وَأَهْلِ عَبَاءِ"]
    ]
  }