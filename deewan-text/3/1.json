{
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["قِرَايَ لَدَى الْمَاجِي قُبَيْلَ حِنَآءِ", "قَبُولِي وَتَطْهِيرِي وَرَفْعُ غِطَآءِ"],
      ["وَيُثْبِتُنِي فِي الْخَادِمِينَ حَظِيَّهُمْ", "وَيَقْبَلُ أَمْدَاحِي لِيَوْمِ لِقَآءِ"],
      ["وَيَقْطَعُ عَنِّى الْبَيْنَ بِالْوَصْلِ دَآئِمًا", "قَدِ اشْتَعَلَتْ بِالشَّوْقِ كُلُّ حَشَآئِي"],
      ["اَاَحْمَدُ يَا خَيْرَ الْأَنَامِ نَبِيَّنَا", "فَمِنْكَ أَتَى الْأَرْسَالَ كُلُّ جِبَآءِ"],
      ["وَفِي كُلِّ حَيٍّ مِنْ حِبَآئِكَ نِعْمَةٌ", "فَأَسْدِلْ لِِاِبْرَاهِيمَ سَيْبَ عَطَآءِ"],
      ["فَقِيرٌ غَرِيبٌ شَاعِرٌ خَادِمٌ لَكُمْ", "مُحِبٌّ لَقَى لِلْحُبِّ كُلَّ جَفَآءِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَأَصْحَابٍ وَأَهْلِ عَبَاءِ"]
    ]
  }