{
    "id": 20,
    "title": "حرف الطاء",
    "huruf": [
      ["صَلَاحُ شُؤُونِي لَسْتُ عَنْهُ بِقَانِطٍ", "وَظِلُّ حَبِيبِ اللَّهِ وَهْوَ مُبَاسِطِي"],
      ["وَيَرْضَى حَبِيبُ اللَّهِ بِالْغَيْثِ تَفَضُّلًا", "فَمَا ضَرَّ مُخْطِئًا مِنْ ظُلُومٍ وَقَابِطِ"],
      ["فَإِنَّ مُحِبًّا أَرْجُو رَفْعَ دِينِهِ", "بِعَزْوٍ وَلِي يَنْقَادُ كُلُّ مُزَابِطِ"],
      ["وَإِنَّ النَّبِيَّ الْهَاشِمِيَّ مُسَاعِدِي", "فَلَا أَكُ مَمْنُونًا عَنْ عَطَاهُ بِسَاخِطِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ عَطَاهُ لَمْ يَكُنْ بِالشَّرَائِطِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ خِيَارِ الْوَسَائِطِ"]
    ]
  }