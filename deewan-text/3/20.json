{
    "id": 20,
    "title": "حرف الطاء",
    "huruf": [
      ["صَلَاحُ شُئُونِي لَسْتُ عَنْهُ بِقَانِطِ", "وَوَصْلُ حَبِيبِ اللَّهِ وَهْوَ مُبَاسِطِي"],
      ["وَيَرْضَى حَبِيبُ اللَّهِ عَنِّي تَفَضُّلًا", "فَمَا ضَرَّ سَقْطٌ مِنْ ظَلُومٍ وَقَاسِطِ"],
      ["فَإِنِّي مُحِبٌّ أَرْتَجِي رَفْعَ دِينِهِ", "بِغَزْوٍ وَلِي يَنْقَادُ كُلُّ مَرَابِطِ"],
      ["وَإِنَّ النَّبِيَّ الْهَاشِمِيَّ مُسَاعِدِي", "فَلَمْ أَكُ يَوْمًا عَنْ عَطَاهُ بِسَاخِطِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ عَطَاءً لَمْ يَكُنْ بِالشَّرَائِطِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَأَصْحَابٍ خِيَارِ الْوَسَائِطِ"]
    ]
  }