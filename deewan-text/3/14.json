{
    "id": 14,
    "title": "حرف السين",
    "huruf": [
      ["مَالَ الْقَلْبَ حُبُّ الْمُصْطَفَى وَتَنَافُسِي", "مَدَى الدَّهْرِ فِي وَصْلِهِ وَهْوَ مُجَالِسِي"],
      ["تَطَوَّفُ فِي الْآفَاقِ طَالِبَ وَصْلِهِ", "وَشَدَّ اغْتِرَافِي وَالْأَمِينُ مُؤَالِسِي"],
      ["فَلَيْسَ رَجَائِي فِي تَمَامِ وَصَالِهِ", "قَوِيًّا وَإِنَّ عَنْهُ لَسْتُ بِآيِسِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ بُدُورِ الْحَنَادِسِ"]
    ]
  }