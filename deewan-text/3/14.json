{
    "id": 14,
    "title": "حرف السين",
    "huruf": [
      ["مَلَا الْقَلْبَ حُبُّ الْمُصْطَفَى وَتَنَافُسِي", "مَدَى الدَّهْرِ فِي وَصْلِيهِ وَهْوَ مُجَالِسِي"],
      ["تَطَوَّفْتُ فِي الْآفَاقِ طَالِبَ وَصْلِهِ", "وَشَدَّ اغْتِرَابِي وَالْأَمِينُ مُؤَانِسِي"],
      ["فَلَيْسَ رَجَآئِي فِي تَمَامِ وِصَالِهِ", "قَوِيًّا وَإِنَّي عَنْهُ لَسْتُ بِيَائِسِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَأَصْحَابٍ بُدُورِ الْخَنَادِسِ"]
    ]
  }