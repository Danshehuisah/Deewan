{
    "id": 16,
    "title": "حرف الصاد",
    "huruf": [
      ["تَمَامُ الْعَطَايَا وَالْمَوَاهِبُ لَمْ تُخَصَّصْ", "بُلُوغُ رِسَالَاتِ الشَّفِيعِ إِلَى الْأَفْضَى"],
      ["فَأَرْشَدَنَا لِلْمُصْطَفَى وَوِدَادِهِ", "وَتَذْكُرُهُ شَوْقًا إِلَيْهِ بِلَا إِخْضَا"],
      ["نَبِيَّ الْهُدَى حَبْرَ الْوَرَى شَافِعَ الْوَرَى", "فَمِنْكَ تَنَالُ الْكُلَّ مَنْ مَعَ أَوْ خَضَا"],
      ["عَلَوْتَ جَمِيعَ الْمُرْسَلِينَ جَلَالَةً", "فَأَنْتَ رَسُولُ الْكَائِنَاتِ وَلَمْ تُخَصَّا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مِنَ الذَّاتِ حَقَّ الذَّاتِ لِلْمُصْطَفَى نَضَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُتَرْبِبُ الْمَاضِي الضَّلَالَ الَّذِي خَضَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْكِرَامِ وَمَنْ أَوْصَى"]
    ]
  }