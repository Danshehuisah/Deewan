{
    "id": 16,
    "title": "حرف الصاد",
    "huruf": [
      ["تَمَامُ الْعَطَايَا وَالْمَوَاهِبِ لَنْ تُحْصَى", "بُلُوغُ رِسَالَاتِ الشَّفِيعِ إِلَى الْأَقْضصَى"],
      ["فَأَرْشَدَنَا لِلْمُصْطَفَى وَوِدَادِهِ", "وَنَذْكُرُهُ شَوْقًا إِلَيْهِ بِلَا إِحْصَا"],
      ["نَبِيُّ الْهُدَى خَيْرُ الْوَرَى شَافِعُ الْبَرَا", "فَمِنْكَ نَوَالُ الْكُلِّ مَنْ عَمَّ أَوْ خَصَّا"],
      ["عَلَوْتَ جَمِيعَ الْمُرْسَلِينَ جَلَالَةً", "فَأَنْتَ رَسُولُ الْكَآئِنَاتِ وَلَمْ تُحْصَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مِنَ الذَّاتِ حَقِّ الذَّاتِ لِلْمُصْطَفَى نَصَّا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُقَرِّبُنِى الْمَاحِي الضَّلَالِ الَّذِي خُصَّا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْكِرَامِ وَمَنْ اَوْصَى"]
    ]
  }