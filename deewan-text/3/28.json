{
    "id": 28,
    "title": "حرف الميم أيضا",
    "huruf": [
      ["مَحَا مِنْ فُؤَادِي حُبَّ لَيْلَى وَتَنْدُمِ", "وِدَادُ الْإِمَامِ الْهَاشِمِيِّ الْمُفَخَّمِ"],
      ["فَخُذْ فِي حَدِيدِ الْعَاشِقِينَ بِذِكْرِهِ", "رُوَيْدَكَ رِفْقًا بِالْمُحِبِّ الْمُتَيَّمِ"],
      ["مُحَمَّدٌ مُحَمَّدٌ أَمَدٌ", "مُحَمَّدٌ مُخْتَارٌ حَبِيبُ الْمُقَدَّمِ"],
      ["مُحَمَّدٌ طَهَ عَاقِبٌ وَهْوَ مُصْطَفَى", "بَشِيرٌ نَذِيرٌ ضَيْغَمٌ أَيْ ضَيْغَمُ"],
      ["دَعَانِي هَوَى الْمَاضِي السَّرَاجِ وَإِنَّنِي", "بِذَنْبِي مَعْقُولٌ فَمَنْ لِي بِسُلَّمِ"],
      ["رَسُولٌ أَمِينٌ وَهْوَ هَادٍ وَرَحْمَةٌ", "أَبُو الْقَاسِمِ الْمَنْصُورُ تِرْسِي وَأَسْلَمِي"],
      ["سَرَى الْمُصْطَفَى لَيْلًا وَوَافَى بِخَمْسَةٍ", "عَرَجْنَا بِهَا وَالْفَضْلُ لِلْمُتَقَدِّمِ"],
      ["وَأَوْصَى بِهَا عِنْدَ الْعُرُوجِ مُؤَكَّدًا", "فَفِيهَا يَنَالُ الْعَبْدُ كُلَّ التَّقَدُّمِ"],
      ["لَهُ وَبِهِ قُمْ وَارْكَعَنْ تَوَاضُعًا", "تَرَى قُرَّةً لِلْعَيْنِ مِنْ خَيْرِ مُنْعِمِ"],
      ["إِذَا قُمْتَ مِنْ بَعْدِ الْوُضُوءِ مُرَتِّلًا", "وَتَسْجُدُ مِنْ بَعْدِ الرُّكُوعِ الْمُعَظَّمِ"],
      ["لَقَدْ طُوِيَتْ عَنْكَ الْمَسَافَةُ مُحْرَزًا", "وَصَلَّتْ إِلَى الْمَحْبُوبِ بِالْكَبَرِ وَعَطِّلِ"],
      ["لِدَيْهِ إِلَهُ الْعَرْشِ شُكْرٌ مُؤَبَّدٌ", "عَلَى الْمُصْطَفَى الْمُخْتَارِ سِرِّي الْمُكَتَّمِ"],
      ["أُسَائِلُهُ تَحْقِيقَ مَا كُنْتُ رَاجِيًا", "لِدِينِي وَدُنْيَايَ بِطَهَ الْمُفَخَّمِ"],
      ["هَدَانِي تَكْبِيرُ الصَّلَاةِ مُسَلِّمًا", "عَلَى ذَلِكَ الْكُبْرِ الْعَظِيمِ الْمُطَلْسَمِ"]
    ]
  }