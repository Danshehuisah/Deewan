{
    "id": 31,
    "title": "حرف الهاء",
    "huruf": [
      ["هَنِيئًا لِإِبْرَاهِيمَ لَاحَ هِلَالُهُ", "هِلَالٌ بَدَا لِلنَّاظِرِينَ جَمَالُهُ"],
      ["هِلَالُ رَبِّي فِيهِ جَاءَ مُحَمَّدٌ", "فَعَمَّ لَنَا الْبُشْرَى وَعَمَّ نَوَالُهُ"],
      ["بِأَفْضَلِ أَرْضٍ حَلَّ أَفْضَلُ مُرْسَلٍ", "بِأَفْضَلِ يَوْمٍ فَاسْتَبَانَ كَمَالُهُ"],
      ["قَدِ اخْتِيرَ مِنْ كُلِّ الْعَوَالِي أَصْلُهُ", "كَمَا اخْتِيرَ وَاخْتِيرَتْ لِذَاكَ فِعَالُهُ"],
      ["مُحَمَّدٌ مُخْتَارٌ وَآدَمُ طِينَةٌ", "مُحَمَّدٌ يَوْمَ الْبَعْثِ زَاكَ خِصَالُهُ"],
      ["مُحَمَّدٌ نُورُ الْخَلْقِ وَهْوَ مُحَمَّدٌ", "عَظِيمٌ عَظِيمُ الْخَلْقِ عَمَّ جَلَالُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَزُولُ عَذَابٌ إِنَّ مِنْكَ زَوَالُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُمَلِّي إِبْرَاهِيمَ الْفَقِيرَ وِصَالُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُبِيدُ عَدُوَّ الَّذِينَ مِنْكَ قِتَالُهُ"],
      ["نَبِيٌّ كَرِيمٌ رَحْمَةٌ لِلنَّاسِ رَاحَةٌ", "بِهِ يَقْتَدِي الْأَكْوَانُ إِلَّا لِأَمْهَالِهِ"],
      ["فَذَاكَ وَإِنْ خَانَتْ سُلَيْمَى وَأَخْلَفَتْ", "يَعُدْهُ مَدَى الْأَيَّامِ وَافٍ ذِمَامُهُ"],
      ["فَذَاكَ الَّذِي إِنْ مَنَّ يَوْمًا بِوَصْلِهِ", "فَمَا ضَرَّ مِنْ وَعْدٍ لِسَلْمَى حَمَامُهُ"],
      ["فَذَاكَ إِذَا حَلَّيْتُ سَمْعِي بِكَلَامِهِ", "تَصِيرُ سُلَيْمَى كَالْهَنَاءِ كَلَامُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُسَاقُ لِنَفْسِي الدَّهْرَ مِنْكَ مَرَامُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْيَقَظَى كِرَامُهُ"]
    ]
  }