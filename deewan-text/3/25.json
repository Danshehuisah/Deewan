{
    "id": 25,
    "title": "حرف الكاف",
    "huruf": [
      ["كَفَانِي عَلَى الْعِلَّاتِ أَيَّ سَالِكِ", "بِحُبِّي لِمَنْ يَنْمِيهِ فِهْرٌ وَمَالِكُ"],
      ["لِكُلٍّ فَتىً حُبٌّ وَقَصْدٌ وَمَذْهَبٌ", "وَإِنِّي بِحُبِّ الْهَاشِمِيِّ الْهَارِبُ آسِكُ"],
      ["فَشُغْلِي مَدِيحُ الْمُصْطَفَى وَوِدَادُهُ", "سَبِيلِي الَّذِي مَا عِشْتُ إِنِّي سَالِكُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُدَارِكُنِيَ الْمَوْلَى وَقِرْفِي أُدَارِكُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ هَذَا وَتَدَارَكُوا"]
    ]
  }