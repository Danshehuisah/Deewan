{
    "id": 33,
    "title": "حرف الهاء",
    "huruf": [
      ["هَنِيئًا لِإِبْرَاهِيمَ لَاحَ هِلَالُهُ", "هِلَالٌ بَدَى لِلنَّاظِرِينَ جَمَالُهُ"],
      ["هِلَالٌ رَبِيعٌ فِيهِ جَاءَ مُحَمَّدٌ", "فَتَمَّ لَنَا الْبُشْرَى وَعَمَّ نَوَالُهُ"],
      ["لِأَفْضَلِ أَرْضٍ حَلَّ أَفْضَلُ مُرْسَلٍ", "بِأَفْضَلِ يَوْمٍ فَاسْتَبَانَ كَمَالُهُ"],
      ["قَدِ اخْتِيرَ مِنْ كُلِّ الْعَوَالِمِ أَصْلُهُ", "كَمَا اخْتِيرَ وَاخْتِيرَتْ لِذَاكَ فِعَالُهُ"],
      ["مُحَمَّدٌ مُخْتَارٌ وَءَادَمُ طِينَةٌ", "مُحَمَّدُ يَوْمَ الْبَعْثِ رَاقَ خِصَالُهُ"],
      ["مُحَمَّدُ نُورُ الْخَلْقِ وَهْوَ مُحَمَّدٌ", "عَظِيمٌ عَظِيمُ الْخُلْقِ تَمَّ جَلَالُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَزُولُ عَذَابٌ ءَانَ مِنْكَ زَوَالُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَتِمُّ لِبَرْهَامَ الْحَقِيرِ وِصَالُهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُبِيدُ عَدُوَّ الَّدِّينَ مِنْكَ قِتَالُهُ"],
      [" يَكُونُ عَدُوّى شُدَّ مِنْكَ وَبَالُهُ ,عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["مَتَى لَاحَ مِنْ فَوْقِ السَّمَاءِ هِلَالُهُ ,عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      [" بِهَا خُصِّصَ الْأَصْحَابُ طُرًّا وَءَالُهُ ,عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"]
    ]
  }