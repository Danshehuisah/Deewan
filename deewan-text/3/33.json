{
    "id": 33,
    "title": "حرف الياء",
    "huruf": [
      ["ضَعِيفٌ حَقِيرٌ مُذْنِبٌ جَاءَ شَاكِيَا", "أَتَاكَ رَسُولَ اللَّهِ لِلْمَدْحِ حَاكِيَا"],
      ["فَهَلْ يَقْبَلَنْ خَيْرُ الْوَرَى ذَاكَ شَافِعًا", "لَهُ كُلَّ أَوْقَاتٍ أَمْ يُنِيلُ الْمَعَالِيَا"],
      ["فَإِنِّي وَرَاءَ الشَّاعِرِينَ وَأَرْتَجِي", "تَذَكُّرَ خَيْرِ الْخَلْقِ مِنْهُ أَمَامِيَا"],
      ["وَلَمْ أَتَّخِذْ غَيْرَ دَعْوَى مَحَبَّةٍ", "وَلَا عَمَلٍ يَأْتِي بِصِدْقٍ مَقَالِيَا"],
      ["فَقَدْ قَاتَبَتْنِي حَتَّى التَّدَارُكُ لَا أَرَى", "سِوَى الْمُصْطَفَى الْهَادِي يُدَارِكُ حَالِيَا"],
      ["أَجِرْنِي مِنْ نَفْسٍ أَرَاهَا خَبِيثَةً", "فَكُلُّ زَمَانٍ مَا تَسُومُ الرَّدَى لِيَا"],
      ["فَتَتَّقِدُنِي مِنْ شُؤُونِهَا لَا تَضُرُّنِي", "فَبَاطِنُهَا إِذْ ذَكَرْ طَهَ جَلَائِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَلْقَى الْأَمِينَ الْإِمَامَ الْهَادِيَا"],
      ["عَلَيْهِ مَعَ الْآلِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ مَدَى الدَّهْرِ بَاقِيَا"]
    ]
  }