{
    "id": 33,
    "title": "حرف الياء",
    "huruf": [
      ["ضَعِيفٌ حَقِيرٌ مُذْنِبٌ جَاءَ شَاكِيَا", "أَتَاكَ رَسُولَ اللَّهِ لِلْمَدْحِ حَاكِيَا"],
      ["فَهَلْ يَقْبَلَنْ خَيْرُ الْوَرَى ذَاكَ شَافِعًا", "لَهُ كُلَّ وَقْتٍ أَمْ يُنِيلُ الْمَعَالِيَا"],
      ["فَإِنِّي وَرَاءَ السَّآئِرِينَ وَأَرْتَجِي", "تَذَكُّرَ خَيْرِ الْخَلْقِ مِنْهُ أَمَامِيَا"],
      ["وَلَمْ أَتَذَوَّدْ غَيْرَ دَعْوَى مَحَبَّةٍ", "وَلَا عَمَلٌ يَأْتِي بِصِدْقِ مَقَالِيَا"],
      ["فَقَدْ فَاتَنِي حَتَّى التَّدَارُكَ لَا أَرَى", "سِوَى الْمُصْطَفَى الْهَادِي يُدَارِكُ حَالِيَا"],
      ["أَجِرْنِي مِنْ نَفْسٍ أَرَاهَا خَبِيثَةً", "فَكُلُّ زَمَانٍ مَا تَسُومُ الرَّدَى لِيَا"],
      ["فَتُنْقِذُنِي مِنْ شُؤْومِهَا لَا تَضُرُّنِي", "قَبَائِحُهَا إِذْ ذِكْرُ طَهَ جَلَائِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُهَيِّئُلِي لُقْيَا الْأَمِينِ اِمَامِيَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ مَدَى الدَّهْرِ بَاقِيَا"]
    ]
  }