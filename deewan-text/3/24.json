{
    "id": 24,
    "title": "حرف الفاء",
    "huruf": [
      ["لِقَاءُ نَبِيِّ اللَّهِ وَهْوَ مُلَاطِفُ", "مَرَامِي وَمِنْ دُونِ الْمَرَامِ مَتَالِفُ"],
      ["فَلَوْ كُنْتُ نَعْلًا لِلْأَمِينِ لَتَمَّ لِي", "مُرَادِى وَإِلَّا فَالصَّدِيقُ الْمُلَاطِفُ"],
      ["فَمَا الْحُلْوُ فِي الدَّارَيْنِ إِلَّا وِصَالُهُ", "وَكُلُّ سِوَى هَاذَا رِيَاحٌ عَوَاصِفُ"],
      ["فَإِنْ لَمْ أَجِدْ تَقْبِيلَ كَفِّ مُحَمَّدٍ", "فَمَالَذَّلِي عَيْشِى وَعُمْرِيَ تَالِفُ"],
      ["وَرَبِّي وَرَبِّ الْمُصْطَفَى وَهْوَ كَامِلٌ", "أَفَاضَ إِلَيْهِ مِنْهُ وَهْوَ يُلَاطِفُ"],
      ["لِذَا هَامَ مَنْ قَدْ هَامَ فِي الْحُبِّ بَيْنَ مَنْ", "بِلَيْلَى وَمَيْلَى أَوْرَثَتْهُ الطَّوَائِفُ"],
      ["يُهَيِّجُ حُبِّيهِ هِلَالُ رَبِيعِهِ", "فَفِيهِ تُنَادِي بِالسُّرُورِ الْهَوَاتِفُ"],
      ["وَإِنِّى لَتَعْرُونِي إِذَا لَاحَ هِزَّةٌ", "كَذَالِكَ إِنْ يَنْطِقْ بِوَصْفِكَ وَاصِفُ"],
      ["جَمَالُكَ يُنْسِينِي حُلَى كُلِّ بَهْجَةٍ", "وَإِنِّيَ عُمْرِي عِنْدَ بَابِكَ عَاكِفُ"],
      ["وَجُودُكَ يُنْسِينِي نَوَالًا سِوَاءَهُ", "وَمَا الْجُودُ إِلَّا مِنْكَ وَالْكُلُّ غَارِفُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا تَنْحُواْ لِنَحْوِى الْعَوَاطِفُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا تَنْحُواْ لِقَصْرِي اللَّطَآئِفُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أُهْدَى وَإِنِّيَ عَارِفُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَصَحْبٍ كُلُّهُمْ مِنْكَ خَارِفُ"]



      ["جَمِيعُ غَرَامِي وَالْكِتَابِ وَخَالِقِي", "لِأَحْمَدَ نُورِ الْحَقِّ سِرِّ الْحَقَآئِقِ"],
      ["جَفَانِي وَلَمْ أَجْفُ الْأَخِلَّا وَلَمْ أَخَفْ", "إِذَا مَا صَفَا وَقْتِي لِخَيْرِ الْخَلَائِقِ"],
      ["أَرِقْتُ وَنَامَ الْأَقْرَبُونَ مُهَيَّمًا", "سَمِيرِي سُطُورِي فَوْقَ بِيضِ الْمَهَارِقِ"],
      ["أُخَاطِبُ خَيْرَ النَّاسِ سِرِّي وَمَرْكَزِي", "غِيَاثِي وَتُرْسِي فِي الْوَغَى وَالْمَضَائِقِ"],
      ["يُقَرِّبُنِي حَقًّا لَدَيْهِ فَأَنْثَنِي", "بِنُورٍ يَضِي لِلْقَلْبِ كُلَّ الرَّقَآئِقِ"],
      ["فَسِرْتُ بِهِ أَطْوِي الْمَقَامَاتِ رَاحِلًا", "إِلَى اللَّهِ رَبِّ النَّاسِ مُعْطِي الْخَوَارِقِ"],
      ["وَإِنْ دَهِشَ الْأَقْطَابُ يَوْمًا بِمَشْهَدٍ", "فَلِي الْوَصْلُ وَالتَّمْكِينُ مِنْ فَضْلِ خَالِقِي"],
      ["سَرَى الْسِّرُّ فِي سِرِّي فَكُلِّيَ سِرُّهُ", "بِيُمْنِ رَسُولِ قَاطِعٍ لِلْعَلَائِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَسْمُواْ عَلَى كُلِّ فَآئِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً تَقِينِي الشَّرَّ مِنْ كُلِّ طَارِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا الدَّهْرَ سَبْقِي لِلْعُلَا كُلَّ سَابِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "سَلَامَ مُحِبٍّ شَفَّهُ الْحُبُّ عَاشِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "سَلَامَ خَدِيمٍ ضَرَّهُ وَجْدُ وَامِقِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاتِي عَلَيْهِ الدَّهْرَ أَقْوَى وَثَائِقِي"]
    ]
