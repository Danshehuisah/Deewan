{
    "id": 24,
    "title": "حرف الفاء",
    "huruf": [
      ["لِقَاءُ نَبِيِّ اللَّهِ وَهْوَ مُلَاطِفِي", "مَرَامِي وَمِنْ دُونِ الْمَرَامِ مَتَالِفُ"],
      ["فَلَوْ كَشَفُوا عَنْ آلِ أَمِينٍ لَمَا", "لِي مَرَادٌ وَلَا فَالضِّيقُ الْمُلَاطِفُ"],
      ["فَمَا الْحُلْوُ فِي الدَّارَيْنِ إِلَّا وِصَالُهُ", "وَكُلٌّ سِوَى هَذَا رَبَاحٌ عَوَاصِفُ"],
      ["فَإِنْ لَمْ أَجِدْ تَثْبِيلَ كَفِّ مُحَمَّدٍ", "فَمَالِيَ لَا يَعْشَى وَعُمْرِي تَالِفُ"],
      ["وَرَبِّي وَرَبُّ الْمُصْطَفَى وَهْوَ كَامِلٌ", "أَقَاضِي إِلَيْهِ مِنْهُ وَهْوَ يُلَاطِفُ"],
