{
    "id": 36,
    "title": "حرف الواو",
    "huruf": [
      ["وَإِنِّي أُنَسَّى الدَّهْرَ سُعْدَى كَذَا أَرْوَى", "لِحُبِّ حَبِيبٍ مَا تَذَكَّرْتُهُ أَرْوَى"],
      ["فَإِنْ تَسْأَلُوا عَنْ مَذْهَبِي وَمُتَيَّمِي", "فَحُبُّ النَّبِيِّ الْهَاشِمِيِّ وَهْوَ مَنْ أَهْوَى"],
      ["إِلَيْهِ مَسِيرِي وَهْوَ قَصْدِي وَمَطْلَبِي", "سَبِيلِي اقْتِفَا مَا عَنْ جَلَالَتِهِ يُرْوَى"],
