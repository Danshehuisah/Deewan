{
    "id": 30,
    "title": "حرف النون",
    "huruf": [
      ["تَلَوْتُ لِحُبِّي ذَاكَ وَهْوَ الْمُبَيَّنُ", "لِمَا شَرَعَ الْمَوْلَى وَإِنَّ لِمُؤْمِنٍ"],
      ["وَذَاكَ الْمَكِينُ النُّورُ السَّرَاجُ بِحُبِّهِ", "صُبِغْتُ بِهِ وَالصَّبْغُ بِالْحُبِّ أَحْسَنُ"],
      ["فَمَنْ لِي بِسِدْرَةٍ فِي الْحَجِيجِ لِطَيْبَةٍ", "أَعْكُفْ خَذَا فِي الرِّيَاضِ وَأُحْسِنُ"],
      ["فَمَنْ لِي وَذَنْبِي كَالْقُبُورِ أَقِفُهُ", "لَدَى قَبْرِ خَيْرِ النَّاسِ وَهْوَ الْمُبَيَّنُ"],
      ["فَمَنْ لِي وَقَدْ هَاجَ اشْتِيَاقِي بِزَوْرَةٍ", "أُفَلِّكُ بِهَا قَيْدَ الدُّنُوبِ وَأَعْلَمُ"],
      ["فَإِنِّي وَتَبْتِيلِي وَوَجْدِي وَمَعْرِفَتِي", "أَرْجُو لِقَاهُ إِذْ حَوْلَ ذَاكَ أَدْنَدِنُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأَبْقَى وَإِنِّي مُؤْمِنٌ بِكَ مُحْسِنُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ لِحُبِّي مُمَكِّنُ"]
    ]
  }