{
    "id": 30,
    "title": "حرف الميم أيضا",
    "huruf": [
      ["مَحَا مِنْ فُؤَادِي حُبَّ لَيْلَى وَتَنْدَمِ", "وِدَادُ الْإِمَامِ الْهَاشِمِيِّ الْمُفَخَّمِ"],
      ["حَدَابِيَ حَادِي الْعَاشِقِينَ بِذِكْرِهِ", "رُوَيْدَكَ رِفْقًا بِالْمُحِبِّ الْمُتَيَّمِ"],
      ["مُحَمَّدُ مَحْمُودٌ مُحَمَّدُ أَحْمَدٌ", "مُحَمَّدُ مُخْتَارٌ حَبِيبُ الْمُقَدِّمِ"],
      ["مُحَمَّدُ طَهَ عَاقِبٌ وَهْوَ مُصْطَفَى", "بَشِيرٌ نَذِيرٌ ضَيْغَمٌ أَيُّ ضَيْغَمِ"],
      ["دَعَانِي هَوَى الْمَاحِي السِّرَاجِ وَإِنَّنِي", "بِذَنْبِيَ مَعْقُولٌ فَمَنْ لِي بِسُلَّمِ"],
      ["رَسُولٌ أَمِينٌ وَهْوَ هَادٍ وَرَحْمَةٌ", "أَبُو الْقَاسِمِ الْمَنْصُورُ تِرْسِي وَأَسْهُمِي"],
      ["سَرَى الْمُصْطَفَى لَيْلًا وَوَافَى بِخَمْسَةٍ", "عَرَجْنَا بِهَا وَالْفَضْلُ لِلْمُتَقَدِّمِ"],
      ["وَأَوْصَى بِهَا عِنْدَ الْعُرُوجِ مُوَكِّدًا", "فَفِيهَا يَنَالُ الْعَبْدُ كُلَّ التَّقَدُّمِ"],
      ["لَهُ وَبِهِ قُمْ وَارْكَعَنَّ تَوَاضُعًا", "تَرَى قُرَّةً لِلْعَيْنِ مِنْ خَيْرِ مُنْعِمِ"],
      ["إِذَا قُمْتَ مِنْ بَعْدِ الْوُضُوءِ مُرَتِّلًا", "وَتَسْجُدُ مِنْ بَعْدِ الرُّكُوعِ الْمُعَظَّمِ"],
      ["لَقَدْ طُوِيَتْ عَنْكَ الْمَسَافَةُ جَهْرَةً", "وَصَلْتَ إِلَى الْمَحْبُوبِ كَبِّرْ وَعَظِّمِ"],
      ["لِرَبِّي إِلَهِ الْعَرْشِ شُكْرٌ مُؤَبَّدٌ", "عَلَى الْمُصْطَفَى الْمُخْتَارِ سِرِّي الْمُكَتَّمِ"],
      ["أُسَائِلُهُ تَحْقِيقَ مَا كُنْتُ رَاجِيًا", "لِدِينِي وَدُنْيَاءِي بِطَهَ الْمُفَخَّمِ"],
      ["هَدَايَيَ تَكْثِيرُ الصَّلَاةِ مُسَلِّمًا", "عَلَى ذَالِكَ الْكنْرِ الْعَظِيمِ الْمُطَلْسَمِ"]
    ]
