{
    "id": 23,
    "title": "حرف الغين",
    "huruf": [
      ["يُفَلِّي وَوَصْلًا بَعْدَ كَشْفٍ سَعَادَةً", "لِمَنْ عَدُوًّا يَقْرِي كَذَا وَيُبَالِغُ"],
      ["أَسِيرٌ أَنَى ضَيْفًا بِبَابِكَ مُعْدِمًا", "فَهَلْ لَكَ فِيهِ وَوِرْدُكَ الدَّهْرَ سَائِغُ"],
      ["أَعِنْهُ أَعِنْهُ يَا مُعِينُ فَإِنَّهُ", "فَقِيرٌ حَقِيرٌ وَهْوَ خَيْرَكَ بَالِغُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ حَقُّهُمْ مِنْكَ دَافِعُ"]
    ]
  }