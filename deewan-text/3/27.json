{
    "id": 27,
    "title": "حرف الميم",
    "huruf": [
      ["حَبِيبِي رَسُولُ اللَّهِ وَهْوَ الْمُتَيَّمُ", "مَدَى الدَّهْرِ فِيهِ خَاطِرِي يَتَرَجَّمُ"],
      ["فَقَدْ خَلَّ فِي سَوْدَاءِ قَلْبِي وِدَادُهُ", "وَهَلْ ثَمَّ لِلْخِنْذِيذِ فِيهِ تَكَلُّمُ"],
      ["فَمَا تَرَكَ الْبُوصِيرَ قَوْلًا لِقَائِلٍ", "وَكَفَّ وَحَسْبُ الْمَدْحِ أَنْ يَتَكَلَّمُوا"],
      ["وَقَدْ نَطَقَ الْقُرْآنُ بِالْحَقِّ مَادِحًا", "سُوَرًا لِرَسُولِ اللَّهِ وَالذِّكْرُ أَحْكَمُ"],
      ["وَيَكْفِيهِ مَدْحًا ذَاتُهُ وَسُمُوُّهُ", "مُحَمَّدٌ وَصْفٌ جَامِعُ الْمَدْحِ مُبْرَمُ"],
      ["تَذَكَّرْتُهُ وَسْطَ الْفِتَاةِ وَقَدْ جَرَى", "بِنَا هَيْكَلٌ يَفْرِي الْقِطَاعَ وَيَبْرُمُ"],
      ["وَقَدْ طَرِبَ الرُّكْبَانُ وَالْبَعْضُ رَاقِدٌ", "وَنَارُ اشْتِيَاقِي وَالْهَوَى يَتَضَرَّمُ"],
      ["يُذَكِّرُنِي الْبَحْرُ الْمُحِيطُ بِفَيْضِهِ", "أَبُو الْقَاسِمِ الْبَحْرُ الْخِضَمُّ الْغَطَمْرَمُ"],
      ["يُذَكِّرُنِي وَادِي الْبَقَا وَعَقِيقَهُ", "وَلِلصَّخْرَةِ الْمُلْسَاءِ وِدٌّ وَمَغْرَمُ"],
      ["فَهَلْ تَسْمَحُ الْأَيَّامُ يَوْمًا بِعَوْدَةٍ", "إِلَيْهِ فَأَرْعَى الْقَلْبَ مَتَى أَسْقَمُ"],
      ["عَسَاهَا وَلَيْتِي وَالْمُحِبُّ مُسَامِحٌ", "إِذَا مَا تَمَنَّى هَلْ لِمَا أَتَمَنَّى أُحْرَمُ"],
      ["فَأَشْفِي غَلِيلَ الْقَلْبِ عِنْدَ نَبِيِّنَا", "وَأَرْوِي غَلِيلًا وَالدُّنُوبُ تُهْدَمُ"],
      ["سَلَامٌ عَلَى خَيْرِ الْأَنَامِ مُحَمَّدٍ", "سَلَامٌ عَلَى مَنْ حُبُّهُ الْقَلْبَ يَكْلَمُ"],
      ["سَلَامٌ عَلَى خَيْرِ الْقُبُورِ جَمِيعِهَا", "سَلَامٌ عَلَيْهِ وَهْوَ أَبْهَى وَأَفْخَمُ"],
      ["سَلَامٌ عَلَى هَادِي الْعِبَادِ مُحَمَّدٍ", "سَلَامٌ عَلَى خَيْرِ الْوَرَى وَهْوَ أَعْظَمُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاتٌ وَتَسْلِيمٌ بِذَلِكَ أَخْتِمُ"]
    ]
  }