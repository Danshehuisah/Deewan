{
    "id": 6,
    "title": "حرف الحاء",
    "huruf": [
      ["يُصَاحِبُنِي حُبُّ النَّبِيِّ وَأَنْسِجُ", "مَدَائِحَهُ وَالنَّفْسُ مِنِّيَ تَبْحَجُ"],
      ["يَقِينًا يَقِينِي الْمُصْطَفَى وَيُنِيلُنِى", "مُرَادِي فَإِنِّي بِالْمَدَائِحِ أَلْهَجُ"],
      ["أُنَادِي رَسُولَ اللَّهِ فِي كُلِّ حَالَةٍ", "إِلَيْهِ مَسِيرِي فَهْوَ قَصْدِي وَمَنْهَجُ"],
      ["وَرَاحِلَةٌ وَهْوَ الْمَزَادُ فَإِنَّهُ", "رَسُولٌ مِنَ الْمَوْلَى إِلَى النُّورِ يُخْرِجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَأَصْحَابٍ سَمَواْ وَتَبَلَّجُواْ"]
    ]
  }