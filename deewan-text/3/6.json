{
    "id": 6,
    "title": "حرف الحاء",
    "huruf": [
      ["يُصَاحِينِي حُبُّ النَّبِيِّ وَأَنْشُجُ", "مَدَائِحُهُ وَالنَّفْسُ مِنِّيَ تَبْجُحُ"],
      ["يَقِينًا يَقِينِي الْمُصْطَفَى وَيُبَلِّغُ", "مَرَادِي فَإِنِّي بِالْمَدَائِحِ أَلْهَجُ"],
      ["أُنَادِي رَسُولَ اللَّهِ فِي كُلِّ حَالَةٍ", "إِلَيْهِ مَسِيرِي فَهْوَ قَصْدِي وَمَنْجِي"],
      ["وَرَاجِلَةً وَهْوَ الْمَزَادُ فَإِنَّهُ", "رَسُولٌ مِنَ الْمَوْلَى إِلَى النُّورِ يُخْرِجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ مَتَى وُصِلُوا بَلِّغُوا"]
    ]
  }