{
    "id": 5,
    "title": "حرف الجيم",
    "huruf": [
      ["ذِمَامُ وَفِيٍّ لَا يَخُونُ وَيَنْكُثُ", "ذِمَامَكَ خَيْرَ النَّاسِ فِيهِ سَيَمْكُثُ"],
      ["أَجِرْنِي فَإِنَّ الْقَلْبَ ظَلَّ بِوَحْشَةٍ", "وَلَسْتُ أُرَى فِي غَيْرِ طِبِّكَ اَبْحَثُ "],
      ["فَإِنَّ الْتِفَاتَ الْقَلْبِ وَقْتًا لِغَيْرِهِ", "عَذَابٌ شَدِيدٌ لَسْتُ أَرْضَاهُ يَحْدُثُ"],
      ["أَجِرْنِي أَجِرْنِي يَا حَبِيبِي فَإِنَّنِي", "ضَعِيفٌ حَقِيرٌ فِي ثَنَائِكَ يَلْبَثُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وءَالٍ وَصَحْبٍ عَهْدَهُمْ لَيْسَ يَنْكُثُ"]
    ]
  }