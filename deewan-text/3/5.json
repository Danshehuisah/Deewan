{
    "id": 5,
    "title": "حرف الجيم",
    "huruf": [
      ["ذِمَامٌ وَفِيٌّ لَا يَكُونُ وَلَا يَكُتُ", "ذِمَامُكَ خَيْرُ النَّاسِ فِيهِ سَيَفْكُتُ"],
      ["أَجِرْنِي فَإِنَّ الْقَلْبَ ظَلَّ بِوَحْشَةٍ", "وَلَسْتُ أَرَى فِي غَيْرِ حُبِّكَ أُحْبَتُ"],
      ["فَإِنَّ الْتِفَاتَ الْقَلْبِ نَحْوَ غَيْرِهِ", "عَذَابٌ شَدِيدٌ لَسْتُ أَرْضَاهُ يَحْدُثُ"],
      ["أَجِرْنِي أَجِرْنِي يَا حَبِيبِي فَإِنَّنِي", "ضَعِيفٌ حَقِيرٌ فِي ثَنَائِكَ يَلْبَثُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ عَهْدُهُمْ لَيْسَ يَفْكُتُ"]
    ]
  }