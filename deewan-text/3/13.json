{
    "id": 13,
    "title": "حرف الزاي",
    "huruf": [
      ["فَإِنَّكَ خَيْرُ النَّاسِ أَنْتَ الْمُبَارِرُ", "لِإِعْلَاءِ دِينِ اللَّهِ أَنْتَ الْمُنَاجِرُ"],
      ["وَإِنَّكَ أَسْعَى النَّاسِ أَشْجَعُ فَارِسٍ", "لِذَا دَانَ مَنْ قَدْ كَانَ قَبْلُ يُنَاجِرُ"],
      ["قَسَمْتَ وَلَمْ تَبْخَلْ وَمَا فُهْتَ كَاذِبًا", "وَلَسْتَ جَبَانًا مِنْ عَطَاكَ الْجَوَائِرُ"],
      ["وَهَذَا عَبِيدٌ قَدْ أَتَى مُتَكَفِّفًا", "عَلَى أَنَّهُ بِالْحُبِّ وَالْحُبُّ فَائِرُ"],
      ["يَرُومُ مَنَالًا قَدْ تَقَاصَرَ دُونَهُ", "فُحُولٌ مَضَى لَا عَجْزُ إِذْ هُوَ جَائِرُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ عَلَى الَّذِينَ تَبَارَزُوا"]
    ]
  }