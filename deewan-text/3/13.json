{
    "id": 13,
    "title": "حرف الزاي",
    "huruf": [
      ["فَإِنَّكَ خَيْرُ النَّاسِ أَنْتَ الْمُبَارِرُ", "لِإِعْلَاءِ دِينِ اللَّهِ أَنْتَ الْمُنَاجِرُ"],
      ["وَإِنَّكَ أَسْخَى النَّاسِ أَشْجَعُ فَارِسٍ", "لِذَا دَانَ مَنْ قَدْ كَانَ قَبْلُ يُبَارِزُ"],
      ["قَسَمْتَ وَلَمْ تَبْخَلْ وَمَا فُهْتَ كَاذِبًا", "وَلَسْتَ جَبَانًا مِنْ عَطَاكَ الْجَوَائِزُ"],
      ["وَهَاذَا عَبَيدٌ قَدْ أَتَى مُتَكَفِّفًا", "عَلَى أَنَّهُ وَالْحِبِّ بِالْحُبِّ فَائِزُ"],
      ["يَرُومُ مَنَالًا قَدْ تَقَاصَرَ دُونَهُ", "فُحُولٌ مَضَوْا لَا غَرْوَ إِذْ هُوَ جَائِزُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَأَصْحَابٍ عَلَى الدِّينِ بَارَزُواْ"]
    ]
  }