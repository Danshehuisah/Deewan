{
    "id": 7,
    "title": "حرف الحاء",
    "huruf": [
      ["بَلَى إِنَّ حُبَّ الْهَاشِمِيِّ رَبَاحُ", "وَمَدْحِي لَهُ سِحْرٌ أَرَاهُ مُبَاحُ"],
      ["وَخَمْرٌ حَلَالٌ لِلْغَبُوقِ وَبَلْهَ مَا", "سِوَاهُ فَفِيهِ لِلنَّدِيمِ جُنَاحُ"],
      ["وَنِلْتُ بِهِ كُلَّ الْمُرَادَاتِ إِنَّنِي", "أَتَانِي بِمَدْحِي لِلْأَمِينِ نَجَاحُ"],
      ["أُجَالِسُهُ مَهْمَا صَفَالِي مَجَالِسِي", "وَيَجْبُرُ كَسْرَ الْغَيْرِ مِنْهُ صَلَاحُ"],
      ["أُجَالِسُ بِالْأَمْدَاحِ سِرِّي وَعُمْدَتِي", "مُحَمَّدُ مَنْ هُوَ لِلْمَهِيضِ جَنَاحُ"],
      ["فَيَنْصُرُ مَظْلُومًا وَيَكْسِبُ دَآئِمًا", "لِذِي عَدَمٍ لِلْخَلْقِ مِنْهُ فَلَاحُ"],
      ["وَلِي مِنْهُ بَعْدَ الْعُسْرِ يُسْرٌ وَكَيْفَ لَا", "وَمَا لِي عَلَى الْعِلَّاتِ مِنْهُ بَرَاحُ"],
      ["يُحَوِّلُ خَيْرُ النَّاسِ حَالِي وَإِنَّهُ", "يَجِىءُ بُعَيْدَ الَّيْلِ مِنْهُ صَبَاحُ"],
      ["فَإِنِّي ذَلِيلٌ عَاجِزٌ مُتَمَسِّكٌ", "بِذَيْلِ الَّذِي لِلْكُفْرِ مِنْهُ رِمَاحُ"],
      ["كَفَانِي بِمَدْحِ الْهَاشِمِيِّ وَتَزْدَرِي", "سِوَاهَا وَلِى بَعْدَ الْغَدُوِّ رَوَاحُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَرُوقُ مَدِيحِي فِيهِ وَهْوَ رَبَاحُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ كَطِيبِ الْمِسْكِ حِينَ يُفَاحُ"]
    ]
  }