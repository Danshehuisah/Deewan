{
    "id": 7,
    "title": "حرف الخاء",
    "huruf": [
      ["بَلَى إِنَّ حُبَّ الْهَاشِمِيِّ رَاحَتِي", "وَمَدْحِي لَهُ بَحْرٌ أَرَاهُ مُبَاحَا"],
      ["وَمُجْرٍ لِخَلْقٍ لِلْغُبُوقِ وَنَهْلِهِ مَا", "سِوَاهُ فَفِيهِ لِلْتَّدَاوِي جُنَاحُ"],
      ["وَنِلْتُ بِهِ كُلَّ الْمَرَادَاتِ إِنَّنِي", "أَتَانِي بِمُدْجِي لِلْأَمِينِ نَجَاحُ"],
      ["أُجَالِسُهُ مَهْمَا صَفَا لِي مَجَالِسِي", "وَحِبٌّ كَمَا لِلْغَيْرِ مِنْهُ صَلَاحُ"],
      ["أُجَالِسُ بِالْأَمْدَاحِ سِرِّي وَعُدَّتِي", "مُحَمَّدٌ مَنْ هُوَ لِلْمَهِيضِ جَنَاحُ"],
      ["فَيَنْصُرُ مَظْلُومًا وَيَكْسِبُ دَائِمًا", "لِي عَدَمٌ لِلْخَلْقِ مِنْهُ فَلَاحُ"],
      ["وَيَمْنَحُ بَعْدَ الْعُسْرِ يُسْرًا وَكَفَّى", "لَا وَمَا لِي عَلَى الْعِلَّاتِ مِنْهُ بَرَاحُ"],
      ["حُجُولُ خَيْرِ النَّاسِ خَالِي وَإِنَّهُ", "حَيَّهُ بَعْدَ اللَّيْلِ مِنْهُ ضَبَاحُ"],
      ["فَإِنِّي ذَلِيلٌ عَاجِزٌ مُتَمَلِّقٌ", "بِذَلِكَ الَّذِي لِلْكُفْرِ مِنْهُ رَمَاحُ"],
      ["كَفَانِي بِمَدْحِ الْهَاشِمِيِّ وَأَزْدَرِي", "سِوَاهُ وَبَعْدَ الْغُدُوِّ رَوَاحُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَرُوقُ مَدِيحِي فِيهِ وَهْوَ رَبَاحُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ كَفِيلُ الْمُنْسَكِ حِينَ يُتَاحُ"],
      ["خَدِيمٌ ثَوَى بِالْبَابِ وَالْحُبُّ رَاسِخٌ", "بِقَلْبٍ لَهُ وَهْوَ الْمَدَائِحَ نَاسِحُ"],
      ["خِتَامٌ لِتَمَامٍ لِلنُّبُوَّةِ فَاقْبَلَنْ", "مُحِبًّا مُسِيئًا قَدْ أَتَى وَهْوَ صَارِحُ"],
      ["خِصَالُ الْمَعَالِي قَدْ حَوَتْهَا جَمِيعُهَا", "مَا تَتَرَقَّى فِي الْأَرْسَالِ فَالْمَجْدُ شَامِحُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَذَا كُلُّ شَأْنِي لِلشُّؤُونِ نَاسِخُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ حُبُّهُمْ فِيكَ رَاسِخُ"]
    ]
  }