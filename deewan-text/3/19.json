{
    "id": 19,
    "title": "حرف الصاد أيضاً",
    "huruf": [
      ["شُؤُونٌ دَهَتْنِي سَيَّرَتْنِي لِمَنْ نَهَضْ", "لِتَفْرِيجِ كَرْبِ الْمَكْرُوبِينَ وَمَنْ نَهَضْ"],
      ["سَلَامٌ عَلَيْهِ وَالسَّلَامُ مُحَمَّدٌ", "فَرَاحَ شُؤُونِي وَالسُّرُورُ إِلَى عِوَضْ"],
      ["مُحَمَّدٌ خَيْرُ النَّاسِ أَكْرَمُ مَنْ مَضَى", "وَفَرْعًا وَبَدْلًا وَهْوَ لِلَّهِ قَدْ مُحِضْ"],
      ["أَعْنِي أَعْنِي مَنْ حَمَى وَدَارِكًا", "لِأَحْوَالِ عَبْدٍ عَبْرَ عَهْدِكَ مَا قَبَضْ"],
      ["أَتَشَرَّكُ عَبْدًا لَا يُؤَبَّسُ بِوَاتِكُمْ", "عَلَى سُوءِ حَالٍ فَهْوَ لَا يَتَّقِي الْعَوَضْ"],
      ["فَتَفْرِيجُ كُرُوبِي وَاقْطَعُ كُلَّ مَهَامِهٍ", "لِقُرْبِ مَزَارِ الْمُصْطَفَى حَيْثُهَا بُهِضْ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ حُبُّهُمْ خَيْرُ مُفْتَرَضْ"]
    ]
  }