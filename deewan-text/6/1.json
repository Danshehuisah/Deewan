    "title": "حرف الألف",
    "huruf": [
      ["أَبِيتُ بِخَيْرِ الْخَلْقِ خَيْرِ مَرَاءِ", "نَفَى الشَّكَّ وَالْأَسْوَاءَ وَكُلَّ مِرَاءِ"],
      ["وَهَيَّجَ شَوْقِي وَالْمَحَبَّةَ وَالصَّبَا", "وَأَرَّقَنِي إِذْ نَامَ أَهْلُ خِبَائِي"],
      ["يُؤَنِّسُنِي طِرْسِي وَحِبْرِي وَلَقْلَقِي", "هَزَارًا وَقَلْبِي أُنسَهُ بِشِقَائِي"],
      ["مُحَمَّدُ مُخْتَارُ الْإِلَهِ نَبِيُّهُ", "عَلَيْهِ أَتَتْ آيَاتُهُ بِثَنَاءِ"],
      ["فَلَا أَقْفُو غَيْرَ الْمُصْطَفَى لَسْتُ ثَالِثًا", "سِوَى ذِكْرِهِ كُفْوًا لِمَلَامِ مَلَائِي"],
      ["هَلِ الَّذِينَ غَيْرُ الذِّكْرِ وَالسُّنَّةِ الَّتِي", "عَنِ الْمُصْطَفَى صَحَّتْ فَيْلَقُ دَوَائِقِ"],
      ["أَنْصَبَ خِلَافًا بَيْنَ طَهَ وَغَيْرِهِ", "يَزَاهُ لَبِيبٌ غَيْرَ عَيْنِ عَمَاءِ"],
      ["أَيَا نَاسُ خَلُّوا الْهَزَلَ وَاقْفُوا مُحَمَّدًا", "وَإِلَّا تَرَوْا فِي الْهَرْجِ جَدَّ بَرَاءِ"],
      ["مُحَمَّدُ خَيْرُ الْغَالِبِينَ مُحَمَّدُ", "رَسُولٌ أَمِينٌ ذُو سَنًا وَسَنَاءِ"],
      ["فَصِيحٌ بَلِيغٌ مَا يَنْطِقُ عَنْ هَوًى", "بَلِ الْوَحْيِ وَالتَّنْزِيلِ وَحْيِ سَمَاءِ"],
      ["عَلَيْكُمْ بِحَبْلِ اللَّهِ لِلْعَبْدِ وَاتَّقُوا", "فَتْحَ بِنَاءِ الذِّكْرِ تَفْحَ شَقَاءِ"],
      ["وَإِنْ قُلْتُ هَلْ هَذَا الْوِرْدُ مَدْحُ مُحَمَّدٍ", "أَقُولُ نَعَمْ وِرْدِي لِتَبْلُلْ صَفَاءِ"],
      ["فَمَا الْوِرْدُ إِلَّا الذِّكْرُ لِلَّهِ وَحْدَهُ", "نُصَلِّي عَلَى الْمُخْتَارِ خَيْرِ وَرَاءِ"],
      ["فَمَا فِيهِ ذِكْرُ الشَّيْخِ أَوْ ذِكْرُ غَيْرِهِ", "فَوِرْدِي لِدَاءِ الْعَبْدِ عَيْنُ دَوَاءِ"],
      ["رُوَيْدَكُمْ لَا تُنْكِرُوا عَنْ جَمَالِهِ", "لِبَغْيٍ وَعُدْوَانٍ وَعَيْنِ عَمَاءِ"],
      ["فَقَدْ بَلَّغَ الْهَادِي وَأَدَّى أَمَانَةً", "حُدَا حَدُّهُ الْهَادُونَ شُهُبُ دُجَاءِ"],
      ["وَالْأَعْلَامُ قَادَاتٌ بِقُدْسِ نَبِيِّنَا", "لِتَقْفُوَ الْهَدِيَّ بِقُدْسِهِ دُونَ مِيزَاءِ"],
      ["سَوَاءٌ جَلِيلٌ أَوْ حَقِيرٌ فَمَا لَنَا", "سِوَى قَفْوِهِ دَهْرًا صَبَاحَ مَسَاءِ"],
      ["أَلَا يَا رَبَّ جِبْرِيلَ الْأَمِينِ فَثَبِّتَنْ", "عَلَى سُنَّةِ الْهَادِي قُلُوبَ أُولَاءِ"],
      ["وَلَا يَتْلِينَا اللَّهُ بِالزَّيْغِ وَالْهَوَى", "نَعِيشُ عَلَى الْبَيْضَاءِ لِيَوْمِ لِقَاءِ"],
      ["وَلَا يَلْبَسُوا قِشْرَ الْيَقِينِ فَيَحْطَنَا", "بَلِ اللُّبُّ لُبُّ اللُّبِّ مَحْضُ عَطَاءِ"],
      ["سَرَى طَيْفُهُ وَهْنًا وَكِدْتُ لِحُبِّهِ", "أَطِيرُ اشْتِيَاقًا وَالْغَرَامُ بَلَائِي"],
      ["وَكُلٌّ وَلِيلَاهُ وَبُرْهَانُ مُبْتَلًى", "بِأَمْدَاحِ خَيْرِ النَّاسِ عَيْنِ بَهَاءِ"],
