      ["رَمَوْنِي وَمَا نَالُوا مُرَادًا وَإِنَّنِي", "أُمَرِّقُ بِالْمَاضِي جُمُوعَ عِدَائِي"],
      ["سَيُرْغَمُ هَذَا الْجَيْشُ حَقًّا وَإِنَّهُمْ", "يُوَلُّونَ أَدْبَارًا رِقَابَ إِمَاءِ"],
      ["يَسُومُونَ ضَيْمًا لِلْحَدِيدِ وَإِنَّهُمْ", "تَتَرُّسُ بِالْمُخْتَارِ قَبْلَ رِمَاءِ"],
      ["أَيُشْوَى عَلَى جَارِ الْأَمِينِ حَدِيدُهُ", "مَكَائِدَ أَبْنَاءِ لِأَهْلِ بَغَاءِ"],
      ["وَقَدْ زَخْرَفَ الْأَقْوَامُ مَكْرًا بِتَدْوِينٍ", "وَخَطُّوا كِتَابًا قَصْدَ دَفْعِ ضِيَاءِ"],
      ["وَجَاءُوا بِتَدْمِيرٍ خَيْلُهُمْ وَرِجَالُهُمْ", "وَنَاءُوا بِجُزْءٍ بَاطِلٍ وَوَبَاءِ"],
