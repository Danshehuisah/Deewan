{
    "id": 7,
    "title": "حرف الدال",
    "huruf": [
      ["دَعَانِي إِلَى حُبِّ الْعُرُوضِ شُهُودِي", "سُهَادِي وَحِبْرِي وَالطُّرُوسُ شُهُودِي"],
      ["دُمُوعِي عَلَى الْخَدَّيْنِ كَالْغَرْبِ مُوهِنًا", "مَعَ الشَّيْبِ وَالْأَجْرَاسِ ثُمَّ رُقُودِي"],
      ["دَلِيلٌ عَلَى مَا قَدْ دَهَانِي وَإِنَّنِي", "عَرَانِيَ حَالٌ فِي الْوِدَادِ شَدِيدُ"],
      ["دَهَانِي غَرَامٌ خَرَّمَ النَّوْمَ مُوهِنًا", "وَحَلَّ خَرِيقٌ وَالْغَرَامُ وُقُودُ"],
      ["لَقَدْ خَرَّمَ الْوَجْدُ الْخَلَالَ مُحَلِّلًا", "خَرَامًا وَهَلْ هَذَا الْقَضَاءُ سَدِيدُ"],
      ["فَإِنْ حَادَ عَنْ نَهْجِ الرَّسُولِ فَإِنَّنِي", "عَلَى نَهْجِهِ مَا عِشْتُ فَهْوَ مُحِيدُ"],
      ["أَسِيرُ غَرَامٍ لَا أَزَالُ مُتَيَّمًا", "وَعَنْ نَهْجِ خَيْرِ الْخَلْقِ لَسْتُ أَحِيدُ"],
      ["إِذَا سَارَ خَيْرُ النَّاسِ سِرْتُ وَرَاءَهُ", "وَإِنْ حَلَّ يَوْمًا فَالْمَسِيرُ بَعِيدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِكُلِّ مُرَادَاتِي الْكَرِيمُ يُفِيدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَكُونُ لَنَا الْحُسْنَى وَبَعْدُ مَزِيدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ مَا الْفُؤَادُ عَبِيدُ"]
    ]
  }