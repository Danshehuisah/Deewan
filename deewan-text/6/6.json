{
    "id": 6,
    "title": "حرف الحاء",
    "huruf": [
      ["حَرِيصٌ عَلَى إِهْدَاءِ هَذَا الثَّنَا وَالْمَدَائِحِ", "لِجَانِبِ مَنْ سَكَنَاهُ بَيْنَ جَوَانِحِي"],
      ["يُهَيِّجُ أَشْوَاقِي هِلَالُ رَبِيعِهِ", "رَبِيعُ الْمُزُونِ الْوَاكِفَاتِ الدَّوَالِحِ"],
      ["نَشِيجِي فَرَحًا كَانَ مِنْ قَبْلُ دَامِيًا", "وَلِمْ لَا وَشَمْسٌ فِيهِ تَرْقَى الْمَزَابِحِ"],
      ["نَبِيٌّ عَظِيمُ الْخَلْقِ مِفْتَاحُ غَيْبِ مَنْ", "لَهُ الْأَمْرُ أَوْ لِلْحَقِّ كُلِّ الْمَفَاتِحِ"],
      ["تَخَلَّى عَنِ الْإِيمَانِ مَنْ لَيْسَ صَادِقًا", "عَلَى حُبِّهِ مِنْ كُلِّ غَادٍ وَزَائِحِ"],
      ["كَذَا مُؤْثِرٌ شَيْئًا سِوَاهُ وَلَوْ أَنَّهُ", "حَشَاشَةُ نَفْسِ الْمَرْءِ بَيْنَ الْجَوَانِحِ"],
      ["فَحُبُّ رَسُولِ اللَّهِ زَيْنٌ وَمَفْخَرٌ", "وَأَمْنٌ وَإِيمَانٌ وَنَابُ الْمَصَالِحِ"],
      ["فَحُبُّ رَسُولِ اللَّهِ مَالِي وَمَالِكِي", "وَنُبْعِي وَحِرْفِي وَهْوَ عَيْنُ مَرَاجِي"],
      ["هُوَ الْحَسَنُ وَالْإِحْسَانُ مِنْهُ وَإِنَّهُ", "لِمُصْرَفِ حُبِّي ثُمَّ كُلِّ الْمَدَائِحِ"],
      ["حَبَايَ مُرَادِي قَبْلَ عِلْمِي وَنَشْأَتِي", "فَيَبْتَدِرَ الْكُلَّ وَالْكُلُّ مَاحِي"],
      ["طَوَيْتُ مَقَامَاتِ الرِّجَالِ بِحُبِّهِ", "دَنَا فَتَدَلَّى لِي بِرَغْمِ قَبَائِحِي"],
      ["وَأَخْفَى الَّذِي لَا أَبُوحُ بِسِرِّهِ", "بِسُكْرٍ وَصَحْوٍ عِنْدَ صَاحٍ وَصَائِحِ"],
      ["وَفِي الْحَجِّ يَوْمَ الْعِيدِ بِالْخَيْفِ مِنْ مِنًى", "هَجَرْتُ أَتَانِي الْمُصْطَفَى بِالْمَدَائِحِ"],
      ["وَإِنِّي لَتَعْرُونِي لِذِكْرَاهُ هَزَّةٌ", "لِحُسْنِ مُحَيًّا فَاتَ كُلَّ الْمَدَائِحِ"],
      ["وَإِنِّي لَتَعْرُونِي لِذِكْرَاهُ هَزَّةٌ", "جَوَادٌ يَنُوبُ السُّحْبَ إِثْرَ اللَّوَاقِحِ"],
      ["وَإِنِّي لَتَعْرُونِي لِذِكْرَاهُ هَزَّةٌ", "بِعَرْفٍ يَنُوبُ كُلَّ طِيبٍ وَفَائِحِ"],
      ["مَعَ الْحَقِّ حَالَاتُ الْأَمِينِ كَحَالَتِي", "مَعَ الْمُصْطَفَى الْمُخْتَارِ نُورِ الْأَبَاطِحِ"],
      ["يُؤَخِّذُهُ وَالْحَقُّ يَدْنُو صِلَاتُهُ", "عَلَيْهِ وَأُهْدِي نَحْوَهُ بِمَدَائِحِي"],
      ["وَهَذَا الْمَدِيحُ الْحَمْدُ وَالشُّكْرُ حِينَمَا", "يَقِلُّ شَكُورٌ لِلْأُلَى وَالْمَنَائِحِ"],
      ["لَكَ الْحَمْدُ حَمْدَ الذَّاتِ لِلذَّاتِ دَائِمًا", "عَلَى أَحْمَدَ الْمُخْتَارِ أَفْضَلِ مَادِحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابِ النَّبِيِّ الْمُتَنَاصِحِ"],
      ["خَيَالٌ سَرَى أَمْ حَلَّ طَيْبَةَ كُولَا", "شَمَمْتُ أَرِيجَ الْهَاشِمِيِّ فَأَرَّخُوا"],
      ["خِتَامَ نُبُوَّاتِ النَّبِيِّينَ لَنْ تَرَى", "سِوَى خَيْرِ مُقَفًّى وَهْوَ بِالسِّرِّ يَسْرَحُ"],
      ["خَلِيلِ خَلِيلِ أَحْمَدِ الرَّحَمَاتِ الَّذِي", "أَتَى بِنَشِيدٍ بَعْدَ ثَبْتِ الرُّسُلِ يَرْسَخُ"],
      ["فَأَرْكَانُهُ التَّوْحِيدُ هَلْ مِنْ قَائِلٍ", "بِأَنَّ إِلَهِي بِالَّذِي مَنْ يُوَثِّخُ"],
      ["كَذَاكَ نُصَلِّي مَا دَرَيْنَا شَفِيعَنَا", "خُلِقْنَا مِنْ صَلَاةٍ قَطُّ فَالشَّأْنُ أَشْرَخُ"],
      ["نَصُومُ كَمَا صَامَ النَّبِيُّونَ قَبْلَنَا", "وَهَلْ عَابَ صَوْمًا عَاقِلٌ أَوْ مُؤَرِّخُ"],
      ["كَذَاكَ زَكَاةٌ ثُمَّ حَجٌّ فَكُلُّهَا", "مِنَ الشَّرْعِ أَضْوَاءٌ تَلِيقُ بِمَنْ يَرْسَخُ"],
      ["وَلَوْلَا مَعَ التَّوْرِيجِ مَا كَانَ عَابِدٌ", "وَلَا عُمُرَ الدَّارَيْنِ أَيْنَ الْمُوَثِّخُ"],
      ["وَتَعْدَادُ زَوْجِ الشَّرْعِ جَاءَ لِذِكْرِهِ", "تَعُودُ لِنِسْوَانٍ إِلَى يَوْمِ يُنْفَخُ"],
      ["فَإِنْ لَمْ يَكُنْ تُلْفَى جُمُوعًا عَوَانِسًا", "تُخَالِفُ أَحْكَامًا وَكَيْفَ تُوَثِّخُ"],
      ["نَعَمْ وَغَزَا رَدَّ الِاعْتِدَاءَ وَمَا عَدَا", "فَطَهَ عَلَى الْأَكْوَانِ يَسْرُو وَيَسْرَحُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ مَا الْحَبِيبُ يُؤَرِّخُ"]
    ]
