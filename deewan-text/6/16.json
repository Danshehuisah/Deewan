{
    "id": 16,
    "title": "حرف الغين",
    "huruf": [
      ["غَدَا أَتْقَلَّى عَنْ هَوَانٍ أَبْلَغُ", "مَدِيحٌ حَبِيبٍ وَهْيَ نَعْمَايَ تَسْبَغُ"],
      ["غَرَامِي جَمِيعًا لِلْمَدِينَةِ إِذْ نَأَتْ", "دِيَارِي فَهَلْ يَا قَوْمُ تَرْعَوْنَ أَبْلَغُ"],
      ["عَنَاتِي بِهَا عَيْشِي بِهَا الَّذِي بِهَا", "أَنَاهَا رَسُولُ الْعَالَمِينَ الْأَبْلَغُ"],
      ["غَلِيلِي لَا يُرْوَى بِغَيْرِ مَعِينِهَا", "وَإِنَّ شِفَائِي ثَرْبَهَا إِذْ أُمَرَّعُ"],
      ["غَوَى وَعَدَى مَنْ قَدْ يَلُومُ بِحُبِّهَا", "وَأَقْذِفُهُ بِالْحَقِّ فِي الْحِينِ يُدْمِعُ"],
      ["غُرُورٌ هَوًى يَدْعُو لِصَرْفِ سِوَاهَا", "فَلَيْتَ فُؤَادِي فِي هَوَى بَلْدَةٍ يُضْبَعُ"],
      ["عَلَى سَاكِنِي وَادِي الْعَقِيقِ تَحِيَّتِي", "وَإِنْ أَسْهَرُونِي وَالْمَدَامِعَ فَرَّعُوا"],
      ["عَلَى أَحْمَدَ الْمُخْتَارِ مِنْ عِنْدِ رَبِّهِ", "صَلَاةٌ وَتَسْلِيمٌ مِنَ اللَّهِ مُبْلَغُ"]
    ]
  }