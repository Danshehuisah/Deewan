{
    "id": 4,
    "title": "حرف الثاء",
    "huruf": [
      ["يُمَارِي بِأَمْدَاحِي وَإِلَيَّ حَارِثُ", "وَيَأْبَى شَقًا مَنْ قَالَ رَبِّي ثَالِثُ"],
      ["وَأَفْضَلُ مَوْجُودٍ رَسُولِي مُحَمَّدٌ", "وَذَلِكَ عَبْدٌ فَالْمُخَالِفُ عَابِثُ"],
      ["فَمَنْ قَادَ لِلْحُسْنَى يُوَحِّدُ وَإِنَّمَا", "الَّذِي قَالَ بِالتَّثْلِيثِ فِي الْأَرْضِ عَائِثُ"],
      ["سَعِيدٌ بِهَذَا الْإِيمَانِ حِينَ شَقِيتُمْ", "بِتَثْلِيثِكُمْ رَغْمًا فَدِينِي وَارِثُ"],
      ["صَلَاةٌ وَصَوْمٌ وَالزَّكَاةُ فَرِيضَةٌ", "وَحَجٌّ وَتَزْوِيجٌ فَهَذَا الدِّينُ لَابِثُ"],
      ["بِهَذَا الدِّينِ طَهَ الْهَاشِمِيُّ مُحَمَّدٌ", "فَأَنَا مَدَى دَهْرِي بِهَذَا الدِّينِ مَاكِثُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَقِينَا شُرُورَ الْمُفْتَرِي إِنْ كَانَ نَافِثُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ مَا الْمُحِبُّ يُنَافِثُ"]
    ]
  }