{
    "id": 17,
    "title": "حرف الفاء",
    "huruf": [
      ["فَوَا أَسَفِي بَانَ الْقَتَا ذَاكَ يُوسِفُ", "تَرَاقَى كَئِيبٍ تَأْسَى عَنْهُ يُوسُفُ"],
      ["عَسَانِي وَلَيْتِي الْيَوْمَ أَيَّ مَحِيصٍ", "بِوَادِي عَقِيقٍ مَرْبَعًا كُنْتُ آلَفُ"],
      ["مَغَانٍ بِهَا خَلَّ الْهُدَى أَذْعَنَ الْعِدَى", "وَفَاضَ النَّدَى لِلْكُلِّ وَالْكُلُّ يَغْرِفُ"],
      ["مَغَانٍ ثَنَاؤُهَا بِالسَّعَادَةِ سَرْمَدًا", "خَتَاجِرُهَا بَحْثٌ وَذُو الْعَقْلِ يُنْصِفُ"],
      ["مَغَانٍ بِنَا الْهَادِي خَازِنُ سِرِّهِ", "بِهِ عَرَفَ الْبَارِيَ الْفُحُولُ وَعَرَّفُوا"],
      ["بِهِ عَلَّمَ الْأَسْمَاءَ آدَمُ أَصْلُهُ", "لِذَا سَجَدَ الْأَمْلَاكُ إِذْ جَاءَ يَخْلُفُ"],
      ["فَمِنْهُ أَتَانِي الْعِلْمُ وَالْفَيْضُ وَالْهُدَى", "وَقَدْ فُقْتُ فِي الْعِرْفَانِ مَنْ كَانَ يَغْرِفُ"],
      ["تَرَى ذَاكَ شَطْحًا أَوْ تَرَاهُ تَحَدُّثًا", "بِتَغْمَامِهِ أَمْ ذَاكَ مِنْهُ تَغْرِفُ"],
      ["فَإِمَّا شَاءَ ذَا أَوْ ذَاكَ سِيَّانِ إِنَّمَا", "مُرَادِي ثَنَا الْبَحْرِ الَّذِي مِنْهُ أَعْرُفُ"],
      ["وَإِنِّي مُحِبٌّ شَاعِرٌ خَادِمٌ لَهُ", "عَلَى حَضْرَةِ الْهَادِي فُؤَادِي مُطَوِّفُ"],
      ["فَلَمْ أَلْقَ أَعْمَالًا لَهَا أَتَزَوَّفُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["صَلَاتِي وَتَسْلِيمِي بِهَا أَنْتَزِفُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["أُحِبُّ الرَّسُولَ الْهَاشِمِيَّ وَأَهْرُفُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["مَدَى الدَّهْرِ فِي جَذْبِ الْأَمِينِ أُصِيفُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["وَأَجْمَعُ مَدْحَ الْهَاشِمِيِّ وَأُولِفُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["عَلَى بَاطِلِ الرَّهْبَانِ حَقِّي أَقْذِفُ", "عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ"],
      ["مَدَى الدَّهْرِ مَا حَجَّ الْحَجِيجُ وَعَرَّفُوا"]
    ]
  }