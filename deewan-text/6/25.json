{
    "id": 25,
    "title": "حرف الياء",
    "huruf": [
      ["يَقِينِي يَقِينِي رَاحِحًا فِكْرُ غَادِيَا", "عَلَى رَغْمِ قَالِ اللَّيَالِي عَادِيَا"],
      ["يَمِينِي وَشِمَالِي أَحْمَدُ النُّورُ مُرْشِدِي", "أَمَامِي إِمَامِي مُهْلِكُ الْكُفْرِ مَاحِيَا"],
      ["يَسَارِي يَسَارِي مُصْطَفَى الْكَوْنِ مَسْنَدِي", "فَمَنْ كَادَنِي يَلْقَ الرَّدَى وَالْمَخَازِيَا"],
      ["يُؤَمِّنُنِي دَيْشَا وَأُخْرَى فَأَقْتَفِي", "مَنَاهِجَهُ بِالرُّوحِ لِلَّهِ سَارِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَسْرِي كِتَابُ اللَّهِ فِي اللَّيْلِ تَالِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُجِيبُ أَيَا الْمُؤَمِّلُ جَمِيعَ دُعَائِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأَبْقَى أُشَيِّدُ الدِّينَ فِي الْجَوِّ عِدَائِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أُدَمِّرُ بِالْمَاضِي جُمُوعَ عِدَائِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ شَيَّدُوا الدِّينَ عَلَيْنَا"]
    ]
  }