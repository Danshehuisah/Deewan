{
    "id": 23,
    "title": "حرف الهاء",
    "huruf": [
      ["هُوَ الْهَادِي هَدَى الْمُصْطَفَى وَسِوَاهُ", "هَوَى وَضَلَالٌ يُقَدُّ بِسَرَاهُ"],
      ["فَوَحْيٌ مِنَ اللَّهِ الْجَلِيلِ جَلَالُهُ", "عَلَى أَكْمَلِ الْأَرْسَالِ وَهْوَ تَلَاهُ"],
      ["وَيَتْلُوهُ إِذْ لَا مُبِينَ شَرِيعَةً", "إِذَا الْوَحْيُ غَيْرُ الْمُصْطَفَى وَهْدَاهُ"],
      ["أُحِبُّ الرَّسُولَ الْمُصْطَفَى الْقَرْمَ إِنَّهُ", "تَشَرَّبَ قَلْبِي حُبَّهُ وَهْدَاهُ"],
      ["وَلِمْ لَا وَعَيْنِي قَدْ رَأَتْهُ بِحَيِّ مَنْ", "أُحِبُّ وَأَهْوَى عَيْنَهُ وَتَنَاهُ"],
      ["تَجَلَّتْ لَهُ الذَّاتُ الْعَلِيَّةُ قَبْلَ مَا", "أَرَى غَيْرَهُ إِذْ مَا هُنَاكَ سِوَاهُ"],
      ["فَأَوَّلُ مَحْبُوبٍ وَأَوَّلُ ذَاكِرٍ", "وَأَوَّلُ مَذْكُورٍ أُهِيلَ لِقَاهُ"],
      ["فَقَامَ يَدُودُ الْغَيْرَ حُبًّا وَغَيْرُهُ", "يَقُولُ فَمَا غَيْرِي يَشَمُّ شَذَاهُ"],
      ["فَمَنْ عَطَّلَتْهُ بُعْدٌ وَقُرْبٌ حِجَابُهُ", "زَوَالُ حِجَابٍ فَاسْتَبَرَّ بِمِسْعَاهُ"],
      ["فَمَهْمَا يَقُلْ لَا لَا سَبِيلَ لِوَصْلِ مَنْ", "تُحِبُّ فَقُلْ لَا لَا أَرَاكَ سِوَاهُ"],
      ["فَأَنْتَ مُرَادُ الْحَقِّ وَالْكُلُّ وَاصِلٌ", "فَمَنْ دَرَكَ الْعَبْدُ نَالَ مُنَاهُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ عَلَوْا بِثَنَاهُ"]
    ]
  }