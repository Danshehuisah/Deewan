{
    "id": 12,
    "title": "حرف الضاد",
    "huruf": [
      ["ضَمِنْتُ لَهُ وَهِيَ الْفُرُوضُ فُرُوضُ", "يُوَافِيهِ مِتِّي بِالثَّنَاءِ قَرِيضُ"],
      ["وَذَاكَ رَسُولُ اللَّهِ أَحْمَدُ سَيِّدِي", "لِقَلْبِي لَدَى ذِكْرِ الْأَمِينِ نَبُوضُ"],
      ["نَهَضْتُ بِهِ مِنْهُ إِلَى اللَّهِ رَاحِلًا", "خَبَايَا وَلَا تَقُلْ وَلَيْسَ فُرُوضُ"],
      ["وَهَلْ أَبْصَرَتْ عَيْنَاكَ مِثْلِي سَائِرًا", "سُلُوكِي وَجَذْبِي وَالْعُلُومُ فُيُوضُ"],
      ["كَفَانِي فِي سَيْرِي الْعَنَاءُ وَقَادَنِي", "إِلَى الذَّاتِ لَا جُنْدٌ غَزَا أَوْ حَضِيضُ"],
      ["وَكَشْفِي فِي الْأَمْعَاءِ وَالذِّكْرِ لَمْ أَحِشْ", "خَفَائِي إِذَا بَغْشُ الرِّجَالِ حَشِيضُ"],
      ["وَسِرِّي سَرَى فِي الْخَافِقَيْنِ وَعُقِمَتْ", "شُبُوحٌ عَلَوْا حَتَّى تَحُولَ جَرِيضُ"],
      ["عَلَى ذَلِكَ الْمَحْبُوبِ كَهْفِي وَمُرْشِدِي", "صَلَاةً بِهَا قَلْبِي أَرَاهُ رَجِيضُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا عَقَّ الزَّمَانُ غَضِيضُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَدَى الدَّهْرِ مَا دَمْعُ الْمُحِبِّ يَفِيضُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "مَتَابِعُ شِعْرِي فِي ثَنَاكَ تَفِيضُ"]
    ]
  }