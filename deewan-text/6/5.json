{
    "id": 5,
    "title": "حرف الجيم",
    "huruf": [
      ["هَجَارًا لَقِيتُ الْمُصْطَفَى بِعُرُوجِي", "إِلَى اللَّهِ مِنْ هَذَا الْكَوْنِ وَقْتَ خُرُوجِي"],
      ["جَلِيلًا جَمِيلًا كَامِلًا وَمُبَشِّرًا", "بِدَرْكِ مُرَادِ الْعَبْدِ وَقْتَ وُلُوجِي"],
      ["جَزِيلَ تَوَالٍ جَابِرًا جَامِعَ الْهُدَى", "الْوُدُّ بِهِ فِي مَدْخَلِي وَخُرُوجِي"],
      ["جُبِلْتُ أُحِبُّ الْهَاشِمِيَّ وَإِنْ دَنَتْ", "مَرَابِعُهُ زَخْرَفَتْ كُلَّ نَسِيجِي"],
      ["جَفَاقِي مَنَامِي قَبْلَ أَنْ يَدْنُوَ رَضِيعُهُ", "أَيَا نَفْسُ أَوْفِي لِلْحَبِيبِ وَغُوجِي"],
      ["جَزَى الْقَلْعُ الْأَعْلَى يُكَمِّلُ حَاكِمًا", "بِأَيِّ الْمُعَلَّى رَغْمَ كُلِّ غُلُوجِ"],
      ["رُجُوعِي مِنَ الْمَوْلَى لِأَحْمَدَ تَارَةً", "إِلَى الْمَلَإِ الْأَعْلَى فَوْقَ بُرُوجِ"],
      ["كَأَيِّ بَرِيدِ الْمِقْطَرِ لِلْكُلِّ قَاذِفًا", "يَوْمَ هُبُوطِي مِثْلَ وَقْتَ عُرُوجِي"],
      ["تَلَقَّاهُ مِنِّي كُلُّ رُوحٍ مُحَرَّرٍ", "صَفَا وَقْتُهُ وَالْأَمْرُ غَيْرُ مَرِيجِ"],
      ["وَذَلِكَ مِنْ حُبِّ الْحَبِيبِ مُحَمَّدٍ", "حَبِيبٍ حَبَا الْإِحْسَانَ قَبْلُ بَهِيجِ"],
      ["فَمَنْ يَتَعَلَّقْ بِالْأَمِينِ مَحَبَّةً", "يَنَلْ كُلَّ مَا يَهْوَى بِشَمِّ أَرِيجِ"],
      ["مَحَبَّتُهُ فَأْرِي وَأُنُسِي وَلَذَّتِي", "وَدِرْعِيَ الَّذِي أَتَّقِي بِدُونِ فُرُوجِ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ سَيِّدُ خَلْقِهِ", "بِهِ تَبْتَدِي الْعَرْبَاءُ قَبْلَ زُنُوجِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُعَبِّلُ بِالْمَاءِ الْخَطَا وَالثَّلُوجِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ عِدَادَ الْبُرُوجِ"]
    ]
  }