{
    "id": 22,
    "title": "حرف النون",
    "huruf": [
      ["نَعَمْ مُصْطَفَى الْأَكْوَانِ لَيْسَ يَضِينُ", "وَحَقَّ تَجَلَّى الذَّاتِ وَهْوَ يَقِينُ"],
      ["وَقَدْ جَاءَنَا بِالذِّكْرِ يَنْسَخُ كُلَّ مَا", "أَتَى قَبْلَهُ فَالْكَوْنُ دَانَ وَدِينُ"],
      ["كَذَا شَيْخُهُ بَابًا الْمُضْلِلِ يَفْتَرِي", "إِلَهًا سِوَى الْبَارِي وَكَيْفَ يَكُونُ"],
      ["غَيِّي جَهْلٍ قَاسِطٍ غَيْرِ مُنْصِفٍ", "بِتَكْذِيبِ طَهَ الْهَاشِمِيِّ وَيُبِينُ"],
      ["وَهَلْ أَخْبَرَ الْهَادِي بِغَيْرِ حَقِيقَةٍ", "مَضَى قَوْلُ صِدْقٍ وَالْحَدِيثُ يَقِينُ"],
      ["سَبِيلُ سَلَامٍ فِي اتِّبَاعِ مُحَمَّدٍ", "رَسُولٌ كَرِيمٌ مُفْتَشًى وَأَمِينُ"],
      ["لَهُ عِصْمَةٌ وَالْغَيْرُ يَخْطِئُ تَارَةً", "وَطَوْرًا يُصِيبُ مَا لَدَيْهِ يَقِيسُ"],
      ["خَوَارِقُهُ كَالشُّهُبِ وَالْقَطْرِ وَالْحَصَى", "إِمَامٌ نَزِيهٌ كَامِلٌ وَمَضِينُ"],
      ["وَمَنْ بَايَعَ الْمَحْمُودَ فَهْوَ مُبَايِعٌ", "لِدِينٍ فَهَذَا كَالْحَبِيبِ يَمِينُ"],
      ["وَحَيْثُ رَمَاهُمْ قَدْ رَمَاهُمْ بِكَفِّهِ", "إِلَهِي فَهَلْ تُغْنِي هُنَاكَ حُصُونُ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ سَيِّدُ خَلْقِهِ", "فَالْآبَاءُ طُرًّا لِلْأَمِينِ بَنُونُ"],
      ["فَقَدْ كَانَ مَبْعُوثًا وَآدَمُ طِينَةٌ", "نَبِيٌّ لِكُلِّ الْأَنْبِيَاءِ وَمُبِينُ"],
      ["لِمَا أَنْزَلَ الْبَارِي أَتَانَا مُبَيِّنًا", "فَصِيحٌ نَصُوحٌ مُشْفِقٌ وَمُعِينُ"],
      ["جَوَادٌ نَصُوحٌ لَيِّنٌ مُتَوَاضِعٌ", "حَلِيمٌ رَحِيمٌ ذُو صَفًا وَمَتِينُ"],
      ["كَرِيمٌ عَفِيفٌ زَاهِدٌ مُتَمَسِّكٌ", "بِعُرْوَةِ دِينٍ اصْطَفَتْهُ قُرُونُ"],
      ["عَتِيقٌ وَفَارُوقٌ لِدِينٍ شُؤُونُ", "وَعُثْمَانُ ذُو النُّورَيْنِ وَالصَّنْوُ سَيِّدِي"],
      ["عَلِيٌّ أَبُو السِّبْطَيْنِ فَهْوَ مَكِينُ", "وَطَلْحَةُ وَسَعْدٌ وَالزُّبَيْرُ سَعِيدُهُمْ"],
      ["فَهَذَا الدَّهْرُ عَنْ شَأْنِهِ الرِّجَالِ ضَنِينُ", "وَنَجْلُ لِعَوْفٍ قَدْ تَسَامَى إِلَى الْعُلَى"],
      ["وَنَجْلُ جَرَاجٍ لِلْقُرُونِ أَمِينُ", "كَذَا أَهْلُ بَدْرٍ قَبْلَ أُحْدٍ وَخَنْدَقٍ"],
      ["وَفَتْحٍ فَكُلٌّ بِالْمَدِيحِ قَمِينُ", "فَيَا رَبِّ هَبْ لِي بِالْأَمِينِ وَصَحْبِهِ"],
      ["حَيَاةً عَلَى دِينِ الْأَمِينِ دَائِنُ", "وَتَغْلِيلُ أُمُورِي وَاكْفِنِي كُلَّ مَاكِرٍ"],
      ["وَيُعْطِيَنِي مُرَادِي خَالِقِي وَيَعِينُ", "يُقَوِّي بَقِينِي لَا أَرَى نَفْعَ غَيْرِهِ"],
      ["وَلَا ضَرَّهُ عَبْدًا لَدَيْهِ يَصُونُ", "عَلَى الْمُصْطَفَى كُلَّ بَدْءٍ وَمُخْتَمٍ"],
      ["صَلَاةً بِهَا يُخْزِي الْعِدَى وَيَبِينُ", "تَذَكَّرْتُهُ وَالْجِسْمُ يَقْرِي بِكُولَا"],
      ["وَقَلْبِي لَدَى طَهَ الْحَبِيبِ رَهِينُ", "فَمَا لَذَّتِ الْعَيْشُ فِي سِوَى أَرْضِ طَيْبَةٍ"],
      ["بِهَا شَخْصُ خَيْرِ الْعَالَمِينَ دَفِينُ", "فَقَبْرٌ بِهَا سَادَ الْقُبُورَ جَمِيعَهَا"],
      ["وَسَادَ الَّذِي فِيهِ وَقَرَّتْ عُيُونُ", "تَذَكَّرْتُهُ أَفْنَى أُرَاعِي مُفْحَمًا"],
      ["يُنَاجِي إِلَهِي بِالْكِتَابِ يَدِينُ", "تَذَكَّرْتُ وَجْهًا أَخْجَلَ الشَّمْسَ نُورُهُ"],
      ["عَظِيمٌ عَظِيمُ الْخُلْقِ وَهْوَ يَلِينُ", "تَذَكَّرْتُ عَرْفًا أَخْجَلَ الْمِسْكَ نَشْرُهُ"],
      ["بِعَفْرٍ كَبِيرٍ قُلْ لَا تَزَاهُ يَكُونُ", "تَذَكَّرْتُ جُودًا أَخْجَلَ الْوَبْلَ طَلُّهُ"],
      ["فَكُلُّ جَوَادٍ عِنْدَ طَهَ ضَنِينُ", "تَذَكَّرْتُهُ مَا كَانَ فَظًّا وَلَمْ يَكُنْ"],
      ["غَلِيظًا وَيَلْفِيهِ الْبِغَاءُ يَهُونُ", "وَلَمْ يَكُ حَصَّابًا وَدَامَ مُوَقَّرًا"],
      ["عَفُوًّا عَنِ الْجَالِسِ وَهْوَ مَتِينُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["وَآلٍ وَصَحْبٍ مَا اسْتَبَلَّ هَتُونُ"]
    ]
