{
    "id": 9,
    "title": "حرف الراء",
    "huruf": [
      ["أَمِنْ ذِكْرِ خَيْرِ الْخَلْقِ وَهْوَ مُنِيرُ", "سَمَا لَكَ شَوْقٌ لَا تَجِيدُ تَسِيرُ"],
      ["مُحَمَّدُ مُخْتَارُ الْإِلَهِ صَفِيُّهُ", "وَمِنْ عِنْدِهِ قَدْ جَاءَ وَهْوَ بَشِيرُ"],
      ["مُحَمَّدُ مَحْمُودُ الْمَقَامِ مُنِيرٌ", "وَآدَمُ طِينٌ وَالْبَشِيرُ نَذِيرُ"],
      ["كَلَامٌ قَدِيمٌ لَيْسَ حَرْفًا وَإِنَّهُ", "لَوْحِيٌّ وَتَارِي الْعَالَمِينَ مُشِيرُ"],
      ["وَلَا اسْمٌ وَلَا فِعْلٌ يُفَرِّقُ كَلَامَهُ", "عَنِ السَّمْعِ وَالتَّعْبِيرِ وَهْوَ زَبُورُ"],
      ["بَلْ أَمْرٌ مَضَى مُسْتَقْبَلًا كَانَ لَمْ يَكُنْ", "يُضَارِعُ حَيَّ الْغَيْرِ وَهْوَ خَبِيرُ"],
      ["تَلَقَّاهُ خَيْرُ الْغَرْبِ وَهْوَ مُبَيِّنٌ", "بَتَى بُثَّتِ الْإِسْلَامَ وَهْيَ قُصُورُ"],
      ["فَكَسَّرَ أَصْنَامًا بِفَتْحٍ وَخَيْبَرٍ", "إِلَى حِزْبِهِ جَزْمًا وَثَمَّ سُرُورُ"],
      ["فَتَمَّمَ يَرْفَعُ حَقَّهُ بِبِنَانِهِ", "وَآخَرُ مَخْفُوضٌ وَذَاكَ جَزُورُ"],
      ["تَعَرَّفَ فِيهِ الْحَقُّ وَهْوَ مُنَكَّرٌ", "وَهْوَ مُبْتَدَأُ الْكَوْنَيْنِ وَهْوَ أَخِيرُ"],
      ["وَأَسْمَاؤُهُ أَعْلَامُ أَشْخَاصِ عَيْنِهِ", "وَمَهْمَا تَزَافِي فَالرَّسُولُ نَذِيرُ"],
      ["فَإِنَّ بِهِ الْمَوْصُولَ وَهْوَ إِشَارَتِي", "بِهِ وَإِلَيْهِ فَالْمُشِيرُ مُنِيرُ"],
      ["هُوَ الْفَاعِلُ الْمَرْفُوعُ بِالضَّمِّ نَاصِبًا", "عَنِ الْحَضْرَةِ الْعَلْيَاءِ وَهْوَ جَدِيرُ"],
      ["وَقَدْ عَمَّ فِعْلُ الْمُصْطَفَى وَهْوَ شَاسِعٌ", "نَبِيٌّ لِكُلِّ الْأَنْبِيَاءِ سَفِيرُ"],
      ["هُوَ الْحَسَنُ الْوَجْهِ الْجَمِيلِ صِفَاتُهُ", "لَقَدْ خَجِلَتْ إِذْ جَاءَ طَهَ بُدُورُ"],
      ["وَهَيْئَتُهُ تُزْرِي الْحُسُونَ وَكَفُّهُ", "تَفِيضُ مَنَايَا حَاكَ تَدَاهَا بُجُورُ"],
      ["وَقَدْ شَغَلَ الْهَادِي جَمَالُ إِلَهِهِ", "فَلَازَمَهُ طُولَ الزَّمَانِ حُضُورُ"],
      ["فَإِحْسَانُهُ وَالْحُسْنُ فِيهِ تَنَازَعَا", "وَسُبْحَانَ مَنْ مَا شَاءَ عَلَيْهِ قَدِيرُ"],
      ["تَرَى كُلَّ مَفْعُولٍ بِفِعْلِ مُحَمَّدٍ", "وَحَالِي وَتَمْيِيزِي إِلَيْهِ يُشِيرُ"],
      ["أُضِيفُ إِلَيْهِ كُلَّ تَفْصِيلِ مُؤَكِّدٍ", "ذِمَامِي وَعَطْفِي وَالْأَمِينُ مُجِيرُ"],
      ["أُخَاطِبُهُ بِالْمَدْحِ وَهْوَ بِطَلْبَةٍ", "وَشَدِّ اشْتِيَاقٍ وَالدُّمُوعُ غَزِيرُ"],
      ["أُخَاطِبُهُ بِالْمَدْحِ لِأَنَّ لِي مَسَرَّةً", "إِلَيْهِ مَسِيرِي وَالْفُؤَادُ قَرِيرُ"],
      ["أُخَاطِبُهُ بِالْمَدْحِ لِأَنَّ لِي بِكُولَا", "وَقَدْ نَامَ جَارَاتِي وَسُدَّ ثُغُورُ"],
      ["أُخَاطِبُهُ شَوْقًا وَوَجْدًا وَلَوْعَةً", "يَمُوجُ بِهَا يَوْمَ الْتِقَانَا تَمُورُ"],
      ["أُجَاوِرُهُ فِي الْخُلْدِ جَارًا مُقَرَّبًا", "يَؤُمِّنِي وَالْإِثْمُ فِيمَا عَسِيرُ"],
      ["أُجَاوِرُهُ بِالْبَشَرِ وَالْقَلَمِ الَّذِي", "يَكُونُ حِجَابِي وَالسَّعِيرُ تَفُورُ"],
      ["إِلَى كُلِّ مَخْلُوقٍ أَنْتَ مَوَاهِبًا", "وَهَذَا عَبِيدٌ مُذْنِبٌ وَحَقِيرُ"],
      ["وَلَكِنَّهُ جَارٌ مُحِبٌّ وَخَادِمٌ", "بِفَضْلِكَ هَاهُوَ بِالْعَطَاءِ جَدِيرُ"],
      ["وَهَلْ يَسْتَوِي إِلَّا مِنْ سِوَاكَ أَمَادِرٌ", "أَمِ الْبَرْمَكِيُّ أَوْ دُو عَنْوَةٍ أَوْ فَقِيرُ"],
      ["فَسِيَّانِ عِنْدِي ذَانِ لَمْ أَرْجُ غَيْرَهُ", "مَنَالُ حَبِيبِي يَسْتَدِيرُ يُدِيرُ"],
      ["فَجُودُ رَسُولِ اللَّهِ أَحْمَدَ سَيِّدِي", "إِذَا ضَنَّ أَجْوَادُ الْأَنَامِ كَثِيرُ"],
      ["فَمِنْ جُودِهِ الْكَوْنَانِ وَالْعَالَمُ الَّذِي", "تَقَاصَرَ عَنْ حِسٍّ عَنْهُ وَهْوَ كَبِيرُ"],
      ["فَأَمْرٌ تَعَالَى عَنْ خُطُورٍ وَخَاطِرٍ", "وَسُبْحَانَ مَنْ عَبْدٌ لَدَيْهِ بَشِيرُ"],
      ["أَرَى كُلَّ شَيْءٍ مَا خَلَا اللَّهَ بَاطِلًا", "وَمَا النَّصْرُ إِلَّا مِنْهُ وَهْوَ النَّصِيرُ"],
      ["وَإِنَّ حَبِيبَ اللَّهِ طَهَ نَجِيُّهُ", "صَفِيُّ إِلَهِ الْخَلْقِ وَهْوَ وَزِيرُ"],
      ["عَلَيْهِ اخْتِيَارًا أَنْزَلَ الْحَقُّ كَافِدًا", "بَشِيرًا نَذِيرًا صَابِرًا وَشَكُورًا"],
      ["فَجَمْعِي وَتَصْرِيفِي لِحُبِّ مُحَمَّدٍ", "وَفِيهِ بُيُوعِي هَلْ تَرَاهُ يَبُورُ"],
      ["إِذَا عَدَدَ الْأَقْوَامُ يَوْمًا وَفَاخَرُوا", "فَخَارًا فَإِنِّي بِالْأَمِينِ فَخُورُ"],
      ["وَحُبِّي صَحِيحٌ ثَابِتٌ مُتَوَاتِرٌ", "فَقَوْتٌ بِهِ قَاسَاهُ وَهْوَ كَثِيرُ"],
      ["وَبَحْرٌ بَسِيطٌ كَامِلُ الْمَدِّ وَافِرٌ", "وَكَوْنِيَ إِثْبَاتٌ عَلَيْهِ يَسِيرُ"],
      ["بِفَضْلِ إِلَهِ النَّاسِ جَلَّ جَلَالُهُ", "أَنَالُ مَقَامًا مِنْهُ شَابَ صَفِيرُ"],
      ["تُصَوَّرُ حَالَاتُ الْأَمِينِ لِمُزْنِهِ", "وَقَدْ عَمَّ تَصْدِيقِي وَذَاكَ شَهِيرُ"],
      ["فَهَلْ بِعَقِيقٍ لِي مَزَادٌ وَمَنْسَرِحٌ", "أُصَلِّي عَلَى خَيْرِ الْوَرَى وَأَزُورُ"],
      ["سِرَاجٌ مُنِيرٌ بَيَّنَ اللَّهُ أَمْرَهُ", "بِمَوْلِدِهِ إِذْ هَدَّ مَنَّتُهُ قُصُورُ"],
      ["وَقَدْ خَمَّدَ النِّيرَانَ غَازِي عُيُونِهِمْ", "بِطَلْعَتِهِ مَنْ مِنْهُ يَسِيلُ نَهِيرُ"],
      ["وَقَدْ هَتَفَتْ تِلْكَ الْهَوَاتِفُ أَفْضَحَتْ", "بِهَاتِكِ أَنْ قَدْ جَاءَ وَهْوَ نَذِيرُ"],
      ["لَقَدْ جَاءَنَا مِنَّا رَسُولًا لِكُلِّنَا", "رَءُوفًا رَحِيمًا بِالْغَمِيسِ نَسِيرُ"],
      ["تَرَاءَتْ قُصُورُ الرُّومِ عِنْدَ بُرُوزِهِ", "فَطَارَتْ قُلُوبٌ أَوْ تَكَادُ تَطِيرُ"],
      ["وَذَلَّتْ قُضَاةٌ شُغُضِيَاتٌ بِأَنَّهُ", "لِكُلِّ مَخْلُوقٍ أَفِيضَ تَكِيرُ"],
      ["فَلَا شَكَّ لِلْمَاضِي الصِّلَالِ فَإِنَّهُ", "لَهُ جَوْهَرٌ فَرْدٌ حَالَةً يَطِيرُ"],
      ["وَقَدْ كَانَ مَخْصُوصًا وَجَاءَ مُعَمَّمًا", "جَدًا وَنَدًى لِلْمُسْنِتَيْنِ نَسِيرُ"],
      ["أَفَاضَ النَّدَى لِلْكُلِّ أَطْلَقَ سُنَّتَهُ", "ضَعِيفٌ أَتَى سَائِلَهُ وَخَطِيرُ"],
      ["بِغَارِ حِرَاءٍ جَاءَهُ الْوَحْيُ إِذْ عَدَا", "رِيَاضُ جِنَانٍ عِنْدَهُ وَسَعِيرُ"],
      ["فَدَّى لِمَيْنٍ جَاءَ أَمَدَّ قَابِلًا", "أَوَامِرَهُ وَالْبَحْرُ لَيْسَ يَغُورُ"],
      ["وَخَزِيٌّ لِأَصْحَابِ الْأَسْمَالِ لِضَيِّنِهِ", "جَمُولٌ عَصَى الْهَادِي وَمِنْهُ فُجُورُ"],
      ["إِذَا جَادَ بِالْمَعْرُوفِ فَالْكُلُّ غَائِمٌ", "وَيَا وَيْحَ أَهْلِ الشِّرْكِ حِينَ يَغِيرُ"],
      ["فَسَلْ عَنْ حُنَيْنٍ بِعْدَ بَدْرٍ وَسَلْهُمُ", "عَنْ أَهْلِ كِتَابٍ حِينَ خَانَ نَذِيرُ"],
      ["وَخَيْبَرَ وَادِي الْقُرَى وَقُرَيْظَةٍ لَهُ", "وَمَكَّةَ إِذْ خَيْلُ الرَّسُولِ تُثِيرُ"],
      ["حَجُونٌ تَبَدَّى فِيهِ خَيْلُ مُحَمَّدٍ", "لِوَاءُ أَمِينِ اللَّهِ فَوْقَ يَطِيرُ"],
      ["فَقَدْ وَطِئَ الْمَاضِي رِقَابَ أُشْتَائِهِ", "وَافَى إِلَى الْبَطْحَاءِ وَهْوَ وَقُورُ"],
      ["بِجَالُ قُرَيْشٍ تَحْتَ ظِلِّ سُيُوفِهِ", "فَأَغْضَى وَلَا تَثْبِيبَ قَالَ صَبُورُ"],
      ["وَقَدْ فَرَّ صَفْوَانٌ وَبَاتَ مُعَرَّبًا", "وَقَدْ لَانَ صَفْحًا إِذْ تَلَيْهُ نُصُورُ"],
      ["وَكُسِّرَتِ الْأَصْنَامُ حِينَ تَنَاثَرَتْ", "وَقَدْ سُمِعَ التَّكْبِيرُ تَمَّ حُبُورُ"],
      ["وَتَائِلَةٌ تَغْوِي أَسَافَ مُدَمَّرٌ", "كَذَا هُبَلُ الْمُحْزَى دَعَاهَا تُبُورُ"],
      ["قُلِ الْحَقُّ جَاءَ وَهْوَ دِينُ مُحَمَّدٍ", "وَمَلِكٌ أَبَى أَنْ يَتَّقِيهِ حَقِيرُ"],
      ["قَدِ اهْتَزَّ بَيْتُ اللَّهِ إِذْ طَافَ آمِنًا", "بِهِ حَاشِرٌ وَالْقَلْبُ تَمَّ قَرِيرُ"],
      ["وَأَبْطَلَ أَحْكَامَ الْجَهَالَةِ نَاصِبًا", "شَرِيعَتَهُ الْغَرَّاءَ وَالْعَدْلُ يَسِيرُ"],
      ["يَحْفَظُ دِمَاءً بِالصِّيَانَةِ دَائِمًا", "لِعِرْضٍ وَمَالٍ مَا اسْتَمَرَّ دُهُورُ"],
      ["وَأَكْرَمُ وَالْحَمْدُ لِلَّهِ وَحْدَهُ", "صَلَاةٌ عَلَى هَادِي الْخَلَائِقِ نُورُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "خَفِيرِي حَبِيبُ اللَّهِ وَهْوَ خَفِيرُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ عَلَى الْهَادِي إِلَيْهِ شَكُورُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "حَبِيبِي مَنْصُورٌ وَغَيْرِي يَبُورُ"]
    ]
  }