{
    "id": 15,
    "title": "حرف العين",
    "huruf": [
      ["غَبِيصٌ مِنْ مَعْرُوفِ الْقَلْبِ مُولَعٌ", "قَرِيبٌ مِنَ الْمَحْبُوبِ بِالْبُعْدِ مُوسِعِ"],
      ["وَذَلِكَ إِبْرَاهِيمُ يَهْوَى مُحَمَّدًا", "وَأَمْرَ وُجُودِ الْكَوْنِ غَيْرُ مُوَقَّعِ"],
      ["وَلَا زَالَ يَشْكُو الْبَيْنَ وَالْحَالُ إِنَّهُ", "حَبِيبِي مَعِي فِي الْبَيْتِ أَوْ وَسْطَ بَلْقَعِ"],
      ["إِذَا لَاحَ بَرْقٌ شَوْقَهُ الْقَلْبَ أَوْ حَدَا", "لَهُ مُطْرِبٌ كَالْحَمَامِ الْمُسَجَّعِ"],
      ["تَزَافِي وَإِنِّي غَائِبٌ فِيهِ حَاضِرٌ", "أُحَاكِي زُفُودًا سَاهِرًا فَوْقَ مَضْجَعِي"],
      ["فَدَافِي الَّذِي أَعْنِي أَلَا إِنَّ فِصَالَ مَنْ", "يُوَاصِلُنِي فِي كُلِّ تَنْحَى وَمَزْبَعِ"],
      ["فَيَكْفِيَكَ مَا سَلْبَائِنِي غِيدُهَا", "فَقُرُّ الْمَعَالِي آخِذَاتٌ بِمُجْمَعِي"],
      ["مُوَاجَهَةُ الْهَادِي وَشِبْهُ أَرِيحَاءَ", "وَفَهْمِيَ الْبَذِّي يُوحِي وَيُلْقَى لِمُسْمَعِي"],
      ["كَذَا رَفْعُ ذَاتِ الْخَيْفَةِ مُغْلِقًا", "بِإِطْلَالِ آزَالٍ كَرِدْنَالِ الْمُضَيَّعِ"],
      ["أَرِيلُ خِلَافًا يَيِّنُ قَوْمَ مُحَمَّدٍ", "فَنَرْكُضُ نَحْوَ التَّوْحِيدِ مِنْ كُلِّ مَوْضِعِ"],
      ["فَنَمْشِي عَلَى نَهْجِ الْأَمِينِ سَوِيَّةً", "نُتَابِعُهُ فَالْكُلُّ جِدُّ مُتَّبَعِ"],
      ["فَإِنْ عَزَّ لُقْيَاهَا فَإِنَّ الْقُدَامَ دَائِمًا", "عَلَى سُنَّةِ الْهَادِي عَلَى خَيْرِ مَهْيَعِ"],
      ["نُصَلِّي كَمَا كَانَ النَّبِيُّ مُصَلِّيًا", "نَصُومُ كَذَا نَطْغُو سَبِيلًا مُتَبَّعَا"],
      ["وَنُنْفِقُ لَا نُبْقِي نُرِيدُ صِرَاطَهُ", "نَحُجُّ كَحَجِّ الْهَاشِمِيِّ الْمُتَبَّعِ"],
      ["نُكَرِّرُ حَفَّا لَا إِلَهَ سِوَى الَّذِي", "لَهُ الْخَلْقُ وَالْأَمْرُ الْعَظِيمُ الْمُتَمَنِّعِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبِ الْهَاشِمِيِّ الْمُشَرَّعِ"]
    ]
  }