{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["فَمَا لِي غَيْرُ الْمُصْطَفَى الْبَدْرِ مَأْوَبُ", "وَفِي جَائِزَاتِ الْغَيْرِ مَا لِي مَرْغَبُ"],
      ["هُوَ الْكُلُّ مِنْهُ الْكُلُّ بَطْنًا وَظَاهِرًا", "فَبَاطِلٌ سِوَاهُ مَا لَنَا فِيهِ مَشْرَبُ"],
      ["فَمِنْ نُورِهِ الْكَوْنَانِ مِنْهُ تَفَجَّرَتْ", "عُلُومُ جَمِيعِ الرُّسُلِ وَالْكُلُّ يَشْرَبُ"],
      ["فَمُوسَى وَإِبْرَاهِيمُ وَالرُّوحُ كُلُّهُمْ", "تَوَسَّلَ بِالْهَادِي الْأَمِينِ فَقُرِّبُوا"],
      ["هُوَ الْكَامِلُ الْمَحْمُودُ وَالرَّسُولُ وَالْمُنَى", "وَأَنْتَ الْحَبِيبُ الْمُصْطَفَى وَالْمُقَرَّبُ"],
      ["وَقَدْ شَهِدَ اللَّهُ الْعَظِيمُ بِأَنَّهُ", "عَظِيمٌ لِخَيْرِ الْخَلْقِ خُلُقٌ مُهَذَّبُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا يَتَقَاضَى لِلْعَبْدِ مَطْلَبُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ فِي كُلِّ طَرْفَةٍ", "كَذَاكَ سَلَامٌ مِثْلَ مَا سُلِّيَ أَوْ أَطْيَبُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً لَنَا كُلَّ الْمَقَامَاتِ تَجْلِبُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالْأَصْحَابِ دَهْرًا تَقَرَّبُوا"]
    ]
  }