{
    "id": 30,
    "title": "حرف الم اللألف",
    "huruf": [
      ["تَجَدَّدَ بِحَمْدِ اللَّهِ طَهَ خَلِيلَا", "وَلَمْ أَتَّخِذْ غَيْرَ الرَّسُولِ سَبِيلَا"],
      ["وَلَمْ أَرْجُ مَخْلُوقًا سِوَاهُ لَعَلَّهُ", "إِذَا مَا جَفَا جَافٍ يَكُونُ خَلِيلَا"],
      ["فَإِنَّ مَعَ الْعَالَاتِ حِبًّا وَخَادِمًا", "وَلَسْتُ أَرَى غَيْرَ الْحَبِيبِ جَمِيلَا"],
      ["وَمَا لِي إِذَا مَا حَلَّ خَطْبٌ سِوَاهُ", "فَظِلُّ رَسُولِ اللَّهِ كَانَ ظَلِيلَا"],
      ["أُنَادِيهِ يَا طَهَ الْأَمِينُ فَإِنَّنِي", "خَلِيفُ أَسًى مَا إِنْ وَجَدْتُ سَبِيلَا"],
      ["فَقَدْ شَدَّ فَقْرِي وَاغْتِرَابِي فَدُلَّنِي", "وَأَوْلِنِي سِوَى الْهَادِي الْكَرِيمِ بَخِيلَا"],
      ["فَكُنْ لِي فِي الْأَحْلَى كُنْ لِي بِغَيْثِي", "وَكُنْ وَزَرِي إِنَّنِي أَرَاكَ جَلِيلَا"],
      ["فَإِنْ لَمْ تُدَارِكْنِي فِي شُؤُونِي بِعَطْفَةٍ", "وَحَاشَاكَ مَا لِي مِنْ سِوَاكَ وَكِيلَا"],
      ["فَأَسْبِلْ عَلَيْنَا ذَيْلَ سِتْرٍ وَعَطْفَةٍ", "وَأَسْدِ إِلَيْنَا مِنْ عَطَاكَ جَزِيلَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْكِرَامِ عَدُوْلَا"]
    ]
  }