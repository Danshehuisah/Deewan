{
    "id": 10,
    "title": "حرف الراء",
    "huruf": [
      ["جَعَلْتُكَ يَا خَيْرَ الْأَنَامِ سَفِيرَا", "وَكُلُّ زَمَانٍ قَدْ أَرَاكَ مُجِيرَا"],
      ["بِكَوْنِكَ رِزْقُ الْخَلْقِ طُرًّا وَخَيْرُهُ", "وَغَيْرُكَ لَمْ يَلْقَوْا لَدَيْهِ نَصِيرَا"],
      ["فَأَنْتَ حَبِيبُ اللَّهِ وَالْمَلْكُ مُلْكُهُ", "أَرَاكَ أَمِيرًا لِلْإِلَهِ وَزِيرَا"],
      ["فَتَرْحَمُ هَذَا الْعَبْدَ بِالْحَقِّ لَائِذًا", "فَلَمْ يَكُ يُحْشَى مِنْ سِوَاكَ أَمِيرَا"],
      ["يَزِيدُ أَمَانِي مَدْعَكَ ثُمَّ بِتَابِهِ", "رُعُودَ عَدُوٍّ إِذْ أَرَاهُ حَسِيرَا"],
      ["فَهَلْ يَخْشَعُ الْيَوْمَ لَدَى كَبِدِ السَّمَا", "نُبَاحًا لِمَعْقُولِ الْكِلَابِ ضَرِيرَا"],
      ["فَحُبُّ رَسُولِ اللَّهِ عِصْمَةُ وَرَاحَةٌ", "وَحِصْنٌ أَرَاهُ لِلْمُحِبِّ مَصِيرَا"],
      ["تَحُدُّ وَدَادَ الْمُصْطَفَى وَمَدِيحَهُ", "جَوَادِي وَسَيْفِي وَالْقَنَا وَخَفِيرَا"],
      ["وَرَدْءُ الْجُيُوشِ الرَّادُ الْمُبَلِّغُ لِلْمُنَى", "وَذَاكَ لَعَمْرُ اللَّهِ نِعْمَ نَصِيرَا"],
      ["وَهُوَ خَاتِمٌ لِلرُّسْلِ وَهْوَ إِمَامُهُمْ", "فَأَوَّلُ بَلْ آخِرُ الرُّسْلِ جَاءَ أَخِيرَا"],
      ["وَبَاطِنُهُمْ حَقًّا وَذَلِكَ ظَاهِرٌ", "فَجَاءَ بَشِيرًا لِلْمُنُوعِ نَذِيرَا"],
      ["فَأَلْزَمْتُ لَا أَنْفَكُّ أَنْسِجُ مَدْحَهُ", "وَكُنْتُ لِشُرْبِ الْعَاشِقِينَ مُدِيرَا"],
      ["فَأَسْقَيْتُهُمْ نَهْلًا وَعَلًّا وَدَادَهُ", "وَبَذْلُ مُدَامِ الْغَافِلِينَ حَقِيرَا"],
      ["سَكَارَى بِلَا إِثْمٍ وَغَوْلٍ فَإِنَّهُمْ", "صَفَا وَقْتُهُمْ وَالْمُلْكُ كَانَ كَبِيرَا"],
      ["بِمَقْعَدِ صِدْقٍ جَالِسِينَ جَلِيسُهُمْ", "مَلِيكُ جُمُوعِ الْمَالِكِينَ قَدِيرَا"],
      ["يَسِيرُونَ سَيْرًا فِي الْمَجَالِسِ فَاعْجَبَنْ", "لِسَتْرِ جُلُوسٍ يُشْبِهُونَ صُحُونَا"],
      ["وَقَدْ رَتَّعُوا فِي تِلْكَ رَوْضٍ مَغَارِفٍ", "تَرَاهُمْ سُكُوتًا وَالْمَقَامُ مُشِيرَا"],
      ["كَلَامٌ قَدِيمٌ لَا يُمَلُّ سَمَاعُهُ", "يَكُونُ عَلَى الْجَمْعِ الْقَدِيمِ خُمُورَا"],
      ["خَدِيمُكَ هَذَا أَسْقِهِ كُلَّ بُرْهَةٍ", "وَأَحْيِ بِهِ طُولَ الزَّمَانِ قُبُورَا"],
      ["خَدِيمُكَ مَلْكُ الْمُلُوكِ وَأَمْرِهَا", "خَدِيمُكَ مَخْدُومُ الْمُلُوكِ أَمِيرَا"],
      ["مُطَاعٌ أَمِينٌ فِي الْعَوَالِي كُلِّهَا", "فَيُرْشِدُهُمْ نَحْوَ الْإِلَهِ تَصِيرَا"],
      ["رَجَائِي وَظَنِّي فِي الْحَبِيبِ وَحِبِّهِ", "كَبِيرٌ أَلْقَاهُ كَبِيرٌ كَبِيرَا"],
      ["بِجَاهِ عَظِيمِ الْجَاهِ أَحْمَدَ سَيِّدِي", "وَمَنْ هَاجَرُوا أَوْ مَنْ رَآهُ نَصِيرَا"],
      ["عَلَيْهِ صَلَاةً إِذْ يَفِيضُ جَنَاهَا", "تَفُوحُ لِمَنْ قَدْ كَانَ مِنْكَ عَشِيرَا"]
    ]
  }