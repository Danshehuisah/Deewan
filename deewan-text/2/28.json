{
    "id": 28,
    "title": "حرف الياء",
    "huruf": [
      ["زَمَانِي لَا أَنْفَكُّ أَهْدِي الْقَوَافِيَا", "لِمَنْ قَدْ صَفَا لِلْحَقِّ بِالْحَقِّ وَافِيَا"],
      ["أُجَالِسُهُ دَهْرِي بِرُوحِي وَرُوحِهِ", "وَهَلْ مَجْلِسُ الْأَشْبَاحِ قَدْ حَانَ تَالِيَا"],
      ["أَرَانِي إِذَا وَافَيْتُ أَحْمَدَ زَائِرًا", "سَأَقْضِي لُبَانَاتِ الْفُؤَادِ مَثَالِيَا"],
      ["فَشَدَّ لِذَاكَ الْعَزْمَ وَارْتَحَلَ شَمْلَةً", "قَطَعْتُ بِهِ بَطْحَاءَ مَا كَانَ قَاصِيَا"],
      ["فَقَدْ زَادَنِي شَوْقًا وَحُبًّا لِقَدْرِهِ", "فَتَبْكِي بِمَا تُرْوِي الْمَرَاوِي الْبَوَاكِيَا"],
      ["سَلَامٌ عَلَى رَوْضِ الْحَبِيبِ وَبَعْدَهُ", "سَلَامٌ عَلَى رَوْضِ الَّذِي كَانَ ثَانِيَا"],
      ["سَلَامٌ عَلَى رَوْضِ الشَّهِيدِ سِرَاجِنَا", "سَلَامٌ عَلَى الْأَحْبَابِ حَازُوا الْمَعَالِيَا"],
      ["سَلَامٌ عَلَى زَوْجِ الْبَتُولِ وَزَوْجِهَا", "وَثَالِثِ أَرْكَانِ الْخِلَافَةِ سَامِيَا"],
      ["سَلَامٌ عَلَى أَهْلِ الْبَقِيعِ جَمِيعِهِمْ", "يُحَيِّيهِمُ تَيْمٌ بِأَسْرِكَ ثَانِيَا"],
      ["رِيَاضٌ أَرِيضَةٌ دِيَارُ أَحِبَّتِي", "وَأَذْكَتْ نِيَارَ الشَّوْقِ لِلْقَلْبِ صَالِيَا"],
      ["وَوَقَّى اللَّهُ سُفُنًا بَلَّغَتْنِي بِلَادَهُمْ", "بِعَامِي فَدَتْهَا النُّوقُ تَمْأَلُ السَّوَاقِيَا"],
      ["مُحَمَّدُ يَاسِينُ وَأَحْمَدُ حَاشِرٌ", "وَعَاقِبُ وَالْهَادِي نَفَى الْكُفْرَ مَاحِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ مِنْ كُلِّ ذَرَّةٍ", "كَذَاكَ سَلَامٌ لِلصَّلَاةِ مُحَاكِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ فِي كُلِّ لَحْظَةٍ", "عَدِيدَ أَسَامِي الْإِسْمِ إِذْ كَانَ عَالِيَا"],
      ["عَلَيْكَ صَلَاةٌ مِنْكَ نَحْوَكَ سَيِّدِي", "كَذَاكَ سَلَامٌ لِلصَّلَاةِ مُسَاوِيَا"],
      ["عَلَيْكَ صَلَاةُ الْغَيْبِ بِالْغَيْبِ دَائِمًا", "كَذَاكَ سَلَامٌ لِلصَّلَاةِ مُجَارِيَا"],
      ["وَصَلَّى عَلَيْهِ غَيْبُ غَيْبٍ بِغَيْبِهِ", "وَأَسْرَارِهِ سِرًّا وَجَهْرًا وَخَافِيَا"],
      ["وَصَلَّى جَمِيعُ الْكَائِنَاتِ بِأَسْرِهَا", "عَلَى أَحْمَدَ الْمَحْمُودِ مَنْ جَاءَ هَادِيَا"],
      ["وَآلٍ وَأَصْحَابٍ مَدَى قَوْلِ خَادِمٍ", "زَمَانٍ لَا أَنْفَكُّ أَهْدِي الْقَوَافِيَا"]
    ]
  }