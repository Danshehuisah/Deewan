{
    "id": 28,
    "title": "حرف الهاء",
    "huruf": [
      ["سَلَامٌ عَلَى طَهَ الْأَمِينِ الْوَجِيهِ", "لَدَى الْحَضْرَةِ الْعَلْيَا النَّزِيهِ النَّبِيهِ"],
      ["سَلَامٌ عَلَيْهِ مِنْ خَدِيمٍ مُتَيَّمٍ", "بِحُسْنِ مُحَيًا مَا لَهُ مِنْ شَبِيهِ"],
      ["مُحَيًّا بِهِ شَمْسُ النَّهَارِ قَدَ اشْرَقَتْ", "يَفُوذُ خَدِيمٌ قَدْ تَأَمَّلَ فِيهِ"],
      ["عَلَى أَحْمَدٍ خَيْرِ الْوَرَى حَقَّ قَدْرِهِ", "صَلَاةٌ وَتَسْلِيمٌ عَدِيدَ سِنِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُبَعِّدُ أَعْدَائِي وَكُلَّ سَفِيهِ"],
      ["فَهُوَّ سِلَاحِى وَهْوَ سَيْفِي وَمِغْفَرِي", "بِهِ رُدُّ عَنِّي مَكْرَ كُلِّ فَقِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَشْفَعُ فِينَا فَهْوَ خَيْرُ وَجِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَصْطَفِينِي فَوْقَ كُلِّ نَزِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَءَالٍ وَأَصْحَابٍ وَكُلِّ ذَوِيهِ"],
      ["عَلَيْهِ مِنَ الْعَبْدِ الْخَدِيمِ تَحِيَّةٌ", "تَفُوقُ تَحَايَا الْكُلِّ فُوْهُ لِفِيهِ"]
    ]
  }