{
    "id": 23,
    "title": "حرف الكاف",
    "huruf": [
      ["حَمَامَةَ وَادِي الدَّوِّ وَيْلَكِ مَا لَكِ", "فَقَدْ هِجْتِ لِي تَذْكَارَ نَجْلِ الْعَوَاتِكِ"],
      ["سَلَامٌ عَلَى قَبْرِ الْأَمِينِ الْمُبَارَكِ", "فَكَنْزٌ لِإِحْيَاءٍ وَذُخْرُ الْهَوَالِكِ"],
      ["سَلَامٌ عَلَى فَخْرٍ لِنَصْرٍ وَمَالِكٍ", "وَغُنْيَةُ أَيْتَامٍ وَمَأْوَى الْمَمَالِكِ"],
      ["سَلَامٌ عَلَيْهِ مِنْ خَدِيمٍ مُتَيَّمٍ", "يُبَشِّرُهُ مِنْ كُلِّ حَاكٍ وَحَائِكِ"],
      ["فَإِنْ يَكُ جُثْمَانِى بِسِنْغَالَ إِنَّنِي", "بِرُوحِي لَدَى ذَاكَ الْحَبِيبِ الْمُبَارَكِ"],
      ["أَحَضْرَةَ خَيْرَ الْخَلْقِ حَضْرَةَ سَيِّدِي", "وَيَا حَضْرَةَ الْمُخْتَارِ مُبْدِي الْمَنَاسِكِ"],
      ["أُحِبُّكُ حُبًّا تَامَ قَلْبِي وَقَادَهُ", "وَمَا ذَا عَلَيَّ فِي امْتِدَاحِ جَنَابِكِ"],
      ["فَئَايُكِ لَا تَنْهَى وَقَدْرُكِ فَوْقَهَا", "وَمِقْدَارُكِ السَّامِي الْعَلِى فَوْقَ ذَالِكِ"],
      ["فَأَنْتَ حَبِيبُ اللَّهِ جَلَّ جَلَالُهُ", "وَأَوْلَاكَ مَا أَوْلَاكَ غَيْرَ مُشَارَكِ"],
      ["سَرَى بِكَ لَيْلًا ثُمَّ أَدْنَاكَ جَاذِيًا", "وَفُزْتَ بِسِرٍّ فَاتَ خَاطِرَ سَالِكِ"],
      ["خَرَجْتَ مِنَ الْأَكْوَانِ وَالسِّرِّ سَامِيًا", "وَفُتَّ اغْتِلَاءً كُلِّ حَيٍّ وَهَالِكِ"],
      ["وَغِبْتَ عَنِ الْمَكْنُونِ وَالْغَيْبِ رَاقِيًا", "وَفُتَّ لَعَمْرِي كُلَّ دَارٍ وَدَارِكِ"],
      ["أَيَا حَيُّ يَا قَيُّومُ يَا رَبِّ هَبْ لَنَا", "نَصِيبًا مِنَ السِّرِّ الْعَزِيزِ الْمُدَارِكِ"],
      ["وَتَجْعَلُنِي دَهْرِي خَدِيمَ جَنَابِهِ", "بِنَفْسِي وَرُوحِي مُخْلِصًا عِنْدَ مَالِكِي"],
      ["أَرَانِيَ عَبْدًا سَاءَهُ سُوءُ حَالِهِ", "فَلَمْ يَكُ يَرْجُواْ غَيْرَ مَحْضِ تَدَارُكِ"],
      ["يَظَنُّونَ بِي خَيْرًا وَلَا خَيْرَ إِنَّمَا", "رَأَوْا حَضْرَةَ الْمَحْبُوبِ سِتْرَ جَمَالِكِ"],
      ["فَلَا تَفْضَحَنْ يَوْمَ الْوُقُوفِ مُقَصِّرًا", "وَكُنْ لِيَ يَا مَوْلَايَ مَنْجَي الْمَمَالِكِ"],
      ["فَقَدْ ضَاعَ عُمْرِي وَالسَّفَاهَةُ كَاسْمِهَا", "فَهَلْ مِنْ شَفِيعٍ فِي وَهَلْ مِنْ مُدَارِكِ"],
      ["وَضَيَّعْتُ عُمْرِي فِي التَّكَاسُلِ وَالْوَنَى", "فَوَيْلَكِ هَاذِي النَّفْسُ أَعْظِمْ بِدَآئِكِ"],
      ["وَصَفْتِ لِمَرْضِي النَّاسِ كُلَّ دَوَآئِهِمْ", "فَوَيْلَكِ شَرَّ النَّفْسِ مَنْ لِدَوَائِكِ"],
      ["فَئَاهٍ لِإِبْرَاهِيمَ إِنْ دَامَ هَاكَذَا", "فَئَاهٍ لِإِبْرَاهِيمَ إِنْ لَمْ تُدَارِكِ"],
      ["عَلَى أَنَّهُ مِنْ حُسْنِ ظَنٍّ لِرَبِّهِ", "لَيَرْجُواْ مَنَالًا فَوْقَ كُلِّ سَوَالِكِ"],
      ["وَيَشْهَدُ لِلْمَوْلَى الْعَظِيمَ امْتِنَانِهِ", "بِتَفْوِيضِ أَمْرٍ لِلْعَظِيمِ التَّدَارِكِ"],
      ["بِحُبِّ رَسُولِ اللَّهِ حَقًّا وَذِكْرِهِ", "عَلَيْهِ صَلَاةُ اللَّهِ رَبِّ الْمَلَائِكِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ فِي كُلِّ لَحْظَةٍ", "وَآلٍ وَصَحْبٍ وَالْمُقِيمِي الْمَنَاسِكِ"]
    ]
  }