{
    "id": 23,
    "title": "حرف اللام",
    "huruf": [
      ["وُفِّقْتُ بِرَبٍّ جَادَ لِي بِالْمَأْمَلِ", "وَسَرَّحَ طَرْفِي فِي جَمَالِ الْمُرْتَجِي"],
      ["أَحَبُّ طَرِيقَ يَا مُتَدَاحٍ نَبِيَّنَا", "لِكُلِّ فَصِيحٍ مَنْ بَلِيغٍ مُزْجِي"],
      ["وَأُسْبِغُهُ بِالصِّدْقِ مَقْصُورَ هِمَّةٍ", "يَأْشَاءُ مَدْحٍ مُوصَلٍ لَمْ يُقَصَّرِ"],
      ["وَأُوجِزْتُ لَوْ أَطْنَبْتُ فِي حَقِّ سَيِّدِي", "فَرِيدٍ عَدِيسِ الْمُنْتَهَى خَيْرُ مُؤْمَنِ"],
      ["فَبَحْرُ بَسِيطٍ كَامِلُ الْمَدِّ وَافِرٌ", "طَوِيلٌ عُبَابٌ مَدُّ طَهَ الْمُفَضَّلِ"],
      ["أَحَبُّ مَدِيحًا صَحَّ مُتْنًا مُسَلَّمًا", "لِأَحْسَنِ مَمْدُوحٍ وَأَفْضَلِ مُرْسَلِ"],
      ["تَوَاتَرَ قَطْعًا أَنَّ طَهَ مُحَمَّدًا", "إِمَامُ جَمِيعِ الرُّسْلِ خَيْرُ مُكَمَّلِ"],
      ["وَهُوَ فَاتِحِي وَالْخَتْمُ أَحْمَدُ نَاصِرِي", "هَدَانِي إِلَى ذَاكَ الْجَمَالِ الْمُجَمَّلِ"],
      ["أُحِبُّ وَرَبِّ الْبَيْتِ أَحْمَدَ سَيِّدِي", "وَزِينَةَ نَفْسِي وَهْوَ كَهْفِي وَمَأْمَلِي"],
      ["وَمَنْ ذَا الَّذِي يَشْفِي مِنَ الْحُبِّ وَهْوَ فِي", "حَبِيبِ إِلَهِ الْعَالَمِينَ الْمُبَجَّلِ"],
      ["لَهُ خُطَّتَا لَوْلَاكَ أَسْلُفْ تَفْدَهُ", "يُشَفَّعُ وَعَمْرِي ذَاكَ أَرْفَعُ مَنْزِلِ"],
      ["وَحَازَ لِوَاءَ الْحَمْدِ وَالْفَخْرِ سَيِّدًا", "لِلْآبَاءِ وَالْآبَاءِ أَفْضَلُ مَأْمَلِ"],
      ["فَبُرْهَانُ هَذَا الْعَبْدِ فِيهِ تَشَفُّعِي", "وَفِي صَحْبِهِ فِي عَاجِلٍ وَمُؤَجَّلِ"],
      ["فَبُرْهَانُ هَذَا الْعَبْدِ فِيهِ تَشَفُّعِي", "فَلَمْ يَزِدْ غَيْرَ الْمُصْطَفَى مِنْ مُؤَمَّلِ"],
      ["وَصَلِّ أَيَا مَوْلَايَ مِقْدَارَ قَدْرِهِ", "عَلَى مَنْ هَدَانِي لِلْجَمِيلِ الْمُجَلِّي"],
      ["وَصَلِّ أَيَا مَوْلَايَ مِقْدَارَ قَدْرِهِ", "عَلَى مَنْ هَدَانِي لِلْكَمَالِ الْمُكَمَّلِ"],
      ["وَآلٍ وَأَصْحَابٍ كِرَامٍ أَمَاجِدٍ", "وَمَنْ سَلَكُوا نَهْجَ الْأَمِينِ الْمُرَمَّلِ"]
    ]
  }