{
    "id": 17,
    "title": "حرف الطاء",
    "huruf": [
      ["ثَقِفْتُ اعْوِجَاجَ الْخَلْقِ وَالْكُلُّ يَغْبِطُ", "مَقَامِي لَدَى الْمَاحِي وَبِالْفَيْضِ يَبْسُطُ"],
      ["فَهُو صِفَةٌ وَاسْمٌ وَذَاتٌ وَغَيْبُهَا", "وَهُو قَاسِمٌ عَدْلٌ كَرِيمٌ وَمُقْسِطُ"],
      ["تَنَوَّرْثُهُ فِي حَالَتَيْهِ فَهَالَنِي", "كَمَالُ جَمَالٍ لِلْمَدِيحِ يُنَشِّطُ"],
      ["أُنَادِيهِ يَا طَاهَ الْأَمِينُ وَعَاقِبُ", "وَحَاشِرُ وَالْهَادِي وَأَحْمَدُ أَخْبِطُ"],
      ["مُحَمَّدُ يَاسِينٌ وَحَامِدُ مُصْطَفًى", "كَرِيمُ السَّجَايَا وَصْفُهُ لَيْسَ يُضْبَطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَرْتَقِي مَنْ كَانَ مِنْ قَبْلُ فَرَّطُوا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَقْتَنِي مَا لَا يُشَابُ فَيُخْبَطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَسْبِقُ الْأَقْطَابَ طُرًّا وَأَفْرُطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تَرَبِّى السَّامِعِينَ وَتُنْشِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الَّذِينَ قَدُ اغْبِطُوا"]
    ]
  }