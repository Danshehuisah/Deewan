{
    "id": 17,
    "title": "حرف الظاء",
    "huruf": [
      ["ظَفِرْتُ بِسِرٍّ قَبْلَنَا لَيْسَ يُحْفَظُ", "فَبَحْرُ رَسُولِ اللَّهِ بِالسِّرِّ يَلْفِظُ"],
      ["وَقَدْ عَلِمَ الْأَقْوَامُ أَنِّي خَدِيدُهُ", "مُتَّبِعٌ شَوْقًا وَدَّهُ الدَّهْرَ أَحْفَظُ"],
      ["شُغِفْتُ بِحُبِّ الْهَاشِمِيِّ وَإِنَّنِي", "أُخَالُ سَفِيهًا مَنْ سِوَاهُ يُقَرِّظُ"],
      ["فَلَيْسَ كَرِيمٌ يُرْتَجَى غَيْرُ أَحْمَدَ", "وَلَيْسَ مَلِيكًا مَا سِوَاهُ يُلَفِّظُ"],
      ["وَمَاذَا عَلَى بُرْهَامَ هَامَ بِحُبِّهِ", "كَرِيمٌ جَمِيلُ الْخُلْقِ مَا قَطُّ يُغْلِظُ"],
      ["فَلَيْسَ عَلَيَّ اللَّوْمُ فِي ذِكْرِ وَصْفِهِ", "وَإِنْ كُنْتُ لَا أَعْدُو فَتَيْلَا أُقَرِّظُ"],
      ["فَذِكْرِي لَهُ إِكْسِيرُ كُلِّ سَعَادَةٍ", "عَلَيْهِ صَلَاهُ آخِرَ الدَّهْرِ تُحْفَظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَرْتَقِي فِي الْحُبِّ وَالْمَدْحَ أَحْفَظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأَبْقَى خَدِيمًا بِالنَّدَى أَتَلَفَّظُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ مَدَى الدَّهْرِ تُحْفَظُ"]
    ]
  }