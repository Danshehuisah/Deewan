{
    "id": 1,
    "title": "حرف الهمزة",
    "huruf": [
      ["قَلِيلُ وِدَادِ الْعَبْدِ فِيكَ صَفَآءُ", "وَمَدْحُكَ مِنْ دَآءِ الْقُلُوبِ شِفَآءُ"],
      ["وَذِكْرُكَ يَا خَيْرَ الْأَنَامِ غَنِيمَةٌ", "وَلِلْمُبْتَغِى الْعُلْيَا سَنًا وَسَنَآءُ"],
      ["فَإِنَّكَ يَا يَاسِينُ طَاهَ مُحَمَّدٌ", "أَتَاكَ مِنَ الْمَوْلَى الْجَلِيلِ ثَنَآءُ"],
      ["وَقَدْ خَضَعَ الْعَرْشُ الْمَجِيدُ لِوَطْأَةٍ", "فَإِنَّكَ فَوْقَ الْكَآئِنَاتِ سَمَآءُ"],
      ["وَصَلَّتْ بِكَ الْأَرْسَالُ وَالْكُلُّ خَادِمٌ", "مِنَ الْحَضْرَةِ الْعَلْيَا أَتَاهُ عَلَآءُ"],
      ["خَدِيمُكَ إِبْرَاهِيمُ يَطْمَعُ فِيكَ يَا", "كَرِيمًا بِهِ لِلْأَنْبِيَاءِ عَطَآءُ"],
      ["وَأَنْتَ مُحِيطٌ بِالشُّؤُونِ فَلَا أَرَى", "أَنَصُّ عَلَى الْحَاجَاتِ مِنْكَ غِنَآءُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا يَنْفَكُّ عَنْهُ غِطَآءُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَنْجَلِي الظَّلْمَا وَنِيلَ حِبَآءُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ طُرًّا مَنْ حَوَتْهُ عَبَآءُ"]
    ]
  }