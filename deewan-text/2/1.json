{
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["قَلِيلُ وِدَادِ الْعَبْدِ فِيكَ صَفَاءُ", "وَمَدْحُكَ مِنْ دَاءِ الْقُلُوبِ شِفَاءُ"],
      ["وَذِكْرُكَ يَا خَيْرَ الْأَنَامِ غَنِيمَةٌ", "وَلِلْمُبْتَنَى الْعَلْيَاءِ سَنًا وَسَنَاءُ"],
      ["فَإِنَّكَ يَا يَاسِينَ طَهَ مُحَمَّدٌ", "أَتَاكَ مِنَ الْمَوْلَى الْجَلِيلِ ثَنَاءُ"],
      ["وَقَدْ خَضَعَ الْعَرْشُ الْمَجِيدُ لِوَطْأَةٍ", "فَإِنَّكَ فَوْقَ الْكَائِنَاتِ سَمَاءُ"],
      ["وَصَلَّتْ بِكَ الْأَرْسَالُ وَالْكُلُّ خَادِمٌ", "مِنَ الْحَضْرَةِ الْعَلْيَاءِ أَنَّى لَهُ عَلَاءُ"],
      ["خَدِيمُكَ إِبْرَاهِيمُ يَطْمَعُ فِيكَ يَا", "كَرِيمًا بِهِ لِلْأَنْبِيَاءِ عَطَاءُ"],
      ["وَأَنْتَ مُحِيطٌ بِالشُّؤُونِ فَلَا أَرَى", "أَنِّي عَلَى الْحَاجَاتِ مِنْكَ غَنَاءُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا يَنْفَكُّ عَنِّي عَزَاءُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا تَنْجَلِي الْخَلْفَاءُ وَيُحْظَى حِبَاءُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْأَهْلِ طُرًّا مَنْ حَوَاهُ عَبَاءُ"]
    ]
  }