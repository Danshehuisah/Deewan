{
    "id": 8,
    "title": "حرف الدال",
    "huruf": [
      ["بَرَى الْقَلْبَ حُبُّ الْهَاشِمِيِّ مُحَمَّدٍ", "تَحُوفُ تَوَامِي بِالْغَرَامِ الْمُسْتَهِدِّ"],
      ["رَسُولٌ مِنَ الْقُدْرِ الْقَدِيمِ مَنَالُهُ", "تَحَيَّرَ فِيهِ خَاطِرُ الْمُتَرَدِّدِ"],
      ["عُبُودِيَتُهُ مَقْرُونَتُهُ بِسِيَادَةٍ", "بَشِيرٌ نَذِيرٌ قَاصِدٌ خَيْرُ مُقْصِدِ"],
      ["مَذَلَّتُهُ الْعُرْوَةُ الْقَدِيمُ جَلَالُهُ", "جَمَالٌ فَيَبْدُو بِالْجَمَالِ الْمُجَدَّدِ"],
      ["فَيَحْرُ بِي حَامِدٌ وَمُحَمَّدٌ", "جَوَادٌ كَرِيمٌ مَدْحُهُ خَيْرُ مُنْشَدِ"],
      ["وَلَيْسَ يَرَى مَنْ ضَامَهُ الدَّهْرُ ضَارِعًا", "مَدَى الدَّهْرِ إِلَّا نَالَ خَيْرَ مُنْجِدِ"],
      ["وَهَذَا خَدِيمٌ قَدْ أَتَى مُتَضَرِّعًا", "فَمَلْ لَهُ يَا خَيْرَ صِنْدِيدِ"],
      ["وَكُنْ حِصْنَهُ عَمَّا يَخَافُ وَكُنْ لَهُ", "فَهَلْ وَزَرٌ يُلْقَى كَأَحْمَدَ سَيِّدِي"],
      ["عَلَيْهِ صَلَاةُ رَبِّهِ حَقَّ قَدْرِهِ", "مَعَ الْآلِ وَالْأَصْحَابِ بَلْ كُلِّ أَحْمَدِ"],
      ["قَضَى لِي قَاضِي الْحُبِّ وَهْوَ مُبَرِّرٌ", "بِأَنِّيَ الْمُجَلَّى فِي مَحَبَّتِهِ أَحْمَدِ"],
      ["لِذَائِكَ أَقْضِي فِي الْوُجُودِ بِأَسْرِهِ", "قَضَاءَ ذَوِي الْآمَالِ غَيْرَ مُنْقَدِ"],
      ["فَلُلْتُ شَبَاةَ الْمُعْتَدِينَ وَطَالَمَا", "أُحَدِّدُ أَذْهَانًا لِإِدْرَاكِ مَقْصِدِي"],
      ["وَفَرَّقْتُ جَمْعًا لِلْأَبَاطِيلِ جَامِعًا", "لِأَشْتَاتِ أَشْوَاقٍ بِقَلْبٍ مُعْتَبَدِ"],
      ["يُحِبُّ رَسُولُ اللَّهِ طَهَ مُحَمَّدٍ", "حَبِيبُ إِلَهِ الْعَالَمِينَ الْمُمَجَّدِ"],
      ["حَبِيبٌ خَلِيلٌ تَمَّ مَعْنًى وَصُورَةً", "وَوَصْفًا وَذَاتًا خَيْرُ مَأْوَى وَمَرْصَدِ"],
      ["تَكَامَلَ فِيهِ الْحُسْنُ غَيْبًا وَمَشْهَدًا", "فَلَيْسَ كَطَهَ الْمُصْطَفَى عِنْدَ مَشْهَدِي"],
      ["وَأَثْنَى عَلَيْهِ رَبُّهُ بِكَلَامِهِ", "فَأَعْجَزَ بَلْ لَيْسَ لَهُ يَدُ مُسْتَنِدِ"],
      ["وَيَكْفِيهِ مَدْحًا ذَاتُهُ وَصِفَاتُهُ", "مُحَمَّدٌ فِعْلُ الْحَمْدِ مِنْ حَمْدِ أَحْمَدِ"],
      ["عَلَيْهِ وَآلِ الصِّدْقِ أَعْلَى صَلَاتِهِ", "كَذَا مَنْ بَرَاهُ الشَّوْقُ نَحْوَ مُحَمَّدِ"]
    ]
  }