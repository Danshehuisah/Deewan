{
    "id": 6,
    "title": "حرف الحاء",
    "huruf": [
      ["لَقَدْ فَاحَ لِي مِنْ نَشْرِ أَحْمَدَ فَائِحُ", "فَخَرَّمَنِي نَوْمِي الدُّمُوعُ السَّوَافِحُ"],
      ["تَقَطَّعُ الْكَبِدُ بِعِشْقٍ وَمَطْمَعٍ", "تَنَازَعَهُ يَأْسٌ فَضَاقَ الْجَوَانِحُ"],
      ["حَمْدًا لَهُ إِذْ بُلِيتُ بِحُبِّهِ", "فَمِنْهُ بَدَا لِلْعَالَمِينَ الْمَصَالِحُ"],
      ["وَنِلْتُ بِهِ مَا فَاتَ حَدَّ تَفَضُّلٍ", "خَطَايَايَ طُوبَى وَهْوَ مَوْتِي صَالِحُ"],
      ["لَكَ الْحَمْدُ كُلُّ الْحَمْدِ شُكْرًا وَصَلِّ", "عَلَى مَنْ لِعَلْيَاءَ تَطِيبُ الْمَدَائِحُ"],
      ["لَكَ الْحَمْدُ يَا مَوْلَايَ حَقًّا وَصَلِّ", "عَلَيْهِ مَدَى الْأَيَّامِ مَا نَاحَ نَائِحُ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ أَحْمَدُ حَامِدٌ", "تَبَدَّثَ لَنَا مِنْهُ الْمُنَى وَالْمَنَائِحُ"],
      ["لَكَ الْحَمْدُ يَا مَوْلَايَ حَقًّا وَصَلِّ", "عَلَيْهِ مَدَى الْأَيَّامِ مَا نَاحَ نَائِحُ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ أَحْمَدُ حَامِدٌ", "تَبَدَّثَ لَنَا مِنْهُ الْمُنَى وَالْمَنَائِحُ"],
      ["تَبَدَّثَ لَهُ ذَاتُ الْمُهَيْمِنِ سَاجِدًا", "وَذَلِكَ مَرْمًى كَلَّ عَنْهُ الْقَوَارِحُ"],
      ["فَذَلِكَ عَبْدٌ جَلِيلٌ سَيِّدٌ طُهْرٌ", "بِهِ خُصَّتْ لِلْعَالَمِينَ الْمَرَابِحُ"],
      ["عَلَيْهِ صَلَاةُ رَبِّهِ حَتَّى قَدْرِهِ", "وَمَا فَاحَ عِنْدَ الِاخْتِتَامِ الْفَوَائِحُ"]
    ]
  }