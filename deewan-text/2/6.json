{
    "id": 6,
    "title": "حرف الحاء",
    "huruf": [
      ["لَقَدْ فَاحَ لِي مِنْ نَشْرِ أَحْمَدَ فَآئِحُ", "فَحَرَّمَنِي نَوْمِي الدُّمُوعُ السَّوَافِحُ"],
      ["تَقَطَّعَ اَكْبَادِى بِعِشْقٍ وَمَطْمَعٍ", "تَنَازَعَهُ يَاسٌ فَضَاقَ الْجَوَانِحُ"],
      ["حَمِدْتُ اِلَاهِى إِذْ بُلِيتُ بِحُبِّهِ", "فَمِنْهُ بَدَى لِلْعَالَمِينَ الْمَصَالِحُ"],
      ["وَنِلْتُ بِهِ مَا فَاتَ حَدًّ تَفَضُّلًا", "حَيَاتِيَ طُوبَى وَهْوَ مَوْتِيَ صَالِحُ"],
      ["لَكَ الْحَمْدُ كُلُّ الْحَمْدِ شُكْرًا وَصَلِّيَن", "عَلَى مَنْ لِعُلْيَاهُ تَطِيبُ الْمَدَائِحُ"],
      ["لَكَ الْحَمْدُ يَا مَوْلَايَ حَقًّا وَصَلِّيَنْ", "عَلَيْهِ مَدَى الْأَيَّامِ مَا نَاحَ نَائِحُ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ أَحْمَدُ حَامِدٌ", "تَبَدَّتْ لَنَا مِنْهُ الْمُنَى وَالْمَنَائِحُ"],
      ["نَفَي عَنْ دُيُورِي كُلَّ بُؤْسٍ وُغُمَّةٍ", "وَطَيْرٍ وَشُؤْمٍ قَدْ تُرِيهَا الْبَوَارِحُ"],
      ["وَاَلْهَمَنَا ذِكْرَالْإِلَهِ وَمَدْحَ مَنْ", "تُكِلُّ لَدَي اَدْنَي ثَنَاهُ الْقَرَآئِحُ"],
      ["تَبَدَّتْ لَهُ ذَاتُ الْمُهَيْمِنِ سَاذِجًا", "وَذَالِكَ مَرْمًي كَلَّ عَنْهُ الْقَوَارِحُ"],
      ["فَذَالِكَ عَبْدُ الْعَيْنِ سَيِّدُ نُقْطَةٍ", "بِهَا حَصَلَتْ لِلْعَالَمِينَ الْمَرَابِحُ"],
      ["عَلَيْهِ صَلَاةُ رَبِّهِ حَقَّ قَدْرِهِ", "وَمَا فَاحَ عِنْدَ الِإِخْتِتَامِ الْفَوَائِحُ"]
    ]
  }