{
    "id": 20,
    "title": "حرف الفاء",
    "huruf": [
      ["كَفَانِي شُرُورَ الْجِنِّ وَالْإِنْسِ مَنْ نَفَى", "دُجَى الْبَغْيِ وَالْأَنْسَاءَ بِالنُّورِ مُصْطَفَى"],
      ["كَفَانِي مَكْرَ الْمَاكِرِينَ وَكَيْدَهُمْ", "كَفَى الْخَوْفَ وَالْبَأْسَاءَ عِنْدِي وَالْجَفَا"],
      ["وَالزَّمَنِي ذِكْرُ الْحَبِيبِ وَمَدْحُهُ", "عَلَيْهِ صَلَاةُ اللَّهِ مَا شَارِقٌ خَفَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ كَالْقَطْرِ وَالْحَصَى", "وَكَالرَّمْلِ وَالْأَوْرَاقِ مَا دَامَ مُتْحَفَا"],
      ["وَكَالْقَطْرِ وَالْمِفْضَارِ بَطْنًا وَظَاهِرًا", "مَدَى الدَّهْرِ يَا مَنْ قَادَ لِي كُلَّ مَا اصْطُفِي"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ سَيِّدُ خَلْقِهِ", "صَلَاةٌ عَلَيْهِ وَارْحَمَنَّ وَشَرُفَا"],
      ["تَجَلَّتْ لَهُ الذَّاتُ الْعَلِيَّةُ سَاجِدًا", "وَعَيْنُ الْعَمَى وَالطَّمْسُ مُعْطًى وَمُتْحَفَا"],
      ["فَتَمَّمَهُ رَبٌّ كَرِيمٌ أَحَبَّهُ", "وَأَكْمَلَهُ جِسْمًا وَمَعْنًى وَضُعْفَا"],
      ["حَبَاهُ وَأَجْدَاهُ وَقَرَّبَ ذَاتَهُ", "لِحَضْرَتِهِ الْعَلْيَاءِ وَأَعْطَى وَأَتْحَفَا"],
      ["فَهْوَ أَوَّلُ التَّوْجِيدِ أَوَّلُ قَابِلٍ", "تَجَلِّيَ ذَاتِ الْحَقِّ زَحْزَحَ رَفْرَفَا"],
      ["وَأَوَّلُ مَوْجُودٍ وَأَوَّلُ خَادِمٍ", "وَأَوَّلُ مَخْدُومٍ أَطِيعَ وَأُتْلِفَا"],
      ["وَأَوَّلُ مَذْكُورٍ وَأَوَّلُ ذَاكِرٍ", "وَأَوْفَى لَنَا خِزْقًا سَرِيًّا مُشَرَّفَا"],
      ["فَأَعْطَى لِكُلِّ الْخَلْقِ كُلَّ فَوَاضِلٍ", "وَأَعْطَى لِأَهْلِ الْفَضْلِ فَضْلًا وَتَفَنَّا"],
      ["بِهِ نَابَ سِرُّ الْكَائِنَاتِ فَآدَمٌ", "فَنُوحٌ فَإِبْرَاهِيمُ فَالْكُلَّ أُتْحِفَا"],
      ["فَمُوسَى فَعِيسَى ثُمَّ حَيَّ مُحَمَّدٌ", "بِهِ أُتْحِفُوا حَمَلُوا الْأَمَانَةَ وَالْوَفَا"],
      ["وَمَا رِيقَ مِنْ خَيْرِ الْأَنَامِ مُحَمَّدٍ", "سِوَى طِيلَةِ الْمَاضِي الطِّلَالِ مُتْقِنَا"],
      ["بِغَارِ حِرَاءٍ قَدْ أَتَتْهُ رِسَالَةٌ", "مِنَ اللَّهِ مَهْمَا جَاءَهُ مُتَعَكِّفَا"],
      ["فَجَاءَ نَذِيرًا دَاعِيًا وَمُبَشِّرًا", "وَأَرْشَدَ مَنْ قَدْ كَانَ قَبْلُ تَعَسَّفَا"],
      ["وَصَلَّى وَصَامَ الصَّيْفَ حَجَّ مُجَاهِدًا", "وَزَكَّى وَشَادَ الدِّينَ وَالْكَوْنَ ثَقَّفَا"],
      ["وَجَاهَدَ فِهْرًا عِنْدَ بَدْرِ مُحَمَّدٍ", "وَجِبْرِيلُ أَوْ مِيكَالُ فِيهِ تَكَشَّفَا"],
      ["كَذَلِكَ إِسْرَافِيلُ جَاءَ مُبَارِزًا", "كَذَلِكَ عَزْرَائِيلُ لِلْحَرْبِ لَفَّفَا"],
      ["بِخَمْسَةِ آلَافٍ أَتَوْهُ بِشَارَةً", "وَنَصَرَهُ مَوْلَى الْبَرَايَا وَقَدْ كَفَى"],
      ["إِمَامٌ وَسَيِّدِي أَبُو بَكْرٍ الْعَالِي", "أَبُو حَفْصٍ الْفَارُوقُ حِبِّيَ مَنْ صَفَا"],
      ["وَعُثْمَانُ ذُو النُّورَيْنِ وَالصِّنْوُ قَدْ أَتَى", "عَلِيٌّ أَبُو السِّبْطَيْنِ كَاللَّيْثِ مُشْرِفَا"],
      ["وَطَلْحَةُ وَسَعْدٌ وَالزُّبَيْرُ سَعِيدُهُمْ", "وَنَجْلُ لِعَوْفٍ ثُمَّ عَامِرٌ مَنْ وَفَى"],
      ["فَيَا قَبْرَ جَمْعِ الْكَافِرِينَ جَمِيعِهِمْ", "قَدْ أَرْضَيْتُمُ الْمَوْلَى بِنُصْرَةِ مُصْطَفَى"],
      ["بِكَسْرِكُمُ الْأَصْنَامَ جَبْرَ قُلُوبِنَا", "وَشِدْتُمْ مَنَارَ الْحَقِّ أَعْلَى وَأَشْرَفَا"],
      ["أَيَا اللَّهُ يَا رَحْمَانُ يَا حَيُّ هَبْ لِي", "أَقِمْ بِيَ أَرْكَانًا لِدِينِكَ ذَا اقْتِفَا"],
      ["أُرَجِّي بِرَبِّ الْبَيْتِ مِنْكَ تَدَارُكًا", "لِقَرْنِي وَأَرْجُو الدَّهْرَ مِنْكَ تَعَطُّفَا"],
      ["رَجَائِي كَبِيرٌ وَاسِعٌ دُونَ فَضْلِهِ", "أَيَا رَبِّ فَضْلًا مِنْكَ لُطْفًا تَلَطُّفَا"],
      ["فَلَا رَاحَةً لِلْعَبْدِ فِي غَيْرِ نَيْلِهِ", "مَطَالِبَ أُوفِدْتُ بَحْرَ جُودٍ مُنِيفَا"],
      ["بِجَاهِ رَسُولِ اللَّهِ خَيْرِ رَجَائِنَا", "فَنُقِّوهُ لَهُمْ آثَارَ صِدْقٍ وَقَدْ وَفَى"],
      ["وَجَاهِهِمْ عِنْدَ الْإِلَهِ وَجَاهِ مَنْ", "أَتَى بَعْدَهُمْ فِي قَفْوِ آثَارٍ مُقْتَفَى"],
      ["عَلَيْهِ صَلَاةُ رَبِّهِ حَقَّ قَدْرِهِ", "وَآلٍ وَأَصْحَابٍ وَمَنْ قَدْ تَحَقَّفَا"]
    ]
  }