{
    "id": 9,
    "title": "حرف الذال",
    "huruf": [
      ["ذَكَرْتُ رَسُولَ اللَّهِ طَاهَ مَنَ انْقَذَا", "فَؤَادِي عَنِ الْأَهْوَاءَ أَمْرِيَ نَفَّذَا"],
      ["ذَكَرْتُ نَبِيَّ الْأَنْبِيَاءِ الَّذِي بِهِ", "يَفُوزُ خَدِيمٌ مِنْهُ يُدْرِكُ مَأْخَذَا"],
      ["ذَكَرْتُ الَّذِي لَمْ أَنْسَهُ الدَّهْرَ إِذْ لَنَا", "بِهِ حَالَةٌ لَمْ تُعْطِ لِلذِّكْرِ مَنْفِذَا"],
      ["فَمَا خَاطِرٌ لِلْعَبْدِ إِلَّا مُحَمَّدٌ", "وَمَا إِنْ يَرَى الرَّائِي سِوَاهُ وَلَا قَذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا طَابَ لِلْأَرْوَاحِ لِلْمُصْطَفَى غِذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَقْرُبُ الْهَادِي إِلَى الْعَبْدِ مُنْقِذَا"],
      ["فَطَاهَ حَبِيبُ اللَّهِ وَهْوَ خَلِيلُهُ", "وَهَذَا خَدِيمٌ مَادِحًا مُتَلَذِّذَا"],
      ["عَسَى الْمُصْطَفَى يَوْمًا يَجُودُ بِوَصْلِهِ", "وَيُعْطِي مُرَادِي يَا خَدِيمُ لِتَأْخُذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَكَرِّرُ تَسْلِيمَ الْحَبِيبِ تَلَذُّذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالْأَصْحَابِ مَا النُّورُ أَنْقَذَا"]
    ]
  }