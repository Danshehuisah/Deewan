{
    "id": 9,
    "title": "حرف الذال",
    "huruf": [
      ["ذَكَرْتُ رَسُولَ اللَّهِ طَهَ مَنْ أَتَقَى", "فَؤَادِي مِنَ الْأَهْوَاءِ وَأَمْرِي نَفَّذَا"],
      ["ذَكَرْتُ نَبِيَّ الْأَنْبِيَاءِ الَّذِي بِهِ", "يَقُودُ خَدِيمٌ مِنْهُ يُدْرِكُ مَأْخَذَا"],
      ["ذَكَرْتُ الَّذِي لَمْ أَنْسَهُ الدَّهْرَ إِذْ لَنَا", "بِهِ حَالَةٌ لَمْ تُطْوَ لِلذِّكْرِ مَنْفَذَا"],
      ["فَلَا خَاطِرٌ لِلْعَبْدِ إِلَّا مُحَمَّدٌ", "وَمَا إِنْ يَرَى الرَّائِي سِوَاهُ وَلَا يَقْذِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا طَابَ لِلْأَرْوَاحِ بِالْمُصْطَفَى غِذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَقْرُبُ الْهَادِي إِلَى الْعَبْدِ مُنْقِذَا"],
      ["فَطَهَ حَبِيبُ اللَّهِ وَهْوَ خَلِيلُهُ", "وَهَذَا خَدِيمٌ مَادِحًا مُتَلَذِّذَا"],
      ["عَسَى الْمُصْطَفَى يَوْمًا يَجُودُ بِوَصْلِهِ", "وَيُعْطِينِي مُرَادِي يَا خَدِيمُ لِتَأْخُذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَكَرَّرُ تَسْلِيمَ الْحَبِيبِ تَلَذُّذَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالْأَصْحَابِ مَا النُّورُ أَتَقَى"]
    ]
  }