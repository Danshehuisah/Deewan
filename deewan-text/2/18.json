{
    "id": 18,
    "title": "حرف العين",
    "huruf": [
      ["أَبْرَقٌ بَدَا نَحْوَ الْمَرَابِعِ يَلْمَعُ", "فَهَنِيًّا لِامْرِئٍ إِذْ يَلْمَعُ الْبَرْقُ يَدْمَعُ"],
      ["لَمَحْتُ فَوَهْنًا وَيْلَكَ هِجْتَ صَبَابَتِي", "وَزَفْرَاتِ دَمْعٍ سَاعَةَ الْحَيُّ تَهْجَعُ"],
      ["تَذَكَّرَ أَيَّامَ الصِّبَا وَهْيَ قَدْ مَضَتْ", "وَلَمْ يَبْقَ إِلَّا لَوْعَةٌ وَتَوَجُّعُ"],
      ["سَقَى اللَّهُ أَرْضًا بِالْمَدِينَةِ أَنَّهَا", "مَحَطٌّ لِحَالٍ فِيهِ خِرْقِي يُرْقَعُ"],
      ["دِيَارُ حَبِيبِ اللَّهِ وَهْوَ أَمِينُهُ", "دِيَارٌ بِهَا تُلْقَى الْمَرَافِقُ أَجْمَعُ"],
      ["دِيَارٌ لِمَنْ هَامَ الْفُؤَادُ بِحُبِّهِ", "وَتَذْكَارُهُ لِلْقَلْبِ مَرْعًى وَمَرْتَعُ"],
      ["دِيَارٌ لِأَعْلَى الْخَلْقِ خُلْقًا وَخَلْقَهُ", "دِيَارٌ لِمَنْ فِي الْخَلْقِ يَعْطِي وَيَمْنَعُ"],
      ["وَأَكْرَمِهِمْ نَفْسًا وَصِهْرًا وَنِسْبَةً", "وَعِلْمًا وَآدَابًا وَأَتْقَى وَأَخْشَعُ"],
      ["فَقَدْ كَانَ خَيْرَ الْخَلْقِ فَحْمًا مُنَضَّجًا", "وَذَا هِبَةٍ وَالْمَشْيُ فِيهِ تَقَلَّعُ"],
      ["وَأَزْهَرَ لَوْنًا أَدْعَجَ الْعَيْنِ تَزْدَرِي", "بِعَيْنِ الْمَهَا عِنْدَ الْخَمِيلَةِ تَرْتَعُ"],
      ["وَأَنْجَلَ عَيْنًا أَهْدَبَ الشَّفْرِ وَاسِعًا", "جَبِينُ رَسُولِ اللَّهِ وَالْخَلْقُ أَوْسَعُ"],
      ["أَرَجُّ وَأَفْقَى وَجْهُ طَهَ مُدَوَّرٌ", "وَلِحْيَتُهُ كَثَّاءُ وَصَدْرٌ مُوَسَّعُ"],
      ["وَمَنْكِبُهُ أَعْظَمْ بِهِ وَعِظَامُهُ", "ضِخَامٌ وَرَبُّ الْقَدْرِ طَهَ الْمُرَفَّعُ"],
      ["كَذَا عَضُدٌ عَبْلٌ وَعَبْلٌ ذِرَاعُهُ", "مُرَحَّبُ رَاحَاتٍ وَالْأَنْوَارُ تَلْمَعُ"],
      ["وَسَائِلُ أَطْرَافٍ وَغَيْرُ مُسَدَّدٍ", "عَظِيمُ كَرَادِيسٍ مِنَ الْخَلْقِ أَرْفَعُ"],
      ["وَأَشْنَبُ ثَغْرٍ إِنْ تَبَسَّمَ يَنْجَلِي", "كَحَبِّ غَمَامٍ أَوْ كَلَامِضِ الْبَرْقِ يَلْمَعُ"],
      ["وَهَامَتُهُ عَظْمَى لِشَعْرٍ تَرَجَّلَ", "وَخَافِضُ طَرْفٍ سَاكِنٌ فَهْوَ يَخْشَعُ"],
      ["وَأَعْضَاؤُهُ مَوْصُولَةٌ بِتَفَكُّرٍ", "إِذَا فَرَّقَ الْفَضْلَ وَالْحَقَّ يَرْجِعُ"],
      ["وَكَاللُّؤْلُؤِ الْمَكْنُونِ وَالْمِسْكُ عَرْفُهُ", "فَمِثْلُ رَسُولِ اللَّهِ لَمْ يُخْلَقْ مُجَمَّعُ"],
      ["وَأَحْلَمُ خَلْقِ اللَّهِ أَعْدَلُ خَلْقِهِ", "مِنَ النَّاسِ أَسْحَى بَلْ مِنَ النَّاسِ أَشْجَعُ"],
      ["وَيَخْدُمُ لِلْأَهْلِينَ يَخْصِفُ نَعْلَهُ", "وَيَقْطَعُ لَحْمًا وَهْوَ لِلثَّوْبِ يَرْقَعُ"],
      ["أَشَدُّ حَيَاءً وَهْوَ يَأْتِي لِمَنْ دَعَا", "وَيَغْضَبُ لِلْمَوْلَى إِلَى الْحَقِّ يَرْجِعُ"],
      ["وَلَمْ يَتَوَرَّعْ عَنْ حَلَالٍ وَلَوْ حَالَ", "وَلَمْ تُلْفِهِ فِي غَالِبِ الْوَقْتِ يَشْبَعُ"],
      ["وَيَرْكَبُ أَحْيَانًا جَوَادًا وَمَرَّةً", "حِمَارًا وَحِينًا رَاجِلًا يَتَقَلَّعُ"],
      ["كَذَلِكَ فِي الْمَلْبُوسِ وَالطِّيبُ فَائِحٌ", "يُجَالِسُ أَقْوَامًا وَالْخَصْمُ يُرْفَعُ"],
      ["وَيَمْزَحُ أَحْيَانًا يُؤَلِّفُ مَرَّةً", "وَمَا هَابَ مُلْكًا قَطُّ فَالشَّأْنُ أَرْفَعُ"],
      ["وَمَا حَقَّرَ الْمِسْكِينَ يَدْعُو جَمِيعَهُمْ", "وَبِاللَّهِ مَوْلَى الْخَلْقِ ذَا الْخُلْقَ يَجْمَعُ"],
      ["وَأَكْرَمَهُ الْمَوْلَى أَجَلَّ كَرَامَةً", "وَخَصَّ بِهِ مَنْ لِلْخَلَائِقِ يَنْفَعُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ مَا ذَرَّ شَارِقٌ", "وَمَا غَنَّتِ الْحَمَامَاتُ عَلَى الْغُصْنِ تَسْجَعُ"],
      ["وَمَا رُدَّ ضَيْمُ الدَّهْرِ عَنْ سَاحَةِ الَّذِي", "يُزَخْرِفُ أَمْدَاحًا وَيَشْدُو وَيَسْجَعُ"],
      ["وَآلٍ وَأَصْحَابٍ مَدَى قَوْلِ شَيِّقٍ", "أَبْرَقٌ بَدَا نَحْوَ الْمَرَابِعِ يَلْمَعُ"]
    ]
  }