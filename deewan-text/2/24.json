{
    "id": 24,
    "title": "حرف الميم",
    "huruf": [
      ["دَعَانِي مِنْ تَذْكَارِ سَلْمَى وَتَشَنُّفِي", "فَإِنَّ جَمَالَ الْهَاشِمِيِّ مَتَرَنَّحِي"],
      ["إِذَا أَطْرَبَ الْأَقْوَامَ مَلْهًى وَمَطْرَبٌ", "طَرِبْتُ بِذِكْرِ الْهَاشِمِيِّ الْمُكَرَّمِ"],
      ["جَلِيسِي إِذَا أَخْلُو جَمَالُ مُحَمَّدٍ", "حَبِيبُ إِلَهِ الْعَالَمِينَ الْمُعَظَّمِ"],
      ["فَعِيدٌ تَجَلَّى سَيِّدُ الْكَوْنِ يَا لَهُ", "تَحَيَّرَ فِيهِ خَاطِرُ الْمُتَرَنِّمِ"],
      ["خَوَارِقُهُ تُغْشِي الْعَوَالِمَ حَضْرَةً", "وَمَا انْقَاسَتْ قَدْرًا لِطَهَ الْمُقَدَّمِ"],
      ["كَمَا مَا أَتَى لِلْأَنْبِيَا مِنْ خَوَارِقٍ", "وَمَا لَاحَ لِلْأَصْحَابِ فِي كُلِّ مَلْحَمِ"],
      ["وَمَوْلِدُهُ أَعْظِمْ بِهِ وَعُلُومُهُ", "وَإِسْرَاؤُهُ بَعْدَ الْجَمَالِ الْمُفَخَّمِ"],
      ["وَأَخْلَاقُهُ عَدْلًا وَلِينًا وَشِدَّةً", "وَعِلْمًا وَجُودًا وَاتِّقَاءً لِمَأْثَمِ"],
      ["وَمَا ضَلَّ طَهَ الْهَاشِمِيُّ وَمَا غَوَى", "فَسُورَةَ وَالنَّجْمِ اثْنَتَانِ وَتَقْحَمِ"],
      ["تَرَى الْمُصْطَفَى ظُهْرًا وَبَطْنًا وَتَظْهَرَنْ", "بِسِرٍّ مِنْ أَسْرَارِ الْإِلَهِ مُكَتَّمِ"],
      ["تَرَانِي مَا خَمَّانِي النَّوْمُ بِالشَّوْقِ مُنْشِدًا", "أَلَا نَعَمْ صَبَاحًا أَيُّهَا الرَّبْعُ وَاسْلَمِ"],
      ["تَرَى مَنْظَرًا هَامَ الْفُؤَادُ بِحُبِّهِ", "فَيُسْلِيكَ عَنْ لَيْلَى وَمَيْلَى وَتَنْدُمِ"],
      ["وَهِنْدٍ وَدَعْدٍ أَوْ سُلَيْمَى وَزَيْنَبٍ", "وَفَاطِمَ أَوْ سَلْمَى وَأَسْمَا وَمَرْيَمِ"],
      ["وَقُلْ لِمُلُوكِ الْأَرْضِ هَامُوا خُيُولَهُمْ", "وَهَا ذَاكَ مُلْكٌ لَا يُبَاعُ بِدِرْهَمِ"],
      ["دُعَاءُ الْخَلَائِقِ لِلْمَوْلَى فَمِنْهُمْ", "مُصَدِّقٌ وَمِنْهُمْ جَحُودٌ لَمْ يُسْلِمِ"],
      ["فَفَرَّقَ أَجْنَادَ الْكِتَابِ فِيهِمُ", "يَدُوبُ لِأَشْيَافٍ لَهُمْ كُلُّ مُخْدَمِ"],
      ["تَرَاهُمْ كَأَنَّ الْمَوْتَ فِيهِمْ حَيَاتُهُمْ", "وَأَقْدَمُهُمْ خَيْرُ الْوَرَى بِتَبَسُّمِ"],
      ["إِذَا مَا وَطِيسٌ قَدْ حَمَى لَيْسَ فَاثِمًا", "مَقَامُكَ شَفْرٌ فِي الْجُيُوشِ الْعَرَمْرَمِ"],
      ["فَأَشْجَعُ خَلْقِ اللَّهِ طَهَ مُحَمَّدٌ", "وَأَسْخَاهُمْ نَفْسًا لَدَى كُلِّ مَغْنَمِ"],
      ["فَأَقْلِقْ لِدُنْيَا النَّاسِ عِنْدَ نَبِيِّنَا", "فَسِيَّانِ وَقْتُ الْجِدِّ أَوْ وَقْتُ مَعْدَمِ"],
      ["فَيُعْطِي وَلَا يُبْقِي وَغَيْرُ مُنْقِصٍ", "تَرَى غَمْرَةً يُعْطِي بِوَجْهِ مُقَسَّمِ"],
      ["أَتَيْتُكَ يَا خَيْرَ الْبَرِيَّةِ أَبْتَغِي", "مَنَالًا عَظِيمًا مِنْ جَوَادٍ مُكَرَّمِ"],
      ["وَتَعْلَمُ حَاجَاتِ الْعَبِيدِ جَمِيعَهَا", "أَرَانِي أَسْتَلِفُ الْكُلَّ مِنْ خَيْرِ مُسْلِمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ مَا حَنَّ عَاشِقٌ", "وَمَا نِيلَ حَاجَاتٌ بِطَهَ الْمُكَرَّمِ"],
      ["وَآلٍ وَأَصْحَابٍ كِرَامٍ أَجِلَّةٍ", "نُجُومِ الْهُدَى فِي كُلِّ بَدْءٍ وَمُخْتَمِ"]
    ]
  }