{
    "id": 16,
    "title": "حرف الضاد",
    "huruf": [
      ["غَرَامِي وَشَوْقِي لِلنَّبِيِّ الَّذِي مَحَضْ", "تَصِيحَتْهُ وَالْحُبُّ فِي ذَاتِهِ فُرِضْ"],
      ["حَبِيبِي حَبِيبُ اللَّهِ طَهَ مُحَمَّدٌ", "وَذَاكَ دَوَاءُ الْقَلْبِ إِنْ ضَاقَ أَوْ مَرِضْ"],
      ["مَحَبَّتُهُ فَوْتُ الْقُلُوبِ وَرَاحَةٌ", "مِنَ الْهَمِّ وَالْأَحْزَانِ وَالْحُبُّ مُفْتَرَضْ"],
      ["أَلَا يَا رَسُولَ اللَّهِ وَجَّهْتُ وَجْهَتِي", "إِلَيْكَ فَكُنْ لِي الدَّهْرَ إِنْ عَارَضَ عَرَضْ"],
      ["فَمَا أَعْتَذُ فِي النَّائِبَاتِ سِوَاكُمْ", "لِذَا الْعَبْدِ وَالْمَطْلُوبُ ذَائِكَ وَالْغَرَضْ"],
      ["فَمَا لِي إِلَّا أَحْمَدٌ وَصِحَابُهُ", "وَذَلِكَ كَنْزٌ لَا يَزَالُ وَلَا يَنْقَرِضْ"],
      ["أَبُو بَكْرٍ الْعَالِي الْإِمَامُ وَسَيِّدِي", "أَبُو حَفْصٍ الْفَارُوقُ لِلَّذِينَ قَدِ افْتَرَضْ"],
      ["وَعُثْمَانُ ذُو النُّورَيْنِ وَاللَّيْثُ سَيِّدِي", "أَبُو حَسَنٍ مَنْ حُبُّهُ الدَّهْرَ يُفْتَرَضْ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَعْتَلِي فَوْقَ الْحَجِيجِ وَمَنْ عَرَضْ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا دَأْبِي مِنْ حُبِّ أَحْمَدَ قَدْ رُحِضْ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ أَمْسَكُوا دِينَ النَّبِيِّ وَمَنْ قَبَضْ"],
      ["تَقِفُّ اعْوِجَاجَ الْخَلْقِ وَالْكُلُّ يُغْبِطُ", "مَقَامِي لَدَى الْمَاضِي وَبِالْفَيْضِ يُنْسَطُ"],
      ["فَهُوَ صِفَةٌ وَاسْمٌ وَذَاتٌ وَغَيْهَا", "وَهُوَ قَاسِمٌ عَدْلٌ كَرِيمٌ وَمُقْسِطُ"],
      ["يَتَوَرَّثُهُ فِي حَالَتَيْهِ فَهَالَنِي", "كَمَالُ جَمَالٍ لِلْمَدِيحِ يُنْبِطُ"],
      ["أُنَادِيهِ يَا طَهَ الْأَمِينُ وَعَاقِبُ", "وَحَاشِرُ وَالْهَادِي وَأَحْمَدُ أَخْبِطُ"],
      ["مُحَمَّدُ يَاسِينُ وَحَامِدُ مُصْطَفَى", "كَرِيمُ السَّجَايَا وَصْفُهُ لَيْسَ يُضْبَطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَزْدَهِي مَنْ كَانَ مِنْ قَبْلُ فَرَّطُوا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَقْتَدِي مَا لَا يُنَابُ فَيُخْبَطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَسْبِقُ الْأَقْطَابَ طُرًّا وَأَفْرُطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تَرْعَى الْمُسْلِمِينَ وَتُنْشِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الَّذِينَ قَدْ أَنْبَطُوا"]
    ]
  }