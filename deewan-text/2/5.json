{
    "id": 5,
    "title": "حرف الجيم",
    "huruf": [
      ["ضِيَاؤُكَ مِنْهُ الْكَوْنُ قَدْ يَتَبَلَّجُ", "وَمِنْ فَيْضِكَ الْجَارِي الْبِحَارُ تَمَوَّجُ"],
      ["أَأَحْمَدُ يَا طَهَ الْأَمِينُ مُحَمَّدُ", "عَلَيْكَ سَلَامٌ دَوْبَةُ الْمِسْكِ يَأْتَجُ"],
      ["فَمِنْ طِيبِهِ طَابَ الْجِنَانُ وَنَشْرُهُ", "بِهِ فَاحَ مِسْكٌ وَالْكِيَا وَالْبَتَفْسَجُ"],
      ["وَمِنْ حُسْنِهِ حُورُ الْجِنَانِ تَزَيَّنَتْ", "وَمِنْهُ جَلَا كُلَّ نَارٍ تَتَأَجَّجُ"],
      ["وَمِنْ عِلْمِهِ لَوْحُ الْعَلِيمِ وَجُودُهُ", "بِهِ وَعَلَيْهِ الْخَلْقُ وَالْأَمْرُ يُنْسَجُ"],
      ["لِذَاكَ سَرَى وَالْكُلُّ مُوَطِّئٌ تَعْلُهُ", "فَأَكْرِمْ بِخَيْرِ الْخَلْقِ مَنْ هُوَ أَنْهَجُ"],
      ["وَشُقَّ لَهُ الْبَحْرُ الْعَبِيرُ وَأَسْبَلَتْ", "عَمَاءٌ يَوَدُّ دَائِمًا يَتَأَجَّجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا فَأْزِ أَحْبَابِي وَضِدِّيَ مُرْعَجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُحَلِّي لِسَانِي الدَّهْرَ لَا أَتَلَجْلَجُ"],
      ["عَلَيْهِ صَلَّى اللَّهُ ثُمَّ سَلَّمَهُ", "صَلَاةً لَنَا أَنْوَارُهَا تَبْتَلِجُ"],
      ["عَلَيْهِ صَلَّى اللَّهُ ثُمَّ سَلَّمَهُ", "صَلَاةً بِهَا كُلُّ الْكُرُوبِ تَفَرَّجُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ مِنَ الطَّيِّبِ الْأَبَحِّ"]
    ]
  }