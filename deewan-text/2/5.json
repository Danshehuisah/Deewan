{
    "id": 5,
    "title": "حرف الجيم",
    "huruf": [
      ["ضِيَاؤُكَ مِنْهُ الْكَوْنُ قَدْ يَتَبَلَّجُ", "وَمِنْ فَيْضِكَ الْجَارِي الْبِحَارُ تَمَوَّجُ"],
      ["أَأَحْمَدُ يَا طَهَ الْأَمِينُ مُحَمَّدًا", "عَلَيْكَ سَلَامٌ دُوْنَهُ الْمِسْكُ يَأْرَجُ"],
      ["فَمِنْ طِيبِهِ طَابَ الْجِنَانُ وَنَشْرُهُ", "بِهِ فَاحَ مِسْكٌ وَالْكِيَا وَالْبَنَفْسَجُ"],
      ["وَمِنْ حُسْنِهِ حُورُ الْجِنَانِ تَزَيَّنَتْ", "وَمِنْهُ جَلَالٌ نَارُهُ تَتَأَجَّجُ"],
      ["وَمِنْ عِلْمِهِ لَوْحُ الْعَلِيِّ وَجُودُهُ", "بِهِ وَعَلَيْهِ الْخَلْقُ وَالْأَمْرُ يُنْسَجُ"],
      ["لِذَاكَ سَرَى وَالْكُلُّ مَوْطِأُ نَعْلِهِ", "فَأَكْرِمْ بِخَيْرِ الْخَلْقِ مَنْ هُوَ أَبْهَجُ"],
      ["وَشُقَّ لَهُ الْبَدْرُ الْمُنِيرُ وَأَسْبَلَتْ", "غَمَامٌ بِوَدْقٍ دَآئِمًا يَتَثَجْثَجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا فَازَ اَحْبَابِي وَضِدِّيَ مُزْعَجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَحُلُّ لِسَانِي الدَّهْرَ لَا أَتَلَجْلَجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهُ ثُمَّ سَلَامُهُ", "صَلَاةً لَنَا أَنْوَارُهَا تَتَبَلَّجُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهُ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا كُلُّ الْكُرُوبِ تُفَرَّجُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ مِنَ الطِّيبِ اَاْرَجُ"]
    ]
  }