{
    "id": 22,
    "title": "حرف الكاف",
    "huruf": [
      ["حَمَامَةَ وَادِي الدَّوْحِ وَيْلَكَ مَا لَكِ", "فَقَدْ هِجْتِ لِي تَذْكَارَ نَجْلِ الْعَوَائِكِ"],
      ["سَلَامٌ عَلَى قَبْرِ النَّبِيِّ الْمُبَارَكِ", "فَكَمْ مِنْ خَبَايَا وَدُخَانِ الْهَوَالِكِ"],
      ["سَلَامٌ عَلَى فَخْرٍ لِنَصْرٍ وَمَالِكٍ", "وَعُنْيَةِ أَيْتَامٍ وَمَأْوَى الْمَمَالِكِ"],
      ["سَلَامٌ عَلَيْهِ مِنْ خَدِيمٍ مُتَّبِعٍ", "يَبِيتُ لَهُ مِنْ كُلِّ حَالٍ وَحَائِكِ"],
      ["فَإِنْ يَكُ مَقَامِي بِسِنْغَالَ إِنَّنِي", "بِرُوحِي لَدَى ذَاكَ الْعَبِيدِ الْمُبَارَكِ"],
      ["أُحَضِّرُهُ خَيْرُ الْعُلَى حَضْرَهُ سَيِّدِي", "وَيَا حَضْرَةَ الْمُخْتَارِ مُبْدِي الْمَنَاسِكِ"],
      ["أُحِبُّكُ حُبًّا تَامَّ قَلْبِي وَقَادَهُ", "وَمَا ذَا عَلَيَّ فِي امْتِدَاحِ جَنَابِكِ"],
      ["فَأَنْتَ حَبِيبُ اللَّهِ جَلَّ جَنَابُكَ", "وَأَوْلَاكَ مَا أَوْلَاكَ غَيْرُ مُشَارِكِ"],
      ["سَرَى بِكَ لَيْلًا ثُمَّ أَدْنَاكَ رَاجِيًا", "وَفُزْتَ بِسِرٍّ فَاتَ خَاطِرَ سَالِكِ"],
      ["خَرَجْتَ مِنَ الْأَكْوَانِ وَالسِّرِّ سَامِيًا", "وَفُقْتَ اغْتِلَامَ كُلِّ حَيٍّ وَهَالِكِ"],
      ["وَغِبْتَ عَنِ الْمَكْنُونِ وَالْغَيْبِ رَاقِيًا", "وَفُقْتَ لَعَمْرِي كُلَّ دَارٍ وَدَارِكِ"],
      ["أَيَا حَيُّ يَا قَيُّومُ يَا رَبِّ هَبْ لَنَا", "نَصِيبًا مِنَ السِّرِّ الْغَرِيزِ الْمُدَارِكِ"],
      ["وَتَجْعَلْنِي دَهْرِي خَدِيمَ جَنَابِهِ", "بِنَفْسِي وَرُوحِي مُخْلِصًا عِنْدَ مَالِكِي"],
      ["أَرَى الْعَبْدَ مَسَّاءً سُوءُ حَالِهِ", "فَلَمْ يَكُ يَرْجُو غَيْرَ مَحْضِ تَدَارُكِ"],
      ["يَظَلُّونَ بِهِ خَيْرًا وَلَا خَيْرَ إِنَّمَا", "رَأَوْا حَضْرَةَ الْمَحْبُوبِ سِتْرَ جَمَالِكِ"],
      ["فَلَا تَفْضَحَنِّي يَوْمَ الْوُقُوفِ مُقَصِّرًا", "وَكُنْ لِي يَا مَوْلَايَ مُنْجِيَ الْمَمَالِكِ"],
      ["فَقَدْ ضَاعَ عُمْرِي وَالسَّفَاهَةُ كَاسِيَةٌ", "فَهَلْ مِنْ شَفِيعٍ لِي وَهَلْ مِنْ مُدَارِكِ"],
      ["وَضَيَّعْتُ عُمْرِي فِي التَّكَالِيفِ وَالْوَقَارِ", "فَوَيْلَكَ هَذِي النَّفْسُ أَعْظِمْ بِذَاتِكِ"],
      ["وَصْفًا لِعَرْضِي التَّاسِ كُلٌّ دَوَاتِهِ", "فَوَيْلَكَ شَرَّ النَّفْسِ مَنْ لِدَوَاتِكِ"],
      ["فَيَا لِإِبْرَاهِيمَ إِنْ دَامَ هَكَذَا", "فَيَا لِإِبْرَاهِيمَ إِنْ لَمْ تُدَارِكِ"],
      ["عَلَى أَنَّهُ مِنْ حُسْنِ ظَنِّي لَدَيْهِ", "لِيَرْجُوَ مَنَالًا فَوْقَ كُلِّ سَوَالِكِ"],
      ["وَنَشْهَدُ لِلْمَوْلَى عَظِيمَ امْتِنَانِهِ", "بِتَفْوِيضِ أَمْرِي لِلْعَظِيمِ التَّدَارِكِ"],
      ["يُحِبُّ رَسُولَ اللَّهِ حَقًّا وَذِكْرَهُ", "عَلَيْهِ صَلَاةُ اللَّهِ رَبِّ الْمَلَائِكِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ فِي كُلِّ لَحْظَةٍ", "وَآلٍ وَصَحْبٍ وَالْمُقَبِّلِ الْمَنَاسِكِ"]
    ]
  }