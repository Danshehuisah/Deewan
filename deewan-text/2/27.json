{
    "id": 27,
    "title": "حرف الهاء",
    "huruf": [
      ["سَلَامٌ عَلَى طَهَ النَّبِيِّ الْوَجِيهِ", "لَدَى الْحَضْرَةِ الْعَلْيَاءِ النَّبِيهِ التَّلِيهِ"],
      ["سَلَامٌ عَلَيْهِ مِنْ خَدِيمٍ مُتَّبِعٍ", "بِحُسْنِ مُحَيَّا مَا لَهُ مِنْ شَبِيهِ"],
      ["مُحَيًّا بِهِ شَمْسُ النَّهَارِ قَدْ أَشْرَقَتْ", "يَقُوذُ خَدِيمٌ قَدْ تَأَمَّلَ فِيهِ"],
      ["عَلَى أَحْمَدَ خَيْرِ الْوَرَى حَقَّ قَدْرِهِ", "صَلَاةٌ وَتَسْلِيمٌ عَدِيدَ سِنِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُبَعْدُ أَعْدَائِي وَكُلَّ سَفِيهِ"],
      ["فَهْوَ سِلَاحِي وَهْوَ سَيْفِي وَمِغْفَرِي", "بِهِ أَرُدُّ عَنِّي مَكْرَ كُلِّ فَقِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَشْفَعُ فِينَا فَهْوَ خَيْرُ وَجِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يَشْفِينِي فَوْقَ كُلِّ شَفِيهِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ وَكُلِّ ذَوِيهِ"],
      ["عَلَيْهِ مِنَ الْعَبْدِ الْخَدِيمِ تَحِيَّةٌ", "تَقُودُ تَحَايَا الْكُلِّ فَوْهًا لِفِيهِ"]
    ]
  }