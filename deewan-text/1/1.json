 {
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["أَبَى الْقَلْبُ إِلَّا أَنْ يَكُونَ مُتَيَّمَا", "خَلِيفَ غَرَامٍ بِالنَّبِيِّ مُهَيَّمَا"],
      ["أَبِيتُ بِلَيْلِ التَّمِّ سَهْرَانَ مُنْشِدًا", "لِذِكْرِ الَّذِي قَدْ طَابَ بَدْءًا وَمَخْتَمَا"],
      ["أُسَاجِلُ فِيهِ الْوَرْقَ لَيْلًا وَجِيرَتِي", "نِيَامٌ وَجَفْنِي كَالْمَذَانِبِ مَغْرَمَا"],
      ["أُنَظِّمُ دُرَّ اللَّفْظِ فِي ذِكْرِ وَصْفِهِ", "فَأَحْسِنْ بِوَصْفِ الْبَدْرِ دُرًّا مُنَظَّمَا"],
      ["مُحَمَّدٌ مِفْتَاحُ الْفُتُوحَاتِ سَيِّدِي", "وَخَاتِمُ سِلْكِ الرُّسْلِ خَتْمًا مُقَدَّمَا"],
      ["بِهِ نَالَ كُلُّ الْأَنْبِيَاءِ مَنَالَهُمْ", "وَبِهِ زِينَةُ الْأَكْوَانِ وَقْرًا وَمُعَظَّمَا"],
      ["رَسُولٌ مِنَ الْمَوْلَى وَآدَمُ لَمْ يَكُنْ", "وَلَا دَائِمًا وَمُعَظَّمَا"],
      ["فَنَشْأَتُهُ كَنْزِيَّةُ الْحَقِّ وَحْدَهُ", "لِذَلِكَ أَتَى قَاسِمًا وَمُقَسَّمَا"],
      ["فَأَيُّ الرُّسُلِ أَيُّ مُحَمَّدٍ", "فَمِنْهُ إِلَيْهِ كُلُّ شَأْنٍ مُعَمَّمَا"],
      ["مُحَمَّدٌ هُوَ الْعَرْشِ رَبُّ مَوَاهِبِ", "وَهُوَ الرَّحِيمُ فَأَكْرَمَا"],
      ["بَشِيرٌ نَذِيرٌ مُقْسِطٌ وَهُوَ قَاسِمٌ", "جَوَادٌ كَرِيمٌ بِسْطُ الْكَفِّ مُنْعِمَا"],
      ["مُجْتَبًى فِي الرُّسُلِ وَهُوَ أَمِينٌ مُقَدَّمَا", "حَبِيبُ إِلَهِ الْعَرْشِ بَدْءًا وَخَتْمَا"],
      ["وَأَبْيَضُ يُسْتَسْقَى الْغَمَامُ بِوَجْهِهِ", "بِهِ نُورُ لَيْلِ الْجَهْلِ إِذْ كَانَ مُظْلِمَا"],
      ["قُلُوبُ جَمِيعِ الْخَلْقِ أَحْيَا بِنُورِهِ", "وَأَلْسِنَتُهُمْ أَحْيَا بِفَضْلٍ وَعِلْمَا"],
      ["وَاللَّهُ لَا تَلْفِي الثَّنَا فِي حَمْدِهِ", "فَأَحْمَدُ فَرْدُ جَوْهَرٍ لَنْ يُقَسَّمَا"],
      ["صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ آلِهِ وَالصَّحْبِ الْكِرَامِ ذَوِي النَّمَا"],
      ["فَإِنْ تَسْأَلُوا عَنْ حَبِيبٍ سِوَى يَدِي", "فَحُبُّهُ حَبِيبُ اللَّهِ مَا غَيْرُهُ"],
      ["وَقْتٌ وَسَاعَاتٌ صَرَفْتُ لِذِكْرِهِ", "صَلَاةً وَمَدْحًا مِنْهُ قَدْ صِرْتُ جَمِيلًا"],
      ["فَمَنْ رَامَ دَرْكَ الشَّوْقِ فِي اشْتِيَاقِ نَبِيِّنَا", "فَقَدْ رَامَ أَمْرًا لَا يُحِلُّ مُحَرَّمَا"],
      ["كَمَنْ رَامَ مِسْكَ الْبَدْرِ يَوْمًا بِأُصْبُعٍ", "وَمَنْ رَامَ عَوْدَ الشَّمْسِ يَوْمًا وَأَيَّامَا"],
      ["وَلَكِنَّهُمْ قَدْ غَادَرُوا مُتَرَدِّمًا", "وَقَدْ أَكْثَرُوا أَيْضًا فِي الْوَصْفِ"],
      ["فَآثَرْتُ حُبَّ الْمُصْطَفَى دُونَ غَيْرِهِ", "وَلَوْ أُمَّ كُلْثُومٍ وَلَوْ كَانَ مَرْيَمَا"],
      ["فَوَاللَّهِ مَا فِي الْقَلْبِ حَظٌّ لِغَيْرِهِ", "فَغَيْرُ رَسُولِ اللَّهِ لَيْسَ لَهُ نَصِيبٌ"],
      ["أَشَارَ إِلَى الْمُزْنِ فَسَالَ مُسْرَمَدًا", "وَإِذَا رَامَ مِسْكَ الْمَاءِ أَمْسَكَ مُلْهَمَا"],
      ["وَإِنْ قُرَيْشًا عَابُوهُ وَصَغَّرُوا", "فَقَدْ شُقَّ لَهُ الْجَوُّ بَدْرًا مُعَظَّمَا"],
      ["رُدَّتْ لَهُ الشَّمْسُ بَعِيدَ غُرُوبِهَا", "وَكَذَّبُوا إِذْ أَنْزَلَ الْحَقُّ مُحْكَمَا"],
      ["وَهَدَمَ الْأَحْزَابَ بِرَمْيَةٍ مِنْ كَفِّهِ", "فَيَا عَجَبًا مِنْ رَمْيِهِ حِينَ هَدَّمَا"],
      ["هَدَى اللَّهُ أَقْوَامًا بِنُورِ خَوَارِقٍ", "وَبِسَيْفِهِ يَهْدِي الْبَدْرَ مَنْ كَانَ مُجْرِمَا"],
      ["يُفِيدُ عُلُومًا فَائِضَاتٍ وَمَغْنَمًا", "وَيُبِيدُ جُيُوشًا لِلضَّلَالِ عَرَمْرَمَا"],
      ["فَعَمَّ هُدَاهُ الْأَرْضَ كَرْهًا وَطَاعَةً", "فَعَرَبٌ وَعَجَمٌ أَرْشَدَ الْكُلَّ أَعَمَّا"],
      ["وَتَحْتَ لِوَاءِ الدِّينِ وَالْعِلْمِ وَالتُّقَى", "فَقَدِ انْتَهَى الْأَمْرُ بِالنَّبِيِّ مُحَتَّمَا"],
      ["وَصَارَ فِينَا الْمُسْلِمُونَ وَبَيْنَنَا", "أَئِمَّةُ عِلْمٍ صَالِحُونَ مُكَرَّمَا"],
      ["وَفِينَا رِجَالٌ سَابِقُونَ وَعِنْدَنَا", "خُتِمَتْ بِهِ الْأَقْطَابُ كَنْزًا مُطَلْسَمَا"],
      ["صَلَاةٌ وَتَسْلِيمٌ عَلَى أَحْمَدٍ", "وَآلٍ وَأَصْحَابٍ صِرَاطًا مُقَوَّمَا"]
    ]
  }