{
    "id": 7,
    "title": "حرف الراء",
    "huruf": [
      ["رَمَمْتُ رِكَابَ الشَّوْقِ أَنْحُو الْمَجْعَفَا", "بِهِ جَمَعَ اللَّهُ الْمُفَاخِرَ أَجْمَعَا"],
      ["خَرَجْتُ بِهِ مِنْ كُلِّ ضِيقٍ وَشِدَّةٍ", "دَخَلْتُ بِهِ حِضْنًا حَصِينًا مُمْتِعَا"],
      ["نَبِيٌّ عَظِيمُ الْقَدْرِ مِفْتَاحُ رَحْمَةٍ", "بِهِ صِرْتُ عَيْنَ الْجَنَّةِ لُيْنًا مُدَرَّعَا"],
      ["لِسَانِي بِذِكْرِ الْمُصْطَفَى سَيَّالَةٌ", "مَدِيدُ ذِكْرِ الْعُرْفِ دَهْرًا مُشَيَّعَا"],
      ["سَأَخِذُهُ فِي كُلِّ وَقْتٍ وَبُرْهَةٍ", "إِلَى اللَّهِ شُكْرًا مُنْشِدًا وَمُقَطَّعَا"],
      ["لِأَنِّي مَتَى أَلْزَمْتُ فِكْرِي مَدْحَهُ", "خَلَصْتُ مِنَ الْآثَامِ أَجْمَعَ أَكْتَنَعَا"],
      ["خَلَصْتُ مِنَ الْإِشْرَاكِ وَالشَّلَاقِ وَالْوَنَى", "إِلَى جَنَّةِ الْعِرْفَانِ حُسْرًا مُقَنَّعَا"],
      ["وَتَزْدَادُ ذِكْرَ الْمُصْطَفَى الدَّهْرَ رَاحَتِي", "وَرُوحِي وَرَوْحِي سَامِعًا وَمُسْتَعَا"],
      ["وَمَدْحُ سِوَى الْهَادِي الْمُقْتَى مَذَلَّةٌ", "وَمِنْهُ فَكُلُّ الْمَدْحِ فِيهِ مُجْتَمَعَا"],
      ["فَمِنْ جُودِهِ الدُّنْيَا وَالْأُخْرَى وَعِلْمُهُ", "أَمَدَّ فَلَمْ يَبْقَ بَعْضُ الَّذِي وَعَى"],
      ["وَمِنْ حُسْنِهِ حُورُ الْجِنَانِ تَزَيَّنَتْ", "وَمِنْ نُورِهِ نُورُ الْبُدُورِ تَتَرَّعَا"],
      ["وَمِنْ آيِهِ آيُ الَّذِينَ قَبْلَهُ", "فَلَيْسَ سِوَى الْمُخْتَارِ خَتْمًا رَفَعَا"],
      ["فَكُنْتُ الْبَرَايَا وَهْوَ سِرُّ إِلَهِهِ", "فَلَوْلَاهُ لَا تُلْفَى غَرِيبًا تَمَتَّعَا"],
      ["أَذْكُرُ حَاجَاتِي أَمْ أَسْكُتُ سَيِّدِي", "عَلَيْكَ صَلَاةُ اللَّهِ وَالصَّحْبِ أَجْمَعَا"]
    ]
  }