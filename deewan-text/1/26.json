{
    "id": 26,
    "title": "حرف الظاء",
    "huruf": [
      ["ظَعَنْتُ وَقُدْتُ الْخَلْقَ بِالْمَدْحِ اَلْفَظُ", "وَحُبَّ رَسُولِ اللَّهِ وَالْعَهْدَ اَحْفَظُ"],
      ["نَسِيرُ بِسَيْرٍ يَزْدَرِي وَحْدَ بَازِلٍ", "وَلِي مِقْوَلٌ يَحْدُوا وَبِالْمَدْحِ يَلْفَظُ"],
      ["وَقَدْ عَلِمَ الْأَقْوَامُ اَنِّي مُبَرَّزٌ", "وَمِنْ مَرَضٍ جَارُواْ عَلَيَّ وَأَغْلَظُواْ"],
      ["وَاِنَّى أُبَالِ وَالرَّسُولُ مُجَاوِرِي", "إِذَا صَدَّ أَرْبَابُ النُّفُوسِ وَأَحْفَظُوا"],
      ["وَإِنِّيَ عَبْدُ اللَّهِ أَتْلُوا كِتَابَهُ", "وَ جَنْبَ رَسُولِ اللَّهِ دَهْرِي أُقَرِّظُ"],
      ["وَإِنَّ رِجَالَ اللَّهِ دَانُوا لِطَاعَتِي", "وَلِي بِرَسُولِ اللَّهِ دِرْعٌ مُغَلَّظُ"],
      ["فَعَيْنُ عِنَايَاتِ الْإِلَهِ بِفَضْلِهِ", "بِبَدْوٍ وَمِصْرٍ جَانِبِي الدَّهْرَ تَلْحَظُ"],
      ["وَمَنْ لَا حَظَتْهُ عَيْنُهَا خَفَّ كُلَّمَا", "يُخَافُ عَلَيْهِ وَالْعَدُوُّ يُقَرِّظُ"],
      ["فَأَشْكُرُ رَبِّي بِالْأَمِينِ وَوُدِّهِ", "سَأَخْدِمُهُ مَدْحًا مَدَى الدَّهْرِ يُحْفَظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ مَا قَالَ صَادِقٌ", "وَحُبَّ رَسُولِ اللَّهِ وَالْعَهْدَ اَحْفَظُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "كَذَاكَ سَلَامٌ مَا الْجَنَابُ مُقَرَّظُ"]
    ]
  }