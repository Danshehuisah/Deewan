{
    "id": 22,
    "title": "حرف الخاء",
    "huruf": [
      ["خَدَمْتُ رَسُولَ اللَّهِ شَوْقًا مُحَادِثًا", "بِهِ سَامِرًا فِي ذِكْرِهِ وَمُنَافِضًا"],
      ["حَمَلْتُ وَرَبِّي بِالْوِدَادِ أَمَانَةً", "وَعَهْدًا أُرَاعِيهَا وَلَمْ أُلْفَ نَاكِثًا"],
      ["رَفَعْتُ لِوَاءَ الْحُبِّ وَالدِّينِ سَامِيًا", "وَقَدْ رُضْتُ هَمَّامًا وَمَنْ كَانَ خَارِثًا"],
      ["عَرِفْتُ لِذِكْرِ الْمُصْطَفَى شَغَفًا بِهِ", "وَنَامَ أَخِي وَكَانَ عِنْدِي مُحَادِثَا"],
      ["فَأَرْتَعْتُ نُجْبَ الْفِكْرِ فِي رَوْضِ وَصْفِهِ", "بِمَرْتَعِ أُنْسٍ لَمْ أَجِدْ فِيهِ عَائِثَا"],
      ["فَيَا لَكَ مِنْ مَرْعًى هُنَاكَ وَمَرْتَعٍ", "بَهِيجٍ خَمِيلٍ قَدْ نَضَا وَخَابِثَا"],
      ["وَيَغْدُو طُولَ الدَّهْرِ شَمُّ أَرِيجِهِ", "لِسَامٍ وَخَامٍ ثُمَّ مَنْ كَانَ يَافِثَا"],
      ["مُحَمَّدٌ حَمَّدَ اللَّهَ أَحْمَدٌ حَامِدٌ", "عَلَيْهِ صَلَاةُ اللَّهِ مُثْنَى وَثَالِثَا"],
      ["عَلَيْهِ صَلَاةُ الذَّاتِ بِالذَّاتِ وَحْدَهَا", "وَيَعْلُو غَرَامِي بِالْمَدَائِحِ نَافِثَا"],
      ["بِأَضْعَافِ مَا يَجْرِي مِنَ الْآنِ دَائِمًا", "وَمَا تَقِتُ لِلْمَحْبُوبِ فِيهِ مُحَادِثَا"]
    ]
  }