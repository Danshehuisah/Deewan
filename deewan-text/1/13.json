{
    "id": 13,
    "title": "حرف الميم",
    "huruf": [
      ["مُحَمَّدُ عَبْدُ اللَّهِ غَيْرُ مُشَبَّهِ", "بِهِ بَشَرٌ مَنْ رَامَ ذَالِكَ سَفِّهِ"],
      ["فَهُو صِفَةٌ شَبَّهْتُهُ بِاسْمِ فَاعِلٍ", "وَلَيْسَ بِشِبْهِ الْمُصْطَفَى غَيْرُ عَيْنِهِ"],
      ["مُحَمَّدُ لَمْ يَعْرِفْهُ غَيْرُ إِلَاهِهِ", "يَضِيقُ جَمِيعُ الْكَوْنِ عَنْ حَمْلِ كَوْنِهِ"],
      ["تَعَرَّفَ فِيهِ الْحَقُّ وَهْوَ مُنَكَّرٌ", "مُطَلْسَمُ سِرٍّ لَا يَرِيمُ بِقُدْسِهِ"],
      ["مُحَمَّدُ شَمْسُ الْحَقِّ فَضْلاً وَشُهْرَةً ", "فَهُو الْعَلَمُ الْمَعْرُوفُ عَيْنُ تَنَزُّهِ"],
      [ "جَمَادَاتُ هَاذَا الْكَوْنِ تَدْرِي مُحَمَّدًا", "كَذَا الْعُجْمُ وَالْأَعْجَامُ مِنْ بَعْدِ عُرْبِهِ"],
      ["تَنَكَّرَ مَعْرُوفًا لَدَى كُلِّ عَاقِلٍ", "فَمَا عُرِفَ الْمُخْتَارُ إِلَّا بِنَفْسِهِ"],
      ["فَمِنَّا أَتَانَا مُرْسَلاً وَهْوَ رَحْمَةٌ", "مِنَ اللَّهِ مَوْلَى الْخَلْقِ أَعْظِمْ بِخُلْقِهِ"],
      ["وَزَكَّاهُ رَبُّ الْعَرْشِ وَهْوَ مُبَرِّزٌ", "وَ قَرَّبَهُ قُرْبًا يَحَالُ لِجِنْسِهِ"],
      ["وَمَا وَلَدَ الرَّحْمَانُ فَهْوَ عُبَيْدُهُ", "فَجَلَّ إِلَاهِي لَيْسَ شَيْءٌ كَمِثْلِهِ"],
      [ "وَلَا كِنَّ أَعْلَى الْخَلْقِ فَضْلاً وَرُتْبَةً ", "مُحَمَّدُ ذَاكَ الْعَبْدُ دُونَ مُشَبَّهِ"],
      ["لِذَا تَامَ قَلْبِي قَدْ سَلَوْتُ لِحُبِّهِ", "جمِيعَ أَحِبَّاءِي وَذَادُونَ كَتْمِهِ"],
      ["فَمَا شَاقَ قَلْبِي الْغِيدُ مَا الْغِيدُ بَلْهَهَا", "سَرَابٌ لَدَى طَاهَ الْأَمِينِ الْمُنَزَّهِ"],
      ["تَسَلَّيْتُ عَنْ لَيْلَى وَ مَيْلَى وَ تَنْدَمِ", "بِطَاهَ أَمِينِ اللَّهِ حِبِّي الْمُنَوَّهِ"],
      ["نَبِيذِي وَخَمْرِي الدَّهْرَ سَرْدُ مَدِيحِهِ ", "وَ ذَالِكَ حِصْنِي وَهْوَ جَيْشِي لِنَصْرِهِ"],
      [ "كَفَانِي افْتِخَارًا فِي حَيَاتِي وَبَعْدَهَا", "بِأَنَّ نَبِيِّى الْمُصْطَفَى خَيْرُ رُسُلِهِ"],
      ["وَأَنِّي عُبَيْدُ اللَّهِ أَتْلُوا كِتَابَهُ", "وَذَالِكَ فَخْرٌ أَيُّ فَخْرٍ كَعَدْلِهِ"],
      ["وَإِنِّي وَإِنْ كُنْتُ الْأَخِيرَ زَمَانِهِ", "لَأَرْجُوا بِشَارَاتِ الْأَمِينِ لِصَحْبِهِ"],
      ["سَيَاتِي زَمَانٌ لَا يَزَالُ وَأُمَّتِي", "وَمَا قَالَ فِي عِيسَى سُلُوٌ لِحِزْ بِهِ"],
      ["فَيَارَبِّ فَاسْلُكْ بِي وَحِزْ بِي صِرَاطَهُ ", "وَلَوْ كَانَ قَبْضُ الْجَمْرِ فِي قَفْوِ نَهْجِهِ"],
      ["عَلَيْهِ صَلَاةُ الْحَقِّ فِي كُلِّ لَحْظَةٍ", "مَعَ الْآلِ وَالْأَصْحَابِ وَالْمُقْتَدِي بِهِ"]
    ]
    
