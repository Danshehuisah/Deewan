{
    "id": 17,
    "title": "حرف الضاد",
    "huruf": [
      ["ضَمِنْتُ لِخَيْرِ الْخَلْقِ عَنْ صَفْوِ صَفَائِي", "وِدَادِي مَعَ صَفْوِي وَتَنَائِبِي"],
      ["فَأُنْسِي وَرُوحِي إِنْ ذَكَرْتُ مُحَمَّدًا", "آيَ الْكَوْنِ بَحْرِ الْجُودِ عَيْنَ سَحَائِي"],
      ["جَمِيلُ الْمُحَيَّا مَعْدِنُ الْخَيْرِ كَامِلٌ", "جَلِيلٌ عَظِيمُ الْخُلْقِ رَبُّ لِوَاءِ"],
      ["رَسُولٌ أَمِيرٌ أَجْمَلُ النَّاسِ صُورَةً", "وَأَكْمَلُهُمْ فِي شِدَّةٍ وَرَخَاءِ"],
      ["تَرَقَّى رُقِيًّا مُسْتَحِيلًا لِغَيْرِهِ", "دَنَا فَتَدَلَّى نَالَ خَيْرَ جِبَاءِ"],
      ["رَأَى رَبَّهُ حَقًّا بِعَيْنٍ وَصُورَةٍ", "وَكُلٌّ سِوَى هَذَا وَرَاءٍ وَرَاءِ"],
      ["نَبِيٌّ أَتَانَا شَافِعًا ذَا سَكِينَةٍ", "رَحِيمًا عَظِيمًا ذَا هُدًى وَوَلَاءِ"],
      ["فَسَبْعٌ تَلَتْ سَبْعًا مَثَانِيَ جَهْرَةً", "وَلِلَّهِ مَا أَعْلَى صِفَاتٍ شِفَاءِ"],
      ["فَصَلَّى عَلَيْهِ اللَّهُ فِي كُلِّ طَرْفَةٍ", "عَدِيدَ الْحَصَى وَالرَّمْلِ وَفْقَ مُنَاءِ"],
      ["وَيُغْدِقُ مِنْهُ كُلَّ وَقْتٍ بِشَارَةً", "إِلَى أَبَدِ الْآبَادِ مَحْضَ عَطَاءِ"],
      ["شِتَائِي وَصَيْفِي الدَّهْرَ سَرْدُ مَدِيحِهِ", "وَلَسْتُ أَرَى التَّفْرِيسَ قَبْلَ لِقَاءِ"],
      ["بِهِ أَرْتَجِي قَلْبَ الْمَسَاوِي بِفَضْلِهِ", "مَحَاسِنَ أَحْبَابٍ وَتَبْلَى صَفَاءِ"],
      ["بِهِ أَرْتَجِي كَوْنِي خَدِيمَ جَنَابِهِ", "فَتَخْدُمُنِي أَهْلُ الْبَرَى وَسَمَاءِ"],
      ["وَكَوْنِي لَدَى الْمُخْتَارِ أَوْ عِنْدَ حَيْثُهُ", "كَحَاضِرِ بَدْرٍ ثُمَّ نَبْعَثَ رِضَاءِ"],
      ["وَكَوْنِي لَدَى الْمُخْتَارِ مِثْلَ صِحَابِهِ", "وَأَحْبَابِهِ أَوْ مِثْلَ أَهْلِ عَبَاءِ"],
      ["صَلَاةٌ وَتَسْلِيمُ الْإِلَهِ بِقَدْرِهِ", "عَلَى الْمُصْطَفَى وَالصَّحْبِ أَهْلِ عَلَاءِ"]
    ]
  }