{
    "id": 19,
    "title": "حرف السين",
    "huruf": [
      ["سَلَامٌ عَلَى مَنْ نَارِ لِلْأَسْرَارِ تَابِعٍ", "وَمَرْكَرِ آلَاءِ الْإِلَهِ السَّوَابِعِ"],
      ["فَهْوَ الدُّرَّةُ الْبَيْضَاءُ أَوَّلُ خَامِدٍ", "وَمَغْدِدِ تَحْقِيقٍ وَأَوَّلُ دَامِعِ"],
      ["وَأَوَّلُ تَوْجِيدٍ وَأَوَّلُ قَائِمٍ", "وَأَوَّلُ مَوْصُولٍ إِلَى الْحَقِّ تَابِعِ"],
      ["فَسُبْحَانَ رَبِّي قَدَّسَ الْعَبْدَ سِرُّهُ", "بِنُورٍ نَقَى الْأَنْوَارَ مِنْ كُلِّ تَابِعِ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ طَهَ أُحِبُّهُ", "بِحُبِّ إِلَهِ الْخَلْقِ مُسْدِي الْبَوَارِغِ"],
      ["كَفَانِي افْتِخَارًا أَنِّي شُغِفْتُ بِحُبِّهِ", "سَكِرْتُ بِخَمْرٍ مِنْ وِدَادِكَ سَائِغِ"],
      ["كَفَانِي بِأَنَّ طَهَ وَحَّدَ رَبَّهُ", "وَأَثْنَى عَلَيْهِ رَادِعًا كُلَّ رَائِعِ"],
      ["عَلَى عَابِدِ الذَّاتِ الْمُقَرَّبِ دَائِمًا", "صَلَاةً وَتَسْلِيمًا عَدِيدَ الْبَوَازِغِ"],
      ["وَآلٍ وَأَصْحَابٍ مَدَى قَوْلِ شَيْءٍ", "سَلَامٌ عَلَى مَنْ نَارِ لِلْأَسْرَارِ تَابِعِ"]
    ]
  }