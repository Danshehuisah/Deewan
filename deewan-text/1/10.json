{
    "id": 10,
    "title": "حرف الياء",
    "huruf": [
      ["يَمَمْتُ رَسُولَ اللَّهِ طَاهَ الْمُقَدَّسَا", " عَنِ النِّدِّ وَالْأَضْدَادِ أَصْلاً مُأَسَّسَا"],
      ["رَسُولٌ وَأَصْلُ النَّاسِ مَاءٌ وَجَنْدَلٌ", " فَلَا إِنْسَ فِي ذَاكَ الزَّمَانِ مُأَنِّسَا"],
      ["تَطَوَّرَ فِي الْأَطْوَارِ فِي كُلِّ هَيْكَلٍ", " وَحَتَّى بَدَى لِلنَّاسِ قَرْماً مُقَدَّسَا"],
      ["وَجَاءَ بِأَمْرِ اللَّهِ يَدْعُوا مُبَشِّراً", " نَذِيرًا شَكُورًا ذَاكِرًا وَمُقَدِّسَا"],
      ["هَدَى اللَّهُ أَقْوَامًا قَفَوْهُ أَجِلَّةً", " وَضَلَّلَ قَوْمًا قَدْ قَلَوْهُ وَطَمَّسَا"],
      ["اَلَا فَاذْكُرِ الصِّدِّيقَ ثَانِي حَبِيْبِنَا", " فَقَدْ أَنْفَقَ الْأَمْوَالَ عَمَّرَ أَنْفُسَا"],
      ["وَهَرْولُ إِلَى ذِكْرِ السِّرَاجِ مَلَاذِنَا", " وَذَا عُمَرُ الْفَارُوقُ مَنْ لَنْ يُوَسْوَسَا"],
      ["وَثَلِّثْ بِذِي النُّورَيْنِ عُثْمَانَ مَادِحاً"," فَقَدْ بَدَّدَ الْأَمْوَالَ فِي اللَّهِ مُنْفِسَا"],
      ["وَحِبِّي وَزِيرِ الْبَدْرِ بَابِ عُلُومِهِ", " عَلِيٍّ أَبِي السِّبْطَيْنِ لَيْثًا مُقَلْنِسَا"],
      ["بِجَاهِ رَسُولِ اللَّهِ وَالصَّحْبِ جُمْلَةً", " فَنَفِّسْ كُرُوبِي نَفِّسِ الْكَرْبَ نَفِّسَا"],
      ["صَلَاةٌ وَتَسْلِيمٌ عَلَيْهِ بِقَدْرِهِ", " معَ الْآلِ وَالْأَصْحَابِ مِمَّنْ تَقَدَّسَا"]
]
        
  }