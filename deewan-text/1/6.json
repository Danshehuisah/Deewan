{
    "id": 6,
    "title": "حرف الواو",
    "huruf": [
      ["وُقِيتُ بِرَبِّي جَادَ لِي بِاللَّطَائِفِ", "وَالْمُصْطَفَى الْمُخْتَارِ عَيْنِ الْمَعَارِفِ"],
      ["شُؤُونِي رَفَعْتُ الْكُلَّ لِلَّهِ سَيِّدِي", "وَوَاسِطَتِي الْمَحْمُودُ بَابُ الْمُطَائِفِ"],
      ["لَيْتَ شَطَّ أُحَيٍّ بِالْأَمِينِ مَزَارُهُ", "فَمَشْهَدُهُ فِي الْقَلْبِ لَيْسَ بِصَارِفِ"],
      ["حَبِيبُ إِلَهِ الْعَرْشِ فَدْعًا أُحِبُّهُ", "وَأَذْكُرُهُ يَوْمِي وَأَمْسِي وَآتِيَا"],
      ["حَبِيبٌ خَلِيلٌ خَاتِمٌ وَمُقَدَّمٌ", "كَرِيمٌ عَظِيمٌ خُلُقُهُ عِنْدَ عَارِفِ"],
      ["بَشِيرٌ نَذِيرٌ عَاقِبٌ وَتَنَاهُ", "بِهِ جَاءَ بِالْفُرْقَانِ بَعْدَ الصَّحَائِفِ"],
      ["حَلَفْتُ يَمِينًا إِنَّهُ الدَّهْرَ مُفْرَدٌ", "فَلَا يَتَأَتَّى أَنْ يُرَى بِطَارِفِ"],
      ["وَإِنَّ لِكُلِّ الْأَنْبِيَاءِ خَوَارِقًا", "مِنَ الْمُصْطَفَى قَدْ حَازَهَا كُلُّ خَارِفِ"],
      ["وَهُمْ كُلُّهُمْ عُرْضٌ سِرَاهُ أَجِلَّةٌ", "وَمَا كَانَ مِنْ عَبْدِ اللَّهِ عِنْدَ الطَّوَائِفِ"],
      ["فَمُوسَى وَإِبْرَاهِيمُ مَعَ نَجْلِ مَرْيَمَ", "لَهُمْ رُتْبَةٌ وَالْكُلُّ أَمْنٌ لِخَائِفِ"],
      ["وَلَكِنَّ الْمُخْتَارَ أَرْفَعُ مَنْصِبًا", "وَمِنْهُ نَوَالُ الْأَقْدَمِينَ الْغَطَارِفِ"],
      ["فَمِنْهُ عُلُومُ الْعَالَمِينَ فَآدَمُ", "بِهِ عَلَّمَ الْأَسْمَاءَ قَبْلَ التَّفَارِفِ"],
      ["فَسَادَةُ ذَا أَوْلَادُهُ وَهْوَ سَيِّدٌ", "لِسِرِّ وُجُودِ الْكَوْنِ جَمِّ الْمَعَارِفِ"],
      ["فَأَوْصَافُهُ قُدْسِيَّةٌ وَهْوَ قَدْ سَمَا", "عَلَى رُتْبَةِ الْأَرْسَالِ فَوْقَ السَّقَائِفِ"],
      ["فَآتَاهُمْ آيَاتُهُ وَهْوَ قَدْ سَقَى", "جُيُوشًا بِفَيْضٍ مِنْ يَنَانٍ لِطَائِفِ"],
      ["وَسَبَّحَتِ الْأَحْجَارُ فِي وَسْطِ كَفِّهِ", "وَأَحْيَا الَّذِي قَدْ مَاتَ رَأْسَ الطَّوَائِفِ"],
      ["مَسِسْتَ تَحُوطُهُ الْأَشْجَارُ وَالدِّينُ", "أَفَضْتُ كَذَا عَلَيْهِ وَالصَّبُّ إِفْضَاحُ عَارِفِ"],
      ["وَتَعْدَادُ آيِ الْمُصْطَفَى لَيْسَ نَافِعًا", "فَلَيْسَ بِشَيْرِ الْمَشْرِ مَا فِي الصَّحَائِفِ"],
      ["فَيَا رَبِّ فَاجْعَلْنِي لَهُ الدَّهْرَ خَادِمًا", "وَكُفَّ عَنِّي يَا رَبِّ كَيْدَ الْمَكَارِفِ"],
      ["وَنَفْسِيَ أَبْقِهَا تُبْلِهَا رَشَادًا", "فَلَا تُلْفِ عَبْدًا يَرْتَجِي الرَّخَارِفِ"],
      ["وَأَصْلِحْ شُؤُونَ الْمُتَّقِينَ لِحِزْبِهِمْ", "بَدَا فِي الْقِلَالِ وَالْأَرْضِ أَمْ كُلٌّ عَاكِفِ"],
      ["وَلَا تُشْمِتِ الْأَعْدَاءَ يَوْمًا بِوَاحِدٍ", "فَأَنْتَ جَمِيلٌ قَادِرٌ دُونَ الْمَصَارِفِ"],
      ["صَلَاةٌ وَتَسْلِيمٌ عَلَى مَنْ سَمَا بِهِ", "مَعْدُو بْنُ عُدْوَانَ رُؤُوسُ الْعَطَارِفِ"],
      ["وَالٍ وَأَصْحَابٍ مَدَى قَوْلِ مُوقِنٍ", "وُقِيتُ بِرَبِّي جَادَ لِي بِاللَّطَائِفِ"]
    ]
