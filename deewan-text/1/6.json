{
    "id": 6,
    "title": "حرف الواو",
    "huruf": [
      ["وَثِقْتُ بِرَبِّ جَادَ لِي بِاللَّطَآئِفِ", "وَبِالْمُصْطَفَى الْمُخْتَارِ عَيْنِ الْمَعَارِفِ"],
      ["شُؤُونِي رَفَعْتُ الْكُلَّ لِلَّهِ سَيِّدِي", "وَوَاسِطَتِي الْمَحْمُودُ بَابُ الْلَّطَآئِفِ"],
      ["لَءِنْ شَطَّ عَنِّي بِالْأَمِينِ مَزَارُهُ", "فَمَشْهَدُهُ فِي الْقَلْبِ لَيْسَ بِصَارِفِ"],
      ["حَبِيبُ إِلَاهِ الْعَرْشِ قِدْمًا أُحِبُّهُ", "وَأَذْكُرُهُ يَوْمِي وَأَمْسِي وَآنِفِ"],
      ["حَبِيبٌ خَلِيلٌ خَاتِمٌ وَمُقَدَّمٌ", "كَرِيمٌ عَظِيمٌ خُلُقُهُ عِنْدَ عَارِفِ"],
      ["بَشِيرٌ نَذِيرٌ عَاقِبٌ وَثَنَاؤُهُ", "بِهِ جَاءَنَا الْفُرْقَانُ بَعْدَ الصَّحَائِفِ"],
      ["حَلَفْتُ يَمِينًا إِنَّهُ الدَّهْرَ مُفْرَدٌ", "فَلَا يَتَأَتَّى أَنْ يُثَنَّى بِطَارِفِ"],
      ["وَإِنَّ لِكُلِّ الْأَنْبِيَاءِ خَوَارِقًا", "مِنَ الْمُصْطَفَى قَدْ حَازَهَا كُلُّ خَارِفِ"],
      ["وَهُمْ كُلُّهُمْ غُرٌّ سَرَاةٌ أَجِلَّةٌ", "وَمَا كَابْنِ عَبْدِ اللَّهِ عِنْدَ الطَّوَائِفِ"],
      ["فَمُوسَى وَإِبْرَاهِيمُ مَعْ نَجْلِ مَرْيَمٍ", "لَهُمْ رُتْبَةٌ وَالْكُلُّ أَمْنٌ لِخَائِفِ"],
      ["وَلَاكِنَّمَا الْمُخْتَارَ أَرْفَعُ مَنْصِبًا", "وَمِنْهُ مَنَالُ الْأَقْدَمِينَ الْغَطَارِفِ"],
      ["فَمِنْهُ عُلُومُ الْعَالَمِينَ فَءَادَمٌ", "بِهِ عَلِّمَ الْأَسْمَاءَ قَبْلَ التَّعَارُفِ"],
      ["فَسَادَ بِذَا أَوْلَادُهُ وَهْوَ سَيِّدٌ", "لِسِرِّ وُجُودِ الْكَوْنِ جَمُّ الْمَعَارِفِ"],
      ["فَأَوْصَافُهُ قُدْسِيَّةٌ وَهْوَ قَدْ سَمَى", "عَلَى رُتْبَةِ الْأَرْسَالِ فَوْقَ السَّقَائِفِ"],
      ["فَءَايَاتُهُمْ ءَايَاتُهُ وَهْوَ قَدْ سَقَى", "جُيُوشًا بِفَيْضٍ مِنْ يَنَانٍ لَطَائِفِ"],
      ["وَسَبَّحَتِ الْأَحْجَارُ فِي وَسْطِ كَفِّهِ", "وَأَحْيَا الَّذِي قَدْ مَاتَ رَأْسُ الطَّوَائِفِ"],
      ["مَشَتْ نَحْوَهُ الْأَشْجَارُ وَالذِّيبُ أَفْصَحَتْ", "كَذَا ظَبْيَةٌ وَالضَّبُّ إِفْضَاحَ عَارِفِ"],
      ["وَتَعْدَادُ ءَايِ الْمُصْطَفَى لَيْسَ نَافِعًا", "فَلَيْسَ عُشَيْرَ الْعُشْرِ مَا فِي الصَّحَآئِفِ"],
      ["فَيَا رَبِّ فَاجْعَلْنِي لَهُ الدَّهْرَ خَادِمًا", "وَكُفَّ عَنِّي يَا رَبِّ كَيْدَ الْمَكعَارِفِ"],
      ["وَتَشْفِي بُنَيِّى وَابْقِهِ وَتُنِيلُهُ", "رَشَادًا فَلَا يُلْفَى عُبَيْدَ الزَّخَارِفِ"],
      ["وَأَصْلِحْ شُؤُونَ الْمُنْتَمِينَ لِحِزْبِنَا", "بَدَوْ فِي الْفَلَا وَالْأَرْضِ أَمْ كُلٌّ عَاكِفِ"],
      ["وَلَا تُشْمِتِ الْأَعْدَاءَ يَوْمًا بِوَاحِدٍ", "فَأَنْتَ جَمِيلٌ قَادِرٌ ذُوالْمَصَارِفِ"],
      ["صَلَاةٌ وَتَسْلِيمٌ عَلَى مَنْ سَمَتْ بِهِ", "مَعَدُّبْنُ عَدْنَانِ رُؤُوسُ الْغَطَارِفِ"],
      ["وَءَالٍ وَأَصْحَابٍ مَدَى قَوْلِ مُوقِنٍ", "وُثِقْتُ بِرَبِّ جَادَ لِي بِاللَّطَائِفِ"]
    ]
