{
    "id": 4,
    "title": "حرف الدال",
    "huruf": [
      ["دَعَانِي مِنْ سَلْمَى وَلَيْلَى وَقَلَّا", "لِتَذَكُّرِ رَبَّاتِ الْغَدَائِرِ مُسْجَالَا"],
      ["لِذِكْرِ الَّذِي مِنْ ذِكْرِهِ طِيبَ قَبْلَهُ", "عَلَى أَدَمٍ إِذْ كَانَ فَرْعًا مُؤَصَّلَا"],
      ["لِذِكْرِ الَّذِي لَمْ يَذْكُرِ الْحَقُّ غَيْرَهُ", "مَدَى الدَّهْرِ وَالْأَيَّامِ خَيْرِ مَنْ أُرْسِلَا"],
      ["لِذِكْرِ الَّذِي تَعْرُو فُؤَادِيَ هَزَّةٌ", "لَدَى ذِكْرِهِ وَالْقَلْبُ صَارَ مُقَتَّلَا"],
      ["لِذِكْرِ الَّذِي طَابَ الْجَنَانُ بِنَشْرِهِ", "وَمِنْهُ ضِيَاءُ الْبَدْرِ بَدْرًا مُكَمَّلَا"],
      ["فَلَوْلَاهُ لَا تُلْفَى لَيَالٍ فَإِنَّهُ", "لَبَذْرَةُ هَذَا الْكَوْنِ إِذْ كَانَ مُرْسِلَا"],
      ["وَلَوْلَاهُ لَا أَرْضَ حَيَاةٍ بِلَحْظَةٍ", "فَحَيٌّ بِغَيْرِ الْمُصْطَفَى الْبَدْرِ أَهْمَلَا"],
      ["وَمَنْ بِصِفَاتِ الْمُصْطَفَى حَازَ كُلَّهَا", "حَيَاةً وَمَوْتًا نَالَ عِزًّا مُبَجَّلَا"],
      ["مَآثِرُ خَيْرِ الْخَلْقِ لَمْ يُحْصَ عَدُّهَا", "فَقُلْ فِيهِ مَا قَدْ شِئْتَ عَبْدًا مُفَضَّلَا"],
      ["فَيَا رَبِّ فَاجْعَلْنِي لَدَيْهِ مُقَرَّبًا", "وَصَحْبِي وَأَحْبَابِي وَمَنْ كَانَ مُوصَلَا"],
      ["وَتَجْعَلْنَا لِلْمُتَّقِينَ أَئِمَّةً", "إِلَى أَبَدِ الْآبَادِ سَبْطًا مُرْسَلَا"],
      ["وَلَيِّنْ صُخُورَ الْمَارِدِينَ وَهُدَّهُمْ", "وَقَوِّ التُّقَى الْمُتَّقِينَ ذَوِي الْعَلَا"],
      ["وَأَعْنِ فَقِيرَ الْمُتَّقِينَ لِحِزْبِهِ", "وَنَجِّ جَمِيعَ الْمُؤْمِنِينَ مِنَ ابْتِلَا"],
      ["نَرْقُقْهُمْ يَا رَبِّ بِالشُّكْرِ دَائِمًا", "فَإِنَّكَ مَلْجَأُ الْعَاجِزِينَ مُجَلِّلَا"],
      ["أَيَا رَبُّ يَا مَنْ جُنْدُهُ الدَّهْرَ غَالِبٌ", "وَلَوْ ضَعُفُوا آرَاؤُهُمْ يَا مُؤَمِّلَا"],
      ["لَكَ الْحَمْدُ وَالشُّكْرُ الْمُسْرَمُ دَائِمًا", "فَلَمْ يَخْشَ مَنْ يُلْجَا إِلَيْكَ مُوَكِّلَا"],
      ["صَلَاةً وَتَسْلِيمًا عَلَى طَهَ أَحْمَدٍ", "وَآلٍ وَأَصْحَابٍ وَمَنْ كَانَ مُرْسَلَا"]
    ]
  }