{
    "id": 11,
    "title": "حرف اللام",
    "huruf": [
      ["لِلنَّضْدِ عَنْ قَبْرِ أَحْمَدَ سَرْبَخُ", "فَمَا نَضْدِي عَنْ شَوْقِهِ الدَّهْرَ فَرْسَخُ"],
      ["وَمَا نَضْدِي عَنْ ذِكْرِهِ عَذَلُ عَاذِلٍ", "فَقَدْ زَادَنِي تَذْكَارَ طَهَ الْمُوتَخُ"],
      ["لِسَانِي وَقَلْبِي الدَّهْرَ ذِكْرُ مُحَمَّدٍ", "وَمَنْ حَالُهُ حَالِي مَدَى الدَّهْرِ يَشْخَخُ"],
      ["فَإِنَّ قَرِينَ الْمَرْءِ حَقًّا حَبِيبُهُ", "وَلَوْ كَانَ بُعْدٌ بَيْنَ ذَيْنِ فَيُفْسَخُ"],
      ["وَإِنِّي إِلَى الْعَلْيَاءِ أَدْرَجُ حُبَّهُ", "عَلَى حُبِّ خَيْرِ الْعَلْيَاءِ يَا مَنْ يُوجِعُ"],
      ["كَذَا طَاعَةُ الْهَادِي كَطَاعَةِ رَبِّهِ", "وَتَذْكَارُهُ تَذْكَارُهُ وَهْوَ مُصْحِحُ"],
      ["فَمَنْ بَايَعَ الْمُخْتَارَ فَهْوَ مُبَايِعٌ", "لِدَيْهِ إِلَى الْعَرْشِ ذَلِكَ أَشْجَعُ"],
      ["كَفَانِي وِدَادُ الْخَتْمِ طَهَ مُحَمَّدٍ", "مَوَدَّتُهُ عِنْدِي مِنَ الصَّمِّ أَرْسَخُ"],
      ["وَرُبَّمَا كُلُّ الْمَادِحِينَ قَصِيرَةٌ", "عَنْ إِدْرَاكِ مَا عِنْدِي فَسَبْقِي يَرْسَخُ"],
      ["فَبَيْنِي وَبَيْنَ الْمَادِحِينَ سَرَابِحٌ", "وَعِيرٌ فَمَا جِئْتُ لِمَدْحِي بِسَرْحِ"],
      ["فَبِشِعْرِي أَوْصَافُ الْمَادِحِينَ سَرَابِحٌ", "عَدِيمَةٌ كُفِّئَتْ فَهْوَ أَحْمَدُ يَصْرُخُ"],
      ["صَلَاةٌ وَتَسْلِيمٌ عَلَى طَهَ أَحْمَدٍ", "وَآلٍ وَصَحْبٍ مِثْلَ طِيبٍ يُصْبِخُ"]
    ]
  }