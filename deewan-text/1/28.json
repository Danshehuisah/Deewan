{
    "id": 28,
    "title": "حرف الشين",
    "huruf": [
      ["شَمَخْتَ عَنِ الْأَكْوَانِ يَا خَيْرَ مُنْقِذِى", "وَفُقْتُ بِمَدْحٍ فَآئِقٍ لِزُمُرُّذِ"],
      ["رَسُولٌ مِنَ الذَّاتِ الْمُقَدَّسِ سِرُّهَا", "قُبَيْلَ وُجُودِ السِّرِّ أُنْسِي وَجِهْبِذِي"],
      ["نَبَذْتُ وَرَبِّ الْبَيْتِ حُبَّ سَوَآءِهِ", "اَلَا يَا حَبِيبَ الذَّاتِ سُوئِي اَلَا انْبِذِي"],
      ["فَإِنِّي لَعَمْرِي مَا بَقِيتُ مُتَيَّمٌ", "بِحُبِّ رَسُولِ اللَّهِ كَهْفِي وَمُنْقِذِى"],
      ["وَشُغْلِي مَدَى الْأَيَّامِ مَدْحُ جَنَابِهِ", "اَلَا يَا مَلَاذَ الْخَلْقِ جُدْلِي وَاَنْقِذِي"],
      ["وَقُدْنِي إِلَى الْمَحْبُوبِ جُدْلِيَ بِالْمُنَى ", "وَصِلْنِي فَاِنِّي لِلصِّلَاةِ لَكَالَّذِي"],
      ["اَتَيْتُ وَإِنَّ الْكُثْرَ قِلٌّ بِقِلَّتِي", "تَقَبَّلْ بِفَضْلٍ مِنْكَ خَيْرَ مُنَقِّذِى"],
      ["فَصَلَّى عَلَيْهِ اللَّهُ مِقْدَارَ قَدْرِهِ", "وَءَالٍ وَأَصْحَابٍ عَلَوْا كُلَّ جِهْبِذِي"]
    ]
  }