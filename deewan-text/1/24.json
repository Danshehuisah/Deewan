{
    "id": 24,
    "title": "حرف الظاء",
    "huruf": [
      ["ظَلَمْتُ وَقُدْتُ الْخَلْقَ بِالْمَدْحِ الْفَظِّ", "وَحُبَّ رَسُولِ اللَّهِ وَالْعَهْدَ أَحْفَظُ"],
      ["نَسِيرُ بِمَسْبُورِي يُزَدَّى وَخَذْ بَازِي", "وَلِي مِقْوَلٌ يَحْدُو وَبِالْمَدْحِ يَلْحَظُ"],
      ["وَقَدْ عَلِمَ الْأَقْوَامُ أَنِّي مُبَرَّرٌ", "وَمِنْ مَرَضٍ جَارُوا عَلَيَّ وَأَعْلَظُوا"],
      ["وَأَيْنَ بَلَدِي وَالرَّسُولُ مُجَاوِرِي", "إِذَا صَدَّ أَرْبَابُ النُّفُوسِ وَأَحْفَظُوا"],
      ["وَإِنِّي بِبَلَدِي وَالرَّسُولُ مُجَاوِرِي", "وَأَيْنَ بِبَلَدِي وَالرَّسُولُ مُجَاوِرِي"],
      ["وَإِنَّ رِجَالَ اللَّهِ دَاؤُوا لِطَاعَتِي", "وَلِي بِرَسُولِ اللَّهِ دِرْعٌ مُغَلَّظُ"],
      ["فَعَيْنُ عِنَايَةِ الْإِلَهِ بِفَضْلِهِ", "بَدَا وَمِصْرُ جَانِبِي الدَّهْرَ تَلْحَظُ"],
      ["وَمَنْ لَاحَظَتْهُ عَنْهَا خَفَّ كُلُّ مَا", "يُخَافُ عَلَيْهِ وَالْعَدُوُّ يُقَرِّظُ"],
      ["فَأَشْكُرُ رَبِّي بِالْأَمِينِ وَوُدِّهِ", "سَأَخِذُهُ مَدْحًا مَدَى الدَّهْرِ يُحْفَظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ مَا قَالَ صَادِقٌ", "وَحُبَّ رَسُولِ اللَّهِ وَالْعَهْدَ أَحْفَظُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "كَذَاكَ سَلَامٌ مَا الْجَنَابُ مُقَرِّظُ"]
    ]
  }