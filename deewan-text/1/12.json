{
    "id": 12,
    "title": "حرف الميم",
    "huruf": [
      ["مُحَمَّدُ عَبْدُ اللَّهِ غَيْرُ مُشَبَّهِ", "بِهِ نَشَرٌ مَنْ رَامَ ذَلِكَ يَسْقِهِ"],
      ["فَهْوَ صِفَةٌ شُبِّهْتُهُ بِاسْمِ فَاعِلِ", "وَلَيْسَ بِشِبْهِ الْمُصْطَفَى غَيْرُ غَيْنِهِ"],
      ["مُحَمَّدٌ لَمْ يَعْرِفْهُ غَيْرُ إِلَهِهِ", "يَضِيقُ جَمِيعُ الْكَوْنِ عَنْ حَمْلِ كَوْنِهِ"],
      ["تَغَرَّفَ فِيهِ الْحَقُّ وَهْوَ مُنَكَّرٌ", "مُطَلْسَمُ سِرٍّ لَا عَرِيمُ بِقُدْسِهِ"],
      ["مُحَمَّدُ شَمْسُ الْحَقِّ فَضْلًا وَشُهْرَةً", "فَهْوَ الْعَلَمُ الْمَعْرُوفُ عَيْنُ تَنَرُّهِ"],
      ["جَمَادَاتُ هَذَا الْكَوْنِ تَذْرِي مُحَمَّدًا", "كَذَا الْعُجْمُ وَالْأَعْجَامُ مِنْ بَعْدِ عُرْبِهِ"],
      ["تُذَكِّرُ مَعْرُوفًا لَدَى كُلِّ عَاقِلٍ", "فَمَا عُرِفَ الْمُخْتَارُ إِلَّا بِنَفْسِهِ"],
      ["فَمَا أَتَانَا مُرْسَلًا وَهْوَ رَحْمَةٌ", "مِنَ اللَّهِ مَوْلَى الْخَلْقِ أَعْظَمْ بِخَلْقِهِ"],
      ["وَرَقَّاهُ رَبُّ الْعَرْشِ فَهْوَ مُبَتَّرٌ", "وَقُرْبُهُ قُرْبًا مُحَالٌ لِجُسْئِهِ"],
      ["وَمَا وَلَدَ الرَّحْمَنُ فَهْوَ عَبْدُهُ", "فَجَلَّ إِلَهِي لَيْسَ شَيْءٌ كَمِثْلِهِ"],
      ["وَلَكِنَّ أَعْلَى الْخَلْقِ فَضْلًا وَرُتْبَةً", "مُحَمَّدٌ ذَاكَ الْعَبْدُ دُونَ مُشَبَّهِ"],
      ["لِذَا هَامَ قَلْبِي قَدْ سَلَوْتُ لِحِبِّهِ", "جَمِيعَ أَجِنَّتِي وَذَا دُونَ كُنْهِهِ"],
      ["فَمَا شَاقَ قَلْبِي الْغِيدُ مَا الْغِيدُ بَلْهَ", "سَرَابٌ لَدَى طَهَ الْمُبِينِ الْمُدَرَّهِ"],
      ["تَسَلَّيْتُ عَنْ لَيْلَى وَمَيْلَى وَتَنْدُمٍ", "بِطَهَ أَمِينِ اللَّهِ جِبِّي الْمُنَوَّهِ"],
      ["نَبِيدِي وَخَمْرِي الدَّهْرَ سَرْدُ مَدِيحِهِ", "وَذَلِكَ حِضْنِي وَهْوَ جُبِّي لِنَصْرِهِ"],
      ["كَفَانِي افْتِخَارًا فِي حَيَاتِي وَبَعْدَهَا", "بِأَنَّ نَبِيَّ الْمُصْطَفَى خَيْرُ رُسُلِهِ"],
      ["وَلِي عَبْدُ اللَّهِ أَتْلُو كِتَابَهُ", "وَذَلِكَ فَخْرٌ أَيُّ فَخْرٍ كَعِدْلِهِ"],
      ["وَإِلَّا وَإِنْ كُنْتُ الْأَخِيرَ زَمَانِهِ", "فَأَرْجُو بِشَارَاتِ الْأَمِينِ لِصَحْبِهِ"],
      ["سَيَأْتِي زَمَانٌ لَا يَزَالُ وَأُمَّتِي", "وَمَا قَالَ فِي عِيسَى سُلُوٌّ لِحِزْبِهِ"],
      ["فَيَا رَبِّ فَاسْلُكْ بِي وَحِزْبِي صِرَاطَهُ", "وَلَوْ كَانَ قَبْضُ الْجَمْرِ فِي قَفْوِ نَهْجِهِ"],
      ["عَلَيْهِ صَلَاةُ الْحَقِّ فِي كُلِّ لَحْظَةٍ", "مَعَ الْآلِ وَالْأَصْحَابِ وَالْمُفْتَدِي بِهِ"]
    ]
  }