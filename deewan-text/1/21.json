{
    "id": 21,
    "title": "حرف السين",
    "huruf": [
      ["سلَامٌ عَلَى مُزْنٍ لِلأَسْرَارِ بَالِغِ", "وَ مَرْكَزِ ءَالاَءِ الْإِلَهِ السَّوَابِغِ"],
      ["فَهُو الدُّرَّةُ الْبَيْضَاءُ أَوَّلُ حَامِدٍ", "وَمَعْدِنُ تَحْقِيقٍ وَأَوَّلُ دَامِغ"],
      ["وَأَوَّلُ تَوْحِيدٍ وَأَوَّلُ قَآئِمٍ", "وَأَوَّلُ مَوْصُولٍ إِلَى الْحَقِّ بَالِغِ"],
      ["فَسُبْحَانَ رَبٍّ قَدَّسَ الْعَبْدَ سِرَّهُ", "بِنُورٍ نَفَى الْأَنْوَارَ مِنْ كُلِّ بَازِغِ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ طَاهَ أُحِبُّهُ", "بِحُبِّ إِلَهِ الْخَلْقِ مُسْدِى الْبَوَازِغِ"],
      ["گفَانِي افْتِخَارًا أَنْ شُغِفْتُ بِحُبِّهِ", "سَكِرْتُ بِخَمْرٍ مِنْ وِدَادِكَ سَآئِغِ"],
      ["كَفَانِي بِأَنَّ طَاهَ وَحَّدَ رَبَّهُ", "وَاُثْنِي عَلَيْهِ رَادِعًا كُلَّ زَآئِغِ"],
      ["عَلَى عَابِدِ الذَّاتِ الْمُقَرَّبِ دَآئِماً", "صَلَاةٌ وَتَسْلِيمٌ عَدِيدَ الْبَوَازِغِ"],
      ["وَءَالٍ وَأَصْحَابٍ مَدَى قَوْلِ شَيِّقٍ", "سَلَامٌ عَلَى مُزْنٍ لِلأَسْرَارِ بَالِغِ"]
    ]
  }