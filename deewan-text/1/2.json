{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["بَلِيتُ بِحُبِّ الْمُصْطَفَى الْخَتْمِ أَحْمَدَا", "أَبِى الْكَوْنِ وَالْأَخْلَاقِ فَرْعًا وَمَحْتِدَا"],
      ["أَتَانِي هَوَاهُ قَبْلَ أَنْ أَعْرِفَ الْهَوَى", "صَلِيتُ بِنِيرَانِ اشْتِيَاقِيَ أَحْمَدَا"],
      ["عَلِقْتُ بِهِ وَالنَّاسُ فِي سِنَةِ الْكَرَى", "تَمَتَّعْتُ مِنْهُ الدَّهْرَ إِذْ كُنْتُ مُفْرَدَا"],
      ["وَزُوحِمْتُ فِي هَذَا الزَّمَانِ وَإِنَّنِي", "لَفِى غِيْرَةٍ مِمَّنْ يَرُومُ مُحَمَّدَا"],
      ["وَلَكِنَّنِي جَلَّيْتُ قَبْلَ سِبَاقِهِمْ", "وَقَدْ نِلْتُ تَبْرِيزَ الْقُرُونِ لِأَحْمَدَا"],
      ["وَلِمْ لَا وَعِزُّ الْعَبْدِ عِزُّ مَلِيكِهِ", "فَطَوْعُ يَمِينِي الْكَوْنُ عَبْدًا مُسَوَّدَا"],
      ["أَلَا يَا رَسُولَ اللَّهِ فَارْفَعْ شِكَايَتِي", "إِلَيْكَ وَحَالِي مَا تَرَى الْعَبْدَ سَوِّدَا"],
      ["فَحَاجِي وَحَاجَ الْمُسْلِمِينَ أَحَلْتُهُ", "عَلَيْكَ فَطِبْتُ النَّفْسَا حُرًا مُسَرْمَدَا"],
      ["زَمَانِيَ طَلْقُ الْوَجْهِ غَيْرُ مُكَدَّرٍ", "أَرُوحُ وَأَغْدُو دَآئِمًا لَنْ أَكَمَّدَا"],
      ["أُغَادِي الصَّبُوحَ عِنْدَ أَفْضَلِ مُرْسَلٍ", "وَمَنْ بِرَسُولِ اللَّهِ لَمْ يَخْشَ جَلْمَدَا"],
      ["تَوَلَّى رَسُولُ اللَّهِ أَمْرِي فَلَمْ يَزَلْ", "يُسَاعِدُنِي دَهْرِي فَصِرْتُ مُمَجَّدَا"],
      ["وَإِنَّ اعْتِنَاءَالْمُصْطَفَى عَيْنُ كِيمِيَا", "فَقَدْ صَارَ عَذْبًا مَاءُ مِلْحٍ تَعَوَّدَا"],
      ["وَلَانَ بَعِيرٌ كَانَ صَعْبًا وَأَيْنَعَتْ", "نَخِيلٌ بِعَامٍ بِيْرُهُ صَارَ مُزْبِدَا"],
      ["وَأَعْتِقَ سَلْمَانٌ بِشَوْقِ حَبِيْبِنَا", "وَلَا تَتَنَاهَى لَوْ مَلَأْتَ الْمُجَلَّدَا"],
      [" لِأنَّ الَّذِى لِلْأَ نْبِيَا مِنْ خَوَارِقٍ", "بِهِ نَالَهَا الاَرْسَالُ خَيْرًا مُحَشَّدَا "],
      ["كَذَاكَ كَرَامَاتٌ لِأَ هْلِ وِلاَيَةِ", " فَمِنْهُ اُنِيلُوا مَا اُنِيلُوا لِيُحْمَدَا"],
      [" لِتَكْفِيَ عَنَّا وَاكْفِنَا الدَّهْرَ سَيِّدِى", " جَمِيعَ شُرُورِ قَدْ قَضَيتَ وَاَيِّدَا"],
      ["وَمُدَّ صِفَاتِى مِنْ صِفَاتِكَ سَرْمَدًا", "وَكَمِّلْ لِعِرْفَانِي وَعِلْمِي وَسَدِّدَا  َا"],
      ["وَتُبْصِرُنِي  وَالْمُنْتَمِيْنَ  لِحِزْبِنَا ", "مَنَاهِجَ حَقِّ الحَقِّ دَهْرًا مُاَبَّدَا"],
      ["وَتَهْدِيَنَا نَهجَ الرَّشَادِ اَيِمَّةَ", "لِأَهْلِ التُّقَى وَالْفَوْزِ جُنْدًا مُجَنَّدَا "],
      ["صَلاَةٌ وَتَسْلِمٌ عَلَى مَنْ سَمَتْ بِهِ", " جَمِيعُ الْوَرَى وَالصَّحْبِ وَالْآلِ أَحْمَدَا"]
    ]
  }