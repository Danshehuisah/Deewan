{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["بَلِيتُ بِحُبِّ الْمُصْطَفَى الْخَتْمِ أَحْمَدَا", "أَبَا الْكَوْنِ وَالْأَخْلَاقِ فَرْعًا وَمُحْتَدَا"],
      ["أَتَانِي هَوَاهُ قَبْلَ أَنْ أَعْرِفَ الْهَوَى", "صَلِيتُ بِبِيرَانِ اشْتِيَاقِي أَحْمَدَا"],
      ["عُلِفْتُ بِهِ وَالنَّاسُ فِي سِنَةِ الْكَرَى", "تَمَتَّعْتُ مِنْهُ الدَّهْرَ إِذْ كُنْتُ مُفْرَدَا"],
      ["وَزُحْزِحْتُ فِي هَذَا الزَّمَانِ وَإِنَّنِي", "لَغَيْرَةٍ مِمَّنْ يَسُومُ مُحَمَّدَا"],
      ["وَلَكِنَّنِي جَلَّيْتُ قَبْلَ سِبَاقِهِمْ", "وَقَدْ نِلْتُ تَبْشِيرَ الْقُرُونِ لِأَحْمَدَا"],
      ["وَلِمَ لَا وَعِزُّ الْعَبْدِ عِزُّ مَلِيكِهِ", "فَطَلْعُ يَمِينِي الْكَوْنُ عَبْدًا مُسَوَّدَا"],
      ["أَلَا يَا رَسُولَ اللَّهِ فَارْفَعْ شَكَاتِي", "إِلَيْكَ وَخَالِي مَا تَرَى الْعَبْدَ سَيِّدَا"],
      ["فَحَاجِي وَحَاجُ الْمُسْلِمِينَ أَجَلُّهُ", "عَلَيْكَ فَطِبْ نَفْسًا خَضِرًا مُسْرَمَدَا"],
      ["زَمَانِي طَلْقُ الْوَجْهِ غَيْرُ مُكَدَّرٍ", "أَرُوحُ وَأَغْدُو دَائِمًا لَنْ أَكْمَدَا"],
      ["أُغَادِي الصُّبُوحَ عِنْدَ أَفْضَلِ مُرْسَلٍ", "وَمَنْ يَرْعَ رَسُولَ اللَّهِ لَمْ يَخْشَ جَلْمَدَا"],
      ["تَوَلَّى رَسُولُ اللَّهِ أَمْرِي فَلَمْ يَزَلْ", "مُسَاعِدَنِي دَهْرِي فَصِرْتُ مُمَجَّدَا"],
      ["وَإِنَّ اغْتِنَاءَ الْمُصْطَفَى عَيْنُ كِيمِيَا", "فَقَدْ صَارَ عَذْبًا مَاءُ مِلْحٍ تَعَوَّدَا"],
      ["وَلَانَ بَعِيرٌ كَانَ صَعْبًا وَأَيْسَرَتْ", "نَخِيلٌ بِغَامٍ بِئْرُهُ صَارَ مُزْبِدَا"],
      ["وَأَعْتَقَ سَلْمَانٌ بِشَوْقٍ مُحَمَّدًا", "وَلَا تَتَنَاهَى لَوْ مَلَأْتَ الْمُجَلَّدَا"]
    ]
  }