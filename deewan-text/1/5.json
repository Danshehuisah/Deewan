{
    "id": 5,
    "title": "حرف الهاء",
    "huruf": [
      ["هَوَى الْمُصْطَفَى الْمُخْتَارِ خَالَطَ مُضْمَرِي", "وَكُلِّي وَجَنْبِي فِيهِ سِرِّي وَمَظْهَرِي"],
      ["إِذَا شَاءَ ضَوْءُ الْبَدْرِ مِلْءُ لِذِكْرِهِ", "وَأَذْكُرُهُ فِي كُلِّ مَرْأَى وَمَنْظَرِ"],
      ["وَأَذْكُرُهُ عِنْدَ الْعَلَا وَإِذَا حَلَا", "مَذَاقُ قُهُوِّ عُمْرِي مَذَاقِي وَمُسْكِرِي"],
      ["وَأَذْكُرُهُ عِنْدَ الْبِلَا وَتَقَضِّي", "وَأَذْكُرُهُ فِي غَفْلَتِي مِثْلَ مَحْضَرِي"],
      ["وَأَذْكُرُهُ عِنْدَ الْحَبِيبِ وَلَمْ أَكُنْ", "لِأَنْسَاهُ وَقْتَ الْأَجْنَبِيِّ الْمُكَدِّرِ"],
      ["وَلَسْتُ أَرَى مُسْتَحْسَنًا غَيْرَ وَجْهِهِ", "فَلَيْسَ جَمَالٌ غَيْرُ وَجْهِهِ الْمُدَّثِّرِ"],
      ["مُرَادِيَ كَوْنِي الْمُصْطَفَى عَيْنَ عَيْنِهِ", "وَإِلَّا فَمَوْتِي فِيهِ شَوْقًا لِعُنْصُرِي"],
      ["وَلَوْلَا التَّلَذُّذُ فِي الْجِنَانِ بِنُورِهِ", "لَمَا حَنَّ نَحْوَ الْخُلْدِ كُلُّ مُبَصِّرِ"],
      ["وَلَيْتَ رَسُولَ اللَّهِ كَانَ مُجَاوِرًا", "لِتَرْحَمَ نَارًا خَالِدًا كُلَّ مُسْعَرِ"],
      ["وَلَيْتَنِي كَالصِّدِّيقِ بِلَى وَلَيْتَنِي", "وَلَيْتَنِي كَالْفَارُوقِ لَيْتَنِي كَجَعْفَرِ"],
      ["وَلَيْتَنِي أَكُونُ الْيَوْمَ ثَرْوَةً تَعْلُو", "وَلَيْتَنِي أَرْعَى لِأَمِينِ الْمُبَشِّرِ"],
      ["وَلَيْتَنِي يَوْمًا كُنْتُ شِرِّيعَةً مَاءَهُ", "وَحَامِلَ كَأْسٍ لِلْبَشِيرِ الْمُنَوِّرِ"],
      ["أُعَلِّلُ نَفْسِي بِالْوِصَالِ لَعَلَّهُ", "يَجُودُ بِوَصْلٍ لِلرَّفِيقِ الْمُحَرَّرِ"],
      ["صَلَاةٌ عَلَى يَاسِينَ طَهَ مُحَمَّدٍ", "مَعَ الْآلِ وَالْأَصْحَابِ غَيْرِ مُبَدَّدِ"]
    ]
  }