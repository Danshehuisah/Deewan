{
    "id": 5,
    "title": "حرف الهاء",
    "huruf": [
      ["هَوَى الْمُصْطَفَى الْمُخْتَارِ خَالَطَ مُضْمَرِي", "وَكُلِّي وَجُزْءِي فَهِْوَ سِرِّي وَمَظْهَرِي"],
      ["إِذَا ضَاءَ ضَوْءُ الْبَدْرِ مِلْتُ لِذِكْرِهِ", "وَأَذْكُرُهُ فِي كُلِّ مَرْأً وَمَنْظَرِي"],
      ["وَأَذْكُرُهُ عِنْدَ الْاَغَانِي وَإِذْ حَلَا", "مَذَاقٌ فَهُو عُمْرِي مُذَاقِي وَمُسْكِرِي"],
      ["وَأَذْكُرُهُ عِنْدَ الْبَلَا وَنَقِيْضِهِ", "وَأَذْكُرُهُ فِي غَيْبَتِي مِثْلَ مَحْضَرِي"],
      ["وَأَذْكُرُهُ عِنْدَ الْحَبِيبِ وَلَمْ أَكُنْ", "لِأَنْسَاهُ وَقْتَ الْأَجْنَبِيِّ الْمُكَدَّرِي"],
      ["وَلَسْتُ أَرَى مُسْتَحْسَنًا غَيْرَ وَجْهِهِ", "فَلَيْسَ جَمَالٌ غَيْرُ وَجْهِ الْمُدَّثِّرِي"],
      ["مُرَادِيَ كَوْنِي الْمُصْطَفَى عَيْنَ عَيْنِهِ", "وَإِلَّا فَمَوْتِي فِيهِ شَوْقًا لِعُنْصُرِي"],
      ["وَلَوْلَا التِذَاذٌ فِي الْجِنَانِ بِنُورِهِ", "لَمَا حَنَّ نَحْوَ الْخُلْدِ كُلُّ مُبَصَّرِي"],
      ["وَلَيْتَ رَسُولَ اللَّهِ كَانَ مُسَعِّرًا", "لِبَرْهَامَ نَارًا خَالِدًا كُلَّ مَسْعَرِي"],
      ["وَلَيْتِيَ كَالسِّبْطَيْنِ عِدْلَيْنِ فَوْقَهُ", "وَلَيْتِيَ كَالْصِّدِّيْقِ لَيْتِي كَجَعْفَرِ"],
      ["وَلَيْتِي أَكُونُ الْيَوْمَ ثَرْبَةَ نَعْلِهِ", "وَلَيْتِي أَرَاكٌ لِلْأَمِينِ الْمُبَشِّرِي"],
      ["وَلَيْتِيَ يَوْمًا كُنْتُ شُرْبَةَ مَآءِهِ", "وَحَامِلَ كَاسٍ لِلْبَشِيرِ الْمُنَوَّرِي"],
      ["أُعَلِّلُ نَفْسِي بِالْوِصَالِ فَعَلَّهُ", "يَجُودُ بِوَصْلٍ لِلرَّفِيقِ الْمُحَرَّرِي"],
      ["صَلَاةٌ عَلَى يَاسِينَ طَاهَ مُحَمَّدٍ", "مَعَ الْآلِ وَالْأَصْحَابِ غَيْرُ مُبَتَّرِي"]
    ]
  }