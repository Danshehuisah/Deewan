{
    "id": 18,
    "title": "حرف القاف",
    "huruf": [
      ["قَدِ اسْتَأْصَلَ الْمَحْبُوبُ كُلِّي وَجُمْلَتِي", "وَوَاصَلَنِي وَالْغَيْرَاتُ تَوَلَّتِ"],
      ["وَهَا أَنَّ هَذَا الْحِبَّ غَيْبٌ إِلَهِنَا", "وَقَلْبُ الْوَرَى وَالذَّاتُ فِيهِ تَجَلَّتِ"],
      ["وَصَلَّتْ عَلَيْهِ فَهْوَ بَطْنٌ وَظَاهِرٌ", "فَظَاهِرُهُ عَبْدٌ وَلِلْبَطْنِ صَلَّتِ"],
      ["أَفَاضَ لَهُ مِنْهُ إِلَيْهِ فَهَالَنِي", "مَحَبَّةَ رَسُولِ اللَّهِ وَالْعَيْنُ كَلَّتِ"],
      ["فَتَنْتَنِي شَوْقًا وَعَزَّ لِقَاؤُهُ", "إِذِ الْعِيسُ لَا تُجْدِي وَالْأَفْقَامُ ضَلَّتِ"],
      ["أَهِيمُ بِهِ طَوْرًا أَلَذُّ بِذِكْرِهِ", "فَأَسْلُو وَطَوْرًا لَمْ أُرَمْ غَيْرَ وَصْلَتِي"],
      ["وَطَوْرًا أَرَى أَنَّ الْحَيَاةَ مَرِيرَةٌ", "وَطَوْرًا أَرَاهَا بُغْيَتِي ثُمَّ وَلَّتِ"],
      ["وَتَذْكَارُ أَطْوَارِي بِشَوْقٍ حَبِينَا", "نَكِلُّ فَمِي وَهْوَ عَيْنُ مَضَلَّتِي"],
      ["صَلَاةٌ عَلَى عَيْنِ الْغَيْبِ وَغَيْبِهَا", "وَآلٍ وَصَحْبٍ مَا الْغُيُوبُ اضْمَحَلَّتِ"],
      ["رَفَعْتُ حِجَابَ الْبَيْنِ وَالْبَيْنُ لَنْ يُطْوَى", "وَأَبْعَدَتْ إِذْ أَذْهَبَتْ لِلْحِبِّ مَنْ يَهْوَى"],
      ["رُجُوعِي مِنَ الْمَوْلَى الْجَلِيلِ جَلَالُهُ", "إِلَيْهِ بِحُبِّ الْهَاشِمِيِّ وَلَا غَرْوَى"],
      ["رَأَيْتَ وَقَدْ مَدَّ الْمُهَيْمِنُ ظِلَّهُ", "يُصَلِّي عَلَى عَبْدٍ عَلَى الْجَهْرِ وَالتَّجْوَى"],
      ["رَسُولٌ أَتَانَا وَهْوَ سِرٌّ مُقَدَّسٌ", "وَأَرْسَلَهُ الْمَوْلَى مِنَ الْغَابَةِ الْقُصْوَى"],
      ["رَقِيتُ ذُرَى الْعِرْفَانِ مِنْ سِرِّ حُبِّهِ", "وَرُضْتُ عَوِيصَاتِ الْعُلُومِ وَلَا دَعْوَى"],
      ["رَسُولٌ مَتَى أَشْدُو بِإِنْشَاءِ مَدْحِهِ", "تَحُفُّ جَنَابِيَ الْمَكْرُمَاتُ كَمَا أَهْوَى"],
      ["رَفِيعُ الْآيَاتِ كَافِي الْعَبَادِ فَصَلِّنْ", "عَلَيْهِ صَلَاةً لَنْ تُحَاطَ وَلَنْ تُحْوَى"],
      ["رَحِيمُ الْآيَاتِ مِثَالُ مَنْ جَلَّ ذِكْرُهُ", "فَصَلِّ عَلَيْهِ وَارْفَعِ الضِّيقَ وَالشَّكْوَى"],
      ["رَسُولٌ حَبِيبٌ ذَاكِرٌ وَمُقَدَّسٌ", "فَعِيلٌ وَجُودُ الْكَائِنَاتِ وَلَا شَرْوَى"],
      ["رَمَيْتَ وَمَا رَمَيْتَ وَإِنَّمَا", "صِفَاتُ جَلَالٍ لِلْجَلِيلِ فَلَا مَأْوَى"],
      ["رَقِيبُ الْآيَاتِ هَادِي الْعَبِيدِ فَصَلِّنْ", "عَلَى الْمُصْطَفَى الْمَنْصُورِ مَنْ تُرْجَى بِهِ الْمُثْوَى"],
      ["رَؤُوفٌ شَكُورٌ وَهَّابٌ صَلِّنْ", "عَلَى الْمُصْطَفَى الْمُخْتَارِ يَا مَنْ لَهُ الْمَأْوَى"],
      ["صَلَاةً عَلَيْهِ مِثْلَ مَا اللَّهُ عَلَّمَ", "وَآلٍ وَصَحْبٍ مَا الْمُحِبُّ لَهُ يَهْوَى"]
    ]
  }