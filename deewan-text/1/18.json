{
    "id": 18,
    "title": "حرف الضاد",
    "huruf": [
      ["ضَمِنْتُ لِخَيْرِ الْخَلْقِ عَيْنِ صَفَاءِ", "صَفَاءَ وِدَادٍ مَعْ صَفَاءِ ثَنَآءِ"],
      ["فَأُنْسِي وَرَوْحِي إِنْ ذَكَرْتُ مُحَمَّدًا", "أَبَا الْكَوْنِ بَحْرَ الْجُودِ عَيْنَ سَخَآءِ"],
      ["جَمِيلُ الْمُحَيَّا مَعْدِنُ الْخَيْرِ كَامِلٌ", "جَلِيلٌ عَظِيمُ الْخُلْقِ رَبُّ لِوَآءِ"],
      ["رَسُولٌ أَمِينٌ أَجْمَلُ النَّاسِ صُورَةً", "وَأَكْمَلُهُمْ فِي شِدَّةٍ وَرَخَآءِ"],
      ["تَرَقَّى رُقِيًّا مُسْتَحِيلاً لِغَيْرِهِ", "دنَا فَتَدَلَّى نِيلَ خَيْرَ حِبَآءِ"],
      ["رَءَى رَبَّهُ حَقًّا بِعَيْنٍ وَصُورَةٍ", "وَكُلٌّ سِوَى هَاذَا وَرَاءَ وَرَآءِ"],
      ["نَبِيٌّ أَتَانَا شَافِعًا ذَا سَكِينَةٍ", "رحِيماً عَظِيمًا ذَا هُدًى وَوَلَآءِ"],
      ["فَسَبْعٌ تَلَتْ سَبْعاً مَثَانِيَ جَهْرَةً", "وَلِلَّهِ مَا أَغْلَى صِفَاتِ شِفَآءِ"],
      ["فَصَلَّى عَلَيْهِ اللَّهُ فِي كُلِّ طَرْفَةٍ", "عَدِيدَ الْحَصَى وَالرَّمْلِ وَفْقَ مُنَآءِ"],
      ["وَ يُعْطِيهِ مِنِّي كُلَّ وَقْتٍ بِشَارَةً", "إِلَى أَبَدِ الْآبَادِ مَحْضَ عَطَآءِ"],
      ["شِتَائِي وَصَيْفِ الدَّهْرَ سَرْدُ مَدِيحِهِ", "وَلَسْتُ أَرَى التَّعْرِيسَ قَبْلَ لِقَآءِ"],
      ["بِهِ أَرْتَجِي قَلْبَ الْمَسَاوِي بِفَضْلِهِ", "مَحَاسِنَ أَحْبَابٍ وَنَيْلَ صَفَآءِ"],
      ["بِهِ أَرْتَجِي كَوْنِي خَدِيمَ جَنَابِهِ", "فَتَخْدِمُنِي أَهْلُ الْبَرَا وَسَمَآءِ"],
      ["وَكَوْنِي لَدَى الْمُخْتَارِ أَوْ عِنْدَ رَبِّهِ", "كَحَاضِرِ بَدْرٍ ثُمَّ بَيْعِ رِضَآءِ"],
      ["وَكَوْنِي لَدَى الْمُخْتَارِ مِثْلَ صِحَابِهِ ", "وَأَحْبَابِهِ أَوْ مِثْلَ أَهْلِ عَبَآءِ"],
      ["صَلَاةٌ وَتَسْلِيمٌ الْإِلَهِ بِقَدْرِهِ", "عَلَى الْمُصْطَفَى وَالصَّحْبِ أَهْلِ عَلَآءِ"]
    ]
  }