{
    "id": 25,
    "title": "حرف الغين",
    "huruf": [
      ["غَرَامِي وَشَوْقِي لِلنَّبِيِّ يَنُشُطُ", "فَلَامِي وَتَجْرِي فِي الْمَدِيحِ وَتَقْرُطُ"],
      ["وَمَاذَا عَلَيَّ إِنْ جُنِنْتُ بِحُبِّهِ", "وَقَدْ صَارَ مِنْ تَحْتِي وَلِيدٌ وَأَشْيَطُ"],
      ["فَلَيْسَ عَلَيَّ اللَّوْمُ فِي مَدْحِ سَيِّدِي", "فَمَا شِئْتُهُ مَدْحًا فَلَمْ أَكُ أَفْرِطُ"],
      ["فَبَحْرٌ مِنَ الْأَسْرَارِ وَالْعِلْمِ زَاخِرٌ", "جَوَاهِرُهُ تُزْرِي الْعُقُودَ فَتَغْبِطُ"],
      ["وَبَدْرٌ مِنَ الْأَنْوَارِ وَالْهُدَى طَالِعٌ", "وَأَجْحَلَ شَمْسًا فِي الضُّحَى فَتَغْبِطُ"],
      ["وَلَيْثُ الْوَعَى جَمُّ التُّقَى صَارِمُ الْعِدَى", "وَيَقِسْمُ أَمْوَالَ الْإِلَهِ وَيَقْسِطُ"],
      ["فَهْوَ لِلْعِدَى فِي طَيِّهَا كُلُّ يَفْحَطُ", "جَلِيلٌ جَمِيلٌ مُصْلِحٌ وَهْوَ مُحْبِطُ"],
      ["أَفَادَ جُمُوعَ الْبِيضِ وَهْوَ أَبَادَهُمْ", "وَأَرْشَدَ مَنْ قَدْ كَانَ فِي الْغَيِّ يَحْبِطُ"],
      ["وَلِلنَّاسِ أَهْلِ الدِّينِ عِتْقٌ غَيْرُهُمْ", "خَبِيرٌ بَصِيرٌ وَاهِبٌ وَهْوَ مُقْسِطُ"],
      ["مُحَمَّدٌ مَاحِي الْكُفْرِ مَدُّ ضِيَائِهِ", "فَقَدْ جَمَعَ الْأَضْدَادَ يَعْلُو وَيَهْبِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ مَا قَالَ مُغْرَمٌ", "غَرَامِي وَشَوْقِي لِلنَّبِيِّ يَنُشِطُ"]
    ]
  }