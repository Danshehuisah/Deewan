{
    "id": 16,
    "title": "حرف الفاء",
    "huruf": [
      ["فَأَهْلًا بِشَهْرٍ قَدْ أَتَى بِالْمُخْتَصِّ", "مُحَمَّدٍ عَبْدِ اللَّهِ سِرِّ الْمُلْتَصِّ"],
      ["لَقَدْ جَالَ قَبْلَ الْكَوْنِ فِي الْغَيْبِ وَحْدَهُ", "بِعِزٍّ وَتَشْرِيفٍ وَسِرٍّ مُحْتَصِّ"],
      ["تَسَتَّرَ فِي الْأَلْبَاسِ فَالْكَوْنُ كُلُّهُ", "مُظَاهِرُ أَلْبَاسٍ لِهَذَا الْمُخْتَصِّ"],
      ["تَطَوَّرَ فِي الْأَطْوَارِ إِذْ كَانَ وَحْدَهُ", "يَتَكَرُّ عَنْ عَيْنِ الْبَصِيرِ الْمُحْتَصِّ"],
      ["فَأَهْلًا وَسَهْلًا مَرْحَبًا ثُمَّ مَرْحَبًا", "مَتَى جَاءَنَا الْمَخْصُوصُ سِرِّي وَمُخْلِصِي"],
      ["أَهْوَى نَفْسِي ثُمَّ يَوْمِي وَشَهْرَهُ", "كَذَا بَلَدًا قَدْ مَسَّنِي خَيْرُ أَخْمَصِ"],
      ["وَفِيهَا وَعَبْدَ اللَّهِ ثُمَّ عَقِيلَهُ", "أَتَتْ قَوْمَهَا بِالرُّوحِ عَنْ تَشْخُصِ"],
      ["صَلَاةٌ وَتَسْلِيمُ الْإِلَهِ بِقَدْرِهِ", "عَلَى الْمُصْطَفَى وَالْآلِ بَلْ كُلِّ مُخْلِصِ"]
    ]
  }