      ["شَمَخْتَ عَنِ الْأَكْوَانِ يَا خَيْرَ مُنْقِذِي", "وَفُقْتُ بِمَدْحٍ فَأَنِفِي لَزُمَرُدْ"],
      ["رَسُولٌ مِنَ الذَّاتِ الْمُقَدَّسِ سِرُّهَا", "فَبِيلُ وُجُودِ السِّرِّ أُنْسِي وَجُهْبُدِي"],
      ["تَبَدَّثْ وَرَبِّ الْبَيْتِ حُبَّ سِوَائِهِ", "أَلَا يَا حَبِيبَ الذَّاتِ سُوفِي أَلَا انْبِذِ"],
      ["فَإِنَّ لَعَمْرِي مَا بَقِي مُنْتَبِذٌ", "بِحُبِّ رَسُولِ اللَّهِ كَهْفِي وَمُنْقِذِي"],
      ["وَشُغْلِي مَدَى الْأَيَّامِ مَدْحُ جَنَابِهِ", "أَلَا يَا مَلَاذَ الْخَلْقِ جُدْ لِي وَأَنْفِذِ"],
      ["وَقُدْنِي إِلَى الْمَحْبُوبِ جُدْ لِي بِالْمُنَى", "وَصَلِّ فَإِنَّ لِلصَّلَوَاتِ لَكَالَّذِي"],
      ["أَبَتْ وَإِنَّ الْكُثْرَ قَلٌّ بِقَلْبِي", "تَقْتُلُ بِفَضْلٍ مِنْكَ خَيْرَ مُنْقِذِ"],
      ["فَصَلَّى عَلَيْهِ اللَّهُ مِقْدَارَ قَدْرِهِ", "وَآلٍ وَأَصْحَابٍ عَلَوْا كُلَّ جُهْبُدِ"]
    ]
  }
]