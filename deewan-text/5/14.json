{
    "id": 14,
    "title": "حرف النون",
    "huruf": [
      ["نُوَحِّدُ مَوْلَانَا بِأَنَّهُ مُنَّانُ", "وَبِالرُّسُلِ وَالْأَمْلَاكِ وَهْوَ الْمُهَيْمِنُ"],
      ["وَنَحِيمُ طَوْرًا عَنْ ثَنَاءِ نَبِيِّنَا", "قُصُورًا وَطَوْرًا بِالْمَدَائِحِ نُعْلِنُ"],
      ["وَإِنْ كُنْتُ لَمْ أُحْسِنْ مَدِيحَ مُحَمَّدٍ", "سَمَوْتُ أُورَاقًا بِحُبِّكَ أُعْلِنُ"],
      ["وَإِنْ كَتَبُوا الْمَدْحَ يَوْمًا وَأَثْبَتُوا", "سَمَاعِي أَكُنْ مِثْلَ الَّذِينَ قَدْ أَحْسَنُوا"],
      ["فَيَا فَوْزَ إِبْرَاهِيمَ إِنْ جَاءَ ذِكْرُهُ", "بِرُمْزَةٍ مَنْ يُثْنِي عَلَيْكَ وَيُحْسِنُ"],
      ["وَتَرْكِ تَمَامًا لِلْقُصُورِ أَثِيلَهُ", "مُحَالٌ فَرَأْيُ الَّذِينَ قَدْ أَحْسَنُوا"],
      ["عَسَى الْمُصْطَفَى يَوْمًا يَجُودُ بِنَظْرَةٍ", "تُغَيِّلُ أَوْزَارِي وَقَلْبِي تَسْمِنُ"],
      ["وَإِنْ شَاءَ قَوَّانِي لِحَمْلِ خِلَافَةٍ", "لِكَيْ أَرْفَعَ التَّوْحِيدَ وَالْكُلُّ مُؤْمِنُ"],
      ["لِلْجَهْلِ جُلُّ النَّاسِ أَقَلُّ بَعْضُهُمْ", "هَادٍ وَإِنِّي مُؤْمِنٌ بِكَ مُحْسِنُ"],
      ["فَأَرْفَعُ عَلَمًا لِلْجَهَالَةِ وَاضِعًا", "وَأَكْسِرُ رَايَاتِ الصَّلِيبِ وَأَدْفِنُ"],
      ["فَيُرْفَعُ الْجَوْزُ الْعَظِيمُ قَالَ تُرَى", "سِوَى الْعِلْمِ وَالدِّينِ الْحَنِيفِ يُزَيِّنُ"],
      ["فَتَمْسِي رِجَالُ اللَّهِ فِي ظِلِّ رَاحَةٍ", "وَعِزٍّ وَتَمْجِيدٍ وَبِالْحَقِّ أُعْلِنُوا"],
      ["يَكُونُ زِمَامُ الْعَالَمِينَ جَمِيعِهِمْ", "بِأَيْدِي رِجَالٍ بِالْعُلُومِ تَمَكَّنُوا"],
      ["فَتَأْتِي مَسِيحٌ وَالرِّجَالُ رِجَالُهُ", "يَدِينُ لِإِمَامٍ هَاشِمِيٍّ يَتَدَيَّنُ"],
      ["هُنَالِكَ عَمَّ الْفَيْضُ لَا شَكَّ لَنْ تَرَى", "سِوَى غَارِفٍ بِاللَّهِ وَالشَّرْعِ مُتْقِنُ"],
      ["فَيَحْكُمُ عِيسَى لَا تَكُونُ وِلَايَةٌ", "بَعِيدَ مَمَاتِ الرُّوحِ فَالْخَيْرُ يُدْفَنُ"],
      ["فَإِنْ لَمْ يَكُنْ مَنْ يَذْكُرُ اللَّهَ زُلْزِلَتْ", "زَلَازِلُ سَاعَاتٍ وَنَادَى الْمُؤَذِّنُ"],
      ["فَيَا رَبِّ حَقِّقْ بِالْأَمِينِ رَجَاءَنَا", "فَمَا لِي سِوَى أَنْ أَسْأَلَ اللَّهَ مُغْدِنُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا لِلدِّينِ قَصْرِي مَأْمَنُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ وَالدِّينِ قَدْ أَحْسَنُوا"]
    ]
