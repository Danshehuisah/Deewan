{
    "id": 4,
    "title": "حرف الدال",
    "huruf": [
      ["دُجَى الْكُفْرِ جَلَّاهُ الْإِمَامُ مُحَمَّدُ", "أَبُو الْقَاسِمِ الْمَاضِي الصَّلَالَاتِ أَحْمَدُ"],
      ["فَبِشُكْرِهِ طِرْسِي وَنَفْسِي وَلَقْلَقِي", "مَدَى الدَّهْرِ فَهْوَ الْمُنْتَقَى وَالْمَجْدُ"],
      ["وَيَشْكُرُهُ قَالِي وَحَالِي لَعَلَّنِي", "عَلَى كُلِّ حَالٍ يَصْطَفِينِي مُحَمَّدُ"],
      ["شِفَاءٌ لِأَمْرَاضِي مَدِيحُ جَنَابِهِ", "وَذَاكَ سِلَاحِي وَهُوَ سَبْقِيَ الْمُهْتَدُ"],
      ["نَبِيٌّ بِهِ قَدْ فَازَ كُلُّ مُقَرَّبٍ", "لَدَى الْحَضْرَةِ الْعَلْيَا فَذَاكَ الْمُصَمَّدُ"],
      ["فَسَعْدِي وَآتَانِي وَنَسْلِي بِذِكْرِهِ", "وَذَاكَ بِلَا فَخْرٍ عَلَى الْكُلِّ سَيِّدُ"],
      ["فَمَا فَخْرُهُ إِلَّا الْعُبُودَةُ لَمْ يَرُمْ", "سِوَاهَا وَذَاكَ الْفَخْرُ فَخْرٌ مُخَلَّدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "إِذَا كَرَّهَا دَهْرًا عَلَاةً وَسُؤْدَدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ بِهَا مَا لَمْ يَنَلْهُ مُسَوَّدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا عَهْدِي لَدَيْهِ مُؤَكَّدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا هَذَا الْعَبْدُ دَهْرًا مُؤَيَّدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا يُسْقَى ظِمَاءً وَيُزْدَدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بَيْنَ أَثْنَائِهَا الدَّهْرُ تَوْقَدُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَقْبَلُ مِنِّيَ الْمُنَى وَيُقَبِّطُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ سَلَكُوا نَهْجَ الْأَمِينِ وَوَحَّدُوا"]
    ]
  }