{
    "id": 26,
    "title": "حرف الغين",
    "huruf": [
      ["غَمَامٌ بِآلَاءِ الْإِلَهِ الْمُوَابِعُ", "قَدْ أَرْسَلَهُ الْمَوْلَى إِلَى كُلِّ بَابِعِ"],
      ["وَذَلِكَ شَرْعُ الْمُصْطَفَى وَكِتَابُهُ", "فَفِيهِ بِشَارَاتٌ وَكُلُّ الدَّوَابِعِ"],
      ["فَأَبْطِلْ أَيَا مَوْلَايَ كُلَّ مُمَوَّهٍ", "بِوَاضِحِ بُرْهَانٍ عَلَا كُلَّ دَابِعِ"],
      ["أَعِثْنَا أَيَا مَوْلَانَا مَنْ جَلَّ ذِكْرُهُ", "فَنَكْسِبَ مَنْ وَلَّى بِكُلِّ السَّوَابِعِ"],
      ["أَعِثْنَا أَعِثْنَا أَيَا مُغِيثُ فَإِنَّمَا", "أَلِفْنَا بِكَ الضَّرَّاءَ مِنْ كُلِّ سَابِعِ"],
      ["فَإِنْ لَمْ تُدَارِكْنَا فِي الْبِلَادِ وَأَهْلِهَا", "وَحَاشَاكَ ذَاقُوا مَطْعَمًا غَيْرَ سَائِغِ"],
      ["فَيَا رَبِّ عَافِ الْعَبْدَ وَالصَّحْبَ جُمْلَةً", "وَإِنْ فَاتَ فِي الطَّاعَاتِ غَيْرَ مُبَالِغِ"],
      ["وَلَكِنَّ حُبِّي فِي الْأَمِينِ مُحَكَّمٌ", "وَذَاكَ صِوَاعُ الْحَقِّ أَحْسَنَ ضَابِعِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِشُكْرٍ فِي قَلْبِي سَنًا كُلَّ بَارِعِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَلَى بَارِقٍ مُرْزِنٍ بِالْعَرَابِحِ بَالِغِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ وَتَسْلِيمٌ عَدِيدَ الْبَوَارِعِ"]
    ]
  }