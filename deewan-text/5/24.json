{
    "id": 24,
    "title": "حرف الذال",
    "huruf": [
      ["ذَكَرْتُ الَّذِي بِالذِّكْرِ مِنْهُ تَلَذُّذِي", "نَبِيًّا بِعُلْيَاهُ عَلَا كُلَّ هُجَنَّدِ"],
      ["مُحَمَّدُ أُنْسِي وَهْوَ كَنْزِي وَمَلْجَئِي", "وَسِرِّي وَمِنْ كُلِّ الْبَلِيَّاتِ مُنْقِذِي"],
      ["وَهُوَ الَّذِي لَمْ يَدْعُ دَاعٍ بِذِكْرِهِ", "وَلَمْ يُسْتَجَبْ وَالذِّكْرُ عَيْنُ تَلَذُّذِي"],
      ["بِهِ آدَمٌ قَدْ تِيبَ حِينَ تَقَطَّعَتْ", "وَسَائِلُهُ مَا إِنْ يَرَى مِنْ مُنْقِذِ"],
      ["وَنُوحٌ وَإِبْرَاهِيمُ مُوسَى وَيُونُسُ", "وَعِيسَى وَإِسْمَاعِيلُ وَالْكُلُّ هُجَنَّدِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَإِنَّ لِوَصْلِ الْمُصْطَفَى الْغَوْثَ كَالَّذِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَا أَنَّ يَوْمًا فِي سِوَاهُ تَلَذُّذِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أُجَوِّدُ بِمَدْحٍ فَائِقٍ لِلْمُزَنَّدِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَعِثْنَا بِإِمَامِ الْهَاشِمِيِّ وَأَنْقِذِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِشَطْرِ رُؤُوسِ الْكُفْرِ طُرًّا وَتَنْبِذِ"]
    ]
  }