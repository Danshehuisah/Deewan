{
    "id": 20,
    "title": "حرف الراء",
    "huruf": [
      ["رَسُومِي أَمْدَاحُ النَّبِيِّ وَلَا فَخَرْ", "فَمَا فِي سِوَى مَدْحِي لَهُ أَنْسِجُ الشِّعْرَا"],
      ["رَفَضْتُ جَمِيعَ الشِّعْرِ غَيْرَ مَدِيحِهِ", "سِوَى دَعْوَةِ الْمَوْلَى أَوْ أَنْ أَقْصِدَ الذِّكْرَا"],
      ["رَجَعْتُ إِلَى الْمَوْلَى بِأَمْدَاحِ غَائِبًا", "وَأَمْسَيْتُ مِنْ مَدْحِ النَّبِيِّ أَعْتَلِي الْخُضْرَا"],
      ["رَقِيتُ ذُرَى الْعِرْفَانِ فِي الْعِلْمِ فَائِقًا", "وَرُضْتُ عَوِيصَاتِ الْعُلُومِ وَلَا فَخَرْ"],
      ["رَأَيْتُ رَسُولَ اللَّهِ جَادَ بِمُغْيَثٍ", "وَمَا غَابَ عَنِّي الدَّهْرَ بَزًّا وَلَا بَخَرَا"],
      ["رَفَعْتُ لِوَاءَ الذِّكْرِ وَالْمَدْحِ غَارِفًا", "بِنَحْرِ حَبِيبِي حَيْثُ الْهَوَى نَحْرَا"],
      ["رَأَيْتُ رَسُولَ اللَّهِ جَادَ بِمُغْيَثٍ", "وَمَا غَابَ عَنِّي الدَّهْرَ بَزًّا وَلَا بَخَرَا"],
      ["رَمَيْتُ بِهِ فِي عَيْنِهِمْ وَنُحُورِهِمْ", "وَقَدْ سُلِبُوا مِنْ عِزِّهِمْ عُوْضُوا فَقُرَا"],
      ["رَمَوْنِي وَمَا نَالُوا مَرَادًا وَإِنَّنِي", "بِذِكْرِ رَسُولِ اللَّهِ أَقْتُلُهُمْ صَبْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِيَأْخُذَ لِي ثَأْرِي وَلَمْ أَكْتُبِ الْوِزْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَسُوسُ بِهَا قِرْفِي لِمَا يُضْمِرُ الْأُخْرَى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا تُسْقَى الْبَسَاتِينُ وَالْبَرَّا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَبُوعُ لَنَا الْعَلْيَاءَ وَالْمَجْدَ وَالْفَخْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا تُشْفَى الْبَشَاشَاتُ لِيَ الْهَذْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِيَقْبَلَ خَيْرُ الْخَلْقِ تَقْوَايَ وَالْبِشْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتَمْحُوَ بِيَ الْأَضْلَالَ وَالْبَشْرَاكَ وَالْكُفْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُعِزُّ بِهَا صَحْبِي وَتَكْفِيهِمُ الشَّرَّا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُسَهِّلُ حَجَّ الْبَيْتِ وَتُطْوِي لِيَ الْفَقْرَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ هُمُ الدَّوْلَةُ الْكُبْرَى"]
