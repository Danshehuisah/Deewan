{
    "id": 7,
    "title": "حرف الزاي",
    "huruf": [
      ["زَمَانٌ سَعْدٌ مِنْهُ فَوْزٌ لِقَائِرٍ", "لِمَدْحِ هُمَامٍ مُجْزِلٍ لِلْجَوَائِرِ"],
      ["لِمَدْحِ هُمَامٍ مِنْهُ بُشْرَى وَهُدَىً", "وَقَدْ جُبْتُ مِنْ خَيْرِهِ كُلَّ الْمَفَاوِرِ"],
      ["خَبَايَا وَأَعْطَانِي وَأَجْزَلَ نَيْلَهُ", "وَحَتَّى خَبَايَا مَا ذَكَرْتُهُ غَيْرُ جَائِرِ"],
      ["وَيَذْكُرُهُ مِسْكِي جِنَانِي وَلَقْلَقِي", "فَلَا أَكْتُ يَوْمًا عَنْ ثَنَاهُ بِعَاجِرِ"],
      ["جَمِيلٌ جَلِيلٌ كَامِلٌ ذُو مَكَانَةٍ", "جَوَادٌ وَفِي الْهَيْجَا أَمَامَ الْمَرَاكِرِ"],
      ["عَلِيمٌ حَلِيمٌ صَابِرٌ وَهْوَ شَاكِرٌ", "وَفِي اللَّهِ أَعْطَى فِي السَّوَاءِ لَمْ يُتَارِزِ"],
      ["عَظِيمٌ عَظِيمُ الْخَلْقِ عَيْنُ لِرَحْمَةٍ", "وَمَنْ مَالَ يَوْمًا عَنْهُ لَيْسَ بِقَائِرِ"],
      ["أُصَرِّحُ وَجْدًا بِالْمَحَبَّةِ نَحْوَهُ", "وَأَعْنَاهُ مَا فِي الْقَلْبِ عَنْ زَمْرِ زَامِرِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَعُدُّ ذِكَرَاهُ كَعَدِّ الْعَجَائِرِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَدِيدَ الْوَرَى مِنْ مُسْتَكِبٍّ وَبَارِزِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تُرَقِّينِي لِخَيْرِ الْغَرَائِرِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمَنْ أَحْسَنُوا فِي الدِّينِ كُلَّ مُبَارِزِ"]
    ]
  }