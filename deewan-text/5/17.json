{
    "id": 17,
    "title": "حرف الفاء",
    "huruf": [
      ["فَهَلْ بِعَقِيقٍ لِي بِطَيْبَةَ مَوْقِفُ", "يُفَرَّجُ فِيهِ الْهَمُّ حِينًا وَيُكْشَفُ"],
      ["عَقِيقٌ وَبَطْحَانٌ وَوَادِي مُدَيْنَتِي", "إِلَيْهِ اشْتِيَاقِي وَالْغَرَامُ يَكْلُفُ"],
      ["وَوَادِي قَنَاةٍ وَالْبَقِيعُ فَكُلُّهَا", "دِيَارِي وَذِكْرَاهَا لِوَجْدِي تَقُفُّ"],
      ["وَهَلْ لِي وُقُوفٌ بِالْبَقِيعِ مُسَلِّمًا", "عَلَى أَهْلِهِ وَالدَّمْعُ مَتَّى أَكُفْكِفُ"],
      ["فَإِنِّي وَتَبْتِيلِي وَوَجْدِي وَلَوْعَتِي", "وَمَا لِي خَلِيلٌ فِي التَّوَلُّهِ يُنْصِفُ"],
      ["وَلَا الْبَحْرُ مَتَّى بِالْعِبَارَةِ وَافِيًا", "وَمَا لَاقَ فِي جَنْبِ النَّبِيِّ تَكَلُّفُ"],
      ["فَتَفْحَشَ مَقْدُورٌ مَدِيحُ نَبِيِّنَا", "فَيَقْبَلُ عُذْرِي بِالْمَدَائِحِ مُنْصِفُ"],
      ["وَسَهْلٌ ثَنَاءُ الْمُصْطَفَى وَطِبَاعُهُ", "وَأَفْعَالُهُ تُبْدِي النُّهَى وَتَعَرُّفُ"],
      ["كَلٌّ وَعِلْمٌ ثُمَّ جُودٌ وَعِفَّةٌ", "وَعَزْمٌ وَحَزْمٌ بِالْمَدَائِحِ يُوصَفُ"],
      ["وَعَقْلٌ وَحِلْمٌ ثُمَّ حُسْنُ سِيَاسَةٍ", "وَزَهْدٌ وَصَبْرٌ قَدْرُهُ لَيْسَ يُغْرَفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ عَطَاءً عِنْدَهُ لَا يُسَوَّفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُقَرِّبُ لِي الْبَيْتَ الْحَرَامَ أَطُوفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَلَى جَدْثِ الْمُخْتَارِ دَهْرِي أَعْكِفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَنِ السُّنَّةِ الْبَيْضَاءِ لَا أَتَعَشَّفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَا مَزْحَ لِي يَوْمًا بِعِلْبَائِي تَقَشُّفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَمْ أَبْتَلِ مَنْ يَلْحَى وَلَا مَنْ يَعْتُفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأَهْرُفُ دَهْرِي بِالَّذِي كُنْتُ أَعْرِفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَمْ أَبْتَلِ عَنْ مَدْحِ النَّبِيِّ أَتَوَقَّفُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ شَكَرُوا وَتَعَفَّفُوا"]
    ]
  }