{
    "id": 16,
    "title": "حرف العين",
    "huruf": [
      ["عَلَى الْمُصْطَفَى الْمُخْتَارِ زَيْنِ الْمَجَامِعِ", "غَرَامِي وَتَبْتِيلِي وَسَيْلُ مَدَامِعِي"],
      ["ثَوَى فِي سَوَادِي وَدَادُ مُحَمَّدٍ", "أَكْبِدُ شَوْقًا يَنِمُّ قَوْمَ هَوَاجِعِ"],
      ["مُنَى الْبَاهِبَاتِ جَفْنِي ذَكَرْتُ مُحَمَّدًا", "وَأَذْكُرُهُ فِي خَلْوَتِي وَمَجَامِعِي"],
      ["وَعِنْدَ سُرُورِي وَاكْتِئَابِي وَإِنْ أَنَا", "أَرَى أَنَّنِي فِي حَيْثُهُ وَالْمَرَابِعِ"],
      ["خَرِيفِي وَصَيْفِي وَالرُّبَى جَمِيعُهَا", "كَذَا شِتَائِي ذِكْرٌ يَمُجُّ الْجَوَامِعَ"],
      ["أَيَا سَيِّدِي خَيْرَ الْوَرَى وَنَبِيَّنَا", "يَقِينًا أُنَادِي خَاضِرِي الدَّهْرَ سَامِعِي"],
      ["أَجِرْنِي جِوَارًا هَاشِمِيًّا فَلَمْ أَخَفْ", "فَلَمْ يَكُ يَوْمًا مَنْ تَجُرْهُ بِضَائِعِ"],
      ["أَجِرْنِي بِمَا يُغْنِي عَنِ الْكُلِّ سَرْمَدًا", "فَلَمْ يَكُ ذَنْبِي مِنْ جَدَاكَ بِمَائِعِ"],
      ["فَإِنِّي ذَلِيلٌ عَاجِزٌ مُتَحَيِّرٌ", "فَقِيرٌ حَقِيرٌ ضَارِعٌ أَيّ ضَارِعِ"],
      ["وَمَا لِيَ دَفْعٌ وَاجْتِلَابٌ وَلَمْ يَكُنْ", "لَدَيَّ سِوَى مَدْحِي وَدَفْعُ الْمَدَافِعِ"],
      ["وَقَدْ لُعِبَتْ أَيْدِي الْغَوَايَةِ بُرْهَةً", "بِأَجْنَابِ مَنْ لَمْ يَحْتَصِنْ بِالْمَدَافِعِ"],
      ["وَلِلَّهِ عِزٌّ بَعْدَهُ لِرَسُولِهِ", "وَلِلْمُؤْمِنِينَ الْمُقْتَفِينَ لِشَارِعِ"],
      ["فَإِنْ رَبِّ فَضْلًا أَعْطِ عِزَّةَ دِينِنَا", "سَرِيعًا وَتَمْحُو بَاطِلَ أَهْلِ الْمُقَاوِعِ"],
      ["بِجَاهِ رَسُولِ اللَّهِ أَحْمَدَ خَيْرِ مَنْ", "أَتَانَا مِنَ الْمَوْلَى بِخَيْرِ الشَّرَائِعِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا فَيْضُ الْجَدَادِ وَالْمَتَافِعِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتِكْبُرُ فِي كُلِّ الْبِلَادِ جَوَامِعِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَطِيطُ بِخَيْرِ الْخَلْقِ كُلَّ مَطَامِعِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا تَبْقَى لِمَوْتِي مَسَامِعِي"],
      ["وَالْأَبْصَارُ وَالْقُوَى بِمَدْحِكَ سَيِّدِي", "عَلَيْكَ صَلَاةٌ مِنْ جَمِيعِ أَصَابِعِي"],
      ["عَلَيْكَ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَكُلِّ الَّذِي يَقْفُوكَ زَيْنَ الْمَجَامِعِ"]
    ]
