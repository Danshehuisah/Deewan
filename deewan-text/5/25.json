{
    "id": 25,
    "title": "حرف الظاء",
    "huruf": [
      ["ظَغِنْتُ وَحُبَّ الْهَاشِمِيِّ أُحَافِظُ", "إِلَى حَضْرَةِ الْعَلْيَا وَرَبِّي أُحَافِظُ"],
      ["وَلَا أَنِيَ عَنْ ذِكْرِ طَهَ وَمَدْحِهِ", "مُزُورَ زَمَانِي أَوْ يَؤُوبَنَّ قَارِظُ"],
      ["صَلَاتِي وَصَوْمِي ثُمَّ حَجِّي بِذِكْرِهِ", "وَأَذْكُرُهُ مَهْمَا دَعَتْنِيَ الْمَوَاعِظُ"],
      ["أُحِبُّ رَسُولَ اللَّهِ حَقًّا وَإِنَّنِي", "عَلَى حُبِّهِ مَا دُمْتُ مِمَّنْ يُحَافِظُ"],
      ["أَهِيمُ بِهِ مَا عِشْتُ دَهْرًا وَكَيْفَ لَا", "وَعَيْنُ عِنَايَاتِي لِحِزْبِي تُلَاحِظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَإِنَّ بِذِكْرَاهُ مَدَى الدَّهْرِ لَافِظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَذَاكَ رَسُولٌ نَاجِعُ الْخَلْقِ وَاعِظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأَبْقَى وَإِنِّي قَارِئُ الذِّكْرِ حَافِظُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَلَى الصَّلَوَاتِ الْخَمْسِ دَهْرِي أُحَافِظُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ أَمْسَكُوا الدِّينَ الْقَوِيمَ وَحَافِظُوا"]
    ]
  }