{
    "id": 23,
    "title": "حرف الثاء",
    "huruf": [
      ["خَدَمْتُ رَسُولَ اللَّهِ دَهْرِي أَنْسِخُ", "مَدَائِحَهُ وَالْحُبُّ فِي الْقَلْبِ يَرْسَخُ"],
      ["لَقَدْ خَصَّهُ الْمَوْلَى بِأَعْلَى كَرَامَةٍ", "شَرِيعَتُهُ كُلُّ الشَّرَائِعِ تَنْسَخُ"],
      ["وَقَدْ جَاءَ فِي الذِّكْرِ الْحَكِيمِ ثَنَاؤُهُ", "مِنَ اللَّهِ يَتْلُوهُ إِلَى يَوْمٍ يُنْفَخُ"],
      ["مِنَ الْحَرْفِ وَالتَّبْدِيلِ صَانَ إِلَهَنَا", "كِتَابًا لَهُ وَالْهُودُ مِنْ ذَاكَ مُسْتَرِيحُوا"],
      ["وَقَدْ أَخْزَى الْمُسْنَ الْمَصَاحِفَ تَظْلِمُهُ", "فَلَمْ يُحْكِ شِبْهَ الذِّكْرِ يَوْمًا مُوَرَّخُ"],
      ["بِهِ نَارُ أَقْطَارِ الْبِلَادِ كَأَنَّهُ", "ضِيَاءُ نَهَارٍ مِنْ دُجَى اللَّيْلِ يَسْلَخُ"],
      ["بِهِ يُرْزَقُ الْمُضْطَرُّ فَالْيُمْنُ كُلُّهُ", "مِنَ الذِّكْرِ فَلْيَصْرُخْ بِهَذَا الذِّكْرِ مُصْرِخُ"],
      ["فَإِنَّ وُجُودَ الْمُصْطَفَى وَكِتَابَهُ", "لَأَكْبَرُ آلَاءٍ بِذَنَبٍ يُوَزَّخُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَيَطْوِي عَنِ الْبَطْحَاءِ تَيْمَاءَ سَرْبَخُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأَخِي وَمَا بَيْنِي وَبَيْنَكَ فَرْسَخُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا طَابَ لِي دُنْيَا وَأُخْرَى وَبَرْزَخُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةً بِهَا أَبْقَى وَمَدْحَكَ أَنْسَخُ"]
    ]
  }