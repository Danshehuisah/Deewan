{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["بَرِئْتُ مِنَ الْإِشْرَاكِ وَالشَّكِّ وَالْعُجْبِ", "يُحِبُّ رَسُولَ اللَّهِ فِي الْبُعْدِ وَالْقُرْبِ"],
      ["سَلِمْتُ مِنَ الْأَغْرَاضِ أَخْلَصْتُ وَهَجْرَتِي", "لِرَبِّي وَعِتْرِي زَالَ عَنِّي مَعَ الْحُجْبِ"],
      ["وَأَمْدَحُ خَيْرَ الْخَلْقِ خَادِمَ بَابِهِ", "وَذِكْرُهُ نَفْسِي وَسِرِّي كَذَا قَلْبِي"],
      ["كَفَانِي كَوْنِي شَاعِرَ الْبَابِ خَادِمًا", "يَخْدُمُهُ خَيْرُ الْخَلْقِ فَازَجْبِي عِتْرِي"],
      ["فَكُفِّي وَحُشَّاشٌ أَيِلًا كَرَامَةً", "يَمْدَحُكَ يَا مَأْمُونُ فِي الْجَهْرِ وَالْغَيْبِ"],
      ["وَلَيْتَ لِيَ فِي عَصْرِ الْجَهَالَةِ وَالْهَوَى", "لِمَادِحِهِ فِي حَالَةِ الْبَسْطِ وَالْكَرْبِ"],
      ["يُفَرِّجُ عَنِّي كُلَّ كَرْبٍ وَأَثْرَهُ", "وَذِكْرُهُ الْمُخْتَارُ يَا خَادِمِي حَتَّى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تَرْقِينَا إِلَى الذِّكْرِ وَالْحُبِّ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَذِكْرُهُ الْمُخْتَارُ يَا خَادِمِي حَتَّى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُطَهِّرُ الْقَلْبَ ثُمَّ نَنَالُ كَذَا ثَرْبِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَشْكُرُ سَعْيِي وَالْمُهَيْمِنُ لِي ثَرْبِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَسْقِينِيَ الْمَحْمُودُ بِالْمَنْهَلِ الْعَذْبِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا نَبْقَى مَعَ الْيُمْنِ وَالرِّضْبِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مِنَ الْعَبْدِ إِبْرَاهِيمَ لِلنَّاصِرِ الرَّبِّ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْأَهْلِ وَالْأَوْلَادِ وَالْآلِ وَالصَّحْبِ"]
    ]
