{
    "id": 10,
    "title": "حرف الياء",
    "huruf": [
      ["يُذَكِّرُنِي الْبَرْقُ الْوَمِيضُ الْمَغَانِيَا", "عَقِيقًا وَسَلْعًا وَالْبَقَا وَالْعَوَالِيَا"],
      ["فَعُدْتُ لَهُ بِكُرَاعٍ وَالْحَيُّ كُلُّهُمْ", "رُقُودٌ أَشَمُّ الْمُغْصِرَاتِ السَّوَارِيَا"],
      ["سَقَى اللَّهُ مِنْ بَلْقَعٍ مَزْنٌ مَزَابِعًا", "وَطَنَّهَا الْمُخْتَارُ لِلْكُفْرِ مَاحِيَا"],
      ["حَمَى عَنْ جُفُونِي النَّوْمَ حُبُّ مُحَمَّدٍ", "بِتَذْكَارِهِ لَمَّا سَلَوْتُ الْغَوَانِيَا"],
      ["أَبِيتُ بِبَلْوَى نَابِغِيَ وَقَدْ سَرَتْ", "مُحَيَّا وَدَادِي فِي جَمِيعِ حَشَائِيَا"],
      ["أُنَادِي حَبِيبَ اللَّهِ طَهَ مُحَمَّدًا", "أَبَا الْقَاسِمِ الْهَادِي الْمُفَقَّى مُنَاجِيَا"],
      ["لِتَرْحَمْ خَدِيمًا ضَارِعًا عِنْدَ بَابِكَ", "الْمُؤَمَّلِ يَا مَحْمُودُ فَانْظُرْ لِحَالِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَنَلْ الْعُلَى وَالْمَعَالِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَلْقَى لَدَيْكَ الْأَمَانِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَهْدَى فَأُصْبِحُ هَادِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَبْقَى كَرِيمًا مُؤَامِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَكُونُ بِهَا فَرْدًا عَلَى الْكُلِّ سَامِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَبْقَى وَفَيْضِيَ جَارِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَكُونُ بِهَا نَشْأِي هُدَاهُ وَوَالِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَصُونُ بِهَا مِصْرِي الْغُضُورَ الْخَوَالِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِيَرْضَى رَسُولُ اللَّهِ كُلَّ ثَنَائِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُجِبْ بِهَا الْمَوْلَى جَمِيعَ دُعَائِيَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ شَيَّدُوا الْبِنَاءَ عَلَيَا"]
    ]
