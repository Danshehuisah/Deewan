{
    "id": 9,
    "title": "حرف الطاء",
    "huruf": [
      ["طَبِيبِي سِقَامِي أَحْمَدُ النُّورُ مُقْسِطُ", "جَمِيلٌ خَلِيلٌ مِثْلُهُ لَمْ يَكُنْ قَطُّ"],
      ["طَوَى لِي فِي سَيْرِي الْمَهَامَةَ مُجْزِلًا", "لِتُخْوِي الْعَطَايَا وَالْفُحُولُ قَدْ أَغْطَطُوا"],
      ["فَخِزْيِي وَبُسْتَانِي مَدِيحُ مُحَمَّدٍ", "مَحَطُّ سِرِّ الْحَقِّ لِلرُّوحِ مُهْبِطُ"],
      ["وَذَاكَ الَّذِي مَهْمَا ذَكَرْتُ جَمَالَهُ", "سَرَى الْوَجْدُ فِي حَتَّى أَهِيمُ وَأَخْبِطُ"],
      ["وَذَاكَ الَّذِي مَهْمَا اشْتَغَلْتُ بِمَدْحِهِ", "يَفِيضُ لِي فَيْضًا حَيْثُمَا الْكُلُّ يَغْبِطُ"],
      ["وَذَاكَ الَّذِي لَوْلَاهُ لَمْ تُلْفَ قَطْرَةٌ", "فَهُوَ الْقَاسِمُ الْمَأْمُونُ يُعْطِي وَيُقْسِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَسُجُّ لِي دَهْرِي وَقَلْبِي تَنْبِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَبِيدُ الْعِدَا طُرًّا وَالْأَعَالِي تَبِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَدِينُ لِأَمْرِي كُلُّ شَيْخٍ وَأَشْبِطُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا أَسْبِقُ الْأَقْطَابَ طُرًّا وَأُفْرِطُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ سَلَكُوا دِينَ النَّبِيِّ وَأَفْسَطُوا"],
      ["عَلَيْهِ مَدَى الْأَيَّامِ مَا قَالَ مُغْرَمٌ", "طَبِيبِي سِقَامِي أَحْمَدُ النُّورُ مُقْسِطُ"]
    ]
  }