{
    "id": 22,
    "title": "حرف التاء",
    "huruf": [
      ["أُبِيتُ رَسُولَ اللَّهِ فِي كُلِّ أَوْقَاتِي", "مَعَاشِي وَكَسْبِي فَهْوَ لِي خَيْرُ أَقْوَاتِ"],
      ["وَأَمْدَحُهُ مَا عِشْتُ فِي كُلِّ حَالَةٍ", "قَصِيدِي مَدِيحُ الْهَاشِمِيِّ وَأَبْيَاتِي"],
      ["فَلِي كُلَّ وَقْتٍ حَالٌ بَعْدَ حَالَةٍ", "وَحَالِي مَدْحُ الْمُصْطَفَى خَيْرُ حَالَاتِي"],
      ["وَلِي زَفْرَةٌ لِلْحُبِّ مِنْ بَعْدِ زَفْرَةٍ", "فَيَرْحَمُ خَيْرُ النَّاسِ صَبْرِي وَأَوْقَاتِي"],
      ["وَطَالَ بُكَائِي فَالزَّفِيرُ أَجَنَّنِي", "يُعِينَنِي مِنْ فَيْضِ دُمُوعِي وَأَصْوَاتِي"],
      ["يُدَارِكُنِي طَهَ الْأَمِينُ بِعَطْفَةٍ", "فَيَعْذُبُ تَعْذِيبِي وَوَجْدِي وَلَوْعَاتِي"],
      ["عَلَى عَرَجِي خَلْفَ الْجِيَادِ مُخَلَّقًا", "فَلَمْ أَرْضَ بِالسَّفْسَافِ وَقْتُ إِحْدَاثِي"],
      ["وَأَنْتَ كَرِيمٌ جَابِرٌ ذُو مَكَانَةٍ", "أَعِنِّي وَتَغْنِيسِي فَقَوْلُكَ أُحْدُثُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَقَوْلُكَ يَتَزَايَفُ بِمَدْحِكَ أَخْرُثُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَكُونُ خَدِيمًا عَهْدُهُ لَيْسَ يَنْكُثُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ بَلِّغُوا وَاحْمَدُوا ثُمَّ"]
    ]
  }