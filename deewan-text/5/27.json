{
    "id": 27,
    "title": "حرف الشين",
    "huruf": [
      ["شِفَائِي لِأَمْرَاضِي وَطِيبُ مَعَاشِي", "بِذِكْرِ الْمُقَفَّى وَهْوَ ذَلِكَ فَاشِي"],
      ["سَعِدْتُ بِمَدْحِ الْهَاشِمِيِّ مُحَمَّدٍ", "وَذَلِكَ خَرِيفُ الدَّهْرِ وَهْوَ مَوَاشِي"],
      ["جَنَوْتُ مِنَ الْأَعْدَاءِ وَالشَّرِّ كُلِّهِ", "فَلَمْ أَرَ دَارًا خَشِعًا بِغَوَاشِ"],
      ["حَصَّنْتُ بِذِكْرِ الْمُصْطَفَى النَّفْسَ ثُمَّ مَنْ", "يَتَقَيَّلُنِي مِنْ سَاكِئِينَ وَمَاشِ"],
      ["حَصَّنْتُ بِهِ دِينِي وَدُنْيَايَ ثُمَّ مَنْ", "يَتَفَرَّعُ مِتِّي فِي نَوًى وَفَرَاشِ"],
      ["حَصَّنْتُ بِهِ بَيْتِي وَمَا ثَوَى", "حَوَالَيْهِ مِنْ دُورٍ وَكُلِّ قُمَاشِ"],
      ["حَصَّنْتُ بِهِ حِزْبِي وَأَهْلِي مَوَدَّتِي", "وَكُلَّ فَخْرٍ يَأْتِي لَنَا وَيُمَاشِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَإِنَّ مَدِيحَ الْهَاشِمِيِّ يَرْيَاشِي"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةً بِهَا دَهْرِي تَطِيبُ مَعَاشِي"]
    ]
  }