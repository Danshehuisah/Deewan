{
    "id": 13,
    "title": "حرف الميم",
    "huruf": [
      ["مَدِينَةُ خَيْرِ الْخَلْقِ طَيْبَةُ أَعْظَمُ", "بِلَادًا إِلَى الْعَالَمِينَ وَأَفْخَمُ"],
      ["مَحَلُّ نَصْرِ الْمُصْطَفَى وَجُنُودِهِ", "وَأَنْصَارِهِ وَهْوَ النَّبِيُّ الْمُعَظَّمُ"],
      ["وَفِيهَا مَمَرُّ النَّبِيِّ وَمَقْرُهُ", "بِالْعَقْوَةِ الْعُلْيَا مِنَ الْبَيْتِ أَعْظَمُ"],
      ["وَمَسْجِدُهُ أَعْظِمْ بِهِ وَبُيُوتِهِ", "وَأَنْوَارُهُ وَالْعِلْمُ فِيهَا مُقَدَّمُ"],
      ["تَرَدَّدَ جِبْرِيلُ الْأَمِينُ لِأَهْلِهَا", "خَدِيمًا وَمِيكَائِيلُ وَالْأَمْرُ أَضْخَمُ"],
      ["فَهَلْ لِي مِنَ الْإِلْمَامِ بِطَيْبَةَ زَائِرًا", "عَلَى الْمُصْطَفَى بِالْقُرْبِ مِنْهُ أُسَلِّمُ"],
      ["فَمَا لِي دَوَاءٌ فِي غَيْرِ ذَلِكَ وَإِنَّنِي", "أَرَى رُكْنَ صَبْرِي كُلَّ وَقْتٍ يُهَدَّمُ"],
      ["جَلَّدْتُ حَتَّى عِيلَ صَبْرِي وَلَمْ أَطِفْ", "عَنِ الْمُصْطَفَى حُبِّي وَإِنْ كُنْتُ أُجْرِمُ"],
      ["أُنَادِيكَ خَيْرَ الْخَلْقِ حَيَّا لِتَسْمَحَنْ", "بِعَوْدِي لَهَا إِذْ مَا حَلَالٌ فِي مَطْعَمِ"],
      ["أَكْتِمْ وَجْدًا لَا يَرِيمُ فَخَاطِرِي", "إِلَى طَيْبَةَ الْغَرَّاءِ وَالْحُبُّ يُسْقِمُ"],
      ["لَيْتَ وَطِئَتْ رِجْلِي دِيَارَ مُحَمَّدٍ", "فَأَصْمُدُ وَأَقْضِي شُكْرًا لِسَعْيِي فَأَغْنَمُ"],
      ["فَأَوَّلُ خَلْقِ اللَّهِ نُورُ مُحَمَّدٍ", "وَحَلَّ لِأَصْلَابِ الَّذِينَ قَدْ أَسْلَمُوا"],
      ["وَكُلُّ رَسُولٍ نَائِبٌ عَنْ نَبِيِّنَا", "فَهُوَ الْآخِرُ الْمَخْتُومُ وَهْوَ الْمُقَدَّمُ"],
      ["فَآيَاتُهُمْ آيَاتُهُ وَنَبِيُّنَا", "أَتَى بِكِتَابٍ شَأْنُهُ الدَّهْرَ يُعْجَمُ"],
      ["أَتَى بِهَادٍ لِلْكَافِرِينَ فَأُرْعِبُوا", "فَهَابُوا ظُبَى الْأَشْيَافِ طُرًّا وَأَسْلَمُوا"],
      ["وَشُقَّ لَهُ بَدْرٌ وَوَافَتْهُ دَوْحَةٌ", "وَالْأَحْجَارُ فِي الْبَطْحَاءِ كَائِدٌ تُسْلِمُ"],
      ["وَفَاضَتْ مِيَاهٌ مِنْ بَنَانِ نَبِيِّنَا", "وَأَسْقَتْ جُيُوشًا كُلَّ جَيْشٍ عَرَمْرَمُ"],
      ["شَكَوْا جَمْدَهُمْ عِنْدَ النَّبِيِّ فَسَقَاهُمْ", "غَمَامٌ يَوَدُّ سَيْبًا لَيْسَ يَفْصِمُ"],
      ["سَقَاهُمْ كَذَا الْفَارُوقُ بِالْعَصَا عَلَى يَدِهِ", "بِذِكْرِهِمْ أُسْقَى الْبِلَادَ وَأُطْعَمُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِأَلْقَى بِهَا الْمَوْتَ وَقَلْبِي مُسَلَّمُ"],
      ["وَيَنْشُرُ هَذَا الْفَيْضَ فِي الْوَرَى وَيَعُمُّ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["لِيَتَقَبَّلَ الْمُخْتَارُ وَالْعِلْمَ أَعْلَمُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["لِكُلِّ مُرِيدٍ آخِرَ الدَّهْرِ سُلِّمُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["بِذِكْرِكَ بَدْءًا وَهْوَ ذِكْرُكَ مُحْتَمُ", "عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ"],
      ["صَلَاةٌ وَتَسْلِيمٌ بِذَلِكَ أَخْتِمُ"]
    ]
