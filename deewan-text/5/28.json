{
    "id": 28,
    "title": "حرف اللام ألف",
    "huruf": [
      ["لَدَى الْمُصْطَفَى هَبْ لِي رِضًا وَقُبُولَا", "فَقَدْ عَزَّ عَلَيَّ نَيْلِي إِلَيْهِ وُصُولَا"],
      ["وَهَذَا عَطَشٌ كَالْعِيسِ وَالْمَاءُ فَوْقَهَا", "تَمُوتُ ظِمَاءً مَا تَنَالُ سَبِيلَا"],
      ["وَقَدْ شَدَّ فَقْرِي وَافْتِقَارِي وَلَمْ أَجِدْ", "سِوَى الْمُصْطَفَى الْمَاحِي يُنِيلُ فُحُولَا"],
      ["جَنَيْتُ كَثِيرًا فَالرَّجَاءُ يَقُودُنِي", "إِلَيْهِ وَأَثْمَارِي تَكُونُ كُبُولَا"],
      ["عَلَى أَنَّ أَوْزَارِي الذُّنُوبِ بِبَحْرِهَا", "بِلَا أَثَرٍ يَبْقَى وَجِئْتُ الرَّسُولَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَكُونُ الْمُقَفَّى لِلْعَطَاءِ كَفِيلَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلَسْتُ أَرَى غَيْرَ الرَّسُولِ وَكِيلَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَقَدْ طَالَمَا أَسْدَى إِلَيَّ جَزِيلَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَلَاذِي أَرَاهُ فِي الْخُطُوبِ جَلِيلَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ شَفَاعَاتِ الشَّفِيعِ مُنِيلَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَتَخْزَى أَعَادِيَّا سِرًّا وَغُدُولَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَدُومُ بِظِلٍّ لَا يَزَالُ ظَلِيلَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَطِيعُ كَمَا دَوِّي بِاتِّبَاعِ الرَّسُولَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "إِذَا مِتُّ فِي الْفِرْدَوْسِ نِلْتُ مَقِيلَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "عَلَى كُلِّ حَالٍ لَا أَزَالُ أُصَلِّي"]
    ]
  }