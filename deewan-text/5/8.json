{
    "id": 8,
    "title": "حرف الحاء",
    "huruf": [
      ["حَمَانِي رَسُولُ اللَّهِ عَنْ مَكْرِ مَاكِرٍ", "وَشُؤْمٍ لِدَاعِي شُؤْمٍ وَكُلِّ الْجَوَائِحِ"],
      ["وَسِحْرٍ لِدَاعِي سِحْرٍ وَعَيْنٍ لِعَائِنٍ", "فَمَنْ رَامَ ضُرِّي قَدْ سَعَى فِي مَصَالِحِي"],
      ["بِيُمْنِ رَسُولِ اللَّهِ كَهْنِي وَمَلْجَئِي", "فَمَا مِبْيَضُ الْعَبْدِ الْحَقِيرِ بِذَابِحِ"],
      ["تَصْحَبْ لِمَنْ يَبْغِي السَّلَامَةَ وَالْعُلَا", "يُخَلِّينِي عَنِ الْأَمْدَاحِ مِنْ كُلِّ قَادِحِ"],
      ["فَإِنَّ رَسُولَ اللَّهِ حَامِي ذِمَارِهِ", "وَقَدْ جَاءَ مَنْصُورًا عَلَى كُلِّ كَادِحِ"],
      ["وَقَدْ كُفِيَ الْأَحْزَاتِ يَوْمَ تَحَزَّئُوا", "وَرُدُّوا بِغَيْظٍ بِالْبَلَا فَالْقَوَادِحِ"],
      ["وَإِنَّ مَعَ الْمُخْتَارِ فِي كُلِّ حَالَةٍ", "يُحِبُّ وَذِكْرٍ ثُمَّ قَرْضِ الْمَدَائِحِ"],
      ["فَمَنْ رَاشَ نَحْوِي سَهْمَهُ فَهْوَ رَائِشٌ", "إِلَى نَحْرِهِ فَلْيُبْذَرَنْ بِالْقَوَادِحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ بِهِ كُلَّ الْمُنَى وَالْمَرَابِحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِيَرْفَعَنِي الْهَادِي عَلَى كُلِّ مَادِحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتُمْضَى مِنْ حُبِّ الْأَمِينِ جَوَائِحِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِيُقْبَلَ سَعْيِي ثُمَّ كُلَّ الْمَدَائِحِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَتُسْقَى أَرَاضِي بِالْمُزْنِ الدَّوَالِحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا تُحْيَا وَكُلُّ الْمَصَالِحِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ يَقْتَفِي مِنْ كُلِّ بَرٍّ وَصَالِحِ"]
    ]
  }