{
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["أَبَى لِيَ أَنِّي حَلَّ بَيْنِي وَبَيْنَهُ", "تَنَائِي حَبِيبِي اللَّهِ عَيْنُ الصَّفَاءِ"],
      ["أَهِيمُ بِهِ إِنْ هَامَ غَيْرِي بِزَيْنَبٍ", "وَتَذْكَارُهُ عِنْدِي أَلَذُّ غِذَاءِ"],
      ["أَهِيمُ بِهِ مَا عِشْتُ دُونَ تَغَنُّجٍ", "وَلِي وَلَهُ فِيهِ بَعْدَ فَنَائِي"],
      ["إِذَا انْصَرَفَ الْوَرَّادُ عَنْ دَفْنِ جُثَّتِي", "بَقِيتُ بِهِ أَحْيَا لِيَوْمِ لِقَاءِ"],
      ["إِذَا عَبَّدَ الْعُبَّادُ فِي الْقَبْرِ إِنَّنِي", "بِذِكْرِ رَسُولِ اللَّهِ وَقْتِي تَوَائِي"],
      ["أَنِسْتُ بِهِ وَحْدِي كَفَانِي جَلَالُهُ", "عَنِ الْغَانِيَاتِ الْبِيضِ وَسْطَ خِبَاءِ"],
      ["إِذَا جَزَعُوا الْمَوْلَى وَافْتَخَرُوا بِهَنَا", "فَفَخْرِي وَمَالِي حُبُّ زَيْنِ الْمَلَاءِ"],
      ["إِذَا مَكَرُوا مَكْرًا كُفِيتُ بِذِكْرِهِ", "وَإِنْ مَرَضٌ يَعْرُو فَفِيهِ شِفَائِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُضِيءُ رَسُولُ اللَّهِ كُلَّ ثَنَائِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَكُونُ بِهَا فِي ظِلِّ يَوْمِ الْجَزَاءِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَنَالُ لَدَى الْحُسْنَى كَمَالَ الرِّضَاءِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَكْفِي رَسُولُ اللَّهِ أَهْلَ الْبَلَاءِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَنَالُ مُحِبُّهُ الدَّهْرَ كُلَّ مُنَاءِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "خَدِيمُكَ يَعْلُو كُلَّ أَهْلِ الْعَلَاءِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأَنْوَاهَا تَعْلُو عَنَانَ سَمَاءِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ ثُمَّ آلِ عَبَاءِ"]
    ]
  }