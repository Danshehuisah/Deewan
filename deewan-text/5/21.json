{
    "id": 21,
    "title": "حرف السين",
    "huruf": [
      ["سَلَامٌ عَلَى طَهَ وَخَيْرِ الْمَوَاسِي", "لِكُلٍّ مَعَانٍ حَبُّهُ وَمَقَاسِي"],
      ["عَلَى خَيْرِ نَاسٍ خَيْرُ مَنْ وَطِئَ الثَّرَى", "فَخَيْرُ رَسُولٍ جَاءَ خَيْرَ أَنَاسِ"],
      ["وَأَفْضَلُ مَنْ يُدْعَى لِدَفْعِ نَوَائِبٍ", "وَأَفْضَلُ مَنْ يُجْدِي الْعَطَا وَيُوَاسِي"],
      ["وَأَفْضَلُ مَنْ يَقْرِي وَيَقْرَأُ خَيْرُ مَنْ", "أَتَاهُ مِنَ الْأَمْدَاحِ كُلُّ جِنَاسِ"],
      ["مُحَمَّدُ عَبْدُ اللَّهِ أَحْمَدُ خَيْرُ مَنْ", "يَحُلُّ مَكَانًا فَهْوَ خَيْرُ مُوَاسِي"],
      ["وَأَفْضَلُ مَمْدُوحٍ يُنِيلُ مَثُوبَةً", "وَبَذْلًا وَنَيْلًا مِنْ ثَنَاهُ قَوَاسِي"],
      ["غَرَسْتُ بِأَمْدَاحِي النَّبِيَّ سِعَادَتِي", "فَيَا طِيبَ أَمْدَاحِي وَطِيبَ غِرَاسِي"],
      ["لِبَاسِي وَحِصْنِي مَدْحُ أَحْمَدَ سَيِّدِي", "فَأَمْنَعُ حِصْنٌ وَهْوَ خَيْرُ لِبَاسِ"],
      ["إِذَا حِيدَتْ فِكْرِي مَدَحْتُ مُحَمَّدًا", "فَصِرْتُ ذَكِيًّا أَزْدَرِي بِالْبَاسِ"],
      ["تُضِيءُ لِيَ الْآفَاقُ حَتَّى كَأَنَّنِي", "أُشَاهِدُ غَيْبَ الْغَيْبِ دُونَ نُعَاسِ"],
      ["عَلَى الْمُصْطَفَى فِي كُلِّ بَدْءٍ وَمُرْتَقًى", "صَلَاةٌ وَتَسْلِيمٌ بَقَاءَ الرَّوَاسِي"],
      ["مَعَ الْآلِ وَالصَّحْبِ الْكِرَامِ قَدِ اهْتَدَوْا", "فَكُلُّهُمْ يُهْدِي لِرَيْبِ أُنَاسِي"]
    ]
  }