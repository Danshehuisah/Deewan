{
    "id": 5,
    "title": "حرف الهاء",
    "huruf": [
      ["هُوَ الْمُصْطَفَى مَنْ لَمْ يَثِقْ بِغَيْرِهِ", "هَوَى فِي حِمَى إِذْ غَوَى يَرْعَاهُ"],
      ["سَبِيلُ سَلَامٍ فِي اقْتِفَاءِ صِرَاطِهِ", "هُوَ الْبَابُ لِلْمَوْلَى وَلَيْسَ سِوَاهُ"],
      ["دَعَا الْخَلْقَ لِلْمَوْلَى بِكُلِّ تَضَرُّعٍ", "فَلَا الَّذِي قَدْ زَالَ عَنْهُ شَقَاهُ"],
      ["عَتِيقٌ وَهُوَ خَيْرُ الْوَرَى بَعْدَ رُسُلِهِمْ", "أَبُو حَفْصٍ الْفَارُوقُ بَعْدَ تَلَاهُ"],
      ["وَعُثْمَانُ ذُو النُّورَيْنِ وَاللَّيْثُ سَيِّدِي", "أَبُو حَسَنٍ صِنْوُ النَّبِيِّ وَثَنَاهُ"],
      ["وَطَلْحَةُ وَسَعْدٌ وَالزُّبَيْرُ سَعِيدُهُمْ", "وَعَامِرُ وَالْعَوْفِيُّ زَيْنُ مَلَاهُ"],
      ["وَخَيْرُ قُرُونٍ ثُمَّ قَرْنٌ تَلِيهِمُ", "وَقَرْنٌ تَلِيهِمْ فَضَلُوا جَمِيعَاهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَمَا أَتْقَى إِلَّا لِنَحْوِ رِضَاهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَفِيضُ لِهَذَا الْعَبْدِ فَيْضَ عَطَاهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَكْفِي لِهَذَا الْعَبْدِ كُلَّ عِدَاهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا يَنَالُ الْعَبِيدُ مُنَاهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُسَيِّرُ لِي دَهْرِي لِيَوْمِ لِقَاهُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ عَلَوْا بِعُلَاهُ"]
    ]
  }