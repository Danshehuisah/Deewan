{
    "id": 3,
    "title": "حرف الجيم",
    "huruf": [
      ["جَزَى اللَّهُ عَنَّا ظُلْمَةَ اللَّيْلِ وَالدُّجَى", "فَفِيهَا يَنَالُ الصَّبُّ لِلْحَبِّ مَرْجَا"],
      ["يَبِيتُ يُرَاعِي النَّجْمَ وَالْكُلُّ رَاقِدٌ", "يُنَظِّمُ دُرًّا بَلْ يُنَظِّمُ أَهْجَا"],
      ["تَذَكَّرْتُ خَيْرَ الْخَلْقِ طَهَ مُحَمَّدًا", "جَلِيلَ الْمُحَيَّا أَبْلَجًا كَانَ أَدْعَجَا"],
      ["عَظِيمٌ عَظِيمُ الْخُلْقِ وَالْجُودِ وَالْعَطَا", "شَفِيقٌ شَفِيعٌ مِنْ دُجَى الْكُفْرِ مَخْرَجَا"],
      ["وَذَاكَ الَّذِي لَوْلَاهُ مَا كَانَ كَائِنٌ", "وَلَوْلَاهُ لَمْ نَسْأَلْ إِلَى الْحَقِّ مَنْهَجَا"],
      ["دَعَا الْخَلْقَ لِلْمَوْلَى بِكُلِّ فِعَالِهِ", "وَفِي حَقِّهِ يَغْدُو وَيَرُوحُ وَيُدْلِجَا"],
      ["قَلَوْهُ وَآذَوْهُ بِكُلِّ أَذِيَّةٍ", "فَقَادَ الْبَرَايَا لِلْحَنِيفَةِ مُولِجَا"],
      ["وَجَاهَدَ فِي اللَّهِ حَقَّ جِهَادِهِ", "وَنَوَّرَ أَقْطَارَ الْبِلَادِ وَأَدْلَجَا"],
      ["أَلَمْ يَأْتِهِمْ مَا قَدْ لَقُوهُ بِبَدْرِهِ", "وَقَدْ بَزَغَ الدِّينُ الْحَنِيفِيُّ أَبْلَجَا"],
      ["كَذَا أُحُدًا جَاءُوا وَأَبَوْا بِصَدْمَةٍ", "فَوَلَّوْا فِرَارًا حَيْثُمَا الرُّعْبُ أَزْعَجَا"],
      ["وَقَدْ قَادَ لِلْبَطْحَاءِ جَيْشًا عَرَمْرَمًا", "فَذَلُّوا وَقَدْ دَانُوا مِنَ الْخَوْفِ وَالرَّجَا"],
      ["فَيَا رَبِّ هَبْ لِي بِالْأَمِينِ وَصَحْبِهِ", "كَالْمَرَادِ لِلسَّعَادَةِ مُنْتِجَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْكِرَامِ وَمَنْ جَنَّا"]
    ]
  }