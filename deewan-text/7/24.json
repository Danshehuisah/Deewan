{
    "id": 24,
    "title": "حرف الذال",
    "huruf": [
      ["ذَيَّالُكَ عَبْدٌ طَالَ لِلْمَدْحِ تَابِعًا", "يَرْجُوكَ بَاعِثَ اللَّهِ لِلْكَرْبِ فَارِجَا"],
      ["عَسَى فَرَجٌ يَأْتِي بِهِ اللَّهُ حِينَنَا", "يَهْدِمُ أَهْلَ الدِّينِ مَنْ كَانَ خَارِجَا"],
      ["فَإِنْ نِلْتَهُ أَوْ أَشْرَكُوا فَتُصِيبَنَا", "هُوَ الْحَقُّ وَالتَّوْحِيدُ بَلْ هُوَ الْمَمَازِجَا"],
      ["تَقَلَّصَ لِلتَّوْحِيدِ مَنْ قَالَ مُوقِنًا", "هُوَ الْمَالِكُ الْحَقُّ الْمُقَدَّسُ سَاذِجَا"],
      ["وَأَفْضَلُ خَلْقِ اللَّهِ طَهَ مُحَمَّدٌ", "تَقَرَّبَ بِالتَّقْدِيسِ لِلَّهِ عَارِجَا"],
      ["تَرَاهُ إِذَا لَذَّ الْمَنَامُ مُجَافِيًا", "فِرَاشَ مَنَامٍ لِلْمَخَارِيبِ وَالْجَا"],
      ["دَنَا فَتَدَلَّى بِالسُّجُودِ تَذَلُّلًا", "وَبِالْعِزِّ وَالتَّمْجِيدِ حَازَ الْمَعَارِجَا"],
      ["فَعِزٌّ بِذُلٍّ أَكْسَبَ الضِّدَّ ضِدَّهُ", "كَذَا بِامْتِحَانِ الْخَلْقِ نِلْنَا الْمَخَارِجَا"],
      ["خَرَجْنَا بِهِ مِنْ كُلِّ ضَيْقٍ وَكُرْبَةٍ", "دَخَلْنَا مَفَازًا لَا نَرَى الدَّهْرَ مَأْرَجَا"],
      ["يُهَيِّجُ أَشْوَاقِي هِلَالُ رَبِيعِهِ", "أُهِلَّ بِيُمْنٍ لِلسُّرُورِ مُمَازِجَا"],
      ["تَبَصَّرْ تَجِدْ أَنَّ الْبَلَاءَ بِشَهْرِهِ", "يَتَلَاشَى وَيُولَّى كَالسَّحَابِ دَارِجَا"],
      ["وَذَلِكَ أَنَّ الرَّبَّ مِنْ فَضْلِ جُودِهِ", "لَهُ نَفَحَاتٌ قَدْ تَفُوقُ التَّعَالِجَا"],
      ["وَتِلْكَ خَيَالَاتُ النَّبِيِّ مُحَمَّدٍ", "عَلَيْهِ صَلَاةٌ قَدْ تَنَالُ الْحَوَائِجَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ يَصْطَفِي هَذِهِ الْحَنِيفَةَ نَهْجَا"],
      ["عَلَيْهِ مَدَى الْأَيَّامِ مَا قَالَ خَادِمٌ", "ذَيَّالُكَ عَبْدٌ جَاءَ لِلْمَدْحِ نَاسِجَا"]
    ]
  }