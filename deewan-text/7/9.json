{
    "id": 9,
    "title": "حرف الياء",
    "huruf": [
      ["يُبِيحُ تَشْيِيرُ الْحَجِيجِ وَيُسْعِفُ", "عَلَى الْوَجْدِ وَالْأَيَّامِ حَقًّا وَيُذْنِفُ"],
      ["يَسِيرُ بِهِمْ فَلَكَ الْهَوَاءِ قَدْ أَصْبَحُوا", "يَثِيفُونَ وَأَمْسَوْا بِالنَّبِيِّ نَشَاوَى"],
      ["عَلَى سَاكِنِي سَلْعٍ سَلَامِي فَإِنَّنِي", "كَلِفْتُ بِهِمْ وَجْدًا وَإِنِّيَ أَضْفَى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَكُونُ بِهَا إِلَى عِنْدِ أَحْمَدَ مَوْقِفِي"],
      ["بِجُودِ مَبَالِيكَ قَدْ ذَكَرْتُكَ مُوهِنًا", "وَقَدْ نَامَ كُلُّ النَّاسِ وَالْقَلْبُ يَرْجُفُ"],
      ["يُؤَنِّسُنِي طِرْسِي وَحِبْرِي وَمِنْزَرِي", "وَأَنْسِجُ مَدْحِي وَالدُّمُوعَ أَكْفُكِفُ"],
      ["أُجَاوِرُ خَيْرَ النَّاسِ حَقًّا بِطَيْبَةٍ", "طَوَى نَحْوَ الْفَلَا إِنِّي لَدَيْهِ مُوقَفُ"],
      ["طَوَى نَحْوَ الْقُرَى وَالْبِيدَ حَتَّى كَأَنَّنَا", "دَنَا فَتَدَلَّى لِي وَإِلَى طَابَ مَوْقِفِي"],
      ["حَقَّقَ لِي حَتَّى كَأَنَّنَا", "هَاوٍ وَحُبِّي بِالْجِوَارِ مُنَظَّفُ"],
      ["فَكَمْ قَلَّبَ الْهَادِي الصِّلَالِ هَدَايَاهُ", "إِذِ الْبَاطِلُ يُحْيَا حِينَ بِالْحَقِّ يُقْذَفُ"],
      ["أَرَى مُوبِقَاتِ الْعَبْدِ تُمْسِي عَدِيمَةً", "إِذَا الْتَقَطَ الْهَادِي إِلَيْهِ وَيَعْطِفُ"],
      ["لَهُ خَطَّتَا لَوْلَاكَ سَلْ تُعْطَ وَاشْفَعَنْ", "تُشَفَّعُ وَإِنِّي قُرْبَهُ أَنَاطِفُ"],
      ["عَكَفْتُ عَلَى بَابِ النَّبِيِّ مُحَمَّدٍ", "وَمَنْ فَاتَنِي لَمْ أُلْفَ مِنْ ذَاكَ آلَسِفْ"],
      ["إِذَا مَا صَفَا لِي الْمُنْعِمُ الْمَوْلَى فَإِنَّنِي", "كَمَاصِدِ كَافُورٍ بَلْ أَعْلَى وَأَشْرَفُ"],
      ["خَرِيفِي شِتَائِيَ الدَّهْرَ ذِكْرُ مُحَمَّدٍ", "وَمَدْحُكَ عِنْدِي مَصْيَفِي وَمُصَيِّفُ"],
      ["وَنَوْمِي وَبَغْيِي فِي شُهُودِ نَبِيِّنَا", "سَوَاءٌ فَلِلْأَغْبَارِ لَا أَنَشَأْ وَفِي"],
      ["عَلَى كُلِّ حَالٍ لَا أَرَى غَيْرَ أَحْمَدَ", "جَمِيلًا كَرِيهًا يُجْزِلُ النَّيْلَ يَطْرُفُ"],
      ["وَوَعِيدُ عَدُوِّي لَمْ يُخِفْنِي وَوَعْدُهُ", "سَرَابٌ بِقِيعَانِ مَدَى الدَّهْرِ يُخْلِفُ"],
      ["فَلَوَّا وَكَادُوا بَلْ جَفُوا وَتَقَوَّلُوا", "وَلَا ضَيْرَ إِنِّي أَفْرَأُ الذِّكْرَ أَعْرِفُ"],
      ["عَلَى غَيْرِ ذَنْبٍ غَيْرَ أَنَّ مُحَمَّدًا", "وَأَتْبَاعَهُ سَهْمِي وَلَا أَتْبَعُ التُّفَّهَ"],
      ["رَضِيتُ بِرَبِّي وَالْحَنِيفَةُ مَسْلَكِي", "إِمَامِي رَسُولُ اللَّهِ لَا أَتَغَلَّفُ"],
      ["دَلِيلِي رَسُولُ اللَّهِ وَالْبَيْتُ قِبْلَتِي", "نَصُومُ وَبِالْبَيْتِ الْحَرَامِ نَطُوفُ"],
      ["نُصَلِّي نُمُودًا رَاكِعِينَ وَإِنَّنَا", "عَلَى هَذَا دَرَجْنَا الدَّهْرَ لَا نَتَعَسَّفُ"],
      ["وَلَسْنَا نُبَالي بِالصَّلِيبِ فَلَا نَرَى", "سِوَى خَالِقِ الْأَكْوَانِ يُعْطِي وَيُتْلِفُ"],
      ["وَنَذْكُرُ مَوْلَانَا الْجَلِيلَ تَعَرُّضًا", "لِلْأُنْسِ شُكْرًا وَلَا نَتَفَشَّفُ"],
      ["يَمُوتُ بِغَيْظٍ مَنْ يَعِظُهُ فَإِنَّهُ", "لِوَاءُ الْبَيَانِ يَعْلُو سَرْمَدًا وَيَزْخَرِفُ"],
      ["فَيَا رَبِّ فَاسْلُكْ بِي صِرَاطَ مُحَمَّدٍ", "وَصَحْبِي وَأَوْلَادِي وَمَنْ يَتَحَقَّفُ"],
      ["وَتَغْفِرُ لِي وَالْوَالِدَيْنِ وَهَبْ لَنَا", "دُخُولَ جِنَانٍ لَا تُخَافُ وَأُنْسَفُ"],
      ["وَهَبْ لِي مُرَادِي فِي إِقَامَةِ دِينِ مَنْ", "نَفَى مَا سِوَى الْإِسْلَامِ فِي الْكَوْنِ يُعْرَفُ"],
      ["أَمْوَالِيَ هَذَا الشَّيْبُ وَالْعَيْبُ زَائِدٌ", "وَحُسْنٌ لِعَيْبِي أَنَّ ذَاكَ يُحَفَّفُ"],
      ["وَإِنْ دَامَ هَذَا الْعَيْبُ وَالشَّيْبُ هَكَذَا", "سَأَقْبَلُهُ شَيْئًا مِثْلَ غَيْرِي وَأَنْفُ"],
      ["كَفَى قَدْ أُعْطِي بِالْعِنَانِ بَعْضَهُ", "عَلَى أَنَّ عِلْمَ اللَّهِ لَا يَتَوَقَّفُ"],
      ["صَلَاةً وَتَسْلِيمًا عَلَى خَيْرِ هَاشِمٍ", "وَآلٍ وَصَحْبٍ أَرْشَدُونَ وَتَقْوَى"]
    ]
  }