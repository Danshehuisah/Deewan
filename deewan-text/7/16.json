{
    "id": 16,
    "title": "حرف الفاء",
    "huruf": [
      ["فَإِنَّ مَدِيحَ الْهَاشِمِيِّ سِلَاحِي", "وَجَيْشِي بِهِ أَعْزُو طَوَالَ الرَّمَاحِ"],
      ["مَتَى عَسْكَرُوا أَوْ نَازَلُوا فَحَدِيدُهُ", "يَرُدُّهُمْ رَبِّي فِي الْمَسَا وَالصَّبَاحِ"],
      ["وَإِنِّي بِهِ أَغْزُو الْعِدَى وَأَكِيدَهُمْ", "بِدُونِ رِجَالٍ أَوْ بِدُونِ سِلَاحِ"],
      ["يَتَافَوْنَ مِنِّي كُسَّلًا يَوْمَ مَدْفَعٍ", "وَحَسْبِي وِقَاءُ اللَّهِ فِيهِ صَلَاحِي"],
      ["إِذَا مَا نَاجَى جِيفَةً هَالَهُمْ", "بِدُونِ قِتَالٍ بَلْ بِدُونِ جِرَاحِ"],
      ["لِمَنْ مُلْكُ هَذِهِ الْأَرْضِ يَوْمِي وَقَبْلَهُ", "فَلِلْوَاحِدِ الْقَهَّارِ مِنْهُ ارْتِيَاحِي"],
      ["كَفَانِي كَفَانِي مَا بَقِيتُ فَلَا أَرَى", "فَسَادًا صَلَاحًا بَلْ أُدِيمُ كَفَاحِي"],
      ["فَإِنَّ فَلَاحَ الْعَالَمِينَ بِقَفْوِ مَنْ", "قَدْ أُسْدِيَ لِمَنْ وَالَاهُ كُلَّ فَلَاحِ"],
      ["بِهِ قَدْ عَلَتْ غُرَبُ الْبَسِيطَةِ بَعْدَمَا", "أَذِلُّوا وَضَاعُوا تَحْتَ كُلِّ جَنَاحِ"],
      ["بِهِ بَرَعُوا فِي الْعِلْمِ بَعْدَ جَهَالَةٍ", "وَنَالُوا بِعَبْدِ الْحَشْرِ كُلَّ رَبَاحِ"],
      ["وَقَدْ كَسَّرُوا كِسْرَى وَدَمَّرَ قَيْصَرًا", "جُيُوشُهُمْ بِالْبِيضِ أَوْ بِالرِّمَاحِ"],
      ["تَرَاهُمْ وَأَبْطَالُ الْبِلَادِ تَخَالُهُمْ", "مِنَ الْجِنِّ وَالْأَمْلَاكِ يَنْسِلُ لَاحِي"],
      ["فَلَا يَأْتِ رُوحٌ مِثْلُ رُوحٍ مُحَمَّدٍ", "عَدُوِّي بِذِكْرَاهُ وَفِيهِ رَوَاحِي"],
      ["أُجِبْ لِقَوَافٍ شَائِبِ الْقُودِ قَاصِرٍ", "بِآيَاتِ حُبِّي فِي الْأَمِينِ صِحَاحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِرَاحِ مَدِيحِي الشُّكْرُ دُونَ جَنَاحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَدِيحُ الْإِمَامِ الْهَاشِمِيِّ جَنَاحِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَذِكْرُ الْمُفَقَّى فِي الشُّؤُونِ جَنَاحِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مُحَيَّاهُ أَنْسَانِي غُيُونَ مِلَاحِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ وَأَهْلٍ فَلَاحِ"]
    ]
