{
    "id": 26,
    "title": "حرف الغين",
    "huruf": [
      ["غُتَابٌ بِمَا أَقْبَلْتُمْ فَلْتُبَالِغُوا", "يَا أَعْدَادَ إِخْلَاصٍ تُصِبْكُمْ سَوَابِغُ"],
      ["سَوَابِغُ آلَاءٍ تَطِفْنَ وَظَاهِرٌ", "وَتَنْجَفُهَا بِرٌّ زُووفٌ وَتَالِغُ"],
      ["يَضُمُّ حَبِيبِي خَاتَمَ الرُّسْلِ نَاصِرِي", "مُحَمَّدٌ فِي مَحْوِ الضَّلَالِ الْمُبَالِغُ"],
      ["مُوَطِّدُ هَذَا الدِّينِ بِالْعَزْمِ وَالتُّقَى", "وَقَدْ أَشْرَقَ الْأَرْجَاءُ وَأَضَاءَ الْبَوَارِغُ"],
      ["يُؤَيِّدُهُ رَبُّ الْعِبَادِ وَأَنَّهُ", "مَتَابَةٌ جَنَانٌ لِلْأَبَاطِيلِ دَامِغُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَتَاكَ حَبِيبٌ قَلْبُهُ الْيَوْمَ فَارِغُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَهَلْ يَدْرِكُ الْمُضْلِلُ فِي الشَّأْوِ صَالِغُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ تَابَعُوا نَهْجَ الْأَمِينِ وَتَالَوْا"]
    ]
  }