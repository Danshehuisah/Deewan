{
    "id": 3,
    "title": "حرف الجيم",
    "huruf": [
      ["جَزَى اللَّهُ رَبُّ النَّاسِ خَيْرًا مُحَمَّدَا", "وَإِنِّي لَأَبْغِي شِعْرِي مَا أَرْوُمُ أَحْمَدَا"],
      ["فَأَفْضَلُ خَلْقِ اللَّهِ طُرًّا مُحَمَّدُ", "وَأَكْرَمُهُمْ نَفْسًا وَصِهْرًا وَمَحْتِدَا"],
      ["وَأَحْسَنُهُمْ خَلْقًا وَخُلُقًا وَمَنْطِقًا", "وَأَكْرَمُهُمْ قَوْمًا وَأَنْدَى وَأَجْوَدَا"],
      ["وَأَطْهَرُ خَلْقِ اللَّهِ جِسْمًا وَمَلْبَسًا", "وَأَكْرَمُهُمْ حَيًّا وَمَيْتًا وَأَفْيَدَا"],
      ["وَأَرْحَمُ فِي الدُّنْيَا وَالْأُخْرَى وَأَنَّهُ", "شَفِيعُ الْوَرَى وَالْكُلُّ لِلْخَوْفِ أَرْعَدَا"],
      ["فَكُلُّ نَبِيٍّ قَالَ نَفْسِي وَأُمَّتِي", "يَقُولُ وَيَدْنُو حَامِدًا وَمُحَمَّدَا"],
      ["وَأَيْنَ سَنَا خَلِيلِ اللَّهِ أَيْنَ كَلِيمُهُ", "حَبِيبِي حَبِيبُ اللَّهِ مُعْطِي الْوَرَى الْجَدَا"],
      ["وَأَيْنَ صَفِيُّ اللَّهِ وَالرُّوحُ رُوحُهُ", "أُفَدِّيكَ طَهَ الْهَاشِمِيَّ تَعَمُّدَا"],
      ["وَأَشْهَدُ أَنَّ خَيْرَ الرُّسْلِ سَيِّدَ خَلْقِهِ", "عَلَيْكَ صَلَاةُ اللَّهِ أَفْضَلَ مَنْ هَدَى"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً وَتَسْلِيمًا يَقُودَانِ لِلْهُدَى"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أُحَيِّيكَ تَفْدِيَةً قَبْلَ أَنْ يُجْزَلَ النَّدَى"],
      ["بِكُولَا وَهُنًا قَدْ أَرِقْتُ لِأَذْكُرَهُ", "وَقَدْ نَامَ جَارَاتِي وَحَيَّ تَوَقُّدَا"],
      ["أُسَامِرُهُ لَيْلِي وَقَدْ حَالَ دُونَهُ", "مَهَامِهُ أَطْوِيهَا قَدْ قَطَعْتُهَا ثُمَّ قَدْ قَطَعْتُهَا"],
      ["أَطِيرُ بِهِ مِنْهُ لَهُ مُرْتَحِلًا", "سِرَايَةً وَجُمْعًا قَدْ أَضَاءَ فَمَدَّ بَدَا"],
      ["يُرَجِّي لَا رَوْعٌ وَجِسْمِي وَلَيْتَنِي", "يُرَجِّي فِي دُورِي أَتَبَعُ مُحَمَّدَا"],
      ["أُوَاجِهُ طَهَ الْهَاشِمِيَّ بِبَيْتِهِ", "أُبَلِّغُهُ تَسْلِيمِي وَقَوْمِيَ الَّذِينَ هَدَى"],
      ["أَنَالُ مَرَامِي فَوْقَ مَا كُنْتُ آمُلُ", "إِذَا طَرَقْتُ لِلْهَادِي النَّدَى الْكُلَّ أَرْشُدَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتَقْبَلَ بُنْيَانِي وَتُشَيِّدَهُ مَسْجِدَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتَرْفَعَ مَنْ يُعَلِّي بِنَاءً وَتُسْعِدَا"],
      ["وَتَأْوِي لَهُ كُلَّ الْمَسَاجِدِ وَاحْبُهُ", "مِنَ الْمُحْدَثَاتِ الشَّوْهِ لِلذِّكْرِ سَرْمَدَا"],
      ["وَتُجْمَعُ فِيهِ الْخَيْرُ وَالْعِلْمُ وَالتُّقَى", "إِلَى أَبَدِ الْآبَادِ لَمْ يُلْفَ مُلْحِدَا"],
      ["يُسَيَّرُ بِنَا حَوْلَ الْبِلَادِ دَائِمًا", "بِدِينٍ وَدُنْيَا بَاهِرَ السِّرِّ مُفْرَدَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَدِينَةُ تَبْقَى مَعْقِلَ الْأَمْنِ وَالْهُدَى"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ كُلُّهُمْ إِنَّ مُقْتَدَى"]
    ]
  }