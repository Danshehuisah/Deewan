{
    "id": 7,
    "title": "حرف الزاي",
    "huruf": [
      ["زَمَامِي بِكَفِّي خَيْرُ الرُّسُلِ نَاصِرِي", "مُحَمَّدِ الْهَادِي الْوَرَى ذِي الْبَصَائِرِ"],
      ["وَأَحْمَدُ طَهَ عَاقِبٌ وَمُحَمَّدٌ", "بَشِيرٌ نَذِيرٌ مُصْطَفَى الْكَوْنِ حَاشِرِي"],
      ["شَفِيعُ الْوَرَى مَاضِي الصِّلَالِ مُبَشِّرُ", "الْعِبَادِ وَمَحْمُودُ الْمَقَامِ مُوَازِرِي"],
      ["فَيَشْفَعُ فِيمَا قَدْ جَنَيْتُ مُشَفَّعًا", "فَكُنْ لِي شَفِيعًا فِي حَيَاتِي وَآخِرِي"],
      ["صَفَا لِي وَقْتِي إِذْ خَلَوْتُ أَذْكُرُهُ", "بِكُولَا وَهُنَا نَامَ كُلُّ مُجَاوِرِي"],
      ["طَوَى لِي مَا بَيْنِي وَبَيْنَ حَبِيبِهِ", "بِسِرٍّ مِنَ الْأَسْرَارِ حَقَّ خَاطِرِي"],
      ["فَجَاوَزَ طَهَ الْهَاشِمِيُّ بِكُولَا", "وَقَدْ حَسِبُونِي فِي جِوَارِ الْكَوَافِرِ"],
      ["جِوَازٌ بِهِ رَدَّ الْإِلَهُ مَكَايِدِي", "وَكَيْدَ الْعِدَا إِذْ جَاعِلِي بِالْبَشَائِرِ"],
      ["بِسِرٍّ سَرَى مِنْ حَضْرَةِ الْقُدْسِ قَاذِفٍ", "وَأَعْدَمَ مَوْجُودِي وَأَصْفَى سَرَائِرِي"],
      ["بِيُمْنِ الْإِمَامِ الْهَاشِمِيِّ وَذِكْرِهِ", "وَهْوَ عُدَّتِي فِي كُلِّ بَدْوٍ وَحَاضِرِي"],
      ["فَمَنْ حَارَبَ الْعَبْدَ الْحَقِيرَ فَرُبَّمَا", "بَيَّنْتُ لَهُ بِالْوَيْلِ أَوْ بِالْخَسَائِرِ"],
      ["فَسَائِلْ أَبَا جَهْلٍ وَفِرْعَوْنَ قَبْلَهُ", "وَنَمْرُودَ قَدْ خَابُوا جَمِيعَ الذَّخَائِرِ"],
      ["طَغَوْا وَعَتَوْا عِنْدَ الْبِلَادِ فَأُهْلِكُوا", "بِأَنْوَاعِ خِزْيٍ وُفُقَ تِلْكَ الْكَبَائِرِ"],
      ["وَقِى سُنَنُ اللَّهِ الْجَلِيلِ فَلَنْ تَرَى", "تَبْدِيلَهَا فِي الْخَلْقِ دَهْرَ الدَّهَائِرِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَتَضْمَنُ مَا اسْتَقْبَلْتَ مِنِّي وَظَاهِرِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَكُونُ حَبِيبِي قَائِدِي وَهْوَ جَابِرِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَرْفَعُ شَانِي فِي الْمُسَابِقِينَ الْغَوَابِرِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ السَّرَاةِ الْأَكَابِرِ"]
