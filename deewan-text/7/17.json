{
    "id": 17,
    "title": "حرف الصاد",
    "huruf": [
      ["ضَعِيفٌ ذَلِيلٌ فَاقِدُ الْحِيلَةِ جَاوَزْتُ", "حُدُودًا لِجَبَّارِ السَّمَاءِ وَبَازَزْتُ"],
      ["بَغَى النَّاسُ عَنْ مَدْحِ النَّبِيِّ وَذِكْرِهِ", "إِلَيْكَ تَضَرَّعْنَا لِتُخْزِيَ الْمُبَارِزَا"],
      ["بِبَغْيٍ وَعُدْوَانٍ بَغَى كُلُّ مُسْلِمٍ", "جَمْعُهُمْ إِلَّا لِلَّهِ فَبَارَزُوا"],
      ["تَوَلَّ جَنَابِي وَاحْمِ كُلَّ أَجِيرَتِي", "وَأَهْلِكَ عِدًا جَابُوا إِلَيْنَا الْمَفَاوِزَا"],
      ["عَلَى أَحْمَدَ الْمُخْتَارِ مِنْ عِنْدِ رَبِّهِ", "صَلَاةٌ وَتَسْلِيمٌ تُسَيَّلُ الْجَوَائِزَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَقُوِّي لَنَا ضِدَّ الْبُغَاةِ الْمَرَاكِزَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "أَمْوَالَيَ حَقًّا بَارِزُوا ثُمَّ نَاجِزَا"]
    ]
  }