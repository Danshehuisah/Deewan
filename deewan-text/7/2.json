{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["بِصَوْمِي وَحَجِّي لَمْ أَثِقْ فَالْوَثَائِقُ", "بِفَضْلِ كَرِيمٍ يَوْمَ تُبْلَى الْحَقَائِقُ"],
      ["أُصَلِّي امْتِثَالًا أَذْكُرُ اللَّهَ تَالِيًا", "وَمَا ثَمَّ شَيْءٌ إِنْ تَبَصَّرَ ذَائِقُ"],
      ["تَغَمَّدْ بِفَضْلٍ عَبْدَ سَوْءٍ مُقَصِّرًا", "فَتَنْقُذْهُ إِذْ ضَاقَتْ عَلَيْهِ الطَّرَائِقُ"],
      ["فَإِذَا ضَاقَ صَبُ الْعَبْدِ بِالْكَرْبِ وَالْأَسَى", "وَأَوْفَى وَوَافَاكَ زَالَ الْمَضَايِقُ"],
      ["فَقَدْ جِئْتَ بِالدِّينِ الْحَنِيفِ مُهَدِّدًا", "وَدَافَعْتَ عَنْهُ وَالسُّيُوفُ بَوَارِقُ"],
      ["فَالَ الْعِدَى مِنْ بَأْسِهِمْ قَدْ تَفَتَّتُوا", "وَبَيَّنْتَ نَجْوَى فَازَ مِنْهُ الْخَلَائِقُ"],
      ["وَإِنِّي مُحِبٌّ شَاعِرٌ خَادِمٌ لَكُمْ", "وَشَرْقُ وِدَادِي ضَاقَ مِنْهُ الْمَهَارِقُ"],
      ["تَنَاسَى رِجَالٌ بِالْخَدِيمِ وَأَيَّنِي", "أُسَاجِلُهُمْ لَا أَيَّنَيْ وَأُسَابِقُ"],
      ["أُسَابِقُهُمْ مَا عِشْتُ فِيكَ وَإِنْ أَمُتْ", "يُسَاجِلْهُمْ فَرْعِي وَفِيكَ يُسَابِقُ"],
      ["لِحُبِّكَ يَدْعُونِي دَوَاعٍ عَدِيدَةٌ", "جَمَالٌ وَإِحْسَانٌ وَطَبْعٌ مُوَافِقُ"],
      ["شَجَاعَةُ نَفْسٍ وَعَزْمٌ وَعَقْلُ", "وَحِلْمٌ وَجُودٌ حَارَ فِيهِ الطَّوَارِقُ"],
      ["وَعَقْلٌ وَزُهْدٌ وَحَزْمٌ وَحِكْمَةٌ", "وَصَبْرٌ مَتَى تَسْقِ الْبَلِيَّاتِ خَالِقُ"],
      ["وَآيَاتُ صِدْقٍ بَانَ حَقًّا بِأَنَّهَا", "مِنَ اللَّهِ كُلُّ الْأَمْرِ رَاقٍ وَرَائِقُ"],
      ["إِذْ أَنْتَ لَدَيَّ قَدْ جِئْتَ بِالصِّدْقِ صَادِقًا", "فَإِنَّكَ مَصْدُوقٌ وَأَنَّكَ صَادِقُ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَبُرْهَانُ حِبٌّ عَاشِقٌ فِيكَ وَامِقُ"],
      ["أَتَعْرِفُ مَنْ أَهْوَاهُ حَقًّا مُحَمَّدًا", "نَبِيًّا لِكُلِّ الْأَنْبِيَاءِ وَهْوَ سَابِقُ"],
      ["أَتَعْرِفُهُ ذَاكَ الْمُشَفَّعُ وَأَنَّهُ", "لِوَاءُ الْحَمْدِ فِي كَفَّيْهِ وَالْكُلُّ رَامِقُ"],
      ["أَتَعْرِفُ طَهَ مَنْ يَلُوذُ بِنَحْرِهِ", "أَبُو الْبَشَرِ الْعَالِي وَبُرْهَانُ لَاحِقُ"],
      ["وَنُوحٌ وَمُوسَى ثُمَّ عِيسَى وَكُلُّهُمْ", "يَرَى أَنَّ هَذَا بِالشَّفَاعَةِ لَائِقُ"],
      ["فَيَشْفَعُ مَحْمُودُ الْمَقَامِ مُشَفَّعًا", "وَمُعْطًى سُؤَالًا وَهْوَ بِالْحَقِّ وَاثِقُ"],
      ["أَرَانِي مَعَ الْعِلَّاتِ أَرْمِي خُطُوبَهَا", "أَرْجُو الْبَقَاءَ مِنْهُ تَبْدُ الْخَزَارِقُ"],
      ["إِذَا الْتَفَتَ الْهَادِي إِلَيَّ فَإِنَّهُ", "يُعْطِي سُؤَالِي نُورُهُ وَالْحَقَائِقُ"],
      ["وَيُلْحِقُنِي بِالْمَادِحِينَ تَكَرُّمًا", "يُبَشِّرُنِي فِي جَمْعِهِ وَيُعَانِقُ"],
      ["وَيَسْمَعُ مِدْحِي ذِكْرَهُ وَمَدِيحَهُ", "يُفَاخِرُ بِي فِي الْأَنْبِيَاءِ وَيُوَافِقُ"],
      ["أَقُولُ لَهُ صَحْبِي وَأَهْلَ مَوَدَّتِي", "فَقَالَ ادْخُلُوا صَحْبَ الْخَدِيمِ تَسَابَقُوا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ سَاجَلُوا وَتَسَابَقُوا"]
    ]
