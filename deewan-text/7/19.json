{
    "id": 19,
    "title": "حرف الراء",
    "huruf": [
      ["رَفَعْتُ لِوَاءَ الدِّينِ بِالذِّكْرِ صَارِحًا", "وَذِكْرِي وَوُدِّي كَانَ فِي الْقَلْبِ رَاسِخًا"],
      ["فَيَا مَا أُحَيْلَى ذِكْرَ طَهَ مُحَمَّدٍ", "رَسُولٍ أَتَى بِالذِّكْرِ لِلْغَيْرِ نَاسِخًا"],
      ["أَلَا اعْتَصِمُوا بِالْحَبْلِ حَبْلِ مُحَمَّدٍ", "رِجَالًا وَأَطْفَالًا نِسَاءً وَمَشَايِخَا"],
      ["يَفُوفُونَ رِجَالًا مُدْلِجِينَ قَدْ أَدْمَنُوا", "مُسِيرًا وَجَابُوا فَجْفَجًا وَسَرَائِخَا"],
      ["بِخَيْرِ نَبِيٍّ جَاءَ مِنْ خَيْرِ مَالِكٍ", "بِرُزْحٍ أَقْطَابٌ قَدْ أَمْسَوْا بَرَازِخَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُوَاصِلُنِي مَا جُبْتُ حِسًّا فَرَاسِخَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأَعْلُو بِهَادِي الْخَلْقِ ثُمَّ شَوَامِخَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَهُدُّ بِذِكْرَاهُ الْجِبَالَ الرَّوَاسِخَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَكُلُّهُمْ بِالذِّكْرِ قَدْ كَانَ صَارِخَا"]
    ]
  }