{
    "id": 4,
    "title": "حرف الدال",
    "huruf": [
      ["دَلِيلِي نَبِيِّي قَائِدِي وَهْوَ مُرْشِدِي", "وَأَسْعَى لِرَفْعِ الدِّينِ غَيْرَ مُهَدَّدِ"],
      ["دَفَعْتُ عَنِ الدِّينِ الْحَنِيفِ بِكَفِّهِ", "وَإِنَّا وَإِيَّاهُ فِي نِطَاحِ جَلَمَّدِ"],
      ["دَسَائِسُ أَهْلِ الْمَكْرِ رُدَّتْ لِنَحْرِهِمْ", "وَوَيْلٌ لِمَنْ نَاوَى الرَّقِيبَ بِمَرْصَدِ"],
      ["دَعْوَايَ مَدْحُ الْهَاشِمِيِّ وَذِكْرُهُ", "غَنِيتُ بِهِ عَنْ غَيْرِهِ وَهْوَ مُسْنَدِي"],
      ["دَرَوْا أَنَّنِي خَادِمُ الْمُنْعِمِ الَّذِي عَلَتْ", "بِهِ الْمِئَةُ الْغَزَارُ بِغَيْرِ مُشَهَّدِ"],
      ["دَعَاهُمْ إِلَى هَذَا الْكِتَابِ فَمَنْ أَبَى", "فَهَذَا الْمُشِيرُ قَدْ يَهْتَدِي بِهِ كُلُّ مُعْتَدِ"],
      ["دَلَالَاتُ صِدْقٍ قَدْ تَبَدَّتْ بِقَوْلِهِ", "وَبِالْفِعْلِ وَالْخُلُقِ الْعَظِيمِ فَقَدْ قُدُوا"],
      ["شَرِيعَتُهُ آيَاتُهُ وَصِحَابُهُ", "وَعُنْصُرُهُ مِنْ بَعْدِ أَفْضَلِ مَوْلِدِ"],
      ["نَشَا فَأَفْنَى فِي الْبِرِّ وَالْعَدْلِ وَالْوَفَا", "وَمَا فِيهِ مَذْمُومٌ وَمَا فِيهِ مِنْ دَدِ"],
      ["فَمَا ظَلَمَ الْهَادِي وَلَا مَانَ نَاطِقًا", "وَمَا جَاءَ بِالْفَحْشَا مَدَى الدَّهْرِ صِدِّيدِي"],
      ["فَأَفْضَلُ خَلْقِ اللَّهِ حَقًّا مُحَمَّدٌ", "وَأَحْمَدُ كُلَّ الرُّسْلِ فِي الْيَوْمِ وَالْعَدَدِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلِيَ الْفَخْرُ فِي ذِكْرِ الْحَبِيبِ مُحَمَّدِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَدِيحِيَ بَحْرٌ يَزْدَرِي كُلَّ صَرْحَدِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَجِرْنِي أَجِرْنِي مُصْطَفَى وَمُنْجِدِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَجِرْنِي يَا طَهَ بِبَلْبَلِي لِمَقْصِدِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ كُلُّهُمْ مُخْبِرٌ مُرْشِدِ"]
    ]
