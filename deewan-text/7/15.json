{
    "id": 15,
    "title": "حرف العين",
    "huruf": [
      ["عَلَى طَيْبَةٍ دَارِ الْحَبِيبِ رِيَاضُ", "جِنَانٌ فَلِلْأَقْطَابِ فِيهِ حِيَاضُ"],
      ["يُقَدَّسُ فِيهِ الْعَبْدُ وَهْوَ مُقَرَّبٌ", "لِرَبِّ الْبَرَايَا وَالْعُلُومُ تَنَاضُ"],
      ["فَيُقْبِطُ أَمْلَاكُ الْمَجِيدِ مَقَامَ مَنْ", "بِحُرِّ مِنَ الْأَنْوَارِ فِيهِ رِيَاضُ"],
      ["فَرَوْضُ أَرِيشٍ حَضْرَةٌ قُدْسِيَّةٌ", "تَشْبَهُ بِقَوْمٍ قَدْ عَشَوْهُ وَخَاضُوا"],
      ["فَمَا لَذَّتْ عَيْنِي فِي زُبُوعٍ سِوَائِهِ", "وَقَدْ حَالَ بَيْدٌ وَهْيَ جَبْرٍ عِرَاضُ"],
      ["عَلَى سَاكِنِي سَلْعٍ سَلَامٌ مُكَرَّرٌ", "ثَرَى كَيْ بِهِ نَفْسِي أَجَلٌ وَنِضَاضُ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "لِصُحْفِي وَوَعْيِي مِنْ سَنَاهُ يَفِيضُ"]
    ]
  }