{
    "id": 11,
    "title": "حرف اللام",
    "huruf": [
      ["لَقَدْ عَادَنِي شَوْقِيَ الْمُبْرِحُ مَا لِيَا", "وَقَدْ نَامَ جَارَاتِي وَأُصْبِحَ وَاعِيَا"],
      ["حَنِينًا إِلَى مَوْلَى الرِّسَالَةِ مَنْ غَدَا", "شَفِيعَ الْوَرَى وَالْكُلُّ يَرْجُونَ وَافِيَا"],
      ["أَبَا الْبِيضِ وَالْخَمْسِينَ هَلْ مِنْ لِوَاكَ لِإِثْمِي", "لِشَوْقٍ دَوًا كَالَّذِي كَذَلِكَ مَا بِيَا"],
      ["أَلَا فَاعْذُرُونِي أَوْ فَلُومُوا فَمَا أَنَا", "بِأَمْيَرَ يَأْنَى الْحَالِيُونَ لِحَالِيَا"],
      ["وَمَنْ كَانَ يَدْرِي الْمُنْعِمَ الْمَوْلَى وَعَاقِبًا", "عَرَفْتُ لِحَالَاتِي وَلَوْ كَانَ فَالِيَا"],
      ["أَصِخْ لِإِشَارَاتِي فَإِنِّيَ لَمْ أَبُحْ", "بِسِرِّ حَبِيبِي خَلَّ عَنْكَ سُؤَالِيَا"],
      ["أُحِبُّ الْإِلَهَ الْحَقَّ عَيْنَ مُحَمَّدٍ", "أَفَاضَ لَهُ مِنْهُ إِلَيْهِ مُدَامِيَا"],
      ["فَسُبْحَانَ رَبِّي فَوْقَ حَضْرَةِ قُدْسِهِ", "وَسُبْحَانَ رَبِّي مَا أَجَلَّ إِلَهِيَا"],
      ["إِذَا مَا تَلَا التَّالِي صِفَاتِ نَبِيِّنَا", "بِوَالنَّجْمِ أَمْسَى لِلْحَقِيقَةِ دَارِيَا"],
      ["قَدْ أَثْنَى عَلَيْهِ رَبُّنَا بِكَلَامِهِ", "فَمَاذَا عَسَى بُرْهَانُ يُصِيبُ حَاكِيَا"],
      ["فَعُولُ مُفَاعِلُ فَعُولُنْ مُفَاعِلُنْ", "مَدَى الدَّهْرِ لَا يَأْتِي بِحَقِّكَ مَاحِيَا"],
      ["وَلَكِنَّ مَدْحَ الْمَادِحِينَ تَشَفُّعٌ", "فَيَشْفَعُ لِي طَهَ لِأَجْلِ مَقَالِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُقَرِّبُنِي خَيْرُ الْبَرِيَّةِ رَاضِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَتَوَّجُ أَقْطَارَ الْبِلَادِ ثَنَائِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ وَمَنْ جَاءَ تَالِيَا"]
    ]
  }