{
    "id": 25,
    "title": "حرف الظاء",
    "huruf": [
      ["ظَمَائِي بِخَيْرِ الْهَاشِمِيِّ الدَّهْرَ لَنْ تُرْوَى", "وَقَدْ ذَلَّ ذِكْرَاهُ لِمَنْ نَالَ وَالسَّلْوَى"],
      ["ذَرِينِي يَا دَعْدًا إِنَّ قَلْبِي لَنْ يَهْوَى", "سِوَى أَحْمَدَ مَاحِي الضَّلَالَاتِ وَالْبَلْوَى"],
      ["ظَلَمْتُهُ إِذَا كَبِدْتُهُ حُبَّ سِوَاهُ", "وَطَهَ حَبَانِي نِلْتُهُ غَايَةَ الْقُصْوَى"],
      ["وَهْوَ خَيْرُ خَلْقِ اللَّهِ خَلْقًا وَخُلْقَةً", "لِوَاءُ الْحَمْدِ فِي كَفَّيْهِ أَيْنَ لَهُ شَرْوَى"],
      ["تَهَدَّيْتُ بِالْهَادِي الْعِبَادَ فَمَنْ لَهُ", "رَسُولٌ مِثْلُ الْهَاشِمِيِّ أَبِي الْقُصْوَى"],
      ["أَبِي الْقَاسِمِ الْمَنْصُورِ بِاللَّهِ وَحْدَهُ", "شَفِيعِي وَمَأْمُونِي الْمَكِّيِّ رَاكِبِ الْقُصْوَى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَقِينَا بِهَا النَّاسَ وَالشَّرَّ وَاللَّأْوَاءَ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَقِينَا جَمِيعَ الشَّرِّ وَالْبَغْيِ وَالْغَوَاءَ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُنِيلُ الْمُنَى لِلْعَبْدِ وَيَكْفِيهِ الْبَلْوَى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يُسَخِّرُ لِي دَهْرِي وَيُخْفِضُ لِي الْمَأْوَى"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ سَلَكُوا نَهْجَ الْأَمِينِ وَمَنْ يَتْوَى"]
    ]
  }