{
    "id": 6,
    "title": "حرف الواو",
    "huruf": [
      ["وَلَا جَفَافِي فِيكَ كُلُّ هُجُولِ", "رَفَضْتُ بِدُورِي فِيكَ كُلَّ خَلِيلِ"],
      ["وَنَصْرُ طَهَ الْهَاشِمِيِّ مُؤَيِّدِي", "وَذَاكَ أَنِيسِي بَلْ هُوَ كُلُّ زَمِيلِ"],
      ["وَقَدْ خَاوَلُوا تَعْسًا لَهُمْ لِجَهَالَةٍ", "ضِرَارِي وَإِنِّي فِي جِوَارٍ جَلِيلِ"],
      ["وَقَدْ مَكَرُوا مَكْرًا وَرَبِّي بِفَضْلِهِ", "أَبَادَهُمْ فَالْكُلُّ جِدُّ ذَلِيلِ"],
      ["وَآبُوا خَيَارَى نَادِمِينَ أَذِلَّةً", "وَأَبْقَى خَدِيمًا لِلْأَمِينِ رَسُولِي"],
      ["وَقَدْ ضَرَّهُمْ فَقْرٌ وَذُلٌّ وَفَاقَةٌ", "وَعَارٌ وَخَوْفٌ عِنْدَ كُلِّ سَبِيلِ"],
      ["وَإِنِّي فِي خَيْرٍ وَبِرٍّ وَرِفْعَةٍ", "وَأَمْنٍ وَإِيمَانٍ بِطَهَ الْمُنِيلِ"],
      ["وَإِنْ أَعْمَلُوا فِي كُلِّ مَكْرٍ وَجِيلَةٍ", "فَمَا ضَرَّنِي فِي دَهْرِيَ أَقَلُّ قَلِيلِ"],
      ["وَإِنْ وَعَدُوا أَوْ أَوْعَدُوا فَإِخَالُهُمْ", "مَجَانِينَ لَمْ يُوفُوا وَلَوْ بِفَيْلِ"],
      ["وَإِنِّي بِبَارِقٍ قَدْ غَنِيتُ وَإِنَّنِي", "بِعَيْنِي تَسَاوَى خَاتِمٌ بِتَخِيلِ"],
      ["وَلِمْ لَا وَمَمْدُوحِي الْكَرِيمُ مُحَمَّدٌ", "فَكُلُّ عَطَا مِنْ غَيْرِهِ كَضَئِيلِ"],
      ["وَإِنِّي بِبَلْبَلِي بَعْدَ وَهْنٍ بِكُولَا", "مَتَى لِي شَوْقٌ مَا دَرَيْتُ مُثِيلِي"],
      ["وَلَمْ أَرَ شَيْئًا غَيْرَ وَجْهِ مُحَمَّدٍ", "فَمَا غَيْرُ وَجْهِ الْهَاشِمِيِّ بِجَمِيلِ"],
      ["وَلَيْسَ بِتَجْسِيمِ الْمَعَانِي مُبَالِغًا", "فَتَيْلَا وَتَادٍ فِيهِ جِدٌّ فَتَيْلَا"],
      ["وَأَجْلُ كُلِّ النَّاسِ حَقًّا مُحَمَّدٌ", "وَكُلُّ فَتًى أَجْرَى لَهُ بِجَزِيلِ"],
      ["لَهُ الْحُسْنُ وَالْإِحْسَانُ حَقًّا فَكُلُّنَا", "بِظِلٍّ وَرِيفٍ مِنْ عَطَاهُ ظَلِيلِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مُجِيبُكَ يَرْجُو مِنْكَ خَيْرَ مَقِيلِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَقِلْنِي مِنْ عِبْءٍ عَلَيَّ ثَقِيلِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فِي النَّقْدِ مَهْمَا كُنْتَ عَيْنَ كَيْلِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَتَشْمَلُ أَزْوَاجًا وَكُلَّ قَبِيلِ"]
    ]
  }