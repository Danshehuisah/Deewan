{
    "id": 12,
    "title": "حرف الميم",
    "huruf": [
      ["مُرَادِي عَيْنُ الْحَقِّ تَيْدَكَ لِلْأَنْبِيَا", "فَلَيْسَ سِوَى الذِّكْرِ الْحَكِيمِ بِعَاصِمِ"],
      ["تَلَاهُ الْفَتَى الْمَأْمُونُ مِنْ عِنْدِ رَبِّهِ", "مِنَ الْمَاءِ جِبْرِيلَ أَكْبَرِ خَادِمِ"],
      ["فَجَاءَ بِهِ نُورًا دَعَانَا لِرَبِّهِ", "وَأَبْلَغَنَا مَا فَاتَ كُلَّ الْعَوَالِمِ"],
      ["وَصِرْنَا بِهِ خَيْرَ الْبَرَايَا وَإِنَّمَا", "شُهُودٌ إِذَا يَضْحَى الْمُهَيْمِنُ رَاحَتِي"],
      ["لَنَا شَاهِدٌ عَدْلٌ مُزَكًّى مُبَرَّرٌ", "وَيَرْفَعُنَا فَوْقَ السَّهَا وَالتَّنَاعِمِ"],
      ["وَهَذَا الْمُنْعِمُ الْمَوْلَى مَلْجَأُ الْكُلِّ شَافِعًا", "لِوَاءُ الْحَمْدِ فِي كَفِّهِ هَلْ مِنْ مُزَاحِمِ"],
      ["فَأَنْشُدُ أَمْدَاحِي وَأَشْدُو بِذِكْرِهِ", "جِهَارًا عَلَى رَغْمِ الْعَدُوِّ الْمُسَاحِمِ"],
      ["فَأَشْرَبُ مِنْ كَفِّ الْأَمِينِ وَإِنَّنِي", "أُسَاقِي يَشْفِي الْمُهَيْمِنُ مَلَامِي"],
      ["مَنْ قَالَ قَدْ أَضْلَلْتُ فَالْحَقُّ شَاهِدٌ", "عَلَى أَنَّنِي مَا جُدْتُ عَنْ نَبِيِّ هَاشِمِ"],
      ["وَهَذَا الْبَيَانُ مَوْرُودٌ بِعِلْمٍ قَلَّ يَرِثْ", "أَخُو الْجَهْلِ نُخْرِيًا سَلِيلَ الْأَكَارِمِ"],
      ["وَإِنْ ضَلَّ الْجَهْلُ ذَا الْعِلْمِ وَالْهُدَى", "فَتَفْسِيرُهُ ذُو الْجَهْلِ لَيْسَ بِعَالِمِ"],
      ["بِكَسْبٍ يَكُونُ الْإِرْثُ عِنْدَ نَبِيِّنَا", "عَلَيْهِ صَلَاةُ اللَّهِ عَدَّ الْعَوَالِمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ جُهُورِ الْقَضَارِمِ"],
      ["تُقَلِّدُ طَهَ الْهَاشِمِيَّ وَتُنْفِذُ", "أَوَامِرَهُ فِي الْكَوْنِ وَالْكَوْنُ تَنْقُذُ"],
      ["أَلَمْ تَدْرِ أَنَّ الْهَاشِمِيَّ مُسَامِرِي", "وَمُقْتَدَى مَهْمَا تَحَيَّرَ دِهْدِهُ"],
      ["أَلَمْ تَدْرِ أَنَّ الْهَاشِمِيَّ مُسَاعِدِي", "إِذَا أَبْرَمُوا الْأَحْزَابَ يَوْمًا وَتَقْدِدُوا"],
      ["أَلَمْ تَدْرِ أَنَّ الْهَاشِمِيَّ مُدَافِعِي", "عَنِ الْعَبْدِ مَهْمَا قِيلَ فَارْمُوهُ وَابْذُوا"],
      ["أَلَمْ تَدْرِ أَنَّ الْهَاشِمِيَّ مُؤَيِّدِي", "إِذَا دُهِشَ الْأَقْطَابُ إِذْ قِيلَ فَانْفُذُوا"],
      ["لَقَدْ فَازَ أَحْبَابِي جُنُوا غَرْسَ حُبِّهِ", "مَتَى قِيلَ بُرْهَانُ الْخَدِمِيّ الْمُوقَذُ"],
      ["وَقَدْ قَالَ مَمْدُوحِي قَائِي مُنَفِّذٌ", "أُمُورِي إِلَى بُرْهَانَ فَالْمُنْقِذُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ دَارَكُونِي وَاتَّقِدُوا"]
    ]
  }