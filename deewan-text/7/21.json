{
    "id": 21,
    "title": "حرف التاء",
    "huruf": [
      ["تُزَافِي سَمِيرَ النَّجْمِ بِاللَّيْلِ حَافِظًا", "وِدَادَ الْمُقْتَفَى لِلْعُودِ مُحَافِظَا"],
      ["عَلَى الْخَدِّ دَمْعِي يَرْجُفُ الْقَلْبُ مُوهِنًا", "أُنَاشِدُ أَشْعَارَ الْمَحَبَّةِ لَافِظَا"],
      ["تَرَى السَّيِّدَ أَمْثَالِي سُجُودًا قَدْ أَخْلَصُوا", "لَدَى الذِّكْرِ تُلْفِي الْكُلَّ لِلذِّكْرِ حَافِظَا"],
      ["وَحَسْبِي مَدِيحُ الْمُنْعِمِ الْمَوْلَى وَذِكْرُهُ", "فَلَمْ أَلْتَفِتْ لِلْغَيْرِ دَهْرًا مَلَاحِظَا"],
      ["شَفِيعُ الْوَرَى لَيْثُ الْغَابَةِ مَرْكَزٌ", "لِشَرْعِ إِلَهِ الْعَرْشِ لِلْخَلْقِ وَاعِظَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَرَحْبًا بِكَ مِثْلَ مَنْ رَاحَ قَارِظَا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ عَنْكَ لَاقَوْا وَوَاعِظَا"]
    ]
  }