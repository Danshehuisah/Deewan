{
    "id": 5,
    "title": "حرف الهاء",
    "huruf": [
      ["هَوِيتُ رَسُولَ اللَّهِ طَهَ الْمُشَفَّعَا", "لَدَى الْحَقِّ مَنْ قَصْرُ الصَّلَاةِ لَهُ زُعْزِعَا"],
      ["وَشَتَّتَ شَمْلَ الْكُفْرِ أَمْسَتْ زُبُوعُهُ", "يَبَابًا وَنُورُ الْحَقِّ فَخْرًا تَشَعْشَعَا"],
      ["أَعُوذُ بِرَبِّ الْعَرْشِ جَلَّ جَلَالُهُ", "مِنْ إِمْسَاكِ دِينٍ حَبْلُهُ قَدْ تَقَطَّعَا"],
      ["أَعُوذُ بِرَبِّ النَّاسِ مَالِكِ سِرِّهِمْ", "مِنَ السَّلْبِ أَوْ أَنْ لِلْعِدَى أَتَضَعْضَعَا"],
      ["أَعُوذُ بِرَبِّ الْخَلْقِ وَالْأَمْرِ أَنْ أَرَى", "بِعَيْنِيَّ رُكْنَ الدِّينِ يَوْمًا تَصَدَّعَا"],
      ["وَأَسْأَلُ يَا قَيُّومُ يَا حَيُّ رَبَّنَا", "بِأَنْ تَنْصُرَ الدِّينَ الْقَوِيمَ الْمُوَسَّعَا"],
      ["بِجَاهِ رَسُولِ اللَّهِ أَحْمَدَ مُقْتَفًى", "أَبِي الْقَاسِمِ الْمَاضِي ضَلَالًا مُسْتَبِيغَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا هَذَا الْعَبْدُ دَهْرًا تَمَتَّعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا هَذَا الْعَبْدُ يُلْقَى مُتْبَعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تُصَيِّرُ الْعَبْدَ دَهْرًا مُرْتَفِعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا أُمْسِي كَرِيمًا مُوَسَّعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا أَرَى دَهْرِي مُتَدَرِّعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا يُرْزَقُ الْأَحْبَابُ حِضْنًا مُمْتَنِعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا نَدَمٌ مِمَّنْ لِهَذَا الْقَبْضِ شَتَّعَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهَا مُحِّرَتِ الْحِزْبَانُ إِنْ حَلَّ مَرْبَعَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ سَلَكُوا نَهْجَ الْأَمِينِ تَطَوُّعَا"]
    ]
  }