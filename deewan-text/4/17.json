{
    "id": 17,
    "title": "حرف الفاء",
    "huruf": [
      ["فَهَلْ لَكَ أَنْ تَنْحُوَ لِتَنْحُوَ الْمُؤْتَسِ", "مُحَمَّدِ الْمَاضِي حَبِيرِي الْمُقَدَّسِ"],
      ["أُنَادِي يَا طَهَ وَأَحْمَدُ عَاقِبُ", "وَحَاشِرُ يَا هَادِي الْعِبَادِ الْمُؤْتَسِ"],
      ["مُحَمَّدٌ مُحَمَّدٌ مُحَمَّدٌ حَامِدٌ", "مُحَمَّدٌ الْمُخْتَارُ مَاضِي الْعَرْفِ دَسِ"],
      ["هُوَ الْمُصْطَفَى الْمَحْبُوبُ وَهْوَ الْمُزَيَّلُ", "الْمُدَّثِّرُ يَاسِينُ عَالَ كُلَّ أَفْدَسِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَالْمَسُّ قُرْبُ الْمُقْتَفَى كُلَّ مَلْمَسِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ تَزْدَرِي كُلَّ تَرْجِسِ"]
    ]
  }