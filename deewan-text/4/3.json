{
    "id": 3,
    "title": "حرف الجيم",
    "huruf": [
      ["جَعَلْتُ رَجَائِي فِي الَّذِي هُوَ حَاضِرِي", "أَبُو الْقَاسِمِ الْمَاضِي الصِّلَالِ وَنَاصِرِي"],
      ["بِقَبْضٍ وَبَسْطٍ لَا أُمَلُّ غَيْرَهُ", "وَبَعْضُ سِلَاحِي لِلْعَدُوِّ الْمُكَابِرِ"],
      ["إِذَا حَازَ غَيْرِي عُدَّةً وَعَزَائِمًا", "فَحَسْبِي رَسُولُ اللَّهِ عَنْ كُلِّ نَاصِرِ"],
      ["أَلَمْ يَرْفَعِ الْعِزْبَ الْجَزِيرَةَ بَعْدَ مَا", "حَجَوْا فَارِسًا تَعْلُو الْوَرَى بِالْأَكَاسِرِ"],
      ["وَتَحْسِبُ بِالرُّومِ الْقَيَاصِرَ أَنَّهَا", "تَسَامَى عَلَى أَهْلِ الْعَلَا وَالْمَعَاشِرِ"],
      ["فَصَارُوا مُلُوكَ الْأَرْضِ وَالْكُلُّ تَحْتَهُمْ", "وَقَدْ أَرْشَدُوا الْأَقْيَالَ فَوْقَ الْمَنَابِرِ"],
      ["وَكَسَرُوا شَبَاةَ الْمَارِدِينَ وَزَعْزَعُوا", "حُصُونًا وَأَرْكَانَ الْبُغَاةِ الْجَمَاهِرِ"],
      ["أَلَمْ تَنْصُتِ الْجِنُّ فَوْقَ مَسَامِعٍ", "بِالْكُلْفَةِ إِذْ جِئْتَهُ بِالْبَشَائِرِ"],
      ["أَلَمْ تَنْصُتِ الشَّيْخَ الْحِجَازِيَّ خَاتِمًا", "وَأَعْلَيْتَهُ فَوْقَ الشُّيُوخِ الْأَكَابِرِ"],
      ["فَهَلْ لَكَ فِي هَذَا الْعَبْدِ دُونَ تَأَهٍّل", "مَنَالٌ فَيُمْسِي عِزُّهُ بِالْخَنَاصِرِ"],
      ["فَهَلْ لَكَ فِي بُرْهَانٍ يَا خَيْرَ مُرْسَلٍ", "مُسَاعَدَةٌ فِي كُلِّ بَطْنٍ وَظَاهِرِ"],
      ["فَهَلْ لَكَ فِيهِ وَهْوَ أَصْغَرُ خَادِمٍ", "تُسَوِّدُهُ فَوْقَ الْمُلُوكِ الْأَوَاخِرِ"],
      ["فَهَلْ لَكَ فِيهِ وَهْوَ عَبْدٌ مُنَظَّمٌ", "عَطَاءً فَيَرْوِي كُلَّ آتٍ وَصَادِرِ"],
      ["فَأَنْتَ أَمِينُ اللَّهِ خَازِنُ سِرِّهِ", "وَأَنْتَ الَّذِي أَوْلَاكَ كُلَّ الذَّخَائِرِ"],
      ["فَإِنَّكَ يَا يَاسِينَ عَاقِبُ حَاشِرُ", "الْمُقْتَى مَلَاذِي فِي الْخُطُوبِ الدَّوَائِرِ"],
      ["فَإِنَّكَ يَا خَيْرَ الْأَنَامِ مُحَمَّدًا", "رَجَائِي وَسِرِّي فِي مَجِيعِ الْمَظَاهِرِ"],
      ["وَأَوْلَيْتَنِي مَا لَسْتُ أَهْلًا لِيُغْضِيَ", "عَلَيْكَ صَلَاةُ اللَّهِ يَا خَيْرَ حَاشِرِ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالْأَصْحَابِ أُولِي الْبَصَائِرِ"]
    ]
  }