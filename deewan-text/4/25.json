{
    "id": 25,
    "title": "حرف الظاء",
    "huruf": [
      ["طَعَنْتُ إِلَى وَادِي الْحَبِيبِ الْمُبَهَّجِ", "مُحَمَّدِ الْمَاضِي الصِّلَالِ الْمُسَرَّجِ"],
      ["يُكَاظِمَةُ أَحْبَابٌ قَلْبِي وَسَلْعَهَا", "وَوَادِي الْبَقَا مَغْنَى الْكَرِيمِ الْمُتَوَّجِ"],
      ["فَهَلَّا لِي مِنْ إِلْمَامٍ بِتِلْكَ وَلَيْتَنِي", "أُوَافِيكَ يَا مَنْ نَهْجُهُ الدَّهْرَ مُنْهَجِي"],
      ["أُوَافِي إِلَيْهِ لَوْلَا مَا ذَرَّ شَارِقٌ", "وَلَوْلَا نُورُ الشَّمْسِ لَمْ يَتَبَلَّجِ"],
      ["نَبِيٌّ حَوَى مَا لَمْ يَنَلْهُ مُقَرَّبٌ", "وَلَا فِي بُيُوتِ الْحَيِّ بِالْمُتَوَلَّجِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَعِيشُ بِهَا دَهْرِي بِغَيْرِ مُزَعْزَعِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَإِنِّي أَسِيرُ الْحُبِّ دُونَ تَغَتُّجِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً عَلَى طُولِ الْمَدَى لَمْ تَنْتَجِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَلَى ذَلِكَ الْفَخْمِ الْمُهَابِ الْمُبَهَّجِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "عَلَى ذَلِكَ الْأَفْنَى الْأَزَجِّ وَالْأَبْلَجِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ سَلَكُوا فِي الدِّينِ أَحْسَنَ مَنْهَجِ"]
    ]
  }