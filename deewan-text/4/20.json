{
    "id": 20,
    "title": "حرف الراء",
    "huruf": [
      ["سَلَامٌ عَلَى عِهْنٍ وَبَيْتِ أَرِيسِ", "تَحِنُّ قَلَامِي نَحْوَهَا وَنُقُوسِي"],
      ["مَشَارِبُ خَيْرِ الْخَلْقِ صَفْوَةِ خَلْقِهِ", "وَأَعْظَمِ مَأْلُولٍ سَاسَ كُلَّ نُفُوسِ"],
      ["وَقَدْ أَفْصَحَتْ نُطْقُ الْجَمَادَاتِ أَنَّهُ", "لَأَفْضَلُ مَخْلُوقٍ غَزَا بِحَمِيسِ"],
      ["وَقَدْ بَرَعَتْ فِي الْعِلْمِ بِيَسَرَةٍ", "وَطَاوَعَهُ لِلرُّشْدِ كُلُّ رَئِيسِ"],
      ["وَقَدْ سَخَّتْ أَصْحَابُهُ كُلَّ مُجْرِمٍ", "وَقَدْ غَبَّتْ بِالطَّيِّبِ بِئْرُ أَرِيسِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ قَدْ سَخَوْا بِتَفْيِيسِ"]
    ]
  }