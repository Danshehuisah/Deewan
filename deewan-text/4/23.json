{
    "id": 23,
    "title": "حرف الثاء",
    "huruf": [
      ["ذَكَرْتُ رَسُولَ اللَّهِ ذِكْرَ تَلَذُّذِ", "بِشَيْءٍ سِوَاهُ الدَّهْرَ لَمْ أَتَلَذَّذِ"],
      ["وَهَلْ ثَمَّ غَيْرُ الْمُصْطَفَى وَجَمَالُهُ", "وَهَلْ ثَمَّ مِنْ هَادٍ سِوَاهُ وَمُنْقِذِ"],
      ["ذَرِينِي يَا سَلْمَى لِهَاتِي وَوَحْشَتِي", "أُقَاسِي مَرِيرًا وَهْوَ عَيْنُ تَلَذُّذِي"],
      ["ذَرِينِي لِتَذْكَارِ الْأَمِينِ فَإِنَّهُ", "مَالَ الْقَلْبَ مَا لِي نَحْوَ ذِكْرَاكَ مُنْقِذِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أُلْقَى لِوَصْلِكَ كَالَّذِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَعْلُو عَلَى كُلِّ هِجْدِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ عَائِشِي نُورَ مَأْخِذِي"]
    ]
  }