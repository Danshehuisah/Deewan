{
    "id": 14,
    "title": "حرف النون",
    "huruf": [
      ["تَوَالَى رَسُولُ اللَّهِ أَضْبَحَ وَاكِفَا", "عَلَيَّ مَتَى أَمْسَيْتُ بِالْمَدْحِ وَاصِفَا"],
      ["فَجُودُ رَسُولِ اللَّهِ بِالْبَذْلِ سَائِلٌ", "وَأُلْفَى عَلَى أَبْوَابِهِ الدَّهْرَ عَاكِفَا"],
      ["فَإِنِّي رَاضٍ شَاكِرُ الْقَلْبِ دَائِمًا", "وَلَمْ يُغْنِ نَيْلٌ عَنِ الْوَصْلِ عَارِفَا"],
      ["وَلَسْتُ بِأَهْلٍ أَنْ أَنَالَ كَرَامَةً", "وَلَكِنَّ خَيْرَ الْخَلْقِ سَادَ الْغَطَارِفَا"],
      ["وَإِنِّي أَتَانِي حُبُّهُ قَبْلَ نَشْأَتِي", "صَرَفْتُ تَلِيدَ الْحُبِّ فِيهِ وَطَارِفَا"],
      ["إِذَا هَامَ إِفْرَاقِي بِمَيْلَى وَتَنْدُمِ", "أَهِيمُ بِهِ حِينًا وَوَقْتًا وَآنُفَا"],
      ["وَإِنْ سَهِرَ الْعُبَّادُ فِي دَرْسِ جُرْأَةٍ", "فَجُرْأَتِي هُيَامِي فِي سَنَا الْبَدْرِ عَارِفَا"],
      ["أُسَاجِلُ فِيهِ الْوَرْقَ شَوْقًا مُرَاعِيًا", "تُجُومَ السَّمَا لَبْلِيَ وَأَسْبُلُ وَاكِفَا"],
      ["فَلَمْ أَرَ مِنْ أَهْلِ الصَّبَابَةِ مِثْلَ مَنْ", "يُعَانِي لِمَا عَانَيْتُ بَلْ هُوَ الْأَسَفَا"],
      ["زَفِيرِي وَدَمْعِي يَشْفِيَانِي كِلَاهُمَا", "وَإِنِّي عَلَى هَذَا فِي جِنَانِي قَاطِفَا"],
      ["فَعُرَّ بِذُلِّي لَذَّةٌ بِمَرَارَةٍ", "وَأَلْتَذُّ إِنْ غَيْرِي يُقَاسِي الْمَتَالِفَا"],
      ["بِيُمْنِ رَسُولِ اللَّهِ كَهْفِي وَمَلْجَئِي", "وَمَنْ سَادَ مَنْ تَالُوا الْعَطَايَا الثَّقَائِفَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ أَتَوْا لِلْعَوَارِفَا"]
    ]
  }