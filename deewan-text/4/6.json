{
    "id": 6,
    "title": "حرف الواو",
    "huruf": [
      ["وُصُولُ الْجَمِيعِ الْمَاسِكِينَ بِحَبْلِهَا", "تُحَقِّقُهُ مَنْ لَمْ يَكْذِبْ بِرَبِّهَا"],
      ["وَجَوْبُ فَيَافٍ فِي الْمَعَارِفِ لَمْ تُرَمْ", "فَقَدْ قَصُرَ الْأَقْطَابُ عَنْ دَرْكِهَا شَأْوِيَا"],
      ["بِفَضْلِ إِلَهِ النَّاسِ جَلَّ جَلَالُهُ", "وَحُبِّ رَسُولِ اللَّهِ طَهَ نَبِيِّنَا"],
      ["حَلَفْتُ يَمِينًا أَنَّنِي لَا يُحِبُّنِي", "سِوَى أَسْعَدٍ وَالْعَكْسُ فِي حَالِ بُغْضِيَا"],
      ["وَقَدْ عَلِمَ الْأَقْوَامُ أَنِّي خَدِيدُهُ", "فَفَضْلُ حَبِيبِ اللَّهِ يُلْقَى بِوَصْلِهَا"],
      ["وَمَا قُلْتُ قَوْلِي شَاطِحًا مُتَّبَجِّحًا", "وَمَا مَسَّنِي سُكْرٌ يُقَيّدُ عَفْوِيَا"],
      ["وَإِنَّ خُطُوطِي لِلْأَنَامِ سَعَادَةٌ", "فَلَمْ يَشْقَ يَوْمًا مَنْ رَآهَا وَخَطِّيَا"],
      ["وَمَا قُلْتُ هَذَا دُونَ إِذْنٍ وَإِنَّنِي", "لَكُمْ سِرًّا لَا يَتُاحُ لِغَيْرِيَا"],
      ["وَذَا كُلُّهُ مِنْ حُبِّ سَيِّدِ مُرْسَلٍ", "عَلَيْهِ صَلَاةُ اللَّهِ وَلْتُعْلِ شَأْنِيَا"],
      ["تَتَوَّجُهُ حَتَّى تَحَيَّرَ ثُمَّ إِنَّمَا", "جَلَالُ رَسُولِ اللَّهِ خَيْرَ فِكْرِيَا"],
      ["إِفَاضَتُهُ مِنْهُ إِلَيْهِ مَحَبَّةٌ", "وَسُبْحَانَ رَبِّي ذَلِكَ الْحِبُّ تَجْلِيَا"],
      ["وَمِنْ سِرِّ هَذَا مِنْ شَوْقٍ وَمَغْرَمٍ", "أَزِيدُ اشْتِيَاقًا حِينَ زِدْتُ تَدَلِّيَا"],
      ["فَمَنْ لِي بِوَصْلٍ لِلْحَبِيبِ وَلَيْتَنِي", "أُجَاوِرُهُ فِي حَالَتَيَّ تَمَنِّيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُسَاوِي صَلَاةَ الذَّاكِرِينَ قُبَيْلِيَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "وَمَنْ سَلَكُوا نَهْجَ الْمَحَبَّةِ قَبْلِيَا"]
    ]
  }