{
    "id": 15,
    "title": "حرف الصاد",
    "huruf": [
      ["صَفَا وَقْتُ هَذَا الْعَبْدِ حِينَ تَخَلُّصَا", "وَفُكَّ مِنَ الْأَغْيَارِ وَالْحُبَّ أَخْلَصَا"],
      ["وَذَلِكَ بِحُبِّ الْأَمِينِ وَذِكْرِهِ", "وَقَدْ خَجِلَ الْوَاشُونَ مِمَّنْ تَرَبَّصَا"],
      ["وِقَايَةُ رَبِّي أَغْنَتِ الْعَبْدَ سَرْمَدًا", "إِلَى جَانِبٍ مَنْ كَدَّ لَنْ يَتَخَلَّصَا"],
      ["كَذَا حَرْبُهُ تَكْفِي الْعِدَى فَتْكَهُمْ", "بِسَاحَتِهِمْ صَعْيًا جَزَاءً لِمَنْ عَصَى"],
      ["أَرَانِيَ مَنْصُورًا بِسِرِّ مُحَمَّدٍ", "عَلَيْهِ صَلَاةٌ قَدْ تَعُمُّ مُخَصَّصَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً وَتَسْلِيمًا يُوَافِيهِ مُخْلِصَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "يَنَالُ عَدُوِّي مِنْهُ دَهْرًا تَنَقُّصَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "أَرَى الدَّهْرَ قِرْطَاسِي لِمَدْحِكَ بَصْبَصَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَلَابِسَ تَقْوَى اللَّهِ كُنْتُ أَتَقَمَّصَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَأَصْحَابٍ وَمَنْ قَدْ تَخَصَّصَا"]
    ]
  }