{
    "id": 11,
    "title": "حرف الكاف",
    "huruf": [
      ["كَفَيْتُ حَصَايَ فِي الطَّرِيقِ عَنَاءَا", "فَكُلُّهُمْ بِالْجَذْبِ نَالُوا مَنَاءَا"],
      ["وَلَمْ يَكُ لِلْأَقْطَابِ قَبْلِي مِثْلَ مَا", "لِهَذَا الْعَبْدِ مِنْ فَيْضٍ يَرُوقُ سَنَاءَا"],
      ["وَأَشْكُرُ رَبِّي لَيْسَ سَعْيِي عَاقِرًا", "فَأَصْغَرَ أَثْنَائِي أَطَلُّ فَنَاءَا"],
      ["وَذَلِكَ مِنْ حُبِّ الرَّسُولِ وَسِرِّهِ", "بِسَرْدِي لَهُ الْأَمْدَاحَ حُرْثَ لِوَاءَا"],
      ["فَأَكْبَرُ هَذَا الْعَبْدِ حُبُّ مُحَمَّدٍ", "وَكَثْرِيَ أَنْ أُثْنِيَ عَلَيْهِ ثَنَاءَا"],
      ["وَذَلِكَ جُنْدِي وَهْوَ دِرْعِي وَمِغْفَرِي", "وَإِنْ مَسَّنِي ضُرٌّ أَجِدْهُ دَوَاءَا"],
      ["وَذَا طَاعَتِي دَهْرِي وَضَوْئِي وَحُجَّتِي", "وَفِيهِ صَلَاتِي مِنْهُ بِلَا عَنَاءَا"],
      ["وَذَلِكَ حِزْبِي وَهْوَ نُبْعَتِي وَتَرْوِيقِي", "وَأَكْلِي وَشُرْبِي مِنْهُ بِلَا رِوَاءَا"],
      ["قَلَّا أَرْجُو مَخْلُوقًا سِوَى الْبَدْرِ سَيِّدِي", "مُحَمَّدِ الْمَاضِي الْمُنِيلِ وَلَاءَا"],
      ["وَقَدْ شَدَّ فَقْرِي وَاغْتِرَابِي وَفَاقَتِي", "وَأَكْلِي وَشُرْبِي مِنْهُ بِلَا رِوَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا أَجْنِي جَنًى وَجَدَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا يُعْطِي الْأَمِينُ جَبَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ بِهَا لَمْ أَلْقَ بَعْدُ عَنَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ يَنَالُ الْقَلْبُ مِنْهَا جَلَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِسُقْمِي وَأَمْرَاضِي تَكُونُ شِفَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً عَلَى الْهَادِي تَكُونُ جَزَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا نَفْسِي تَنَالُ غِنَاءَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ مُصْطَفِينَ صَفَاءَا"]
    ]
  }