{
    "id": 2,
    "title": "حرف الباء",
    "huruf": [
      ["بَتَاتٌ لِي أَنَّ الْمُصْطَفَى الدَّهْرَ مُرْشِدِي", "وَمَهْمَا يَكُنْ أَمْرِي فَذَلِكَ مُسْتَنَدِي"],
      ["فَقُوتٌ وَغَيْثٌ مُنْجِدٌ وَمُكَرَّمٌ", "وَمَأْوًى لِعَافٍ وَهْوَ كَهْفِي وَصَنَدِي"],
      ["بَتَاتٌ وَيَقَعُ الْأَرْضُ ظُلْمٌ وَظُلْمَةٌ", "فَأَشْرَقَتِ الْأَرْجَاءُ بِطَلْعَةِ أَحْمَدِ"],
      ["وَهَذَا أَوَانُ الْخَيْرِ مِنْكَ فَإِنَّهُ", "تَلَاطُمُ أَمْوَاجٍ لِيَشْرَقَ مُمْهَدِ"],
      ["فَهَلْ لَكَ أَنْ تُسْدِي إِلَيْنَا كَرَامَةً", "حَبِيرُ غُفُولِ الْكُلِّ يَا خَيْرَ مُنْجِدِ"],
      ["فَإِنْ تَوَلَّنِي مِنْكَ الْجَمِيلُ فَأَهْلُهُ", "وَإِنْ لَمْ أَكُنْ أَهْلًا فَإِنَّكَ مَقْصَدِي"],
      ["وَمِنْكَ رَسُولَ اللَّهِ نَالَ خِلَافَةً", "أَبُو الْبَتْرِ الْأَسْنَى أَبُو كُلِّ مُرْشِدِ"],
      ["وَمِنْكَ خَلِيلٌ وَالتَّقِيُّ وَزَوْجُهُمْ", "أَتَوْا مَقَامَاتٍ عَلَى كُلِّ سَيِّدِ"],
      ["كَذَا يَنْشُرُ مَنْ قَبْلَيْهِمُ وَسِوَاهُمُ", "وَمِنْكَ سُلَيْمَانٌ حَوَى كُلَّ سُؤْدَدِ"],
      ["وَمِنْكَ أَرُومُ الْفَوْزَ وَالْفَضْلَ وَالْجَدَا", "عَلَى رَغْمِ أَنْفِ مَنْ بَغِيضٍ وَحُسَّدِ"],
      ["وَإِنَّ مُرَادِي أَنْ أَنَالَ خِلَافَةً", "عَلَى وَفْقِ مَا أَهْوَى بِجَاهِ مُحَمَّدِ"],
      ["بِلَا سَبَبٍ مِنِّي مُعَافًى وَمُصْطَفَى", "حَبِيرًا بَصِيرًا هَادِيًا كُلَّ مُهْتَدِ"],
      ["وَأُفْضَى لِكُلِّ الْأَوْلِيَاءِ مَرَادُهُمْ", "بِلَا كُلْفَةٍ فِي كُلِّ غَيْبٍ وَمَشْهَدِ"],
      ["وَأَهْدِي الْإِمَامَ الْمَهْدِيَّ الْخُمَّ مُرْشِدًا", "لَهُ كُلَّ وَقْتٍ فِي مَجَالٍ وَمَرْقَدِ"],
      ["بِذَاتِكَ يَا رَبِّي بِسِرِّ صِفَاتِهِ", "وَنُورِكَ يَا رَبِّي إِلَيْهِ كُلَّ مَحْبَدِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْكِرَامِ وَأَحَدِ"]
    ]
  }