{
    "id": 8,
    "title": "حرف الحاء",
    "huruf": [
      ["جَاءَتْهُ هَذَا الْعَبْدِ مِنْ كُلِّ خَائِفِ", "مَحَبَّةُ خَيْرِ الْخَلْقِ مَأْوَى الْأَكَارِمِ"],
      ["هُوَ الْبَحْرُ وَاللَّيْثُ الْجَسُورُ شَجَاعَةً", "وَجُودًا فَحَبْرُ الْخَلْقِ بَحْرُ الْمَكَارِمِ"],
      ["هُوَ الشَّمْسُ وَالْغَيْثُ الْمَرِيعُ هِدَايَةً", "وَبَذْلًا وَنَهْلًا الْغَيْثُ غَيْرُ مُدَاوِمِ"],
      ["فَسَاسَ جَمِيعَ الْعُرْبِ وَالْعُجْمِ كُلَّهَا", "فَعَمَّ هُدَاهُ الْيَوْمَ كُلَّ الْأَقَالِيمِ"],
      ["وَشَتَّتَ شَمْلَ الْمُشْرِكِينَ وَقَدْ عَلَا", "بِصَوْلَتِهِ الْقُوجِيدُ دُونَ مُزَاحِمِ"],
      ["إِمَامٌ كَرِيٌّ مُنْصِفٌ وَمُقَوِّمٌ", "أَدِيبٌ مُهِيبٌ مُحْبِسٌ لِلْمَسَاحِمِ"],
      ["جَلِيلًا جَلِيلًا مُنْفِقًا مُتَوَاضِعًا", "وَلَمْ يَكُ فَظًّا لَا وَلَيْسَ بِظَالِمِ"],
      ["وَقَدْ كَانَ مَنْصُورًا يُرَغِّبُ فَصَحْبُهُ", "بِهِ دَوَّخُوا الْبُلْدَانَ لَا بِالصَّوَارِمِ"],
      ["فَيَا لَيْتَهُ قَوَّى الْعَبِيدَ وَصَحْبَهُ", "لِيُدْرِكَ ثَأْرًا مِنْ عَدُوٍّ وَغَاشِمِ"],
      ["وَيُعْلِي بِنَا التَّوْحِيدَ حَقًّا بِسُرْعَةٍ", "وَيُعْنِي ذَوِي الْحَاجَاتِ مِنْ كُلِّ رَائِمِ"],
      ["بِجَاهِ رَسُولِ اللَّهِ ثُمَّ صِحَابِهِ", "فَيَعْلُو مَنَارُ الدِّينِ فَوْقَ الْمَعَالِمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِكَيْ لَا يَعِيشَ الْعَبْدُ عَيْشَ الْبَهَائِمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلِي شَهْوَةٌ فِي ذِكْرِ تَسْلِيمِ هَاشِمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَقَدْ حَيَّرَ الْمُخْتَارُ أَفْكَارَ عَالَمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "فَلِي سَكْرَةٌ تَفْنَى لَدَيْهَا عَوَالِمِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "بِهِ أَرْتَقِي لِلْحُبِّ أَفْضَى السَّلَالِمِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "مَعَ الْآلِ وَالصَّحْبِ الْبُحُورِ الْخَضَارِمِ"]
    ]
  }