{
    "id": 12,
    "title": "حرف اللام",
    "huruf": [
      ["لَيْنَ الْأَخْذِ لِلْأَقْوَامِ هُمْ وَأَسْتَوْا", "فَسَمَلَ هُجُومِي بِالْأَمِينِ مُسْتَدَّتْ"],
      ["لَقَدْ جَاءَ حَبْرُ الْخَلْقِ وَالْجَدُّ شَامِلٌ", "فَأَخْصَبَتِ الدُّنْيَا فَعَاشُوا وَقُوتُوا"],
      ["فَقَادَ الْبَرَايَا لِلْهُدَى دَاعِيًا نَاصِحًا", "وَقَدْ سَمِعُوا الْقُرْآنَ يُتْلَى وَأَنْصَتُوا"],
      ["فَعَمَّ هُدَى الْهَادِي الْبَسِيطَةَ كُلَّهَا", "وَسَلَّ سُيُوفَ النَّصْرِ صَحْبٌ وَأَثْبَتُوا"],
      ["فَأَشْرَقَ نُورُ الدِّينِ فِي كُلِّ مَوْطِنٍ", "وَصُدِّعَ عَنِ الْأَوْثَانِ فَرْضٌ مُوَقَّتْ"],
      ["إِلَيْكَ رَسُولَ اللَّهِ أَشْكُو فَإِنَّنِي", "قَرُونٌ مَحَوْا أَنْوَارَ دِينٍ وَأَشْكَوْا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا كُلُّ الْوَرَى لَكَ أَخْبَتُوا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَكُونُ بِعَيْنِ اللهِ حِرْزًا لَهُمْ حَيْثُ اسْتَوْا"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أَبْقَى لِسَعْيِي أَفْئِسَ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَمُلْكٌ لِغَيْرِ الْمُسْلِمِينَ مُقَتَتْ"],
      ["عَلَيْكَ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ لِلْأَبَاطِيلِ شَتَّوْا"]
    ]
  }