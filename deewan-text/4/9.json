{
    "id": 9,
    "title": "حرف الطاء",
    "huruf": [
      ["طَاحَتْ بِحُبِّ الْخَلْقِ أَقْوَى الْوَثَائِقِ", "مَالِكُ أَبْنَاءِ الْبُغَاةِ الْقَوَاسِقِ"],
      ["سِلَاحِي رَسُولُ اللَّهِ وَهْوَ تَحَصُّنِي", "وَحِيلِي وَرَجْلِي فَهْوَ سِرُّ الْحَقَائِقِ"],
      ["مَتَى عَنْ دُيُورِي كُلَّ ضَنْكٍ وَفِتْنَةٍ", "وَزَحْزَحَ عَنْهَا كُلَّ بَاغٍ وَقَاسِقِ"],
      ["وَسَاقَ رِجَالَ الْحَبْرِ إِذْ يَقْصِدُونَهَا", "وَأَلْهَمَ صَحْبِي ذَوْقَ كُلِّ الرَّقَائِقِ"],
      ["عَلِيٌّ خَدِيمِي خَازِنُ السِّرِّ كَتْبِي", "بِبَيْنِي مَدْحِي قَدْ عَلَا كُلَّ فَائِقِ"],
      ["فَإِنَّ مَدِيحِي لِلْأَمِينِ طَرِيقَةٌ", "لِتَفْضَاكَ فَيْضًا دُونَهُ كُلُّ سَابِقِ"],
      ["فَإِنَّ رَسُولَ اللَّهِ وَهْوَ مُسَاعِدِي", "مُحِيطٌ بِسِرِّ اللَّهِ رَبِّ الْخَلَائِقِ"],
      ["وَمِنْ بَحْرِهِ لِلصَّحْبِ أَمْسَيْتُ غَارِفًا", "عَلَى وَفْقِ مَا يَرْجُونَ مِنْ فَضْلِ خَالِقِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أُرْوِي ظَمَا كُلِّ وَامِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيَنْسَخُ نَهْجَ الْخَتْمِ كُلَّ طَرَائِقِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا تَسْقِي الْمُلُوكُ حَدَائِقِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُزِينُ سُطُورِي الدَّهْرَ بِبِيضِ الْمَهَارِقِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "بِحُورِ النَّدَى أُسْدِ الْوَغَى وَالْمَضَايِقِ"]
    ]
  }