{
    "id": 22,
    "title": "حرف التاء",
    "huruf": [
      ["تَفَرَّقَتِ الْأَهْوَاءُ وَالْحَقُّ وَاحِدٌ", "وَكَانَ رَسُولًا قَبْلَ آدَمَ طِينَةً"],
      ["وَمَاءً فَمَا الْجَدْوَى لِغَاوٍ وَمَا الْخَبَطُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["صَلَاةٌ بَعْدَ الْقَبْضِ تَشْجَبُ الْبَسَطَ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["وَتَعْلُو سُطُورِي ثُمَّ شَكْلِي كَذَا النَّقْطُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["يَزِيدُ غَرَامِي الشَّيْبُ وَالْكِبَرُ وَالشَّمْطُ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["وَآلٍ وَصَحْبٍ فِي سِوَى الَّذِينَ لَمْ يَسْطُوا"]
    ]
  }