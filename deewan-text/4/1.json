{
    "id": 1,
    "title": "حرف الألف",
    "huruf": [
      ["أَلِفًا عَلَى الْبَحْرِ الْمُحِيطِ وَتَثَرَّكَا", "سَوَاقٍ لَا تُجْدِي ظَمَاءً لِمَنْ شَكَا"],
      ["فَأَعْنِي حَبِيبَ اللَّهِ طَهَ مُحَمَّدًا", "أَبَا الْقَاسِمِ الْهَادِي لِمَنْ قَدْ تَنَسَّكَا"],
      ["أَمِينَ إِلَهِ الْعَرْشِ مَرْكَزَ سِرِّهِ", "بِهِ هَامَ قَلْبُ الْعَبْدِ حَتَّى تَهَتَّكَا"],
      ["فَمَلَكْتُهُ ذَاتِي وَرُوحِي وَنَفْسَهَا", "وَأَهْلِي وَأُولَادِي وَمَنْ يَتَمَسَّكَا"],
      ["وَلَمْتُ أَرَى فِي الْكَوْنِ شَيْئًا أُحِبُّهُ", "سِوَى الْمُصْطَفَى الْمَحْمُودِ فِيكَ وَعِنْدَكَا"],
      ["فَوَقْتٌ مَضَى فِي غَيْرِ إِنْشَاءِ مَدْحِهِ", "وَتَذْكَارِهِ لَمْ أَحْسِبُهُ الدَّهْرَ مُدْرِكَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُضِيءُ لَنَا الظَّلْمَاءَ وَتَرْفَعُ مُشْتَكَى"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُزَحْرِجُ أَعْدَائِي وَبُؤْسِي وَالْبُكَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتُعْلِي عَلَى كُلِّ الْمُلُوكِ عَبِيدَكَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُنِيلُ الْمُنَى وَلْتُعْطِ لِلْعَبْدِ سِرَّكَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَمَلِّكُنِي التَّكْوِينَ وَالْأَمْرَ أَمْرَكَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُوَرِّثُنِي مَنْ فَاتَ مِمَّنْ تَمَلَّكَا"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ وَأَحْوِ لِتَحْوِي كَا"]
    ]
  }