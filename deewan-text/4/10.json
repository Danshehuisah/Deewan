{
    "id": 10,
    "title": "حرف الياء",
    "huruf": [
      ["يُحَيِّرُ أَفْكَارِي لِمَدْحِ الْمُزَمَّلِ", "غَرَامِي وَشَوْقِي لِلْجَمَالِ الْمُكَمَّلِ"],
      ["دَعَانِي جَمَالُ الْمُصْطَفَى فَأَجَبْتُهُ", "بِدَمْعٍ كَوَبْلٍ مِنْ فُؤَادٍ مُقَتَّلِ"],
      ["أَرَانِي أُحِبُّ الْعِرْبَ وَالصَّحْبَ جَمْعَهُمْ", "وَآلًا وَأَنْصَارًا لِحَبْرِ الْمُزَمَّلِ"],
      ["وَلَا سِيَّمَا الشَّيْخَيْنِ ثُمَّ خَلِيفَةً", "يُكَنَّى أَبَا بَكْرٍ وَصِنْوَ الْمُبَجَّلِ"],
      ["كَذَلِكَ مِنْ حُبِّيهِ حُبِّي لِطَيْبَةٍ", "وَأُمِّ الْقُرَى الْبَطْحَا عَلَى كُلِّ مَنْزِلِ"],
      ["كَذَلِكَ مِنْ حُبِّيهِ حُبِّي تِلَاوَةً", "مَقَامٍ وَحَالٍ حُبُّ أَفْضَلِ مُرْسَلِ"],
      ["كَذَلِكَ مِنْ حُبِّيهِ حُبُّ مَدِيحِهِ", "وَأَسْمَائِهِ أَسْمَاءِ حَبْرٍ مُؤَمَّلِ"],
      ["وَحُبِّي لِأَهْلِ اللَّهِ أَنْصَارِ دِينِهِ", "وَبُغْضِي لِمَنْ عَادَاهُ فِي كُلِّ مَنْدَلِ"],
      ["فَلَسْتُ أُحِبُّ الدَّهْرَ شَيْئًا سِوَاهُ", "وَلَسْتُ أُعَادِي غَيْرَ أَعْدَاءِ مُؤْمِلِ"],
      ["لَعَلِّي أَرَى مَا قَدْ أُحِبُّ مُؤَتَدًا", "بِفَضْلِ كَرَمٍ دُونَهُ كُلُّ مُجْزِلِ"],
      ["لَعَلِّي أَرَى أَعْدَاءَ دِينِي تَفَرَّقُوا", "وَصَارُوا جَمِيعًا تَحْتَ جِجْرٍ مُذَلَّلِ"],
      ["وَتَخْفِقُ رَايَاتُ الْإِلَهِ وَدِينِهِ", "بِكَفِّ فَتًى يَدْعُو لِدِينِي مُهَلِّلِ"],
      ["أَلَا يَا رَسُولَ اللَّهِ يَا أَفْضَلَ الْوَرَى", "لِتُصْلِحْ شُؤُونِي لَمْ أَجِدْ عَنْكَ مَعْدِلِ"],
      ["فَإِنِّي جَارٌ شَاعِرُ الْبَابِ خَادِمٌ", "وَإِنَّكَ بَحْرُ الْجُودِ يَا غَوْثُ مُرْمِلِ"],
      ["فَإِنْ أَبْرَقَ الْأَعْدَاءُ يَوْمًا وَأَرْعَدُوا", "فَإِنِّي جَارُ الْمُصْطَفَى الْمُتَفَضِّلِ"],
      ["فَإِنِّي جَارٌ شَاعِرُ الْبَابِ بِأَنَّنِي", "وَإِنْ شَبَّتِ النِّيرَانُ لِلْحَرْبِ إِنَّنِي"],
      ["أَرْجُوكَ أَنْ تَرْمِيَ الدَّهْرَ عَنْهَا بِمِغْزَلِ", "وَمِنْكَ تَرَى فِي الْحَشْرِ وَالْفَرْعِ الَّذِي"],
      ["تَشِيبُ لَهُ الْوِلْدَانُ أَرْفَعَ مَنْزِلِ", "عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ"],
      ["وَآلٍ وَصَحْبٍ قَدْ عَلَوْا كُلَّ أَغْيَلِ"]
    ]
  }