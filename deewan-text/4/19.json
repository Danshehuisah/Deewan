{
    "id": 19,
    "title": "حرف القاف",
    "huruf": [
      ["رَقِيتُ بِحُبِّ الْمُصْطَفَى كُلَّ شَامِخِ", "مِنَ الْمَجْدِ يُزْرِي كُلَّ رَاسٍ وَرَاسِخِ"],
      ["بَلَى إِنَّمَا حُبُّ الْأَمِينِ كَرَامَةٌ", "وَقَدْ فُتُّ مُرْدَانًا وَكُلَّ الْمَشَايِخِ"],
      ["وَمَنْ يَشْتَغِلْ دَهْرًا بِحُبِّ مُحَمَّدٍ", "يَنَلْ كُلَّ مَا يَهْوَى مِنْ أَعْلَى الْبَآزِخِ"],
      ["وَقَدْ جَاءَنِي مِنْهُ الْبِشَارَاتُ أَنَّنِي", "بِمَدْحِهِ أَسْمُو فَوْقَ كُلِّ الشَّوَامِخِ"],
      ["وَقَدْ فَرِحَتْ كُلُّ الْحُرُوفِ لِأَنَّنَا اكْتَسَتْ", "حُلَلًا تُلْهِي النَّاسَ وَنَاسِخْ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "لِتُطْوَى لَنَا الْبَيْدَاءُ وَكُلُّ الْفَرَاسِخِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً تُرِي مِصْرِي كَإِحْدَى النَّوَاسِخِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةً بِهَا أُمْسِي غِيَاثًا لِصَارِخِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ قَدْ قَفَوْا شَرْعَ مَنْ سَخْ"]
    ]
  }