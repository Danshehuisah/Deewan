{
    "id": 27,
    "title": "حرف الشين",
    "huruf": [
      ["شَهِدْتُ وَلَا أَلْقَى لِعَهْدِي أَنُكُثُ", "بِأَنِّي عَلَى حُبِّي لِأَحْمَدَ أَمْكُثُ"],
      ["فَلَيْتَنِي أَلْقَى الْمُصْطَفَى الْقَرْمَ لَيْتَهُ", "عَلَى عَوْجِي دَهْرِي بِرُوعِي أُنَفِّثُ"],
      ["بِحُبِّ رَسُولِ اللَّهِ سَادَتْ عَشِيرَتِي", "وَنَشْأِي وَمَنْ يَرْعَى ذِمَامِي وَيَعْكُثُ"],
      ["بِحُبِّ رَسُولِ اللَّهِ تَعْلُو مَدِينَتُنَا", "عَلَى الْمُدُنِ وَالْأَمْصَارِ وَالْخَبْرُ يُحْدَثُ"],
      ["يُحِبُّ رَسُولِ اللَّهِ تَعْلُو مَنَارَتِي", "مَنَارَاتِ قَوْمٍ عَهْدُهُمُ الدَّهْرَ يَنْكُثُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تُضِيءُ الْقَبْرَ سَاعَةَ أُجْدَثُ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ بِالْحَدِيثِ تَحَدَّثُوا"]
    ]
  }