{
    "id": 26,
    "title": "حرف الغين",
    "huruf": [
      ["غَرَامِي دَعَانِي لِلْفُرَيْشِ وَزَابِغِ", "وَحَنَّتْ بِيَ الْأَشْوَاقُ نَحْوَ أَرِيسِ"],
      ["سَلَامٌ عَلَى يَبْرِينَ أَرِيسَ وَزَوْمَةٍ", "فَمَنْ لِي بِكَأْسٍ مِنْ بِضَاعَةِ سَابِغِ"],
      ["سَلَامٌ عَلَى زَرْقَاءَ عَيْنٍ وَقَدْ مَضَتْ", "عَلَى الْحُورِ وَاشْتَاقَتْ لِسَلْعٍ وَزَابِغِ"],
      ["سَلَامٌ عَلَى قَبْرِ الْأَمِينِ وَرَوْضَةٍ", "ثَرِيكَ ضِيَاءً يَزْدَرِي كُلَّ بَازِغِ"],
      ["سَلَامٌ عَلَى رَوْضِ الْبَقِيعِ فَإِنَّنِي", "أُوَدِّعُ سَلَامِي كُلَّ آتٍ وَبَالِعِ"],
      ["مَحَا حُبُّهُ حُبَّ الْقُرَى مِنْ خَوَاطِرِي", "فَمَا لِيَ إِلَّا ذَاتُ الشَّمْعِ الْبَوَازِغِ"],
      ["وَذَلِكَ مِنْ حُبِّ الْحَبِيبِ فَحُبُّهُ", "مَتَى يَخْدِقَنْ فِي الْقَلْبِ أَعْظَمُ دَامِغِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَيُضِيءُ قَلْبُ الْعَبْدِ مِنْ حَبْرِ صَائِغِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَتَسْتَأْصِلُ الْأَعْدَاءَ مِنْ كُلِّ زَائِغِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَأَكْسِي كِسَى الْأَنْوَارِ مِنْ كُلِّ صَائِغِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "وَآلٍ وَصَحْبٍ أَنْذَرُوا كُلَّ بَالِعِ"]
    ]
  }