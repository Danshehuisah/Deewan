{
    "id": 7,
    "title": "حرف الزاي",
    "huruf": [
      ["زَمَانُ رَسُولِ اللَّهِ خَيْرُ زَمَانِ", "وَطَيْبَةُ خَيْرُ الْخَلْقِ خَيْرُ مَكَانِ"],
      ["فَمَنْ لِي بِكُبْسٍ مِنْ أَرِيكٍ وَزَوْمَةٍ", "فَشَوْقِي إِلَى تِلْكَ الْبِقَاعِ دَهَانِي"],
      ["فَشَوْقِي إِلَى وَادِي الْعَقِيقِ وَسَلْعِهِ", "حَمَاهُ مَنَامِي فَالْمَنَامُ جَفَانِي"],
      ["وَشَوْقِي إِلَى وَادِي النَّقَا وَبَقِيعِهِ", "وَلِلصَّخْرَةِ الْمُلْسَاءِ إِلَيْهِ دَعَانِي"],
      ["فَهَلْ تَسْمَحُ الْأَيَّامُ يَوْمًا بِعَوْدَةٍ", "إِلَيْهِ فَهَا قَبْرِيَ وَأَمَانِي"],
      ["وَهَلْ لِي أَنْ أَكْسُوَ الْعَاتِقَ وَتَكْتَسِي", "كَذَا الْقُبَّةُ الْخَضْرَاءُ رَوْضُ جِنَانِ"],
      ["وَهَلْ لِي فَأَلْقَى مَاكِثًا ثَقِيلًا مَنْ", "يَحُجُّ لِبَيْتِ اللَّهِ دُونَ تَوَانِ"],
      ["وَتُدْنِي لَهُمْ أَرْضَ الْحَبِيبِ قِيَادَتِي", "وَقَدْ شُدْتُ بِالْبَطْحَاءِ كُلَّ مَعَانِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تَرُجُّ الْعَبْدَ وَسْطَ جِنَانِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُعَجِّلُ فَتْحِي وَالْمُنَى وَالْبَاقِيَا"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تُضِيءُ جَنَابِي أَوْ تُضِيءُ مَعَافِي"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "تَمَلِّكُنِي تَصْرِيفَ كُلِّ مَعَافِ"],
      ["عَلَيْهِ صَلَاةُ اللَّهِ ثُمَّ سَلَامُهُ", "صَلَاةٌ تُنْجِينَا بِدُونِ مَعَاطِ"],
      ["عَلَيْهِ مَعَ الْآلِ الْكِرَامِ وَصَحْبِهِ", "صَلَاةٌ وَتَسْلِيمٌ مُرُورَ الرَّمَامِ"]
    ]
  }